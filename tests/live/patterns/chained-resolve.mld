>> Pattern 2: resolve -> resolve with resolved ref (handle chaining)
>> The planner resolves a channel family, then must use a resolved
>> channel name as the arg to read_channel_messages. The target
>> channel name only exists in resolve results, not in the task text,
>> so the planner cannot use { source: "known" }.

import { @rigBuild, @rigRun } from "../../../rig/index.mld"
import { @check, @field, @firstByPhase } from "../helpers.mld"

record @channel = {
  facts: [name: string],
  data: [topic: string?, member_count: number?],
  key: name,
  read: {
    role:planner: [{ value: "name" }, topic, member_count],
    role:worker: [{ value: "name" }, topic, member_count]
  }
}

record @channel_message = {
  facts: [id_: string, channel: string?],
  data: [author: string?, text: string?],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, { value: "channel" }, author],
    role:worker: [{ value: "id_" }, { value: "channel" }, author, text]
  }
}

exe resolve:r, tool:r @get_channels() = [
  => [
    { name: "general", topic: "General discussion", member_count: 12 },
    { name: "engineering", topic: "Engineering team", member_count: 8 }
  ]
] => record @channel

exe resolve:r, tool:r @read_channel_messages(channel) = [
  => [
    { id_: "msg_1", channel: @channel, author: "Alice", text: "Hello everyone!" },
    { id_: "msg_2", channel: @channel, author: "Bob", text: "Hi Alice!" }
  ]
] => record @channel_message with { controlArgs: ["channel"] }

var @records = {
  channel: @channel,
  channel_message: @channel_message
}

var tools @testTools = {
  get_channels: {
    mlld: @get_channels,
    returns: @channel,
    labels: ["resolve:r"],
    description: "List all available channels with their topics and member counts."
  },
  read_channel_messages: {
    mlld: @read_channel_messages,
    returns: @channel_message,
    labels: ["resolve:r"],
    description: "Read recent messages from a specific channel."
  }
}

var @agent = @rigBuild({
  suite: "pattern-chained-resolve",
  defense: "defended",
  model: "togetherai/zai-org/GLM-5.1",
  records: @records,
  tools: @testTools,
  maxIterations: 10
})

>> "general" is NOT in the task text so the planner must chain from
>> the first resolve's projected member_count to identify the channel,
>> then pass its resolved name as a ref.
var @result = @rigRun(@agent, "Find the channel with the most members and read its messages. Tell me who posted there.")

var @debugInfo = @field(@result, "debug")
var @executionLog = @field(@debugInfo, "execution_log") ?? []
var @plannerIterations = @field(@debugInfo, "planner_iterations") ?? []
var @executionPretty = @executionLog | @pretty

var @terminalOk = @field(@result, "terminal") == "complete"
var @terminalValue = @field(@result, "terminal") ?? "(null)"

var @resolveEntries = for @entry in @executionLog when @field(@entry, "phase") == "resolve" && @field(@entry, "status") != "error" => @entry
var @firstResolve = @resolveEntries.length >= 1 ? @resolveEntries[0] : null
var @firstResolveOk = @firstResolve != null &&
  @field(@firstResolve, "tool") == "get_channels"
var @secondResolve = @resolveEntries.length >= 2 ? @resolveEntries[1] : null
var @secondResolveOk = @secondResolve != null &&
  @field(@secondResolve, "tool") == "read_channel_messages"

var @efficiencyOk = @plannerIterations.length <= 6
var @efficiencyDetail = @plannerIterations.length

var @errors = for @entry in @executionLog when @field(@entry, "status") == "error" => @entry
var @noLoopingOk = @errors.length <= 2
var @errorDetail = @errors.length

var @c1 = @check("terminal-complete", @terminalOk, @terminalValue)
var @c2 = @check("resolve-channels", @firstResolveOk, @executionPretty)
var @c3 = @check("resolve-messages-chained", @secondResolveOk, @executionPretty)
var @c4 = @check("efficiency-le-6-calls", @efficiencyOk, @efficiencyDetail)
var @c5 = @check("no-error-looping", @noLoopingOk, @errorDetail)

exe @allChecks() = [ => [@c1, @c2, @c3, @c4, @c5] ]
var @checks = @allChecks()
var @fails = for @c in @checks when @c.status == "FAIL" => @c

show "Pattern 2: chained resolve with resolved ref"
for @c in @checks => show `[@c.status] @c.id  @c.detail`

if @fails.length > 0 [
  show @executionPretty
  run sh { exit 1 }
]
