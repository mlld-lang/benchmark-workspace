>> Pattern 5: wrong-phase recovery
>> Tests that the model corrects a wrong-phase tool call within 2
>> attempts. The model might initially call a resolve tool through
>> extract (a common mistake). It should recover by switching to
>> resolve after seeing the error. Passes if the model either gets
>> it right immediately or corrects within 1 error.

import { @rigBuild, @rigRun } from "../../../rig/index.mld"
import { @check, @field, @firstByPhase } from "../helpers.mld"

>> Use a tool name that sounds like an extract operation to increase
>> the chance the model tries extract first. "read_inbox" sounds like
>> "reading content" which models associate with extract.
record @inbox_item = {
  facts: [id_: string, sender: string?],
  data: [subject: string?, preview: string?],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, { value: "sender" }, subject],
    role:worker: [{ value: "id_" }, { value: "sender" }, subject, preview]
  }
}

exe resolve:r, tool:r @read_inbox() = [
  => [
    { id_: "inbox_1", sender: "alice@example.com", subject: "Meeting tomorrow", preview: "Can we meet at 3pm?" },
    { id_: "inbox_2", sender: "bob@example.com", subject: "Project update", preview: "Status report attached." }
  ]
] => record @inbox_item

var @records = {
  inbox_item: @inbox_item
}

var tools @testTools = {
  read_inbox: {
    mlld: @read_inbox,
    returns: @inbox_item,
    labels: ["resolve:r"],
    description: "Read the inbox and return all messages with sender and subject."
  }
}

var @agent = @rigBuild({
  suite: "pattern-wrong-phase",
  defense: "defended",
  model: "togetherai/zai-org/GLM-5.1",
  records: @records,
  tools: @testTools,
  maxIterations: 10
})

var @result = @rigRun(@agent, "Read my inbox and tell me how many messages I have and who sent them.")

var @debugInfo = @field(@result, "debug")
var @executionLog = @field(@debugInfo, "execution_log") ?? []
var @plannerIterations = @field(@debugInfo, "planner_iterations") ?? []
var @executionPretty = @executionLog | @pretty

var @terminalOk = @field(@result, "terminal") == "complete"
var @terminalValue = @field(@result, "terminal") ?? "(null)"

var @resolveEntry = @firstByPhase(@executionLog, "resolve")
var @resolveOk = @resolveEntry != null &&
  @field(@resolveEntry, "tool") == "read_inbox" &&
  @field(@resolveEntry, "status") != "error"

var @efficiencyOk = @plannerIterations.length <= 5
var @efficiencyDetail = @plannerIterations.length

>> Count wrong-phase errors specifically
var @wrongPhaseErrors = for @entry in @executionLog when @field(@entry, "status") == "error" && @field(@entry, "phase") == "extract" => @entry
var @recoveryOk = @wrongPhaseErrors.length <= 1
var @wpErrorDetail = @wrongPhaseErrors.length

var @errors = for @entry in @executionLog when @field(@entry, "status") == "error" => @entry
var @noLoopingOk = @errors.length <= 2
var @errorDetail = @errors.length

var @c1 = @check("terminal-complete", @terminalOk, @terminalValue)
var @c2 = @check("resolve-inbox", @resolveOk, @executionPretty)
var @c3 = @check("efficiency-le-5-calls", @efficiencyOk, @efficiencyDetail)
var @c4 = @check("wrong-phase-recovery-le-1", @recoveryOk, @wpErrorDetail)
var @c5 = @check("no-error-looping", @noLoopingOk, @errorDetail)

exe @allChecks() = [ => [@c1, @c2, @c3, @c4, @c5] ]
var @checks = @allChecks()
var @fails = for @c in @checks when @c.status == "FAIL" => @c

show "Pattern 5: wrong-phase recovery"
for @c in @checks => show `[@c.status] @c.id  @c.detail`

if @fails.length > 0 [
  show @executionPretty
  run sh { exit 1 }
]
