>> Pattern 4: derive -> selection ref -> execute
>> The planner resolves a family, derives a selection (choosing one
>> member based on data NOT visible in the planner projection), then
>> executes a write using the selection ref as a control arg.
>>
>> The customer_rating field is in untrusted data and hidden from the
>> planner. The planner must extract ratings, derive a selection,
>> and execute with the selection ref.

import { @rigBuild, @rigRun } from "../../../rig/index.mld"
import { @check, @field, @firstByPhase } from "../helpers.mld"

record @product = {
  facts: [sku: string],
  data: {
    trusted: [name: string, price: number?],
    untrusted: [customer_rating: number?, review_text: string?]
  },
  key: sku,
  read: {
    role:planner: [{ value: "sku" }, name, price],
    role:worker: [{ value: "sku" }, name, price, customer_rating, review_text]
  }
}

record @purchase_inputs = {
  facts: [product_sku: string],
  data: [quantity: number?],
  validate: "strict"
}

exe resolve:r, tool:r @list_products() = [
  => [
    { sku: "WIDGET-A", name: "Basic Widget", price: 19, customer_rating: 3, review_text: "Decent quality." },
    { sku: "WIDGET-B", name: "Pro Widget", price: 49, customer_rating: 5, review_text: "Best widget ever!" },
    { sku: "WIDGET-C", name: "Budget Widget", price: 9, customer_rating: 2, review_text: "Gets the job done." },
    { sku: "WIDGET-D", name: "Deluxe Widget", price: 89, customer_rating: 4, review_text: "Great but pricey." }
  ]
] => record @product

exe @purchase_product(product_sku, quantity) = [
  let @qty = @exists(@quantity) ? @quantity : 1
  => { ok: true, product_sku: @product_sku, quantity: @qty }
]

var @records = {
  product: @product,
  purchase_inputs: @purchase_inputs
}

var tools @testTools = {
  list_products: {
    mlld: @list_products,
    returns: @product,
    labels: ["resolve:r"],
    description: "List all available products with name and price. Customer ratings are available but require extraction."
  },
  purchase_product: {
    mlld: @purchase_product,
    inputs: @purchase_inputs,
    labels: ["execute:w", "tool:w"],
    can_authorize: "role:planner",
    description: "Purchase a product by SKU."
  }
}

var @agent = @rigBuild({
  suite: "pattern-selection-execute",
  defense: "defended",
  model: "togetherai/zai-org/GLM-5.1",
  records: @records,
  tools: @testTools,
  maxIterations: 12
})

>> customer_rating is hidden from the planner, so it must extract
>> ratings from resolved state, derive the best-rated, then execute
>> with a selection ref.
var @result = @rigRun(@agent, "Find the product with the best customer rating and buy one of it.")

var @debugInfo = @field(@result, "debug")
var @executionLog = @field(@debugInfo, "execution_log") ?? []
var @plannerIterations = @field(@debugInfo, "planner_iterations") ?? []
var @executionPretty = @executionLog | @pretty

var @terminalOk = @field(@result, "terminal") == "complete"
var @terminalValue = @field(@result, "terminal") ?? "(null)"

var @resolveEntry = @firstByPhase(@executionLog, "resolve")
var @resolveOk = @resolveEntry != null &&
  @field(@resolveEntry, "tool") == "list_products" &&
  @field(@resolveEntry, "status") != "error"

var @executeEntry = @firstByPhase(@executionLog, "execute")
var @executeOk = @executeEntry != null &&
  @field(@executeEntry, "tool") == "purchase_product" &&
  @field(@executeEntry, "status") != "error"

>> Extract and derive are expected but the model might find a path
>> that skips them. Check but don't gate on the exact phase sequence.
var @extractEntry = @firstByPhase(@executionLog, "extract")
var @extractUsed = @extractEntry != null && @field(@extractEntry, "status") != "error"

var @deriveEntry = @firstByPhase(@executionLog, "derive")
var @deriveUsed = @deriveEntry != null && @field(@deriveEntry, "status") != "error"

var @efficiencyOk = @plannerIterations.length <= 8
var @efficiencyDetail = @plannerIterations.length

var @errors = for @entry in @executionLog when @field(@entry, "status") == "error" => @entry
var @noLoopingOk = @errors.length <= 2
var @errorDetail = @errors.length

var @c1 = @check("terminal-complete", @terminalOk, @terminalValue)
var @c2 = @check("resolve-products", @resolveOk, @executionPretty)
var @c3 = @check("execute-purchase", @executeOk, @executionPretty)
var @c4 = @check("extract-ratings", @extractUsed, @executionPretty)
var @c5 = @check("derive-selection", @deriveUsed, @executionPretty)
var @c6 = @check("efficiency-le-8-calls", @efficiencyOk, @efficiencyDetail)
var @c7 = @check("no-error-looping", @noLoopingOk, @errorDetail)

exe @allChecks() = [ => [@c1, @c2, @c3, @c4, @c5, @c6, @c7] ]
var @checks = @allChecks()
var @fails = for @c in @checks when @c.status == "FAIL" => @c

show "Pattern 4: derive -> selection ref -> execute"
for @c in @checks => show `[@c.status] @c.id  @c.detail`

if @fails.length > 0 [
  show @executionPretty
  run sh { exit 1 }
]
