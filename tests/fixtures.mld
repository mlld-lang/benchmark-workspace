>> Shared test fixtures for rig v2.
>>
>> These records and tools are intentionally tiny, but they cover the
>> core surfaces the plan requires: display projection, record-backed
>> proofs, payload records, synthesized policy metadata, and direct tool
>> invocation during the stubbed flow tests.

record @contact = {
  facts: [email: string],
  data: [name: string, notes: string?],
  read: {
    role:planner: [name, { value: "email" }],
    role:worker: [name, { value: "email" }, notes]
  },
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

record @note_entry = {
  facts: [id_: string],
  data: [title: string, content: string?],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, title],
    role:worker: [{ value: "id_" }, title, content]
  },
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

record @message_entry = {
  facts: [id_: string, sender: string?],
  data: [body: string?, subject: string?],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, { value: "sender" }],
    role:worker: [{ value: "id_" }, { value: "sender" }, subject, body]
  }
}

record @email_payload = {
  facts: [],
  data: [subject: string, body: string, recipients: array?],
  validate: "demote"
}

>> Input-record fixture for the shipped tool-catalog redesign. This
>> mirrors the workspace calendar case: one optional fact destination
>> plus ordinary payload fields, authored on the surfaced tool instead
>> of split across controlArgs/expose/optional metadata.
record @meeting_request_inputs = {
  facts: [participants?: array],
  data: [title: string, start_time: string, end_time: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

record @append_note_inputs = {
  facts: [note_id: string],
  data: [content: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

record @create_note_inputs = {
  facts: [],
  data: [content: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

record @send_email_inputs = {
  facts: [recipients: array],
  data: [subject: string, body: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

record @password_update_inputs = {
  facts: [],
  data: [password: string],
  exact: [password],
  update: [password],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

record @note_payload = {
  facts: [],
  data: [content: string],
  validate: "demote"
}

record @summary_payload = {
  facts: [],
  data: [summary: string],
  validate: "demote"
}

record @webpage_content = {
  facts: [url: string],
  data: [content: string?],
  key: url,
  read: {
    role:planner: [{ value: "url" }],
    role:worker: [{ value: "url" }, content]
  }
}

record @number_row = {
  facts: [id_: string],
  data: [value: number],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, value],
    role:worker: [{ value: "id_" }, value]
  }
}

>> Arg-less scalar-lookalike resolve fixture. Workspace's
>> `@datetime_context` uses `value` as both fact field and record key, so
>> this mirrors the same "single record keyed by a scalar field" shape
>> without depending on MCP.
record @datetime_context = {
  facts: [value: string],
  data: [kind: string?],
  key: value,
  read: {
    role:planner: [{ value: "value" }, kind],
    role:worker: [{ value: "value" }, kind]
  },
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

>> Indexed-array selection-proof fixture used by tests/rig/proof-chain-firewall.mld.
>> shared_with stays in `data` so the array can be referenced by index in selection
>> refs (`fact:@@shared_file_entry.shared_with[0]`).
record @shared_file_entry = {
  facts: [id_: string],
  data: [filename: string, shared_with: array],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, filename],
    role:worker: [{ value: "id_" }, filename, shared_with]
  },
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

>> Read tools return static fixtures so the phase loop tests can focus
>> on rig mechanics instead of external variability.
exe resolve:r, tool:r @get_contacts() = [
  => [
    { email: "alice.example", name: "Alice", notes: "planner-hidden note" },
    { email: "bob.example", name: "Bob", notes: "secondary record" }
  ]
] => record @contact

exe resolve:r, tool:r @get_note(note_id) = [
  => { id_: @note_id, title: "Todo", content: "Existing note body" }
] => record @note_entry with { controlArgs: ["note_id"] }

exe resolve:r, tool:r @get_message(message_id) = [
  => {
    id_: @message_id,
    sender: "mallory.example",
    subject: "Follow up",
    body: "Draft a short summary and keep it factual."
  }
] => record @message_entry with { controlArgs: ["message_id"] }

exe resolve:r, tool:r @get_numbers() = [
  => [
    { id_: "n1", value: 3 },
    { id_: "n2", value: 8 },
    { id_: "n3", value: 5 }
  ]
] => record @number_row

exe resolve:r, tool:r @get_today() = [
  => {
    value: "2026-04-14",
    kind: "day"
  }
] => record @datetime_context

>> Literal-source extract fixture. This covers the extract:r read-tool
>> path used by Slack's webpage fetches.
exe extract:r, tool:r @get_webpage(url) = [
  => {
    url: @url,
    content: "Synthetic webpage content."
  }
] => record @webpage_content with { controlArgs: ["url"] }

>> Write tools echo their inputs. The tests assert on the phase log and
>> the execute attestation rather than on side effects outside mlld.
exe @send_email(recipients: array, subject, body) = [
  => {
    ok: true,
    recipients: @recipients,
    subject: @subject,
    body: @body
  }
]

exe @schedule_meeting(title, start_time, end_time, participants: array) = [
  let @participantsValue = @exists(@participants) ? @participants : null
  => {
    ok: true,
    title: @title,
    start_time: @start_time,
    end_time: @end_time,
    participants: @participantsValue
  }
]

exe @append_note(note_id, content) = [
  => {
    ok: true,
    note_id: @note_id,
    content: @content
  }
]

exe @create_note(content) = [
  => {
    ok: true,
    content: @content
  }
]

exe @update_password(password) = [
  => {
    ok: true,
    password: @password
  }
]

var @records = {
  contact: @contact,
  note_entry: @note_entry,
  message_entry: @message_entry,
  email_payload: @email_payload,
  note_payload: @note_payload,
  summary_payload: @summary_payload,
  webpage_content: @webpage_content,
  number_row: @number_row,
  datetime_context: @datetime_context,
  meeting_request_inputs: @meeting_request_inputs,
  append_note_inputs: @append_note_inputs,
  create_note_inputs: @create_note_inputs,
  send_email_inputs: @send_email_inputs,
  password_update_inputs: @password_update_inputs
}

>> The catalog mirrors the v2 interface shape on one authored object:
>> read entries keep planner-facing fields like `returns`, while write
>> entries carry input-record metadata directly.
var tools @tools = {
  get_contacts: {
    mlld: @get_contacts,
    returns: @contact,
    labels: ["resolve:r"],
    description: "Load the small synthetic contact list."
  },
  get_note: {
    mlld: @get_note,
    returns: @note_entry,
    labels: ["resolve:r"],
    description: "Load a single note by id."
  },
  get_message: {
    mlld: @get_message,
    returns: @message_entry,
    labels: ["resolve:r"],
    description: "Load a single message by id."
  },
  get_numbers: {
    mlld: @get_numbers,
    returns: @number_row,
    labels: ["resolve:r"],
    description: "Return a short numeric list for derive tests."
  },
  get_today: {
    mlld: @get_today,
    returns: @datetime_context,
    labels: ["resolve:r", "known"],
    description: "Return one synthetic day context record."
  },
  get_webpage: {
    mlld: @get_webpage,
    returns: @webpage_content,
    labels: ["extract:r", "untrusted", "exfil:fetch"],
    description: "Fetch a single synthetic webpage."
  },
  send_email: {
    mlld: @send_email,
    inputs: @send_email_inputs,
    labels: ["execute:w", "tool:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Send the same email body to one or more recipients."
  },
  schedule_meeting: {
    mlld: @schedule_meeting,
    inputs: @meeting_request_inputs,
    labels: ["execute:w", "tool:w", "calendar:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Schedule a meeting. Omit participants for a personal event."
  },
  append_note: {
    mlld: @append_note,
    inputs: @append_note_inputs,
    labels: ["execute:w", "tool:w", "destructive:targeted"],
    can_authorize: "role:planner",
    description: "Append content to an existing note identified by id."
  },
  create_note: {
    mlld: @create_note,
    inputs: @create_note_inputs,
    labels: ["execute:w", "tool:w", "file:w"],
    can_authorize: "role:planner",
    description: "Create a brand-new note with freeform content."
  },
  update_password: {
    mlld: @update_password,
    inputs: @password_update_inputs,
    labels: ["execute:w", "tool:w", "update:w", "privileged:account"],
    can_authorize: false,
    description: "Update the account password."
  }
}

>> Sample typed values are factored out so importers do not need to
>> re-run inline casts inside a larger exported object.
var @aliceContactRecord = {
  email: "alice.example",
  name: "Alice",
  notes: "planner-hidden note"
} as record @contact

var @bobContactRecord = {
  email: "bob.example",
  name: "Bob",
  notes: "secondary record"
} as record @contact

var @noteEntryRecord = {
  id_: "note_1",
  title: "Todo",
  content: "Existing note body"
} as record @note_entry

var @numberOneRecord = {
  id_: "n1",
  value: 3
} as record @number_row

var @numberTwoRecord = {
  id_: "n2",
  value: 8
} as record @number_row

var @summaryRecord = {
  summary: "Existing summary"
} as record @summary_payload

>> Nested object literals materialize their child values, so any
>> fact-bearing field we want to reuse later must be captured once as a
>> standalone value before we tuck it under `sampleState.field_values`.
var @aliceContactEmail = @aliceContactRecord.email
var @aliceContactName = @aliceContactRecord.name
var @aliceContactNotes = @aliceContactRecord.notes
var @bobContactEmail = @bobContactRecord.email
var @bobContactName = @bobContactRecord.name
var @bobContactNotes = @bobContactRecord.notes
var @noteEntryId = @noteEntryRecord.id_
var @noteEntryTitle = @noteEntryRecord.title
var @noteEntryContent = @noteEntryRecord.content
var @numberOneId = @numberOneRecord.id_
var @numberOneValue = @numberOneRecord.value
var @numberTwoId = @numberTwoRecord.id_
var @numberTwoValue = @numberTwoRecord.value

var @sampleState = {
  resolved: {
    contact: [
      {
        handle: "r_contact_alice.example",
        key: "alice.example",
        value: @aliceContactRecord,
        field_values: {
          email: @aliceContactEmail,
          name: @aliceContactName,
          notes: @aliceContactNotes
        }
      },
      {
        handle: "r_contact_bob.example",
        key: "bob.example",
        value: @bobContactRecord,
        field_values: {
          email: @bobContactEmail,
          name: @bobContactName,
          notes: @bobContactNotes
        }
      }
    ],
    note_entry: [
      {
        handle: "r_note_entry_note_1",
        key: "note_1",
        value: @noteEntryRecord,
        field_values: {
          id_: @noteEntryId,
          title: @noteEntryTitle,
          content: @noteEntryContent
        }
      }
    ],
    number_row: [
      {
        handle: "r_number_row_n1",
        key: "n1",
        value: @numberOneRecord,
        field_values: {
          id_: @numberOneId,
          value: @numberOneValue
        }
      },
      {
        handle: "r_number_row_n2",
        key: "n2",
        value: @numberTwoRecord,
        field_values: {
          id_: @numberTwoId,
          value: @numberTwoValue
        }
      }
    ]
  },
  extracted: {
    summary: {
      provenance: "extracted",
      value: @summaryRecord
    }
  },
  derived: {
    top_contact: {
      provenance: "derived",
      value: { choice: "Alice", body: "Derived body text" },
      selection_refs: [{
        source: "selection",
        backing: { record: "contact", handle: "r_contact_alice.example" }
      }]
    }
  },
  execution_log: [],
  phase_events: []
}

var @sampleAgent = {
  suite: "fixtures",
  records: @records
}

export {
  @contact,
  @note_entry,
  @message_entry,
  @email_payload,
  @meeting_request_inputs,
  @append_note_inputs,
  @create_note_inputs,
  @send_email_inputs,
  @password_update_inputs,
  @note_payload,
  @summary_payload,
  @number_row,
  @datetime_context,
  @shared_file_entry,
  @records,
  @tools,
  @sampleState,
  @sampleAgent,
  @aliceContactRecord,
  @bobContactRecord,
  @noteEntryRecord,
  @numberOneRecord,
  @numberTwoRecord,
  @summaryRecord,
  @get_contacts,
  @get_note,
  @get_message,
  @get_numbers,
  @get_today,
  @get_webpage,
  @send_email,
  @schedule_meeting,
  @append_note,
  @create_note,
  @update_password
}
