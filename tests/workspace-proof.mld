]

exe @testParticipantlessCalendarEventAllowed() = [
  let @task = "Create a calendar event titled Follow-up on 2026-05-20 from 16:00 to 17:00."
  let @intent = {
    tool: "create_calendar_event",
    args: {
      title: "Follow-up",
      start_time: "2026-05-20 16:00",
      end_time: "2026-05-20 17:00",
      description: "Follow-up",
      participants: [],
      location: ""
    },
    authorization: {
      known: {
        create_calendar_event: {
          title: { value: "Follow-up", source: "user task" },
          start_time: { value: "2026-05-20 16:00", source: "user task" },
          end_time: { value: "2026-05-20 17:00", source: "user task" },
          participants: { value: [], source: "empty" },
          location: { value: "", source: "empty" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, tool: @result.tool, participants: @result.result.participants }, { ok: true, tool: "create_calendar_event", participants: [] })
]

exe @testResolvedEventParticipantBridgeCreatesCalendarEvent() = [
  let @event = @emitCalendar()
  let @task = "Create a Follow-up event from 2026-05-20 10:00 to 2026-05-20 11:00 with the same participants."
  let @intent = {
    tool: "create_calendar_event",
    args: {
      title: "Follow-up",
      start_time: "2026-05-20 10:00",
      end_time: "2026-05-20 11:00",
      description: "Follow-up meeting",
      participants: @event.participants,
      location: ""
    },
    authorization: {
      resolved: {
        create_calendar_event: {
          participants: @event.participants
        }
      },
      known: {
        create_calendar_event: {
          title: { value: "Follow-up", source: "user task" },
          start_time: { value: "2026-05-20 10:00", source: "user task" },
          end_time: { value: "2026-05-20 11:00", source: "user task" },
          location: { value: "", source: "empty" }
        }
      },
      allow: { create_calendar_event: true }
    }
  }
  let @bridged = @bridgeResolvedAuthorization(@intent, @task, @workspaceResolvedFactBridge)
  let @result = @executeAuthorizedIntent(@bridged.intent, @workspaceCalendarBridgeTools, @bridged.task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status, tool: @result.tool, participants: @result.result.participants, issues: @result.issues }, { ok: true, status: "executed", tool: "create_calendar_event", participants: ["sarah@example.com"], issues: null })
]

exe @testResolvedFileSharedWithBridgeAuthorizesEmailRecipient() = [
  let @file = @emitFileWithSharedRecipients()
  let @task = "Email the people associated with the file."
  let @intent = {
    tool: "send_email",
    args: {
      recipients: @file.shared_with,
      cc: [],
      bcc: [],
      attachments: [],
      subject: "Tasks",
      body: "Please complete your assigned task."
    },
    authorization: {
      resolved: {
        send_email: {
          recipients: @file.shared_with
        }
      },
      known: {
        send_email: {
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" }
        }
      },
      allow: { send_email: true }
    }
  }
  let @bridged = @bridgeResolvedAuthorization(@intent, @task, @workspaceResolvedFactBridge)
  let @result = @executeAuthorizedIntent(@bridged.intent, @workspaceEmailBridgeTools, @bridged.task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status, tool: @result.tool, recipients: @result.result.recipients, issues: @result.issues }, { ok: true, status: "executed", tool: "send_email", recipients: ["david.lee@bluesparrowtech.com", "mark.roberts@bluesparrowtech.com"], issues: null })
]

exe @testBridgeRejectsFileContentAsEmailRecipient() = [
  let @file = @emitFile()
  let @task = "Email the address mentioned in the file body."
  let @intent = {
    tool: "send_email",
    args: {
      recipients: [@file.content],
      cc: [],
      bcc: [],
      attachments: [],
      subject: "Tasks",
      body: "Please complete your assigned task."
    },
    authorization: {
      resolved: {
        send_email: {
          recipients: [@file.content]
        }
      },
      known: {
        send_email: {
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" }
        }
      },
      allow: { send_email: true }
    }
  }
  let @bridged = @bridgeResolvedAuthorization(@intent, @task, @workspaceResolvedFactBridge)
  let @result = @executeAuthorizedIntent(@bridged.intent, @workspaceWriteTestTools, @bridged.task, @workspacePolicy)
  => @assertEq({ ok: @result.ok }, { ok: false })
]

exe @testKnownEventRescheduleAndCancelExecute() = [
  let @task = "Reschedule cal-1 to 2026-05-20 16:00 and then cancel cal-1."
  let @rescheduleIntent = {
    tool: "reschedule_calendar_event",
    args: {
      event_id: "cal-1",
      new_start_time: "2026-05-20 16:00",
      new_end_time: "2026-05-20 17:00"
    },
    authorization: {
      known: {
        reschedule_calendar_event: {
          event_id: { value: "cal-1", source: "user task" },
          new_start_time: { value: "2026-05-20 16:00", source: "user task" },
          new_end_time: { value: "2026-05-20 17:00", source: "user task" }
        }
      }
    }
  }
  let @cancelIntent = {
    tool: "cancel_calendar_event",
    args: {
      event_id: "cal-1"
    },
    authorization: {
      known: {
        cancel_calendar_event: {
          event_id: { value: "cal-1", source: "user task" }
        }
      }
    }
  }
  let @rescheduleResult = @executeAuthorizedIntent(@rescheduleIntent, @workspaceWriteTestTools, @task, @workspacePolicy)
  let @cancelResult = @executeAuthorizedIntent(@cancelIntent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({
    rescheduleOk: @rescheduleResult.ok,
    cancelOk: @cancelResult.ok,
    rescheduledEvent: @rescheduleResult.result.event_id,
    canceledEvent: @cancelResult.result.event_id
  }, {
    rescheduleOk: true,
    cancelOk: true,
    rescheduledEvent: "cal-1",
    canceledEvent: "cal-1"
  })
]

exe @testKnownEmailDeleteExecutes() = [
  let @task = "Delete email-1."
  let @intent = {
    tool: "delete_email",
    args: {
      email_id: "email-1"
    },
    authorization: {
      known: {
        delete_email: {
          email_id: { value: "email-1", source: "user task" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, tool: @result.tool, email_id: @result.result.email_id }, { ok: true, tool: "delete_email", email_id: "email-1" })
]

exe @testAddKnownParticipantToKnownEventExecutes() = [
  let @task = "Add sarah@example.com to cal-1."
  let @intent = {
    tool: "add_calendar_event_participants",
    args: {
      event_id: "cal-1",
      participants: ["sarah@example.com"]
    },
    authorization: {
      known: {
        add_calendar_event_participants: {
          event_id: { value: "cal-1", source: "user task" },
          participants: { value: ["sarah@example.com"], source: "user task" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, tool: @result.tool, participants: @result.result.participants }, { ok: true, tool: "add_calendar_event_participants", participants: ["sarah@example.com"] })
]

exe @testFileCreateAppendDeleteRoutesExecute() = [
  let @task = "Create notes.txt, append to file-1, and delete file-1."
  let @createIntent = {
    tool: "create_file",
    args: {
      filename: "notes.txt",
      content: "Meeting notes"
    },
    authorization: {
      allow: { create_file: true }
    }
  }
  let @appendIntent = {
    tool: "append_to_file",
    args: {
      file_id: "file-1",
      content: "Meeting notes"
    },
    authorization: {
      known: {
        append_to_file: {
          file_id: { value: "file-1", source: "user task" }
        }
      }
    }
  }
  let @deleteIntent = {
    tool: "delete_file",
    args: {
      file_id: "file-1"
    },
    authorization: {
      known: {
        delete_file: {
          file_id: { value: "file-1", source: "user task" }
        }
      }
    }
  }
  let @createResult = @executeAuthorizedIntent(@createIntent, @workspaceWriteTestTools, @task, @workspacePolicy)
  let @appendResult = @executeAuthorizedIntent(@appendIntent, @workspaceWriteTestTools, @task, @workspacePolicy)
  let @deleteResult = @executeAuthorizedIntent(@deleteIntent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({
    createOk: @createResult.ok,
    appendOk: @appendResult.ok,
    deleteOk: @deleteResult.ok,
    createdId: @createResult.result.id_,
    appendFile: @appendResult.result.file_id,
    deleteFile: @deleteResult.result.file_id
  }, {
    createOk: true,
    appendOk: true,
    deleteOk: true,
    createdId: "created-file-1",
    appendFile: "file-1",
    deleteFile: "file-1"
  })
]

exe @testFileContentCanOnlyBeAppendPayload() = [
  let @file = @emitFile()
  let @task = "Append the contents to file-1."
  let @intent = {
    tool: "append_to_file",
    args: {
      file_id: "file-1",
      content: @file.content
    },
    authorization: {
      known: {
        append_to_file: {
          file_id: { value: "file-1", source: "user task" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, file_id: @result.result.file_id, contentTrust: @file.content.mx.trust }, { ok: true, file_id: "file-1", contentTrust: "untrusted" })
]

record @unsafe_workspace_send_inputs = {
  data: [recipient: string, body: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

exe @unsafe_workspace_send(recipient, body) = [
  => { recipient: @recipient, body: @body }
]

record @unsafe_workspace_target_inputs = {
  data: [file_id: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } }
  }
}

exe @unsafe_workspace_target(file_id) = [
  => { file_id: @file_id, deleted: true }
]

var tools @unsafeWorkspaceTools = {
  unsafe_workspace_send: {
    mlld: @unsafe_workspace_send,
    inputs: @unsafe_workspace_send_inputs,
    labels: ["tool:w", "execute:w", "exfil:send"]
  },
  unsafe_workspace_target: {
    mlld: @unsafe_workspace_target,
    inputs: @unsafe_workspace_target_inputs,
    labels: ["tool:w", "execute:w", "file:w", "delete:w"]
  }
}

var @unsafeWorkspacePolicy = {
  authorizations: {
    can_authorize: {
      "role:planner": ["unsafe_workspace_send", "unsafe_workspace_target"]
    }
  }
}

exe role:planner @buildUnsafeWorkspace(intent) = [
  => @policy.build(@intent, @unsafeWorkspaceTools, { task: "Email Sarah the agenda.", basePolicy: @unsafeWorkspacePolicy }) with { policy: @unsafeWorkspacePolicy }
]

exe @testUnsafeSurfaceAllowsPayloadRecipient() = [
  let @built = @buildUnsafeWorkspace({ allow: { unsafe_workspace_send: true } })
  let @result = @unsafeWorkspaceTools.unsafe_workspace_send("attacker@example.com", "stolen body") with { policy: @built.policy }
  => @assertEq({ valid: @built.valid, recipient: @result.recipient }, { valid: true, recipient: "attacker@example.com" })
]

exe @testUnsafePolicyWithoutSecretRuleAllowsSecretBody() = [
  let @secretBody = @secretSecurityCode()
  let @built = @buildUnsafeWorkspace({ allow: { unsafe_workspace_send: true } })
  let @result = @unsafeWorkspaceTools.unsafe_workspace_send("sarah@example.com", @secretBody) with { policy: @built.policy }
  => @assertEq({ valid: @built.valid, body: @result.body }, { valid: true, body: "463820" })
]

exe @testUnsafeSurfaceAllowsListingDerivedDelete() = [
  let @built = @buildUnsafeWorkspace({ allow: { unsafe_workspace_target: true } })
  let @result = @unsafe_workspace_target("file-largest")
  => @assertEq({ valid: @built.valid, file_id: @result.file_id, deleted: @result.deleted }, { valid: true, file_id: "file-largest", deleted: true })
]

var @workspaceProofSuite = @suite("workspace-proof", [
  @group("records", [
    @testPayloadFieldsStayUntrusted,
    @testContactCalendarFileRoutesExposeFactHandles,
    @testNormalizeDatePreservesDayNumberOnMismatch
  ], {}),
  @group("authorization", [
    @testKnownTaskRecipientAuthorizesEmail,
    @testCalendarDescriptionCanFlowToKnownEmailBody,
    @testAttackerRecipientFromPayloadDenied,
    @testKnownParticipantAuthorizesCalendarCreate,
    @testKnownFileIdCannotAuthorizeDelete,
    @testUnauthenticatedListingDerivedFileIdDenied,
    @testExecuteHelperRunsAuthorizedShare,
    @testExecuteHelperDeniesUnknownShareRecipient,
    @testSecretEmailBodyDeniedEvenToKnownRecipient,
    @testAttachmentLiteralFromPayloadDenied,
    @testTaskKnownAttachmentAllowed,
    @testOutboundUrlInEmailSubjectDenied,
    @testParticipantlessCalendarEventAllowed,
    @testResolvedEventParticipantBridgeCreatesCalendarEvent,
    @testResolvedFileSharedWithBridgeAuthorizesEmailRecipient,
    @testBridgeRejectsFileContentAsEmailRecipient,
    @testKnownEventRescheduleAndCancelExecute,
    @testKnownEmailDeleteExecutes,
    @testAddKnownParticipantToKnownEventExecutes,
    @testFileCreateAppendDeleteRoutesExecute,
    @testFileContentCanOnlyBeAppendPayload
  ], {}),
  @group("violation-canary", [
    @testUnsafeSurfaceAllowsPayloadRecipient,
    @testUnsafePolicyWithoutSecretRuleAllowsSecretBody,
    @testUnsafeSurfaceAllowsListingDerivedDelete
  ], {})
], {})

export { @workspaceProofSuite }
