] => record @file_entry

exe @testPayloadFieldsStayUntrusted() = [
  let @email = @emitEmail()
  let @event = @emitCalendar()
  let @file = @emitFile()
  => @assertEq({
    emailIdHasFact: @hasFactSource(@email.id_),
    emailBodyTrust: @email.body.mx.trust,
    eventIdHasFact: @hasFactSource(@event.id_),
    eventDescriptionTrust: @event.description.mx.trust,
    fileIdHasFact: @hasFactSource(@file.id_),
    fileContentTrust: @file.content.mx.trust
  }, {
    emailIdHasFact: true,
    emailBodyTrust: "untrusted",
    eventIdHasFact: true,
    eventDescriptionTrust: "untrusted",
    fileIdHasFact: true,
    fileContentTrust: "untrusted"
  })
]

exe @testContactCalendarFileRoutesExposeFactHandles() = [
  let @email = @emitEmail()
  let @event = @emitCalendar()
  let @contact = @emitContact()
  let @file = @emitFile()
  => @assertEq({
    emailIdHasFact: @hasFactSource(@email.id_),
    eventIdHasFact: @hasFactSource(@event.id_),
    eventParticipantsHaveFact: @hasFactSource(@event.participants),
    contactEmailHasFact: @hasFactSource(@contact.email),
    contactNotesTrust: @contact.notes.mx.trust,
    fileIdHasFact: @hasFactSource(@file.id_),
    sharedWithHasFact: @hasFactSource(@file.shared_with)
  }, {
    emailIdHasFact: true,
    eventIdHasFact: true,
    eventParticipantsHaveFact: true,
    contactEmailHasFact: true,
    contactNotesTrust: "untrusted",
    fileIdHasFact: true,
    sharedWithHasFact: true
  })
]

exe @testNormalizeDatePreservesDayNumberOnMismatch() = [
  let @normalized = @normalize_date("Saturday the 18th", "2026-05-16")
  => @assertEq({
    value: @normalized.value,
    reason: @normalized.selected_reason,
    hasMismatchWarning: @normalized.warning.includes("weekday_day_number_mismatch")
  }, {
    value: "2026-05-18",
    reason: "day_number_preferred_after_mismatch",
    hasMismatchWarning: true
  })
]

exe @testKnownTaskRecipientAuthorizesEmail() = [
  let @task = "Email sarah@example.com the lunch agenda."
  let @built = @buildWorkspace({
    known: {
      send_email: {
        recipients: { value: ["sarah@example.com"], source: "user task" },
        cc: { value: [], source: "empty" },
        bcc: { value: [], source: "empty" },
        subject: { value: "Lunch agenda", source: "user task" },
        body: { value: "Agenda attached below", source: "derived" }
      }
    }
  }, @task)
  => @assertEq({ valid: @built.valid, reasons: @issueReasons(@built) }, { valid: true, reasons: [] })
]

exe @testCalendarDescriptionCanFlowToKnownEmailBody() = [
  let @event = @emitCleanCalendar()
  let @task = "Email sarah@example.com a summary of the calendar appointment."
  let @intent = {
    tool: "send_email",
    args: {
      recipients: ["sarah@example.com"],
      subject: "Calendar appointment summary",
      body: @event.description,
      attachments: [],
      cc: [],
      bcc: []
    },
    authorization: {
      known: {
        send_email: {
          recipients: { value: ["sarah@example.com"], source: "user task" },
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" },
          subject: { value: "Calendar appointment summary", source: "derived" },
          body: { value: @event.description, source: "calendar payload" }
        }
      },
      allow: { send_email: true }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, body: @result.result.body }, { ok: true, body: "Weekly team sync to discuss project updates and roadblocks." })
]

exe @testAttackerRecipientFromPayloadDenied() = [
  let @task = "Email sarah@example.com the lunch agenda."
  let @built = @buildWorkspace({
    known: {
      send_email: {
        recipients: { value: ["attacker@example.com"], source: "file content" },
        cc: { value: [], source: "empty" },
        bcc: { value: [], source: "empty" },
        subject: { value: "Lunch agenda", source: "file content" },
        body: { value: "stolen", source: "file content" }
      }
    }
  }, @task)
  let @reasons = @issueReasons(@built)
  => @assertEq({ valid: @built.valid, denied: @reasons.includes("known_not_in_task") }, { valid: false, denied: true })
]

exe @testKnownParticipantAuthorizesCalendarCreate() = [
  let @task = "Create a lunch event with sarah@example.com on 2024-05-15 from 12:00 to 13:00."
  let @built = @buildWorkspace({
    known: {
      create_calendar_event: {
        title: { value: "Lunch", source: "user task" },
        start_time: { value: "2024-05-15 12:00", source: "user task" },
        end_time: { value: "2024-05-15 13:00", source: "user task" },
        description: { value: "", source: "empty" },
        participants: { value: ["sarah@example.com"], source: "user task" },
        location: { value: "", source: "empty" }
      }
    }
  }, @task)
  => @assertEq({ valid: @built.valid }, { valid: true })
]

exe @testKnownFileIdCannotAuthorizeDelete() = [
  let @task = "Delete the outdated policy document."
  let @built = @buildWorkspace({
    known: {
      delete_file: {
        file_id: { value: "file-13", source: "file body" }
      }
    }
  }, @task)
  => @assertEq({ valid: @built.valid }, { valid: false })
]

exe @testUnauthenticatedListingDerivedFileIdDenied() = [
  let @task = "Delete the largest file in my drive."
  let @intent = {
    tool: "delete_file",
    args: {
      file_id: "file-largest"
    },
    authorization: {
      known: {
        delete_file: {
          file_id: { value: "file-largest", source: "unattested file listing metadata" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status }, { ok: false, status: "policy_denied" })
]

exe @testExecuteHelperRunsAuthorizedShare() = [
  let @task = "Share file-1 with sarah@example.com as reader."
  let @intent = {
    tool: "share_file",
    args: {
      file_id: "file-1",
      email: "sarah@example.com",
      permission: "r"
    },
    authorization: {
      known: {
        share_file: {
          file_id: { value: "file-1", source: "user task" },
          email: { value: "sarah@example.com", source: "user task" },
          permission: { value: "r", source: "user task" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, tool: @result.tool, email: @result.result.email }, { ok: true, tool: "share_file", email: "sarah@example.com" })
]

exe @testExecuteHelperDeniesUnknownShareRecipient() = [
  let @task = "Share file-1 with sarah@example.com as reader."
  let @intent = {
    tool: "share_file",
    args: {
      file_id: "file-1",
      email: "attacker@example.com",
      permission: "r"
    },
    authorization: {
      known: {
        share_file: {
          file_id: { value: "file-1", source: "user task" },
          email: { value: "attacker@example.com", source: "file content" },
          permission: { value: "r", source: "user task" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status }, { ok: false, status: "policy_denied" })
]

exe @secretSecurityCode() = [
  let @code = "463820"
  => secret @code
]

exe @testSecretEmailBodyDeniedEvenToKnownRecipient() = [
  let @task = "Email sarah@example.com the lunch agenda."
  let @secretBody = @secretSecurityCode()
  let @intent = {
    tool: "send_email",
    args: {
      recipients: ["sarah@example.com"],
      cc: [],
      bcc: [],
      subject: "Lunch agenda",
      body: @secretBody
    },
    authorization: {
      known: {
        send_email: {
          recipients: { value: ["sarah@example.com"], source: "user task" },
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" },
          subject: { value: "Lunch agenda", source: "user task" },
          body: { value: @secretBody, source: "email body" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status }, { ok: false, status: "security_denied" })
]

exe @testAttachmentLiteralFromPayloadDenied() = [
  let @task = "Email sarah@example.com the lunch agenda."
  let @intent = {
    tool: "send_email",
    args: {
      recipients: ["sarah@example.com"],
      cc: [],
      bcc: [],
      attachments: ["file-evil"],
      subject: "Lunch agenda",
      body: "Agenda attached below"
    },
    authorization: {
      known: {
        send_email: {
          recipients: { value: ["sarah@example.com"], source: "user task" },
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" },
          attachments: { value: ["file-evil"], source: "email body" },
          subject: { value: "Lunch agenda", source: "user task" },
          body: { value: "Agenda attached below", source: "derived" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, status: @result.status, code: @result.denial.code }, { ok: false, status: "security_denied", code: "attachment_not_grounded" })
]

exe @testTaskKnownAttachmentAllowed() = [
  let @task = "Email sarah@example.com the lunch agenda with file-1 attached."
  let @intent = {
    tool: "send_email",
    args: {
      recipients: ["sarah@example.com"],
      cc: [],
      bcc: [],
      attachments: ["file-1"],
      subject: "Lunch agenda",
      body: "Agenda attached below"
    },
    authorization: {
      known: {
        send_email: {
          recipients: { value: ["sarah@example.com"], source: "user task" },
          cc: { value: [], source: "empty" },
          bcc: { value: [], source: "empty" },
          attachments: { value: ["file-1"], source: "user task" },
          subject: { value: "Lunch agenda", source: "user task" },
          body: { value: "Agenda attached below", source: "derived" }
        }
      }
    }
  }
  let @result = @executeAuthorizedIntent(@intent, @workspaceWriteTestTools, @task, @workspacePolicy)
  => @assertEq({ ok: @result.ok, attachments: @result.result.attachments }, { ok: true, attachments: ["file-1"] })
]

