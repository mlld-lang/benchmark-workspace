import { @assertEq } from "./assert.mld"
import { @suite, @group } from "./runner.mld"
import { @executeAuthorizedIntent, @bridgeResolvedAuthorization } from "../rig/workers.mld"

import {
  @contact,
  @email_msg,
  @calendar_evt,
  @file_entry,
  @send_email_inputs,
  @delete_email_inputs,
  @create_calendar_event_inputs,
  @cancel_calendar_event_inputs,
  @reschedule_calendar_event_inputs,
  @add_calendar_event_participants_inputs,
  @file_append_inputs,
  @file_create_inputs,
  @file_delete_inputs,
  @share_file_inputs
} from "../bench/domains/workspace/records.mld"

import { @workspacePolicy, @workspaceResolvedFactBridge } from "../bench/domains/workspace/policy.mld"
import { @normalize_date } from "../bench/domains/workspace/datetime.mld"

exe @fake_send_email(recipients, subject, body, attachments, cc, bcc) = [
  => { tool: "send_email", recipients: @recipients, subject: @subject, body: @body, attachments: @attachments, cc: @cc, bcc: @bcc }
]

exe @fake_delete_email(email_id) = [
  => { tool: "delete_email", email_id: @email_id }
]

exe @fake_create_calendar_event(title, start_time, end_time, description, participants, location) = [
  => { tool: "create_calendar_event", title: @title, start_time: @start_time, end_time: @end_time, description: @description, participants: @participants, location: @location }
]

exe @fake_cancel_calendar_event(event_id) = [
  => { tool: "cancel_calendar_event", event_id: @event_id }
]

exe @fake_reschedule_calendar_event(event_id, new_start_time, new_end_time) = [
  => { tool: "reschedule_calendar_event", event_id: @event_id, new_start_time: @new_start_time, new_end_time: @new_end_time }
]

exe @fake_add_calendar_event_participants(event_id, participants) = [
  => { tool: "add_calendar_event_participants", event_id: @event_id, participants: @participants }
]

exe @fake_append_to_file(file_id, content) = [
  => { tool: "append_to_file", file_id: @file_id, content: @content }
]

exe @fake_create_file(filename, content) = [
  => { tool: "create_file", filename: @filename, content: @content, id_: "created-file-1" }
]

exe @fake_delete_file(file_id) = [
  => { tool: "delete_file", file_id: @file_id }
]

exe @fake_share_file(file_id, email, permission) = [
  => { tool: "share_file", file_id: @file_id, email: @email, permission: @permission }
]

var tools @workspaceWriteTestTools = {
  send_email: {
    mlld: @fake_send_email,
    inputs: @send_email_inputs,
    labels: ["tool:w", "execute:w", "comm:w", "exfil:send"]
  },
  delete_email: {
    mlld: @fake_delete_email,
    inputs: @delete_email_inputs,
    labels: ["tool:w", "execute:w", "delete:w", "destructive"]
  },
  create_calendar_event: {
    mlld: @fake_create_calendar_event,
    inputs: @create_calendar_event_inputs,
    labels: ["tool:w", "execute:w", "calendar:w", "exfil:send"]
  },
  cancel_calendar_event: {
    mlld: @fake_cancel_calendar_event,
    inputs: @cancel_calendar_event_inputs,
    labels: ["tool:w", "execute:w", "calendar:w", "delete:w", "destructive"]
  },
  reschedule_calendar_event: {
    mlld: @fake_reschedule_calendar_event,
    inputs: @reschedule_calendar_event_inputs,
    labels: ["tool:w", "execute:w", "calendar:w", "update:w"]
  },
  add_calendar_event_participants: {
    mlld: @fake_add_calendar_event_participants,
    inputs: @add_calendar_event_participants_inputs,
    labels: ["tool:w", "execute:w", "calendar:w", "update:w", "exfil:send"]
  },
  append_to_file: {
    mlld: @fake_append_to_file,
    inputs: @file_append_inputs,
    labels: ["tool:w", "execute:w", "file:w", "update:w"]
  },
  create_file: {
    mlld: @fake_create_file,
    inputs: @file_create_inputs,
    labels: ["tool:w", "execute:w", "file:w"]
  },
  delete_file: {
    mlld: @fake_delete_file,
    inputs: @file_delete_inputs,
    labels: ["tool:w", "execute:w", "file:w", "delete:w", "destructive"]
  },
  share_file: {
    mlld: @fake_share_file,
    inputs: @share_file_inputs,
    labels: ["tool:w", "execute:w", "file:w", "exfil:send"]
  }
}

var tools @workspaceCalendarBridgeTools = {
  create_calendar_event: {
    mlld: @fake_create_calendar_event,
    inputs: @create_calendar_event_inputs,
    labels: ["tool:w", "execute:w", "calendar:w", "exfil:send"]
  }
}

var tools @workspaceEmailBridgeTools = {
  send_email: {
    mlld: @fake_send_email,
    inputs: @send_email_inputs,
    labels: ["tool:w", "execute:w", "comm:w", "exfil:send"]
  }
}

exe role:planner @buildWorkspace(intent, task) = [
  => @policy.build(@intent, @workspaceWriteTestTools, { task: @task, basePolicy: @workspacePolicy }) with { policy: @workspacePolicy }
]

exe @issueReasons(buildResult) = [
  let @issues = @buildResult.issues ?? []
  let @reasons = for @issue in @issues => @issue.reason
  => @reasons
]

exe @hasFactSource(inputValue) = [
  let @sources = @inputValue.mx.factsources ?? []
  => @sources.length > 0
]

