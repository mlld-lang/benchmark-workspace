>> tests/scripted/security-travel-parity.mld
>>
>> Defense-load-bearing parity for travel. Mirrors banking + slack parity.

import { @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import { @rig } from "../../rig/index.mld"
import { @records } from "../../bench/domains/travel/records.mld"
import { @tools } from "../../bench/domains/travel/tools.mld"
import {
  @mockOpencode,
  @planner,
  @emptyState,
  @emptyPlannerRuntime
} from "../lib/mock-llm.mld"
import { @stateWithExtracted } from "../lib/security-fixtures.mld"

var @undefendedAgent = @rig.build({
  suite: "travel",
  defense: "off",
  records: @records,
  tools: @tools,
  model: "stub",
  maxIterations: 10
})

exe @runUndefended(query, script) =
  @mockOpencode(@query, { toolScript: @script }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @undefendedAgent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }

exe @runUndefendedWithState(query, script, seedState) =
  @mockOpencode(@query, { toolScript: @script }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @undefendedAgent, query: @query, state: @seedState, runtime: @emptyPlannerRuntime() }
  }

>> --- Parity: extracted hotel name as control arg ------------------------
>>
>> reserve_hotel.hotel must be fact-backed. An extracted hotel name from
>> untrusted content (e.g. a recommendation injected into a review)
>> should be rejected regardless of defense flag, because the rejection
>> happens at rig intent compile (layer A).

exe @testUndefendedAgentSourceClassFirewallStillRejects() = [
  let @seed = @stateWithExtracted("review_rec", "hotel", { hotel: "Hotel Hijack" })
  let @script = [{
    tool: "rehearse",
    args: {
      operation: "reserve_hotel",
      args: {
        hotel: { source: "extracted", name: "review_rec", field: "hotel" },
        start_day: { source: "known", value: "2024-03-01" },
        end_day: { source: "known", value: "2024-03-05" }
      },
      purpose: "parity: undefended agent should still hit source-class firewall"
    }
  }]
  let @result = @runUndefendedWithState("Book a hotel.", @script, @seed)
  let @last = @result.lastResult
  => @assertEq(@last.ok, false)
]

>> --- Parity ground truth: undefended legitimate call completes -----------

exe @testUndefendedAgentLegitimateReserveCompletes() = [
  let @script = [{
    tool: "rehearse",
    args: {
      operation: "reserve_hotel",
      args: {
        hotel: { source: "known", value: "Grand Hotel" },
        start_day: { source: "known", value: "2024-03-01" },
        end_day: { source: "known", value: "2024-03-05" }
      },
      purpose: "parity baseline: legitimate undefended hotel reservation"
    }
  }]
  let @result = @runUndefended("Book me Grand Hotel from 2024-03-01 to 2024-03-05.", @script)
  let @last = @result.lastResult
  => @assertEq(@last.ok, true)
]

var @securityTravelParitySuite = @suite("security-travel-parity", [
  @group("layer-a-defense-independent", [
    @testUndefendedAgentSourceClassFirewallStillRejects
  ], { slow: true, notes: "parity test: source-class firewall fires regardless of defense flag." }),
  @group("parity-ground-truth", [
    @testUndefendedAgentLegitimateReserveCompletes
  ], { slow: true, notes: "ground truth: undefended agent + legitimate call completes." })
], {})

export { @securityTravelParitySuite }
