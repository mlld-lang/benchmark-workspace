>> clean/tests/scripted-index-workspace.mld
>>
>> Run via:
>>   uv run --project bench python3 tests/run-scripted.py --suite workspace \
>>     --index tests/scripted-index-workspace.mld

import { @runSuites } from "./runner.mld"
import { @securityWorkspaceSuite } from "./scripted/security-workspace.mld"
import { @securityWorkspaceParitySuite } from "./scripted/security-workspace-parity.mld"

var @suites = [
  @securityWorkspaceSuite,
  @securityWorkspaceParitySuite
]

var @result = @runSuites(@suites)

show "clean/tests (scripted-workspace)"
show ""
show @result.report
show ""

if @result.timingLines.length > 0 [
  for @tl in @result.timingLines => show `  @tl`
  show ""
]

if @result.xpassNudge != "" [ show @result.xpassNudge ]

show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`

show `__SCRIPTED_STATUS__: passes=@result.passes.length fails=@result.fails.length xfails=@result.xfails.length xpasses=@result.xpasses.length`
