>> clean/tests/suites/rig/worker-dispatch.mld
>>
>> Worker-dispatch invariants. Covers how the resolve/extract/derive workers
>> dispatch and how planner-tool wrappers thread session state.
>>
>> Stage B shelf-shape: every test exe is `role:worker` and declares its
>> own shelf inline (shelves expire at exe-body exit per m-box-shelf).
>> The `with { session: @planner, seed: {...} }` activation lives inside
>> each test exe — c-a873 showed module-load activation contaminates
>> sibling suites' policy-build runtime.
>>
>> Reads of resolved records go through `@shelf.read(@ps.<recordType>)`
>> on the test-built shelf, not `state.resolved` (gone post-Stage-B).

import { @assertOk, @assertEq, @assertContains } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"

import {
  @records,
  @tools,
  @get_contacts,
  @get_today
} from "../fixtures.mld"
import { @rigBuild } from "../../rig/index.mld"
import {
  @callTool,
  @emptyState,
  @llmCallEntry,
  @shelfRecords
} from "../../rig/runtime.mld"
import { @resolveRefValue } from "../../rig/intent.mld"
import { @phaseCatalog, @phaseToolEntry, @renderToolDocs } from "../../rig/tooling.mld"
import { @dispatchResolve } from "../../rig/workers/resolve.mld"
import { @dispatchExtract } from "../../rig/workers/extract.mld"
import { @planner, @plannerTools } from "../../rig/workers/planner.mld"
import { @emptyPlannerRuntime } from "../../rig/session.mld"

>> --- Module-level fixtures (built once, referenced by tests) -------------

>> Reusable resolve:r tool used by the read-tool-docs / read-tool-params tests.
exe resolve:r, tool:r @search_day_events(query, day) = [
  => {
    value: @day,
    kind: @query
  }
] => record @records.datetime_context

var @builtFixtureAgent = @rigBuild({
  suite: "fixture-build",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools
})

var @plannerExtractFixtureAgent = @rigBuild({
  suite: "fixture-planner-extract",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  overrides: {
    stub: {
      extract: [{
        status: "ok",
        schema_name: "contact",
        name: "contact_details",
        provenance: "extracted",
        preview_fields: ["email", "name"],
        payload: {
          email: "alice.example",
          name: "Alice",
          notes: "planner-hidden note"
        }
      }]
    }
  }
})

var @plannerDeriveFixtureAgent = @rigBuild({
  suite: "fixture-planner-derive",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  overrides: {
    stub: {
      derive: [{
        status: "derived",
        schema_name: "action_items",
        name: "action_items",
        provenance: "derived",
        payload: {
          items: [{
            person_name: "Alice",
            task_description: "Send the launch update",
            deadline: "2026-04-23"
          }]
        },
        summary: "derived action_items"
      }],
      extract: [{
        status: "extracted",
        schema_name: "inline-schema",
        name: "action_items_copy",
        provenance: "extracted",
        preview_fields: ["person_name", "task_description", "deadline"],
        payload: {
          person_name: "Alice",
          task_description: "Send the launch update",
          deadline: "2026-04-23"
        },
        summary: "extracted action_items_copy"
      }]
    }
  }
})

>> Read-tool-arg fixture: every param is control by labeling.
var tools @readArgFixtureTools = {
  search_day_events: {
    mlld: @search_day_events,
    returns: @records.datetime_context,
    labels: ["resolve:r"],
    description: "Search one synthetic day context by query and day."
  }
}
var @readArgFixtureAgent = @rigBuild({
  suite: "fixture-read-args",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @readArgFixtureTools
})
var @readArgDoc = @renderToolDocs(@readArgFixtureTools)[0]

>> --- Planner-tool wrappers (called from test exes via `with { session, seed }`) ---

>> Single resolve dispatch through the planner-tool collection.
exe llm @testPlannerResolve(prompt, config) = [
  => @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.args)
]

>> Batch resolve. Returns the batch result + planner state/runtime so the
>> test exe can also assert on session-side state. The shelf reads happen
>> in the calling test exe (it owns the shelf decl).
exe llm @testPlannerResolveBatch(prompt, config) = [
  let @batchResult = @callTool(@plannerTools.resolve_batch, @plannerTools, "resolve_batch", @config.args)
  let @stateAfter = @planner.state
  let @runtimeAfter = @planner.runtime
  => {
    result: @batchResult,
    state: @stateAfter,
    runtime: @runtimeAfter
  }
]

>> Resolve + ref-resolution + extract chain. Looks the resolved handle up
>> from the seeded shelf after the resolve runs — post-Stage-B handles use
>> `.mx.address.key` (content-derived hash), not the literal `<email>`
>> form the bucket era used, so the test must derive it dynamically.
exe llm @testPlannerExtractChain(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.resolveArgs)
  let @stateAfterResolve = @planner.state
  let @contacts = @shelf.read(@planner.agent.plannerShelf.contact)
  let @alice = @contacts[0]
  let @aliceHandle = `r_contact_@alice.mx.address.key`
  let @ref = { source: "resolved", record: "contact", handle: @aliceHandle, field: @config.refField }
  let @resolvedEmail = @resolveRefValue(@planner.agent, @stateAfterResolve, @ref)
  let @extractArgs = {
    source: { source: "resolved", record: "contact", handle: @aliceHandle },
    schema: @config.extractSchema,
    name: @config.extractName,
    purpose: @config.extractPurpose
  }
  let @extractResult = @callTool(@plannerTools.extract, @plannerTools, "extract", @extractArgs)
  let @stateAfterExtract = @planner.state
  => {
    resolveResult: @resolveResult,
    stateAfterResolve: @stateAfterResolve,
    resolvedEmail: @resolvedEmail,
    extractResult: @extractResult,
    stateAfterExtract: @stateAfterExtract,
    aliceHandle: @aliceHandle,
    aliceRecord: @alice
  }
]

>> Resolve-then-text. The planner ends with a text answer (not a tool
>> call); used by the llmCallEntry session-snapshot omission test.
exe llm @testPlannerTextResult(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.args)
  => "planner final text"
]

>> Resolve + derive + extract chain on the derive-fixture agent.
exe llm @testPlannerDeriveChain(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.resolveArgs)
  let @deriveResult = @callTool(@plannerTools.derive, @plannerTools, "derive", @config.deriveArgs)
  let @extractDerivedResult = @callTool(@plannerTools.extract, @plannerTools, "extract", @config.extractArgs)
  => {
    resolveResult: @resolveResult,
    deriveResult: @deriveResult,
    extractDerivedResult: @extractDerivedResult
  }
]

>> --- Helpers -------------------------------------------------------------

exe @field(inputValue, key) = js {
  return inputValue?.[key] ?? null;
}

>> Bundle a built agent with a per-test shelf. Object spread preserves the
>> `var tools` executable wrapping on `tools` / `toolsCollection` post
>> m-9899 (otherwise @callTool surfaces `tool_missing_executable`).
exe @withShelf(rawAgent, plannerShelf) = [
  => { ...@rawAgent, plannerShelf: @plannerShelf }
]

>> --- Tests ---------------------------------------------------------------

>> Read-dispatch through the catalog directly (no agent build).
exe @testFixtureReadDispatch() = [
  let @result = @callTool(
    @tools.get_contacts,
    @tools,
    "get_contacts",
    {}
  )
  let @ok = @typeof(@result) == "array" && @result.length == 2
  => @assertOk(@ok, `count=@result.length`)
]

>> Read-dispatch through a built agent's toolsCollection.
exe @testBuiltAgentReadDispatch() = [
  let @result = @callTool(
    @builtFixtureAgent.tools.get_contacts,
    @builtFixtureAgent.toolsCollection,
    "get_contacts",
    {}
  )
  let @ok = @typeof(@result) == "array" && @result.length == 2
  => @assertOk(@ok, `count=@result.length`)
]

>> Phase catalog round-trip — get_contacts is callable through the
>> resolve-phase view of the catalog.
exe @testPhaseCatalogPreservesCallability() = [
  let @phaseCat = @phaseCatalog(@builtFixtureAgent, "resolve")
  let @result = @callTool(
    @phaseCat.get_contacts,
    @builtFixtureAgent.toolsCollection,
    "get_contacts",
    {}
  )
  let @ok = @typeof(@result) == "array" && @result.length == 2
  => @assertOk(@ok, `count=@result.length`)
]

>> Phase tool entry round-trip — same callability through @phaseToolEntry.
exe @testPhaseToolEntryPreservesCallability() = [
  let @entry = @phaseToolEntry(@builtFixtureAgent, "resolve", "get_contacts")
  let @result = @callTool(
    @entry,
    @builtFixtureAgent.toolsCollection,
    "get_contacts",
    {}
  )
  let @ok = @typeof(@result) == "array" && @result.length == 2
  => @assertOk(@ok, `count=@result.length`)
]

>> Resolve worker happy path: get_contacts returns 2 contact records,
>> shelf gains 2 contact entries, status="resolved".
exe role:worker @testResolveWorkerSuccessPath() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @dispatchResolve(
    @agent,
    @emptyState(),
    {
      phase: "resolve",
      tool: "get_contacts",
      args: {},
      purpose: "ground the contact list"
    },
    "Find Alice in my contacts.",
    false
  )
  let @ok = @result["error"] == null &&
    @result.result.status == "resolved" &&
    @result.result.count == 2
  => @assertOk(@ok, `error=@result["error"] status=@result.result.status count=@result.result.count`)
]

>> Resolve worker for a scalar-keyed record (datetime_context). Single
>> entry, record_type echoed in the result.
exe role:worker @testResolveWorkerScalarKeyedPath() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @dispatchResolve(
    @agent,
    @emptyState(),
    {
      phase: "resolve",
      tool: "get_today",
      args: {},
      purpose: "ground one synthetic day context"
    },
    "What day is it?",
    false
  )
  let @ok = @result["error"] == null &&
    @result.result.status == "resolved" &&
    @result.result.count == 1 &&
    @result.result.record_type == "datetime_context"
  => @assertOk(@ok, `status=@result.result.status count=@result.result.count record=@result.result.record_type`)
]

>> Planner-tool resolve dispatch (single) goes through the wrapper without
>> recursive activation; result lands on the seeded shelf.
exe role:worker @testPlannerToolCollectionDispatchDoesNotRecurse() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @testPlannerResolve("test", {
    args: { tool: "get_today", args: {}, purpose: "ground one synthetic day context" }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "What day is it?", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @ok = @result["error"] == null &&
    @result.status == "resolved" &&
    @result.count == 1 &&
    @result.record_type == "datetime_context"
  => @assertOk(@ok, `status=@result.status count=@result.count record=@result.record_type`)
]

>> resolve_batch settles in one tool call and writes both record types
>> to the shelf (2 contacts, 1 datetime_context).
exe role:worker @testPlannerResolveBatchSettlesOnce() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @batch = @testPlannerResolveBatch("test", {
    args: {
      resolves: [
        { tool: "get_contacts", args: {}, purpose: "ground contacts" },
        { tool: "get_today", args: {}, purpose: "ground today" }
      ],
      purpose: "ground two independent record families"
    }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice and today's date.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @contacts = @shelf.read(@ps.contact)
  let @datetimes = @shelf.read(@ps.datetime_context)
  let @ok = @batch.result["error"] == null &&
    @batch.result.status == "batch_resolved" &&
    @batch.result.results.length == 2 &&
    @contacts.length == 2 &&
    @datetimes.length == 1 &&
    @batch.runtime.tool_calls == 1
  => @assertOk(@ok, `tool_calls=@batch.runtime.tool_calls results=@batch.result.results.length contacts=@contacts.length datetimes=@datetimes.length`)
]

>> After a single planner-tool resolve, the shelf carries the resolved
>> records (Stage B replacement for state.resolved.contact reads).
exe role:worker @testPlannerSessionStatePersistsAcrossDirectPlannerToolCalls() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @testPlannerResolve("test", {
    args: { tool: "get_contacts", args: {}, purpose: "ground the contact list" }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @contacts = @shelf.read(@ps.contact)
  let @ok = @result["error"] == null &&
    @result.status == "resolved" &&
    @result.count == 2 &&
    @contacts.length == 2
  => @assertOk(@ok, `status=@result.status count=@result.count contacts=@contacts.length`)
]

>> The session-final state surfaces via @raw.mx.sessions.planner; runtime
>> tool_calls reflects both planner-tool dispatches (resolve + extract).
exe role:worker @testSessionFinalStateAccessibleViaMxSessions() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerExtractFixtureAgent, @ps)
  let @chain = @testPlannerExtractChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    refField: "email",
    extractSchema: { email: "string", name: "string" },
    extractName: "contact_details",
    extractPurpose: "inspect one resolved contact"
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @sessionFinal = @chain.mx.sessions.planner
  let @contacts = @shelf.read(@ps.contact)
  let @ok = @sessionFinal.isDefined() &&
    @sessionFinal.runtime.tool_calls == 2 &&
    @contacts.length == 2
  => @assertOk(@ok, `runtime_calls=@sessionFinal.runtime.tool_calls contacts=@contacts.length`)
]

>> @llmCallEntry omits the session snapshot from its rendered log even
>> when one is present in the source value.
exe role:worker @testLlmCallLogOmitsSessionSnapshot() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @raw = @testPlannerTextResult("test", {
    args: { tool: "get_today", args: {}, purpose: "ground one synthetic day context" }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "What day is it?", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @entry = @llmCallEntry("planner", "prompt", @raw, null, "ses_debug", {
    call_kind: "outer_planner",
    outer_planner_session_id: "ses_debug"
  })
  let @entryPretty = @entry | @pretty
  let @rawText = @field(@entry, "raw")
  let @sessionId = @field(@entry, "session_id")
  let @ok = @rawText == "planner final text" &&
    @sessionId == "ses_debug" &&
    !@entryPretty.includes("sessions")
  => @assertOk(@ok, `raw=@rawText log=@entryPretty`)
]

>> Fact provenance survives across the session boundary. Post-Stage-B,
>> the proof trail is encoded as `fact:@<record>.<field>` labels on each
>> field's `.mx.labels` (the per-field `factsources` array shape from the
>> bucket era is gone). Both shelf-read fields and the planner's
>> ref-resolution result carry the fact-tag.
exe role:worker @testSessionResolvedFactsourcesSurviveBoundary() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerExtractFixtureAgent, @ps)
  let @chain = @testPlannerExtractChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    refField: "email",
    extractSchema: { email: "string", name: "string" },
    extractName: "contact_details",
    extractPurpose: "inspect one resolved contact"
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @contacts = @shelf.read(@ps.contact)
  let @first = @contacts[0]
  let @emailLabels = @first.email.mx.labels ?? []
  let @resolvedEmailLabels = @chain.resolvedEmail.value.mx.labels ?? []
  let @emailHasFact = @emailLabels.includes("fact:@contact.email")
  let @resolvedHasFact = @resolvedEmailLabels.includes("fact:@contact.email")
  let @ok = @emailHasFact && @resolvedHasFact
  => @assertOk(@ok, `emailFact=@emailHasFact resolvedFact=@resolvedHasFact emailLabels=@emailLabels.join(",") resolvedLabels=@resolvedEmailLabels.join(",")`)
]

>> Resolved-handle ref resolution still works through the planner session
>> chain (@resolveRefValue against the seeded agent's shelf).
exe role:worker @testPlannerSessionResolvedHandleRemainsReadableAfterDirectResolve() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerExtractFixtureAgent, @ps)
  let @chain = @testPlannerExtractChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    refField: "email",
    extractSchema: { email: "string", name: "string" },
    extractName: "contact_details",
    extractPurpose: "inspect one resolved contact"
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @ok = @chain.resolvedEmail.ok == true &&
    @chain.resolvedEmail.value == "alice.example"
  => @assertOk(@ok, `ok=@chain.resolvedEmail.ok value=@chain.resolvedEmail.value`)
]

>> Source-backed extract on the direct planner-tool path (no recursion)
>> returns the stub-extracted contact_details payload.
exe role:worker @testPlannerSourceBackedExtractWorksOnDirectPlannerToolPath() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerExtractFixtureAgent, @ps)
  let @chain = @testPlannerExtractChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    refField: "email",
    extractSchema: { email: "string", name: "string" },
    extractName: "contact_details",
    extractPurpose: "inspect one resolved contact"
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @ex = @chain.extractResult
  let @ok = @ex["error"] == null &&
    @ex.status == "extracted" &&
    @ex.name == "contact_details"
  => @assertOk(@ok, `status=@ex.status name=@ex.name`)
]

>> Derive on the planner-tool path returns preview_fields the planner can
>> consult before deciding to extract.
exe role:worker @testPlannerDeriveExposesPreviewFields() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerDeriveFixtureAgent, @ps)
  let @chain = @testPlannerDeriveChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    deriveArgs: {
      sources: [{ source: "resolved", record: "contact" }],
      goal: "Extract the action items into a typed array",
      schema_name: "action_items",
      name: "action_items",
      purpose: "prepare one action-item worklist"
    },
    extractArgs: {
      source: { source: "derived", name: "action_items" },
      schema: { person_name: "string", task_description: "string", deadline: "string" },
      name: "action_items_copy",
      purpose: "inspect the derived action items"
    }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Email each person in the TODO list.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @resolve = @chain.resolveResult
  let @derive = @chain.deriveResult
  let @ok = @resolve["error"] == null &&
    @derive["error"] == null &&
    @derive.status == "derived" &&
    @derive.name == "action_items" &&
    @derive.schema_name == "action_items" &&
    @derive.preview_fields.includes("person_name") &&
    @derive.preview_fields.includes("task_description") &&
    @derive.preview_fields.includes("deadline")
  => @assertOk(@ok, `status=@derive.status name=@derive.name`)
]

>> Extract from a derived source on the direct planner-tool path returns
>> the stub-extracted action_items_copy payload (no resolve recursion).
exe role:worker @testPlannerExtractFromDerivedSourceDoesNotRecurse() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@plannerDeriveFixtureAgent, @ps)
  let @chain = @testPlannerDeriveChain("test", {
    resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
    deriveArgs: {
      sources: [{ source: "resolved", record: "contact" }],
      goal: "Extract the action items into a typed array",
      schema_name: "action_items",
      name: "action_items",
      purpose: "prepare one action-item worklist"
    },
    extractArgs: {
      source: { source: "derived", name: "action_items" },
      schema: { person_name: "string", task_description: "string", deadline: "string" },
      name: "action_items_copy",
      purpose: "inspect the derived action items"
    }
  }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: "Email each person in the TODO list.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }
  let @ex = @chain.extractDerivedResult
  let @ok = @ex["error"] == null &&
    @ex.status == "extracted" &&
    @ex.name == "action_items_copy"
  => @assertOk(@ok, `status=@ex.status name=@ex.name`)
]

>> Read-tool-doc rendering classifies every read-tool param as a control
>> arg. The render pass is purely catalog-side, no shelf needed.
exe @testReadToolDocsClassifyAllReadParamsAsControl() = [
  let @control = @field(@readArgDoc, "controlArgs")
  let @payload = @field(@readArgDoc, "payloadArgs")
  let @ok = @control.includes("query") &&
    @control.includes("day") &&
    @payload.length == 0
  => @assertOk(@ok, `control=@control payload=@payload`)
]

>> Resolve worker accepts read-tool params (control args, no legacy
>> payload metadata) without re-classifying them as payload.
exe role:worker @testResolveWorkerAcceptsReadToolParamsWithoutLegacyControlArgs() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@readArgFixtureAgent, @ps)
  let @result = @dispatchResolve(
    @agent,
    @emptyState(),
    {
      phase: "resolve",
      tool: "search_day_events",
      args: {
        query: { source: "known", value: "lunch" },
        day: { source: "known", value: "2026-04-21" }
      },
      purpose: "ground one synthetic day search result"
    },
    "Am I free for lunch at 12:00 on 2026-04-21?",
    false
  )
  let @ok = @result["error"] == null &&
    @result.result.status == "resolved" &&
    @result.result.count == 1 &&
    @result.result.record_type == "datetime_context"
  => @assertOk(@ok, `status=@result.result.status count=@result.result.count`)
]

>> Extract worker steers the planner away from a read tool that belongs
>> in the resolve phase: returns wrong_phase_tool with a repair hint.
exe role:worker @testExtractWorkerGuidesWrongPhaseReadTool() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @dispatchExtract(
    @agent,
    @emptyState(),
    {
      phase: "extract",
      tool: "get_contacts",
      args: {},
      name: "contact_details",
      purpose: "inspect grounded contacts"
    },
    "Find Alice in my contacts."
  )
  let @issues = @result.issues ?? []
  let @issue = @issues[0] ?? null
  let @ok = @result.error == "wrong_phase_tool" &&
    @field(@issue, "tool") == "get_contacts" &&
    @field(@issue, "requested_phase") == "extract" &&
    @field(@issue, "correct_phase") == "resolve" &&
    @field(@issue, "repair").includes("Call resolve(")
  => @assertOk(@ok, `error=@result.error tool=@field(@issue, "tool") correct=@field(@issue, "correct_phase")`)
]

>> Inverse: resolve worker steers away from extract-phase read tools
>> (get_webpage) with a repair hint pointing at the extract phase.
exe role:worker @testResolveWorkerGuidesWrongPhaseExtractTool() = [
  let @sh = @shelfRecords(@records)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = @withShelf(@builtFixtureAgent, @ps)
  let @result = @dispatchResolve(
    @agent,
    @emptyState(),
    {
      phase: "resolve",
      tool: "get_webpage",
      args: {
        url: { source: "known", value: "https://example.com" }
      },
      purpose: "fetch one webpage"
    },
    "Fetch https://example.com.",
    false
  )
  let @issues = @result.issues ?? []
  let @issue = @issues[0] ?? null
  let @ok = @result.error == "wrong_phase_tool" &&
    @field(@issue, "tool") == "get_webpage" &&
    @field(@issue, "requested_phase") == "resolve" &&
    @field(@issue, "correct_phase") == "extract" &&
    @field(@issue, "repair").includes("Call extract(")
  => @assertOk(@ok, `error=@result.error tool=@field(@issue, "tool") correct=@field(@issue, "correct_phase")`)
]

>> --- Suite ---------------------------------------------------------------

var @workerDispatchSuite = @suite("worker-dispatch", [
  @group("read-dispatch", [
    @testFixtureReadDispatch,
    @testBuiltAgentReadDispatch
  ], {}),
  @group("phase-catalog", [
    @testPhaseCatalogPreservesCallability,
    @testPhaseToolEntryPreservesCallability
  ], {}),
  @group("resolve-worker", [
    @testResolveWorkerSuccessPath,
    @testResolveWorkerScalarKeyedPath,
    @testResolveWorkerAcceptsReadToolParamsWithoutLegacyControlArgs,
    @testResolveWorkerGuidesWrongPhaseExtractTool
  ], {}),
  @group("extract-worker", [
    @testExtractWorkerGuidesWrongPhaseReadTool
  ], {}),
  @group("planner-session", [
    @testPlannerToolCollectionDispatchDoesNotRecurse,
    @testPlannerResolveBatchSettlesOnce,
    @testPlannerSessionStatePersistsAcrossDirectPlannerToolCalls,
    @testSessionFinalStateAccessibleViaMxSessions,
    @testLlmCallLogOmitsSessionSnapshot,
    @testSessionResolvedFactsourcesSurviveBoundary,
    @testPlannerSessionResolvedHandleRemainsReadableAfterDirectResolve,
    @testPlannerSourceBackedExtractWorksOnDirectPlannerToolPath,
    @testPlannerDeriveExposesPreviewFields,
    @testPlannerExtractFromDerivedSourceDoesNotRecurse
  ], {}),
  @group("read-tool-docs", [
    @testReadToolDocsClassifyAllReadParamsAsControl
  ], {})
], {})

export { @workerDispatchSuite }

>> --- Standalone runner ---------------------------------------------------

var @result = @runSuites([@workerDispatchSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
if @result.skippedLine != "" [ show @result.skippedLine ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
