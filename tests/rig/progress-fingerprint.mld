>> tests/suites/rig/progress-fingerprint.mld
>>
>> c-3438 (B): @stateProgressFingerprint regression tests.
>>
>> Stage B: state.resolved is gone; the fingerprint reads
>> @agent.plannerShelf — slot.mx.version replaces bucket.version, each
>> record's .mx.address.key replaces handle, .mx.hash captures content
>> drift. The R:<rt>:v<n>:<key>^<hash> wire format is preserved so
>> string-equality progress comparison still works.
>>
>> Each test exe declares its own shelf, populates it, and threads the
>> shelf onto a synthetic agent before calling the fingerprint helper.

import { @assertOk, @assertEq, @assertContains } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import {
  @stateProgressFingerprint,
  @plannerNoProgressThreshold,
  @plannerRuntimeStateWithProgress
} from "../../rig/workers/planner.mld"
import { @emptyState } from "../../rig/runtime.mld"

>> Test record analogous to bench domain hotels.
record @hotel = {
  key: name,
  facts: [name: string],
  data: [price: number?, rating: number?],
  read: [name, { value: "price" }, { value: "rating" }],
  write: { role:worker: { shelves: { upsert: true } } }
}

var @fpRecords = { hotel: @hotel }

exe @mintHotel(name, price) = js {
  return { name, price };
} => hotel

exe @mintHotelWithRating(name, price, rating) = js {
  return { name, price, rating };
} => hotel

>> Build an agent with one hotel A on the shelf — the determinism baseline.
exe role:worker @detAgent() = [
  shelf @ps from @fpRecords with { versioned: true }
  let @w = @shelf.write(@ps.hotel, @mintHotel("A", 100))
  => { records: @fpRecords, plannerShelf: @ps }
]

>> --- Test exes ------------------------------------------------------------

>> FP-1: empty state produces empty fingerprint (no records of any type)
exe role:worker @testFp1EmptyState() = [
  shelf @ps from @fpRecords with { versioned: true }
  let @agent = { records: @fpRecords, plannerShelf: @ps }
  let @fp = @stateProgressFingerprint(@agent, @emptyState())
  >> Empty shelf still emits the per-record-type marker (R:hotel:v0:),
  >> matching the bucket-era contract that names the declared types.
  => @assertEq(@fp, "R:hotel:v0:")
]

>> FP-2: deterministic — same shelf state, same fingerprint
exe role:worker @testFp2Deterministic() = [
  let @agentA = @detAgent()
  let @agentB = @detAgent()
  let @fp1 = @stateProgressFingerprint(@agentA, @emptyState())
  let @fp2 = @stateProgressFingerprint(@agentB, @emptyState())
  => @assertOk(@fp1 == @fp2 && @fp1 != "", `'@fp1' == '@fp2'`)
]

>> FP-3: new resolved record changes fingerprint
exe role:worker @testFp3NewHandleChangesFp() = [
  let @baseline = @stateProgressFingerprint(@detAgent(), @emptyState())
  shelf @ps from @fpRecords with { versioned: true }
  let @w1 = @shelf.write(@ps.hotel, @mintHotel("A", 100))
  let @w2 = @shelf.write(@ps.hotel, @mintHotel("B", 200))
  let @agent = { records: @fpRecords, plannerShelf: @ps }
  let @fp = @stateProgressFingerprint(@agent, @emptyState())
  => @assertOk(@fp != @baseline, `before='@baseline' after='@fp'`)
]

>> FP-4: new field on existing handle changes fingerprint
>> (the dominant travel pattern — prices/ratings landing on already-resolved
>> records). With shelf field-merge, the second write to the same key field
>> updates the record content; .mx.hash changes accordingly.
exe role:worker @testFp4NewFieldOnExistingHandleChangesFp() = [
  let @baseline = @stateProgressFingerprint(@detAgent(), @emptyState())
  shelf @ps from @fpRecords with { versioned: true }
  let @w1 = @shelf.write(@ps.hotel, @mintHotel("A", 100))
  let @w2 = @shelf.write(@ps.hotel, @mintHotelWithRating("A", 100, 4.5))
  let @agent = { records: @fpRecords, plannerShelf: @ps }
  let @fp = @stateProgressFingerprint(@agent, @emptyState())
  => @assertOk(@fp != @baseline, `before='@baseline' after='@fp'`)
]

>> FP-5: slot version bump changes fingerprint. With shelf, content-changing
>> writes increment slot.mx.version; same-content writes do not. Verify
>> the version is reflected in the fingerprint.
exe role:worker @testFp5SlotVersionBumpChangesFp() = [
  let @baseline = @stateProgressFingerprint(@detAgent(), @emptyState())
  shelf @ps from @fpRecords with { versioned: true }
  let @w1 = @shelf.write(@ps.hotel, @mintHotel("A", 100))
  let @w2 = @shelf.write(@ps.hotel, @mintHotelWithRating("A", 100, 4.5))
  let @agent = { records: @fpRecords, plannerShelf: @ps }
  let @fp = @stateProgressFingerprint(@agent, @emptyState())
  >> Two writes for the same key field-merge → slot version increments.
  => @assertOk(@fp.includes("R:hotel:v2:") && @fp != @baseline, `fp='@fp' baseline='@baseline'`)
]

>> FP-6: derive with selection_refs counts as progress
exe role:worker @testFp6DeriveWithSelectionRefCountsAsProgress() = [
  let @agent = @detAgent()
  let @baseline = @stateProgressFingerprint(@agent, @emptyState())
  let @state = {
    extracted: {},
    derived: {
      "best_hotel": {
        preview_fields: ["name", "rating"],
        selection_refs: [{ source: "selection", backing: { record: "hotel", handle: "r_hotel_A" } }]
      }
    },
    extract_sources: {},
    capabilities: { url_refs: {} }
  }
  let @fp = @stateProgressFingerprint(@agent, @state)
  => @assertOk(@fp != @baseline, `before='@baseline' after='@fp'`)
]

>> FP-7 (regression for UT10): a derive that returned empty (preview_fields
>> = ["items"] only, no selection_refs) must NOT count as progress.
exe role:worker @testFp7DeriveItemsOnlyPreviewIsNotProgress() = [
  let @agent = @detAgent()
  let @state = {
    extracted: {},
    derived: {
      "empty_derive": {
        preview_fields: ["items"],
        selection_refs: []
      }
    },
    extract_sources: {},
    capabilities: { url_refs: {} }
  }
  let @fp = @stateProgressFingerprint(@agent, @state)
  => @assertContains(@fp, "D:empty_derive:0")
]

>> FP-8: extract with non-empty payload counts as progress
exe role:worker @testFp8ExtractWithPayloadCountsAsProgress() = [
  let @agent = @detAgent()
  let @baseline = @stateProgressFingerprint(@agent, @emptyState())
  let @state = {
    extracted: {
      "hotel_address": {
        preview_fields: ["street", "city"],
        selection_refs: []
      }
    },
    derived: {},
    extract_sources: {},
    capabilities: { url_refs: {} }
  }
  let @fp = @stateProgressFingerprint(@agent, @state)
  let @differs = @fp != @baseline
  let @hasMarker = @fp.includes("E:hotel_address:1")
  => @assertOk(@differs && @hasMarker, `differs=@differs hasMarker=@hasMarker fp='@fp'`)
]

>> --- Schema round-trip ---------------------------------------------------
>> @plannerRuntime schema round-trip — c-3438 (B) schema fix.

exe @testPr1RuntimeSchemaRoundtripPreservesProgressFields() = [
  let @rt = @plannerRuntimeStateWithProgress(5, 1, null, { phase: "resolve" }, "FP_TEST_VALUE", 3)
  let @okShape =
    @rt.tool_calls == 5 &&
    @rt.invalid_calls == 1 &&
    @rt.progress_fingerprint == "FP_TEST_VALUE" &&
    @rt.calls_since_progress == 3
  => @assertOk(@okShape, `tool_calls=@rt.tool_calls fp='@rt.progress_fingerprint' csp=@rt.calls_since_progress`)
]

>> --- Suite construction --------------------------------------------------

var @progressFingerprintSuite = @suite("progress-fingerprint", [
  @group("fingerprint", [
    @testFp1EmptyState,
    @testFp2Deterministic,
    @testFp3NewHandleChangesFp,
    @testFp4NewFieldOnExistingHandleChangesFp,
    @testFp5SlotVersionBumpChangesFp,
    @testFp6DeriveWithSelectionRefCountsAsProgress,
    @testFp7DeriveItemsOnlyPreviewIsNotProgress,
    @testFp8ExtractWithPayloadCountsAsProgress
  ], { ticket: "c-3438" }),
  @group("schema-roundtrip", [
    @testPr1RuntimeSchemaRoundtripPreservesProgressFields
  ], { ticket: "c-3438" })
], {})

export { @progressFingerprintSuite }

>> --- Standalone runner ---------------------------------------------------

var @result = @runSuites([@progressFingerprintSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
