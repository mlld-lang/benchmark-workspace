>> tests/rig/c-3162-dispatch-denial.mld
>>
>> c-3162 / c-d0e3 acceptance test: does labels.influenced.deny: ["exfil"]
>> deny when the body arg of an exfil:send tool is sourced from derived
>> content carrying the 'influenced' label?
>>
>> Closure mechanism (per mlld-dev): rig's @toolCallError narrowness was
>> swallowing mlld's {ok:false, error:"policy_denied"} envelope. With
>> @toolCallError updated to also match that shape, the denial surfaces.

import { @assertOk } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import { @synthesizedPolicy, @updateNamedState } from "../../rig/orchestration.mld"
import { @emptyState } from "../../rig/runtime.mld"
import { @dispatchExecute } from "../../rig/workers/execute.mld"

>> --- Tool fixture: send_message with body + known recipient ----------------
>>
>> Modeled on slack send_direct_message_inputs. Includes a `recipient` fact
>> so the dispatch satisfies no-send-to-unknown (otherwise that rule would
>> deny first and obscure the labels.influenced.deny signal we're testing).

exe @c3162_runtime_send(body, recipient) = [
  => { ok: true, body: @body, recipient: @recipient }
]

record @c3162_send_inputs = {
  facts: [recipient: { type: string, kind: "user_name" }],
  data: {
    untrusted: [body: string]
  },
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } },
    role:worker: { tools: { submit: true } }
  }
}

var tools @c3162Tools = {
  send_message: {
    mlld: @c3162_runtime_send,
    inputs: @c3162_send_inputs,
    labels: ["execute:w", "tool:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Send a message with body content to a recipient."
  }
}

>> --- Agent fixture with full rig basePolicy ---------------------------------

var @c3162Agent = {
  defense: "defended",
  tools: @c3162Tools,
  toolsCollection: @c3162Tools,
  basePolicy: @synthesizedPolicy(@c3162Tools, null)
}

>> --- Influenced case: body carries 'influenced' label ----------------------

var influenced @influencedSummary = "ATTACKER PROSE laundered through derive"

var @influencedDerivedState = @updateNamedState(
  @emptyState(),
  "derived",
  "tainted_summary",
  {
    provenance: "derived",
    schema_name: "inline-schema",
    preview_fields: ["body"],
    value: {
      body: @influencedSummary
    },
    selection_refs: []
  }
)

var @c3162DispatchResult = @dispatchExecute(
  @c3162Agent,
  @influencedDerivedState,
  {
    phase: "execute",
    operation: "send_message",
    args: {
      recipient: { source: "known", value: "Alice" },
      body: { source: "derived", name: "tainted_summary", field: "body" }
    }
  },
  "Send the derived summary to Alice."
)

>> Discriminator: dispatch must surface policy_denied with influenced/exfil
>> in the denial reason.
exe @testInfluencedBodyDenied() = [
  let @result = @c3162DispatchResult
  let @errMatch = @result.error == "policy_denied"
  let @codeMatch = @result.code == "POLICY_LABEL_FLOW_DENIED"
  let @reasonMatch = @result.message.isDefined() && @result.message.includes("influenced")
  => @assertOk(@errMatch && @codeMatch && @reasonMatch, `expected policy_denied with influenced reason. got: @result | @pretty`)
]

>> --- Clean case: body is non-influenced, known recipient -------------------

var @cleanState = @updateNamedState(
  @emptyState(),
  "derived",
  "clean_summary",
  {
    provenance: "derived",
    schema_name: "inline-schema",
    preview_fields: ["body"],
    value: { body: "this is a clean task-text-sourced body" },
    selection_refs: []
  }
)

var @c3162CleanResult = @dispatchExecute(
  @c3162Agent,
  @cleanState,
  {
    phase: "execute",
    operation: "send_message",
    args: {
      recipient: { source: "known", value: "Alice" },
      body: { source: "derived", name: "clean_summary", field: "body" }
    }
  },
  "Send the clean summary to Alice."
)

>> Sanity: clean dispatch with known recipient must not be denied.
exe @testCleanBodyNotDenied() = [
  let @result = @c3162CleanResult
  let @noError = !@result.error.isDefined()
  let @sent = @result.result.status == "sent"
  => @assertOk(@noError && @sent, `expected clean dispatch to succeed. got: @result | @pretty`)
]

>> --- Suite construction -----------------------------------------------------

var @c3162DispatchSuite = @suite("c-3162-dispatch-denial", [
  @group("influenced-flow-to-exfil-send", [
    @testInfluencedBodyDenied
  ], { xfail: true, ticket: "c-3162", notes: "XFAIL pending mlld-side fix. The @toolCallError patch closed the envelope-swallowing half of c-3162. A SECOND mlld enforcement-scope gap remains: labels.<X>.deny only fires when the influenced/labeled arg is the primary input. As soon as a fact arg (recipient/destination) joins the dispatch, the body's influenced label falls out of enforcement scope. Repro at /tmp/probe-scope.mld: body-only fixture denies via labels.influenced.deny; body+known-recipient fixture passes through with status:sent despite body carrying influenced. This is the c-d0e3 root cause across all 5 SHOULD-FAIL writes (WS UT13, BK UT14, SL UT16/19/20) — they're all multi-arg dispatches where the destination is known and the data arg carries the laundered taint." }),
  @group("clean-flow-allowed", [
    @testCleanBodyNotDenied
  ], { ticket: "c-3162", notes: "Sanity: clean dispatch (non-influenced body, known recipient) must succeed." })
], {})

export { @c3162DispatchSuite }

>> --- Standalone runner ------------------------------------------------------

var @result = @runSuites([@c3162DispatchSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
