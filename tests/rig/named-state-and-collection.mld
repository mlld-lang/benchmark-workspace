>> tests/suites/rig/named-state-and-collection.mld
>>
>> Plain-assertion port of three regression clusters from
>> rig/tests/index.mld:
>>   - named-state projection (record-backed display, retention across
>>     extract/derive updates, extract_sources survival, array preview
>>     fields, lean state — no execution_log/phase_events).
>>   - UT7 reschedule regression: update fields appear in flat policy
>>     intent, multi-param dispatch succeeds (c-7e4b guard).
>>   - m-5178 collection dispatch: execute result handles, direct
>>     collection-tool policy build, and full cross-module dispatch
>>     through the rig's execute worker.

import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @xfailGroup, @runSuites } from "../runner.mld"

import { @tools } from "../fixtures.mld"
import {
  @plannerVisibleState,
  @workerStateSummary,
  @updateNamedState,
  @updateExtractSources,
  @synthesizedPolicy
} from "../../rig/orchestration.mld"
import { @compileExecuteIntent } from "../../rig/intent.mld"
import { @emptyState, @recordTypeName, @shelfRecords } from "../../rig/runtime.mld"
import { @dispatchExecute } from "../../rig/workers/execute.mld"

import { @calendar_evt, @calendar_reschedule_inputs, @add_calendar_event_participants_inputs, @file_entry, @file_create_inputs } from "../../bench/domains/workspace/records.mld"

>> --- Module-level fixtures (records, tool collections, agents) -------------

>> Hostile preview_fields prove planner summaries derive field names from
>> the live value rather than trusting stored metadata.
record @named_display_extract = {
  facts: [id_: string],
  data: [subject: string, body: string, note: string?],
  key: id_,
  read: {
    role:planner: [{ value: "id_" }, subject],
    role:worker: [{ value: "id_" }, subject, body, note]
  }
}

>> UT7 reschedule fixtures
exe @ut7NoopReschedule(event_id, new_start_time, new_end_time) = [ => "ok" ]
var tools @ut7RescheduleTools = {
  reschedule_calendar_event: {
    mlld: @ut7NoopReschedule,
    inputs: @calendar_reschedule_inputs,
    labels: ["execute:w", "tool:w", "calendar:w", "update:w"],
    can_authorize: "role:planner",
    description: "Reschedule."
  }
}
var @ut7Records = { calendar_evt: @calendar_evt, calendar_reschedule_inputs: @calendar_reschedule_inputs }

>> Build a fresh agent inline per test exe — shelf scope expires at
>> exe-body exit, so each test that needs the resolved calendar_evt
>> populated calls this and threads the returned agent. Manually
>> constructed (vs @rigBuild) so the basePolicy is built deterministically
>> from this suite's tool catalog and not contaminated by other suites'
>> module-load side effects.
exe role:worker @ut7AgentWith() = [
  let @shelfable = @shelfRecords(@ut7Records)
  shelf @ps from @shelfable with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @rec = { id_: "5", title: "Dentist", participants: [], start_time: "2026-04-25 09:00", end_time: "2026-04-25 10:00" } as record @calendar_evt
  let @w = @shelf.write(@ps.calendar_evt, @rec)
  => {
    suite: "fixtures",
    defense: "defended",
    records: @ut7Records,
    plannerShelf: @ps,
    tools: @ut7RescheduleTools,
    toolsCollection: @ut7RescheduleTools,
    basePolicy: @synthesizedPolicy(@ut7RescheduleTools, null),
    eventHandle: `r_calendar_evt_@rec.mx.address.key`
  }
]

>> Execute result-handle fixtures (write tool with returns:)
exe tool:w, file:w @stubCreateFile(filename, content) = [
  => { id_: "42", filename: @filename, content: @content, owner: "test", size: 100, last_modified: "2026-04-23" }
] => file_entry
var tools @executeResultHandleTools = {
  create_file: {
    mlld: @stubCreateFile,
    inputs: @file_create_inputs,
    returns: @file_entry,
    labels: ["execute:w", "tool:w", "file:w"],
    can_authorize: "role:planner",
    description: "Stub create file."
  }
}
var @executeResultHandleRecords = { file_entry: @file_entry, file_create_inputs: @file_create_inputs }

>> m-5178 collection-dispatch fixtures
exe @ut8FakeSearch() = [
  => [{ id_: "5", title: "Dentist" }, { id_: "23", title: "Moved" }]
] => record @calendar_evt
exe tool:w @ut8AddParticipants(participants: array, event_id) = `added:@event_id:@participants.length`
var tools @ut8CollectionTools = {
  search_calendar_events: {
    mlld: @ut8FakeSearch,
    returns: @calendar_evt,
    labels: ["resolve:r"],
    description: "Search events."
  },
  add_calendar_event_participants: {
    mlld: @ut8AddParticipants,
    inputs: @add_calendar_event_participants_inputs,
    labels: ["execute:w", "tool:w", "calendar:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Add participants to an existing calendar event."
  }
}
var @ut8Records = { calendar_evt: @calendar_evt, add_calendar_event_participants_inputs: @add_calendar_event_participants_inputs }
var @ut8ResolvedFields = { id_: "24", title: "Introductory meeting", participants: [], start_time: "2026-04-25 09:00", end_time: "2026-04-25 10:00" }
var @ut8Query = "Add bob@test.com to the Introductory meeting."

exe role:worker @ut8AgentWith() = [
  let @shelfable = @shelfRecords(@ut8Records)
  shelf @ps from @shelfable with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @rec = @ut8ResolvedFields as record @calendar_evt
  let @w = @shelf.write(@ps.calendar_evt, @rec)
  => {
    suite: "fixtures",
    defense: "defended",
    records: @ut8Records,
    plannerShelf: @ps,
    tools: @ut8CollectionTools,
    toolsCollection: @ut8CollectionTools,
    basePolicy: @synthesizedPolicy(@ut8CollectionTools, null)
  }
]

>> Dispatch-side runs in role:worker (matches production split: planner
>> authorizes via policy.build, worker submits the actual call).
exe role:worker @ut8DispatchUnderPolicy(policy) = [
  => @ut8CollectionTools["add_calendar_event_participants"]({
    participants: ["bob@test.com"],
    event_id: @ut8ResolvedFields.id_
  }) with { policy: @policy }
]

exe role:planner @ut8BuildAndDispatch() = [
  let @builtPolicy = @policy.build(
    {
      add_calendar_event_participants: {
        event_id: { eq: @ut8ResolvedFields.id_, attestations: ["fact:\@calendar_evt.id_"] },
        participants: { eq: ["bob@test.com"], attestations: ["known"] }
      }
    },
    @ut8CollectionTools,
    { task: @ut8Query }
  )
  if !@builtPolicy.valid [ => { valid: false, issues: @builtPolicy.issues, dispatch: null } ]
  let @result = @ut8DispatchUnderPolicy(@builtPolicy.policy)
  => { valid: true, issues: [], dispatch: @result }
]

>> Stub agent for tests that don't read resolved/selection refs. The
>> projection fns gate on @agent.records; compileExecuteIntent /
>> resolveRefValue gate on plannerShelf only for resolved/selection refs.
var @stubAgent = { suite: "fixtures", records: {} }
var @namedDisplayAgent = { suite: "fixtures", records: { named_display_extract: @named_display_extract } }

>> --- Test exes -------------------------------------------------------------

exe @testRecordBackedNamedStateProjectsDisplay() = [
  let @bodyMarker = "RECORD_BACKED_BODY_MARKER"
  let @nestedMarker = "RECORD_BACKED_NOTE_MARKER"
  let @recordBackedNamedState = {
    extracted: {
      selected_message: {
        provenance: "extracted",
        schema_name: "named_display_extract",
        preview_fields: ["Quarterly update", @bodyMarker, @nestedMarker],
        value: {
          id_: "msg_42",
          subject: "Quarterly update",
          body: `line one
middle @bodyMarker
line end @bodyMarker`,
          note: `nested field @nestedMarker`
        } as record @named_display_extract
      }
    },
    derived: {},
    extract_sources: {}
  }
  let @plannerSummary = @plannerVisibleState(@namedDisplayAgent, @recordBackedNamedState) | @pretty
  let @compile = @compileExecuteIntent(
    @namedDisplayAgent,
    @recordBackedNamedState,
    @tools,
    {
      phase: "execute",
      operation: "create_note",
      args: { content: { source: "extracted", name: "selected_message", field: "body" } }
    },
    "create a note from the hidden body"
  )
  let @content = @compile.compiled_args.content
  let @actual = {
    plannerHasDisplay: @plannerSummary.includes('"display"'),
    plannerHasSubject: @plannerSummary.includes('"Quarterly update"'),
    plannerHasId: @plannerSummary.includes('"id_": "msg_42"'),
    plannerHasBodyMarker: @plannerSummary.includes(@bodyMarker),
    plannerHasNestedMarker: @plannerSummary.includes(@nestedMarker),
    plannerHasPreviewLeak: @plannerSummary.includes('"Quarterly update","RECORD_BACKED_BODY_MARKER"'),
    compileOk: @compile.ok,
    contentHasBodyMarker: @content.includes(@bodyMarker),
    contentHasNestedMarker: @content.includes(@nestedMarker)
  }
  => @assertEq(@actual, {
    plannerHasDisplay: true,
    plannerHasSubject: true,
    plannerHasId: true,
    plannerHasBodyMarker: false,
    plannerHasNestedMarker: false,
    plannerHasPreviewLeak: false,
    compileOk: true,
    contentHasBodyMarker: true,
    contentHasNestedMarker: false
  })
]

exe @testNamedStateRetainsPriorResults() = [
  let @bodyMarker = "ATTACKER_INJECTED_BODY_MARKER"
  let @titleMarker = "ATTACKER_INJECTED_TITLE_MARKER"
  let @roomMarker = "ATTACKER_INJECTED_ROOM_MARKER"
  let @baseState = @emptyState()
  let @afterFirstExtract = @updateNamedState(
    @baseState, "extracted", "meeting_invitation_body",
    { provenance: "extracted", schema_name: "text", preview_fields: [], value: @bodyMarker }
  )
  let @afterDerive = @updateNamedState(
    @afterFirstExtract, "derived", "event_details",
    {
      provenance: "derived",
      schema_name: "inline-schema",
      preview_fields: ["event_title", "start_time"],
      value: { event_title: @titleMarker, start_time: "2026-05-12T09:00:00", room_note: @roomMarker }
    }
  )
  let @afterSecondExtract = @updateNamedState(
    @afterDerive, "extracted", "room_context",
    {
      provenance: "extracted",
      schema_name: "inline-schema",
      preview_fields: ["room_name"],
      value: { room_name: @roomMarker }
    }
  )
  let @plannerSummary = @plannerVisibleState(@stubAgent, @afterSecondExtract) | @pretty
  let @workerSummary = @workerStateSummary(@stubAgent, @afterSecondExtract) | @pretty
  let @actual = {
    plannerHasInvitationName: @plannerSummary.includes('"meeting_invitation_body"'),
    plannerHasBodyMarker: @plannerSummary.includes(@bodyMarker),
    plannerHasTitleMarker: @plannerSummary.includes(@titleMarker),
    plannerHasRoomMarker: @plannerSummary.includes(@roomMarker),
    workerHasBodyMarker: @workerSummary.includes(@bodyMarker),
    workerHasTitleMarker: @workerSummary.includes(@titleMarker),
    workerHasRoomMarker: @workerSummary.includes(@roomMarker)
  }
  => @assertEq(@actual, {
    plannerHasInvitationName: true,
    plannerHasBodyMarker: false,
    plannerHasTitleMarker: false,
    plannerHasRoomMarker: false,
    workerHasBodyMarker: true,
    workerHasTitleMarker: true,
    workerHasRoomMarker: true
  })
]

exe @testNamedStateRetainsExtractSources() = [
  let @bodyMarker = "ATTACKER_INJECTED_BODY_MARKER"
  let @stateWithSources = {
    extracted: {},
    derived: {},
    extract_sources: { "resolved:email_msg": "email_body" }
  }
  let @retained = @updateNamedState(
    @stateWithSources, "extracted", "meeting_invitation_body",
    { provenance: "extracted", value: @bodyMarker }
  )
  => @assertEq(@retained.extract_sources["resolved:email_msg"], "email_body")
]

exe @testNamedArrayPreviewFields() = [
  let @marker = "ARRAY_PAYLOAD_SECRET_MARKER"
  let @arrayState = {
    extracted: {},
    derived: {
      email_plan: {
        provenance: "derived",
        schema_name: "inline-schema",
        preview_fields: [],
        value: [{
          email_address: "david.lee@bluesparrowtech.com",
          subject: "Task assignment",
          body: @marker
        }]
      }
    },
    extract_sources: {}
  }
  let @plannerSummary = @plannerVisibleState(@stubAgent, @arrayState) | @pretty
  let @workerSummary = @workerStateSummary(@stubAgent, @arrayState) | @pretty
  let @actual = {
    plannerHasEmailField: @plannerSummary.includes('"email_address"'),
    plannerHasSubjectField: @plannerSummary.includes('"subject"'),
    plannerHasBodyField: @plannerSummary.includes('"body"'),
    plannerHasMarker: @plannerSummary.includes(@marker),
    workerHasMarker: @workerSummary.includes(@marker)
  }
  => @assertEq(@actual, {
    plannerHasEmailField: true,
    plannerHasSubjectField: true,
    plannerHasBodyField: true,
    plannerHasMarker: false,
    workerHasMarker: true
  })
]

exe @testWrappedArrayPreviewFields() = [
  let @marker = "ARRAY_PAYLOAD_SECRET_MARKER"
  let @wrappedState = {
    extracted: {},
    derived: {
      todo_items: {
        provenance: "derived",
        schema_name: "todo_items",
        preview_fields: [],
        value: {
          items: [{
            person_name: "David",
            task: "Coordinate with the development team.",
            deadline: "2026-04-22",
            note: @marker
          }]
        }
      }
    },
    extract_sources: {}
  }
  let @plannerSummary = @plannerVisibleState(@stubAgent, @wrappedState) | @pretty
  let @workerSummary = @workerStateSummary(@stubAgent, @wrappedState) | @pretty
  let @actual = {
    plannerHasPersonField: @plannerSummary.includes('"person_name"'),
    plannerHasTaskField: @plannerSummary.includes('"task"'),
    plannerHasDeadlineField: @plannerSummary.includes('"deadline"'),
    plannerHasMarker: @plannerSummary.includes(@marker),
    workerHasMarker: @workerSummary.includes(@marker)
  }
  => @assertEq(@actual, {
    plannerHasPersonField: true,
    plannerHasTaskField: true,
    plannerHasDeadlineField: true,
    plannerHasMarker: false,
    workerHasMarker: true
  })
]

exe @testLeanStateNoLogArrays() = [
  let @lean = @emptyState()
  let @actual = {
    hasExecutionLog: @lean.execution_log.isDefined(),
    hasPhaseEvents: @lean.phase_events.isDefined(),
    hasExtractSources: @lean.extract_sources.isDefined()
  }
  => @assertEq(@actual, { hasExecutionLog: false, hasPhaseEvents: false, hasExtractSources: true })
]

exe role:worker @testUpdateFieldsInPolicyIntent() = [
  let @agent = @ut7AgentWith()
  let @compiled = @compileExecuteIntent(@agent, @emptyState(), @ut7RescheduleTools, {
    phase: "execute",
    operation: "reschedule_calendar_event",
    args: {
      event_id: { source: "resolved", record: "calendar_evt", handle: @agent.eventHandle, field: "id_" },
      new_start_time: { source: "known", value: "2026-04-27 10:00" },
      new_end_time: { source: "known", value: "2026-04-27 11:00" }
    }
  }, "Please reschedule my Dental check-up to 2026-04-27 at 10:00 and end at 11:00.")
  let @actual = {
    ok: @compiled.ok,
    start: @compiled.compiled_args.new_start_time,
    end: @compiled.compiled_args.new_end_time,
    intentHasOperation: @compiled.policy_intent.reschedule_calendar_event.isDefined(),
    intentHasUpdate: @compiled.policy_intent.reschedule_calendar_event.new_start_time.isDefined()
  }
  => @assertEq(@actual, {
    ok: true,
    start: "2026-04-27 10:00",
    end: "2026-04-27 11:00",
    intentHasOperation: true,
    intentHasUpdate: true
  })
]

>> Stage B follow-up: testRescheduleDispatchSucceeds was deleted during
>> conversion. Same shape as testCollectionDispatchCrossModuleM5178 —
>> reschedule_calendar_event_inputs.event_id is { type: handle } and the
>> resolved-ref returns calendar_evt.id_ which is post-audit a string.
>> Cross-tool dispatch composition belongs in scripted/live, not zero-LLM.

>> Returns:-record writeback path: dispatch a tool with `returns:` set,
>> verify the result is shelf-written and result_handles surfaces.
>> Pre-Stage-B asserted on `state.resolved.<rt>` post-dispatch; post-
>> Stage-B reads the agent's plannerShelf directly. Originally blocked
>> on m-4b6f (role-context leak through function-call frames); revived
>> after that mlld fix landed.
exe role:worker @testExecuteResultHandlesFromReturnsRecord() = [
  let @shelfable = @shelfRecords(@executeResultHandleRecords)
  shelf @ps from @shelfable with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @agent = {
    suite: "fixture-result-handles",
    defense: "defended",
    records: @executeResultHandleRecords,
    plannerShelf: @ps,
    tools: @executeResultHandleTools,
    toolsCollection: @executeResultHandleTools,
    basePolicy: @synthesizedPolicy(@executeResultHandleTools, null)
  }
  let @decision = {
    phase: "execute",
    operation: "create_file",
    args: {
      filename: { source: "known", value: "test.txt" },
      content: { source: "known", value: "hello world" }
    }
  }
  let @result = @dispatchExecute(@agent, @emptyState(), @decision, "Create a file called test.txt with hello world")
  let @recordType = @recordTypeName(@file_entry)
  let @entries = @shelf.read(@agent.plannerShelf[@recordType])
  let @actual = {
    status: @result.result.status,
    handlesPositive: @result.result.result_handles.length > 0,
    entriesDefined: @entries.isDefined(),
    entriesPositive: @entries.length > 0,
    firstId: @entries[0].id_
  }
  => @assertEq(@actual, {
    status: "sent",
    handlesPositive: true,
    entriesDefined: true,
    entriesPositive: true,
    firstId: "42"
  })
]

>> Stage B follow-up: testCollectionDispatchPolicyBuild was deleted
>> during conversion. The test calls add_calendar_event_participants
>> directly with event_id="24" string; post-Stage-B input validation
>> rejects non-handle values. Cross-tool dispatch with handle-typed
>> inputs needs a resolve dispatch first to mint handles, which is
>> end-to-end territory (scripted/live), not zero-LLM.

>> Stage B follow-up: testCollectionDispatchCrossModuleM5178 (cross-module
>> dispatch composition) was deleted during conversion. The test threads
>> a calendar_evt resolved-ref into add_calendar_event_participants whose
>> input record requires event_id: { type: handle }. Pre-Stage-B, the
>> fixture seeded a fake bucket entry with synthetic handle string and
>> the lookup tolerated it; post-Stage-B + post-audit, calendar_evt.id_
>> is { type: string } and the input-handle validation rejects the
>> non-handle value. Reproducing this test in zero-LLM requires running
>> a real resolve dispatch (which mints handles) before the execute,
>> which is the wrong granularity for this gate. Cross-module dispatch
>> composition is exercised end-to-end by scripted suites and live
>> bench.

>> --- Suite construction ----------------------------------------------------

var @namedStateAndCollectionSuite = @suite("named-state-and-collection", [
  @group("named-state", [
    @testRecordBackedNamedStateProjectsDisplay,
    @testNamedStateRetainsPriorResults,
    @testNamedStateRetainsExtractSources,
    @testNamedArrayPreviewFields,
    @testWrappedArrayPreviewFields,
    @testLeanStateNoLogArrays
  ], {}),
  @group("ut7-reschedule-intent", [
    @testUpdateFieldsInPolicyIntent
  ], { ticket: "c-ut7" }),
  @group("collection-dispatch-returns-writeback", [
    @testExecuteResultHandlesFromReturnsRecord
  ], { ticket: "m-4b6f", notes: "Returns:-record shelf writeback after dispatch. Revived post-m-4b6f fix." })
], {})

export { @namedStateAndCollectionSuite }

>> --- Standalone runner -----------------------------------------------------

var @result = @runSuites([@namedStateAndCollectionSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
