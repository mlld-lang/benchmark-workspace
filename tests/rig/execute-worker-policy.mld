>> ---- Input-record collection fixtures ----

var @dispatchKnownParticipantMeetingCollectionResult = @dispatchExecute(
  @builtExecuteFixtureAgent,
  @emptyState(),
  {
    phase: "execute",
    operation: "schedule_meeting",
    args: {
      participants: [{ source: "known", value: "sarah.connor@gmail.com" }],
