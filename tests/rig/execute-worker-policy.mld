>> clean/tests/suites/rig/execute-worker-policy.mld
>>
>> Plain-assertion tests for the execute-worker's policy-application paths
>> and input-record validation rules. Three sub-groups:
>>   - control-args                    : zero/optional/known control-arg dispatch +
>>                                        natural-datetime canonicalization at
>>                                        compile time.
>>   - input-record-collection         : tool-collection input-record policy on
>>                                        known-participant + collection-derived
>>                                        payload schedule_meeting calls.
>>   - allowlist-blocklist-update-exact: input-record allowlist / blocklist /
>>                                        update / exact denial-and-pass rules.
>>
>> The dispatch fixtures are heavyweight (build a `tools` collection, a
>> base policy, and a built policy in some cases) so they're hoisted to
>> module-level vars. Denial tests put the guarded `when [denied => ...; *
>> => ...]` block inside the test exe so the `denied` handler catches the
>> guard rejection in the same scope as the assertion.

import { @assertOk, @assertEq, @assertContains } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"

import {
  @create_note,
  @schedule_meeting,
  @create_note_inputs
} from "../fixtures.mld"
import { @synthesizedPolicy, @updateNamedState } from "../../rig/orchestration.mld"
import { @emptyState } from "../../rig/runtime.mld"
import { @dispatchExecute } from "../../rig/workers/execute.mld"

>> --- Shared helpers --------------------------------------------------------

exe @field(inputValue, key) = js {
  return inputValue?.[key] ?? null;
}

exe @isBlank(value) = when [
  !@value.isDefined() => true
  @value == null => true
  @value == "" => true
  * => false
]

>> --- Module-level fixtures -------------------------------------------------

>> Local execute-time wrappers: thin wrappers preserve native mlld args while
>> relocating the policy boundary into this module.
exe @runtime_create_note(content) = [
  => @create_note(@content)
]

exe @runtime_schedule_meeting(title, start_time, end_time, participants: array) = [
  let @participantsValue = @exists(@participants) ? @participants : null
  => {
    ok: true,
    title: @title,
    start_time: @start_time,
    end_time: @end_time,
    participants: @participantsValue
  }
]

>> Local meeting input record with optional participants. Mirrors the
>> shape used in the rig invariant suite — keep this here so tests
>> exercise the planner/worker contract directly.
record @local_meeting_request_inputs = {
  facts: [participants?: array],
  data: [title: string, start_time: string, end_time: string],
  validate: "strict",
  write: {
    role:planner: { tools: { authorize: true } },
    role:worker: { tools: { submit: true } }
  }
}

var tools @localExecuteRuntimeTools = {
  create_note: {
    mlld: @runtime_create_note,
    inputs: @create_note_inputs,
    labels: ["execute:w", "tool:w", "file:w"],
    can_authorize: "role:planner",
    description: "Create a brand-new note with freeform content."
  },
  schedule_meeting: {
    mlld: @runtime_schedule_meeting,
    inputs: @local_meeting_request_inputs,
    labels: ["execute:w", "tool:w", "calendar:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Schedule a meeting with optional participants."
  }
}

var @builtExecuteFixtureAgent = {
  defense: "defended",
  tools: @localExecuteRuntimeTools,
  toolsCollection: @localExecuteRuntimeTools,
  basePolicy: @synthesizedPolicy(@localExecuteRuntimeTools, null)
}

>> ---- Control-arg dispatch fixtures ----

var @dispatchCreateNoteResult = @dispatchExecute(
  @builtExecuteFixtureAgent,
  @emptyState(),
  {
    phase: "execute",
    operation: "create_note",
    args: {
      content: { source: "known", value: "Demo note body" }
    }
  },
  "Create a note with content Demo note body."
)

var @dispatchOptionalMeetingResult = @dispatchExecute(
  @builtExecuteFixtureAgent,
  @emptyState(),
  {
    phase: "execute",
    operation: "schedule_meeting",
    args: {
      title: { source: "known", value: "Solo focus block" },
      start_time: { source: "known", value: "2026-04-14 09:00" },
      end_time: { source: "known", value: "2026-04-14 10:00" }
    }
