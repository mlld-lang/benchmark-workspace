>> tests/rig/null-conformance.mld
>>
>> Phase 3-adjacent regression suite. Locks the invariant from m-e5e0 +
>> m-231c (mlld-side fixes ed585629a + 9abefbf3d): values that are
>> SEMANTICALLY null must produce NATIVE-NULL surface where all three
>> idioms agree:
>>   @v == null      → true
>>   @v.isDefined()  → false
>>   @v.isNull()     → true
>>   @typeof(@v)     → "null"
>>
>> The audit covers rig's JS exes that return null. Pre-fix several of
>> these were "working by accident" (silent string coercion at the JS-
>> return boundary made callers' `== null` checks fail but downstream
>> consequences happened to line up). With the runtime fixes landed,
>> each null-returning surface now conforms.
>>
>> Drift detector: any future mlld change that re-breaks JS-return null
>> semantics OR wrapper-null comparison fires this suite immediately.
>> Don't delete the assertions even if they look redundant — they're
>> the only thing standing between the bug class and silent reintroduction.

import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import { @parseRigHandle } from "../../rig/intent.mld"
import {
  @buildUrlCapabilityValue
} from "../../rig/transforms/url_refs.mld"

>> --- Conformance helper ---------------------------------------------------

>> Three-way null check. Returns { eqNull, isDef, isNull, typeofVal,
>> conformsAsNull } so individual assertions can pin specific axes if
>> a future regression breaks one but not all.
exe @nullShape(value) = [
  let @eqNull = @value == null
  let @isDef = @value.isDefined()
  let @isNullField = @value.isNull()
  let @typeofVal = @typeof(@value)
  let @conformsAsNull = @eqNull && !@isDef && @isNullField && @typeofVal == "null"
  => {
    eqNull: @eqNull,
    isDef: @isDef,
    isNull: @isNullField,
    typeofVal: @typeofVal,
    conformsAsNull: @conformsAsNull
  }
]

exe @nonNullShape(value) = [
  let @eqNull = @value == null
  let @isDef = @value.isDefined()
  let @typeofVal = @typeof(@value)
  let @conformsAsValue = !@eqNull && @isDef && @typeofVal != "null"
  => {
    eqNull: @eqNull,
    isDef: @isDef,
    typeofVal: @typeofVal,
    conformsAsValue: @conformsAsValue
  }
]

>> --- Native null baseline (sanity check) ----------------------------------

>> Locks the invariant directly: literal `null` as a function-call arg
>> must bind as the native null sentinel, not as the string "null".
>> Same family as m-e5e0 + m-231c.
exe @testNativeNullLetBoundConforms() = [
  let @lit = null
  let @s = @nullShape(@lit)
  => @assertEq(@s, { eqNull: true, isDef: false, isNull: true, typeofVal: "null", conformsAsNull: true })
]

exe @testNativeNullLiteralArgConforms() = [
  let @s = @nullShape(null)
  => @assertEq(@s, { eqNull: true, isDef: false, isNull: true, typeofVal: "null", conformsAsNull: true })
]

>> --- @parseRigHandle (rig/intent.mld) -------------------------------------

exe @testParseRigHandleNullInputConformsAsNull() = [
  let @s = @nullShape(@parseRigHandle(null))
  => @assertOk(@s.conformsAsNull, `parseRigHandle(null): @s | @pretty`)
]

exe @testParseRigHandleNonStringInputConformsAsNull() = [
  let @s = @nullShape(@parseRigHandle(42))
  => @assertOk(@s.conformsAsNull, `parseRigHandle(42): @s | @pretty`)
]

exe @testParseRigHandleMissingPrefixConformsAsNull() = [
  let @s = @nullShape(@parseRigHandle("not_a_handle"))
  => @assertOk(@s.conformsAsNull, `parseRigHandle('not_a_handle'): @s | @pretty`)
]

exe @testParseRigHandleEmptyKeyConformsAsNull() = [
  let @s = @nullShape(@parseRigHandle("r_record_"))
  => @assertOk(@s.conformsAsNull, `parseRigHandle('r_record_'): @s | @pretty`)
]

exe @testParseRigHandleValidReturnsObject() = [
  let @r = @parseRigHandle("r_calendar_evt_abc123")
  let @s = @nonNullShape(@r)
  => @assertOk(@s.conformsAsValue && @r.record == "calendar_evt" && @r.key == "abc123", `parseRigHandle('r_calendar_evt_abc123'): @s | @pretty + record=@r.record key=@r.key`)
]

>> --- @buildUrlCapabilityValue (rig/transforms/url_refs.mld) --------------

exe @testBuildUrlCapabilityValueEmptyRefIdConformsAsNull() = [
  let @s = @nullShape(@buildUrlCapabilityValue("", "https://example.com"))
  => @assertOk(@s.conformsAsNull, `buildUrlCapabilityValue('', url): @s | @pretty`)
]

exe @testBuildUrlCapabilityValueEmptyUrlConformsAsNull() = [
  let @s = @nullShape(@buildUrlCapabilityValue("ref_001", ""))
  => @assertOk(@s.conformsAsNull, `buildUrlCapabilityValue(id, ''): @s | @pretty`)
]

exe @testBuildUrlCapabilityValueNullUrlConformsAsNull() = [
  let @s = @nullShape(@buildUrlCapabilityValue("ref_001", null))
  => @assertOk(@s.conformsAsNull, `buildUrlCapabilityValue(id, null): @s | @pretty`)
]

>> --- Suite construction ---------------------------------------------------

var @nullConformanceSuite = @suite("null-conformance", [
  @group("native-null", [
    @testNativeNullLetBoundConforms,
    @testNativeNullLiteralArgConforms
  ], { ticket: "m-e5e0", notes: "Baseline: native null behaves correctly via let-binding AND as a function-call literal arg. If literal-arg fails while let-binding passes, mlld's call-site parser is binding the `null` token as text instead of the native null sentinel." }),
  @group("parseRigHandle", [
    @testParseRigHandleNullInputConformsAsNull,
    @testParseRigHandleNonStringInputConformsAsNull,
    @testParseRigHandleMissingPrefixConformsAsNull,
    @testParseRigHandleEmptyKeyConformsAsNull,
    @testParseRigHandleValidReturnsObject
  ], { ticket: "m-231c", notes: "JS-return-null path conformance. Pre-9abefbf3d these returned string-null surfaces and callers' == null checks were 'working by accident'." }),
  @group("buildUrlCapabilityValue", [
    @testBuildUrlCapabilityValueEmptyRefIdConformsAsNull,
    @testBuildUrlCapabilityValueEmptyUrlConformsAsNull,
    @testBuildUrlCapabilityValueNullUrlConformsAsNull
  ], { ticket: "c-bac4", notes: "Replacement for the c-be06 capability-entry helpers — c-bac4 moves URL storage to @url_capability shelf entries built via @buildUrlCapabilityValue." })
], {})

export { @nullConformanceSuite }

>> --- Standalone runner ---------------------------------------------------

var @result = @runSuites([@nullConformanceSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
