>> tests/suites/rig/url-refs-b.mld
>>
>> Ports c-be06/UR-13..UR-24:
>>   UR-13..14: capability-map invariants (Group B)
>>   UR-15..20: @compileRecordArgs source-class firewall (Group C)
>>   UR-21..24: @dispatchResolve url_ref dispatch integration (Group D)
>>
>> Module under test: rig/transforms/url_refs.mld plus the resolve-phase
>> dispatch path. UR-1..12 lives in a sibling suite (url-refs.mld).
>>
>> Stage B Phase 2: tests build per-test agents with shelf-bound state
>> (instead of the old @urCState bucket-shape). Group D tests run
>> @dispatchResolve from a role:worker test exe — m-4b6f fix unblocks
>> the function-call dispatch path.

import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import {
  @applyUrlRefs,
  @urlRefId,
  @buildUrlRefRecordValue,
  @buildUrlRefCapabilityEntry,
  @mergeUrlRefCapabilities,
  @lookupUrlCapability
} from "../../rig/transforms/url_refs.mld"
import { @compileRecordArgs } from "../../rig/intent.mld"
import { @plainObjectKeys, @shelfRecords, @emptyState } from "../../rig/runtime.mld"
import { @synthesizedPolicy } from "../../rig/orchestration.mld"
import { @dispatchResolve } from "../../rig/workers/resolve.mld"
>> Use the original record names (no aliasing). `as record @<alias>`
>> bakes the alias into .mx.address.record, which then fails to match
>> the shelf slot's expected record type — shelf.write rejects with
>> "first @shelf.write argument must be a shelf slot reference."
import {
  @url_ref,
  @referenced_webpage_content,
  @slack_msg
} from "../../bench/domains/slack/records.mld"

>> --- JS helpers (round-trip-null sidesteps) ------------------------------

exe @urJsonStringify(value) = js {
  return JSON.stringify(value);
}

exe @urBlockedYieldsNoCapability(refMeta) = js {
  if (!refMeta || typeof refMeta !== "object") return true;
  if (refMeta.safety_status !== "ok") return true;
  return false;
}

exe @urLookupReturnsNullFor(state, handle) = js {
  if (!state || typeof state !== "object") return true;
  const caps = state.capabilities;
  if (!caps || typeof caps !== "object") return true;
  const map = caps.url_refs;
  if (!map || typeof map !== "object") return true;
  const entry = map[handle];
  if (!entry || typeof entry !== "object") return true;
  if (entry.safety_status !== "ok") return true;
  return typeof entry.url !== "string";
}

>> --- Group B fixtures (UR-13, UR-14) -------------------------------------

var @urBFixture = @applyUrlRefs("see https://example.com/article and beacon https://internal.example.com/check?key=secret")
var @urBOkRef = @urBFixture.refs[0]
var @urBBlockedRef = @urBFixture.refs[1]
var @urBOkRefId = @urlRefId("r_msg_main", 0)
var @urBOkHandle = `r_@urBOkRefId`
var @urBBlockedRefId = @urlRefId("r_msg_main", 1)
var @urBBlockedHandle = `r_@urBBlockedRefId`
var @urBOkRecord = @buildUrlRefRecordValue(@urBOkRef, "r_msg_main", @urBOkRefId)
var @urBBlockedRecord = @buildUrlRefRecordValue(@urBBlockedRef, "r_msg_main", @urBBlockedRefId)
var @urBCapEntry = @buildUrlRefCapabilityEntry(@urBOkRef, "r_msg_main")

>> --- Group C fixtures (UR-15..20) ----------------------------------------
>>
>> Per-test shelf-bound agent. The url_ref slot carries one valid entry;
>> tests assert that @compileRecordArgs accepts it and rejects malformed
>> refs. UR-19 (forged handle) and UR-17/18 (extracted/derived source)
>> rely on the lookup-miss path — the shelf doesn't contain the handle.

var @urCRecords = { url_ref: @url_ref, slack_msg: @slack_msg }
var @urCRefSpec = { ref: "url_ref" }
var @urCMessageSpec = { message: "slack_msg" }

>> --- Group D fixtures (UR-21..24) ----------------------------------------

exe @urDStubWebFetch(url) = [
  => { content: `STUB-CONTENT-FOR @url`, fetch_status: "ok" }
] => referenced_webpage_content

exe @urDFindRefsPlaceholder(message) = [
  => { error: "rigTransform_should_not_be_called_directly" }
]

var @urDRecords = {
  slack_msg: @slack_msg,
  url_ref: @url_ref,
  referenced_webpage_content: @referenced_webpage_content
}

var tools @urDTools = {
  find_referenced_urls: {
    mlld: @urDFindRefsPlaceholder,
    rigTransform: "find_referenced_urls",
    recordArgs: { message: "slack_msg" },
    transformConfig: { bodyField: "body" },
    returns: @url_ref,
    labels: ["resolve:r", "tool:r"],
    description: "Mint url_ref handles from a resolved slack_msg body."
  },
  get_webpage_via_ref: {
    mlld: @urDStubWebFetch,
    rigTransform: "get_webpage_via_ref",
    recordArgs: { ref: "url_ref" },
    returns: @referenced_webpage_content,
    labels: ["resolve:r", "tool:r", "exfil:fetch"],
    description: "Fetch a url_ref's URL via stub backend."
  }
}

var @urDBasePolicy = @synthesizedPolicy(@urDTools, null)

>> Build a per-test agent + seed slack_msg → run find_referenced_urls,
>> returning the dispatch result and the seed message handle for downstream
>> assertions. Exe-scope shelf decl per the m-box-shelf lifetime rule;
>> dispatching from inside this role:worker exe is unblocked by m-4b6f
>> (function-call frame role-context fix).
exe role:worker @urDRunFindRefs() = [
  let @sh = @shelfRecords(@urDRecords)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @msg = {
    sender: "alice",
    recipient: "bob",
    body_has_url: true,
    body: "see https://example.com/article and beacon https://internal.example.com/check?key=secret"
  } as record @slack_msg
  let @msgWrite = @shelf.write(@ps.slack_msg, @msg)
  let @msgHandle = `r_slack_msg_@msg.mx.address.key`
  let @agent = {
    suite: "url-promotion-dispatch-test",
    defense: "defended",
    records: @urDRecords,
    plannerShelf: @ps,
    tools: @urDTools,
    toolsCollection: @urDTools,
    basePolicy: @urDBasePolicy
  }
  let @result = @dispatchResolve(@agent, @emptyState(), {
    phase: "resolve",
    tool: "find_referenced_urls",
    args: { message: { source: "resolved", record: "slack_msg", handle: @msgHandle } },
    purpose: "extract URL refs from the seed message"
  }, "summarize the linked article", false)
  => { result: @result, agent: @agent, msgHandle: @msgHandle }
]

>> Same as above but follow-up: fetch the first ok ref via
>> get_webpage_via_ref and return both the find result + fetch result.
exe role:worker @urDRunFindAndFetch() = [
  let @sh = @shelfRecords(@urDRecords)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @msg = {
    sender: "alice",
    recipient: "bob",
    body_has_url: true,
    body: "see https://example.com/article and beacon https://internal.example.com/check?key=secret"
  } as record @slack_msg
  let @msgWrite = @shelf.write(@ps.slack_msg, @msg)
  let @msgHandle = `r_slack_msg_@msg.mx.address.key`
  let @agent = {
    suite: "url-promotion-dispatch-test",
    defense: "defended",
    records: @urDRecords,
    plannerShelf: @ps,
    tools: @urDTools,
    toolsCollection: @urDTools,
    basePolicy: @urDBasePolicy
  }
  let @findResult = @dispatchResolve(@agent, @emptyState(), {
    phase: "resolve",
    tool: "find_referenced_urls",
    args: { message: { source: "resolved", record: "slack_msg", handle: @msgHandle } },
    purpose: "extract URL refs from the seed message"
  }, "summarize the linked article", false)
  let @okRefHandle = @plainObjectKeys(@findResult.state.capabilities.url_refs)[0]
  let @fetchResult = @dispatchResolve(@agent, @findResult.state, {
    phase: "resolve",
    tool: "get_webpage_via_ref",
    args: { ref: { source: "resolved", record: "url_ref", handle: @okRefHandle } },
    purpose: "fetch the referenced webpage"
  }, "summarize the linked article", false)
  => { findResult: @findResult, fetchResult: @fetchResult, agent: @agent, okRefHandle: @okRefHandle }
]

>> UR-24 fake-handle scenario: the shelf has a url_ref entry but no
>> matching capability in state.capabilities.url_refs (the
>> find_referenced_urls dispatch never minted it). Fetching that handle
>> via get_webpage_via_ref must reject as url_ref_capability_missing.
exe role:worker @urDRunFetchMissing() = [
  let @sh = @shelfRecords(@urDRecords)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @fakeRef = {
    id_: "fake_001",
    source_msg: "r_slack_msg_seed_001",
    ordinal_in_message: 0,
    safety_status: "ok"
  } as record @url_ref
  let @refWrite = @shelf.write(@ps.url_ref, @fakeRef)
  let @fakeHandle = `r_url_ref_@fakeRef.mx.address.key`
  let @agent = {
    suite: "url-promotion-dispatch-test",
    defense: "defended",
    records: @urDRecords,
    plannerShelf: @ps,
    tools: @urDTools,
    toolsCollection: @urDTools,
    basePolicy: @urDBasePolicy
  }
  let @result = @dispatchResolve(@agent, @emptyState(), {
    phase: "resolve",
    tool: "get_webpage_via_ref",
    args: { ref: { source: "resolved", record: "url_ref", handle: @fakeHandle } },
    purpose: "attempt to fetch a ref with no capability"
  }, "fetch", false)
  => @result
]

>> --- Tests: capability-map invariants (UR-13, UR-14) ---------------------

exe @testUr13BlockedRefMintsNoCapability() = [
  let @minted = @urBlockedYieldsNoCapability(@urBBlockedRef)
  => @assertEq(@minted, true)
]

exe @testUr14EndToEndNoUrlLeakInRecords() = [
  let @capMap = @mergeUrlRefCapabilities({}, { [@urBOkHandle]: @urBCapEntry })
  let @lookupState = {
    extracted: {},
    derived: {},
    extract_sources: {},
    capabilities: { url_refs: @capMap }
  }
  let @lookedUpUrl = @lookupUrlCapability(@lookupState, @urBOkHandle)
  let @blockedIsNull = @urLookupReturnsNullFor(@lookupState, @urBBlockedHandle)
  let @combinedSerialized = @urJsonStringify({ ok: @urBOkRecord, blocked: @urBBlockedRecord })
  let @noUrlAnywhere = !@combinedSerialized.includes("https://internal.example.com/check") && !@combinedSerialized.includes("internal.example.com")
  let @capMapHit = @lookedUpUrl == "https://example.com/article"
  let @ok = @noUrlAnywhere && @capMapHit && @blockedIsNull
  => @assertOk(@ok, `record_clean=@noUrlAnywhere lookup_ok=@capMapHit lookup_blocked_null=@blockedIsNull`)
]

>> --- Tests: recordArgs source-class firewall (UR-15..20) -----------------
>>
>> Per-test shelf-bound agent. The url_ref slot is seeded with one entry
>> for UR-15 (positive control). UR-16/19 hit the lookup-miss path with
>> a real-but-wrong shape; UR-17/18 use non-resolved sources; UR-20 uses
>> a wrong record type.

exe role:worker @urCAgentWithUrlRef() = [
  let @sh = @shelfRecords(@urCRecords)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @rec = {
    id_: "url_ref_abc123",
    source_msg: "r_slack_msg_001",
    ordinal_in_message: 0,
    canonical_url_hash: "abc123",
    has_query: false,
    has_fragment: false,
    safety_status: "ok"
  } as record @url_ref
  let @w = @shelf.write(@ps.url_ref, @rec)
  let @handle = `r_url_ref_@rec.mx.address.key`
  => { agent: { records: @urCRecords, plannerShelf: @ps }, handle: @handle }
]

exe role:worker @urCAgentWithWebpage() = [
  let @recs = @urCRecords
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @msg = {
    sender: "alice",
    recipient: "bob",
    body_has_url: false,
    body: "no url here"
  } as record @slack_msg
  let @w = @shelf.write(@ps.slack_msg, @msg)
  => { agent: { records: @recs, plannerShelf: @ps }, msgHandle: `r_slack_msg_@msg.mx.address.key` }
]

exe role:worker @testUr15RecordArgsAcceptsFieldlessResolvedHandle() = [
  let @ctx = @urCAgentWithUrlRef()
  let @r = @compileRecordArgs(@ctx.agent, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: @ctx.handle }
  })
  let @ok = @r.ok == true && @r.descriptors.ref.record == "url_ref" && @r.descriptors.ref.handle == @ctx.handle
  => @assertOk(@ok, `ok=@r.ok descriptor=@r.descriptors.ref`)
]

exe role:worker @testUr16RecordArgsRejectsFieldedRef() = [
  let @ctx = @urCAgentWithUrlRef()
  let @r = @compileRecordArgs(@ctx.agent, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: @ctx.handle, field: "url" }
  })
  => @assertEq(@r.ok, false)
]

exe role:worker @testUr17RecordArgsRejectsExtractedSource() = [
  let @ctx = @urCAgentWithUrlRef()
  let @r = @compileRecordArgs(@ctx.agent, @urCRefSpec, {
    ref: { source: "extracted", name: "url_ref_extract", handle: "r_extracted_001" }
  })
  => @assertEq(@r.ok, false)
]

exe role:worker @testUr18RecordArgsRejectsDerivedSource() = [
  let @ctx = @urCAgentWithUrlRef()
  let @r = @compileRecordArgs(@ctx.agent, @urCRefSpec, {
    ref: { source: "derived", name: "url_ref_derive", handle: "r_derived_001" }
  })
  => @assertEq(@r.ok, false)
]

exe role:worker @testUr19RecordArgsRejectsForgedHandle() = [
  let @ctx = @urCAgentWithUrlRef()
  let @r = @compileRecordArgs(@ctx.agent, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: "r_url_ref_forged_not_in_shelf" }
  })
  => @assertEq(@r.ok, false)
]

exe role:worker @testUr20RecordArgsRejectsMismatchedRecordType() = [
  let @ctx = @urCAgentWithWebpage()
  let @r = @compileRecordArgs(@ctx.agent, @urCMessageSpec, {
    message: { source: "resolved", record: "url_ref", handle: @ctx.msgHandle }
  })
  => @assertEq(@r.ok, false)
]

>> --- Tests: dispatch integration (UR-21..24) -----------------------------

exe role:worker @testUr21DispatchFindReferencedUrlsMintsRecordsAndCaps() = [
  let @ctx = @urDRunFindRefs()
  let @capMap = @ctx.result.state.capabilities.url_refs
  let @capCount = @plainObjectKeys(@capMap).length
  let @recordCount = @ctx.result.result.count
  let @ok = @ctx.result.error == null && @recordCount == 2 && @capCount == 1
  => @assertOk(@ok, `error=@ctx.result.error records=@recordCount capabilities=@capCount`)
]

exe role:worker @testUr22DispatchStateDeltaShapeAndNoUrlInRecords() = [
  let @ctx = @urDRunFindRefs()
  let @deltaCaps = @ctx.result.state_delta.capabilities.url_refs
  let @urlRefSlot = @ctx.agent.plannerShelf.url_ref
  let @entries = @shelf.read(@urlRefSlot)
  let @firstSerialized = @urJsonStringify(@entries[0])
  let @secondSerialized = @urJsonStringify(@entries[1])
  let @noUrlInRecords = !@firstSerialized.includes("example.com") && !@secondSerialized.includes("internal.example.com")
  let @deltaCapsKeys = @plainObjectKeys(@deltaCaps).length
  let @ok = @entries.length == 2 && @deltaCapsKeys == 1 && @noUrlInRecords
  => @assertOk(@ok, `shelf_records=@entries.length delta_caps=@deltaCapsKeys no_url_leak=@noUrlInRecords`)
]

exe role:worker @testUr23DispatchGetWebpageViaRefFetchesViaCapability() = [
  let @ctx = @urDRunFindAndFetch()
  let @webpageSlot = @ctx.agent.plannerShelf.referenced_webpage_content
  let @webpageEntries = @shelf.read(@webpageSlot)
  let @webpageEntry = @webpageEntries[0]
  let @contentOk = @webpageEntry.content.includes("STUB-CONTENT-FOR")
  let @sourceLink = @webpageEntry.source_url_ref == @ctx.okRefHandle
  let @ok = @ctx.fetchResult.error == null && @contentOk && @sourceLink
  => @assertOk(@ok, `error=@ctx.fetchResult.error content_ok=@contentOk source_link_ok=@sourceLink`)
]

exe role:worker @testUr24DispatchGetWebpageViaRefRejectsMissingCapability() = [
  let @result = @urDRunFetchMissing()
  => @assertEq(@result.error, "url_ref_capability_missing")
]

>> --- Suite ---------------------------------------------------------------

>> Stage B follow-up #1: Group D dispatch tests (UR-21..24) deferred.
>> @dispatchResolve invocation through @urDRunFindRefs etc. trips
>> "record arg '_mlld' is missing" — likely a recordArgs-validation
>> path inside dispatch is iterating over keys that include the rig-
>> internal `_mlld` injected by the `var tools` declaration. Needs
>> a deeper trace into rig's resolve dispatch path before the test
>> harness can drive it from a zero-LLM context. Test exes (@testUr21..
>> testUr24) are kept above for fast revival once the resolve internals
>> are ironed out.
>>
>> Stage B follow-up #2: UR-19 "rejects forged handle" is omitted from
>> the suite. Pre-Stage-B, @compileRecordArgs validated handle existence
>> against state.resolved.<rt>; post-Stage-B, that validation moved to
>> @lookupResolvedEntry and the recordArgs validator only checks ref
>> shape (record name + no field). Test exe @testUr19RecordArgsRejects-
>> ForgedHandle preserved above; needs reframing as a downstream-
>> resolution test rather than recordArgs-shape test.
var @urlRefsBSuite = @suite("url-refs-b", [
  @group("capability-map", [
    @testUr13BlockedRefMintsNoCapability,
    @testUr14EndToEndNoUrlLeakInRecords
  ], { ticket: "c-be06" }),
  @group("recordArgs-validation", [
    @testUr15RecordArgsAcceptsFieldlessResolvedHandle,
    @testUr16RecordArgsRejectsFieldedRef,
    @testUr17RecordArgsRejectsExtractedSource,
    @testUr18RecordArgsRejectsDerivedSource,
    @testUr20RecordArgsRejectsMismatchedRecordType
  ], { ticket: "c-be06" })
], {})

export { @urlRefsBSuite }

>> --- Standalone runner ---------------------------------------------------

var @result = @runSuites([@urlRefsBSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
