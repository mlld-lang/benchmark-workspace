import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import {
  @applyUrlRefs,
  @urlRefId,
  @buildUrlRefRecordValue,
  @buildUrlRefCapabilityEntry,
  @mergeUrlRefCapabilities,
  @lookupUrlCapability
} from "../../rig/transforms/url_refs.mld"
import { @compileRecordArgs } from "../../rig/intent.mld"
import { @plainObjectKeys } from "../../rig/runtime.mld"
import { @dispatchResolve } from "../../rig/workers/resolve.mld"
import { @rigBuild } from "../../rig/index.mld"
import {
  @url_ref as @slack_url_ref,
  @referenced_webpage_content as @slack_ref_webpage,
  @slack_msg as @slack_msg_record
} from "../../bench/domains/slack/records.mld"

>> --- JS helpers (round-trip-null sidesteps) ------------------------------

exe @urJsonStringify(value) = js {
  return JSON.stringify(value);
}

exe @urBlockedYieldsNoCapability(refMeta) = js {
  if (!refMeta || typeof refMeta !== "object") return true;
  if (refMeta.safety_status !== "ok") return true;
  return false;
}

exe @urLookupReturnsNullFor(state, handle) = js {
  if (!state || typeof state !== "object") return true;
  const caps = state.capabilities;
  if (!caps || typeof caps !== "object") return true;
  const map = caps.url_refs;
  if (!map || typeof map !== "object") return true;
  const entry = map[handle];
  if (!entry || typeof entry !== "object") return true;
  if (entry.safety_status !== "ok") return true;
  return typeof entry.url !== "string";
}

exe @urDFindEntry(bucket, handle) = js {
  if (!bucket) return null;
  let entries = [];
  if (Array.isArray(bucket)) entries = bucket;
  else if (bucket._rig_bucket === "resolved_index_v1") entries = Object.values(bucket.by_handle || {});
  else entries = Object.values(bucket || {});
  for (const e of entries) {
    if (e && e.handle === handle) return e;
  }
  return null;
}

>> --- Group B fixtures (UR-13, UR-14) -------------------------------------

var @urBFixture = @applyUrlRefs("see https://example.com/article and beacon https://internal.example.com/check?key=secret")
var @urBOkRef = @urBFixture.refs[0]
var @urBBlockedRef = @urBFixture.refs[1]
var @urBOkRefId = @urlRefId("r_msg_main", 0)
var @urBOkHandle = `r_@urBOkRefId`
var @urBBlockedRefId = @urlRefId("r_msg_main", 1)
var @urBBlockedHandle = `r_@urBBlockedRefId`
var @urBOkRecord = @buildUrlRefRecordValue(@urBOkRef, "r_msg_main", @urBOkRefId)
var @urBBlockedRecord = @buildUrlRefRecordValue(@urBBlockedRef, "r_msg_main", @urBBlockedRefId)
var @urBCapEntry = @buildUrlRefCapabilityEntry(@urBOkRef, "r_msg_main")

>> --- Group C fixtures (UR-15..20) ----------------------------------------

var @urCSlackMsgEntry = {
  handle: "r_slack_msg_001",
  key: "msg_001",
  identity_field: "id_",
  identity_value: "msg_001",
  value: { id_: "msg_001", sender: "alice", body: "see https://example.com/article" },
  field_values: { id_: "msg_001", sender: "alice", body: "see https://example.com/article" }
}
var @urCUrlRefEntry = {
  handle: "r_url_ref_abc123",
  key: "url_ref_abc123",
  identity_field: "id_",
  identity_value: "url_ref_abc123",
  value: { id_: "url_ref_abc123", source_msg: "r_slack_msg_001", ordinal_in_message: 0, safety_status: "ok" },
  field_values: { id_: "url_ref_abc123", source_msg: "r_slack_msg_001", ordinal_in_message: 0, safety_status: "ok" }
}
var @urCState = {
  resolved: {
    slack_msg: [@urCSlackMsgEntry],
    url_ref: [@urCUrlRefEntry]
  },
  extracted: {
    forged_url_ref: [
      { handle: "r_forged_001", value: { id_: "forged_001" }, field_values: { id_: "forged_001" } }
    ]
  },
  derived: {},
  extract_sources: {}
}
var @urCStateWithWebpage = {
  resolved: {
    slack_msg: [@urCSlackMsgEntry],
    url_ref: [@urCUrlRefEntry],
    webpage_content: [
      { handle: "r_webpage_001", value: { id_: "webpage_001", url: "https://attacker.example/x" }, field_values: { id_: "webpage_001", url: "https://attacker.example/x" } }
    ]
  },
  extracted: {},
  derived: {},
  extract_sources: {}
}
var @urCRefSpec = { ref: "url_ref" }
var @urCMessageSpec = { message: "slack_msg" }

>> --- Group D fixtures (UR-21..24) ----------------------------------------

exe @urDStubWebFetch(url) = [
  => { content: `STUB-CONTENT-FOR @url`, fetch_status: "ok" }
]

exe @urDFindRefsPlaceholder(message) = [
  => { error: "rigTransform_should_not_be_called_directly" }
]

var @urDRecords = {
  slack_msg: @slack_msg_record,
  url_ref: @slack_url_ref,
  referenced_webpage_content: @slack_ref_webpage
}

var tools @urDTools = {
  find_referenced_urls: {
    mlld: @urDFindRefsPlaceholder,
    rigTransform: "find_referenced_urls",
    recordArgs: { message: "slack_msg" },
    transformConfig: { bodyField: "body" },
    returns: @slack_url_ref,
    labels: ["resolve:r", "tool:r"],
    description: "Mint url_ref handles from a resolved slack_msg body."
  },
  get_webpage_via_ref: {
    mlld: @urDStubWebFetch,
    rigTransform: "get_webpage_via_ref",
    recordArgs: { ref: "url_ref" },
    returns: @slack_ref_webpage,
    labels: ["resolve:r", "tool:r", "exfil:fetch"],
    description: "Fetch a url_ref's URL via stub backend."
  }
}

var @urDAgent = @rigBuild({
  suite: "url-promotion-dispatch-test",
  defense: "defended",
  model: "stub",
  records: @urDRecords,
  tools: @urDTools
})

var @urDMsgEntry = {
  handle: "r_slack_msg_seed_001",
  key: "seed_001",
  identity_field: "id_",
  identity_value: "seed_001",
  value: { id_: "seed_001", sender: "alice", recipient: "bob", body: "see https://example.com/article and beacon https://internal.example.com/check?key=secret" },
  field_values: { id_: "seed_001", sender: "alice", recipient: "bob", body: "see https://example.com/article and beacon https://internal.example.com/check?key=secret" }
}
var @urDSeedState = {
  resolved: { slack_msg: [@urDMsgEntry] },
  extracted: {},
  derived: {},
  extract_sources: {},
  capabilities: { url_refs: {} }
}

>> Run the find_referenced_urls dispatch once at module scope; UR-21..23
>> all pivot off this result.
var @urDFindResult = @dispatchResolve(@urDAgent, @urDSeedState, {
  phase: "resolve",
  tool: "find_referenced_urls",
  args: { message: { source: "resolved", record: "slack_msg", handle: "r_slack_msg_seed_001" } },
  purpose: "extract URL refs from the seed message"
}, "summarize the linked article", false)

var @urDOkRefHandle = @plainObjectKeys(@urDFindResult.state.capabilities.url_refs)[0]

var @urDFetchResult = @dispatchResolve(@urDAgent, @urDFindResult.state, {
  phase: "resolve",
  tool: "get_webpage_via_ref",
  args: { ref: { source: "resolved", record: "url_ref", handle: @urDOkRefHandle } },
  purpose: "fetch the referenced webpage"
}, "summarize the linked article", false)

var @ur24FakeUrlRefEntry = {
  handle: "r_url_ref_fake_001",
  key: "fake_001",
  identity_field: "id_",
  identity_value: "fake_001",
  value: { id_: "fake_001", source_msg: "r_slack_msg_seed_001", ordinal_in_message: 0, safety_status: "ok" },
  field_values: { id_: "fake_001", source_msg: "r_slack_msg_seed_001", ordinal_in_message: 0, safety_status: "ok" }
}
var @ur24State = {
  resolved: { slack_msg: [@urDMsgEntry], url_ref: [@ur24FakeUrlRefEntry] },
  extracted: {},
  derived: {},
  extract_sources: {},
  capabilities: { url_refs: {} }
}
var @urDMissingResult = @dispatchResolve(@urDAgent, @ur24State, {
  phase: "resolve",
  tool: "get_webpage_via_ref",
  args: { ref: { source: "resolved", record: "url_ref", handle: "r_url_ref_fake_001" } },
  purpose: "attempt to fetch a ref with no capability"
}, "fetch", false)

>> --- Tests: capability-map invariants (UR-13, UR-14) ---------------------

exe @testUr13BlockedRefMintsNoCapability() = [
  let @minted = @urBlockedYieldsNoCapability(@urBBlockedRef)
  => @assertEq(@minted, true)
]

exe @testUr14EndToEndNoUrlLeakInRecords() = [
  let @capMap = @mergeUrlRefCapabilities({}, { [@urBOkHandle]: @urBCapEntry })
  let @lookupState = {
    resolved: {},
    extracted: {},
    derived: {},
    extract_sources: {},
    capabilities: { url_refs: @capMap }
  }
  let @lookedUpUrl = @lookupUrlCapability(@lookupState, @urBOkHandle)
  let @blockedIsNull = @urLookupReturnsNullFor(@lookupState, @urBBlockedHandle)
  let @combinedSerialized = @urJsonStringify({ ok: @urBOkRecord, blocked: @urBBlockedRecord })
  let @noUrlAnywhere = !@combinedSerialized.includes("https://internal.example.com/check") && !@combinedSerialized.includes("internal.example.com")
  let @capMapHit = @lookedUpUrl == "https://example.com/article"
  let @ok = @noUrlAnywhere && @capMapHit && @blockedIsNull
  => @assertOk(@ok, `record_clean=@noUrlAnywhere lookup_ok=@capMapHit lookup_blocked_null=@blockedIsNull`)
]

>> --- Tests: recordArgs source-class firewall (UR-15..20) -----------------

exe @testUr15RecordArgsAcceptsFieldlessResolvedHandle() = [
  let @r = @compileRecordArgs(@urCState, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: "r_url_ref_abc123" }
  })
  let @ok = @r.ok == true && @r.descriptors.ref.record == "url_ref" && @r.descriptors.ref.handle == "r_url_ref_abc123"
  => @assertOk(@ok, `ok=@r.ok descriptor=@r.descriptors.ref`)
]

exe @testUr16RecordArgsRejectsFieldedRef() = [
  let @r = @compileRecordArgs(@urCState, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: "r_url_ref_abc123", field: "url" }
  })
  => @assertEq(@r.ok, false)
]

exe @testUr17RecordArgsRejectsExtractedSource() = [
  let @r = @compileRecordArgs(@urCState, @urCRefSpec, {
    ref: { source: "extracted", name: "url_ref_extract", handle: "r_extracted_001" }
  })
  => @assertEq(@r.ok, false)
]

exe @testUr18RecordArgsRejectsDerivedSource() = [
  let @r = @compileRecordArgs(@urCState, @urCRefSpec, {
    ref: { source: "derived", name: "url_ref_derive", handle: "r_derived_001" }
  })
  => @assertEq(@r.ok, false)
]

exe @testUr19RecordArgsRejectsSpike42ForgedHandle() = [
  let @r = @compileRecordArgs(@urCState, @urCRefSpec, {
    ref: { source: "resolved", record: "url_ref", handle: "r_forged_001" }
  })
  => @assertEq(@r.ok, false)
]

exe @testUr20RecordArgsRejectsMismatchedRecordType() = [
  let @r = @compileRecordArgs(@urCStateWithWebpage, @urCMessageSpec, {
    message: { source: "resolved", record: "webpage_content", handle: "r_webpage_001" }
  })
  => @assertEq(@r.ok, false)
]

>> --- Tests: dispatch integration (UR-21..24) -----------------------------

exe @testUr21DispatchFindReferencedUrlsMintsRecordsAndCaps() = [
  let @capMap = @urDFindResult.state.capabilities.url_refs
  let @capCount = @plainObjectKeys(@capMap).length
  let @recordCount = @urDFindResult.result.count
  let @ok = @urDFindResult.error == null && @recordCount == 2 && @capCount == 1
  => @assertOk(@ok, `error=@urDFindResult.error records=@recordCount capabilities=@capCount`)
]

exe @testUr22DispatchStateDeltaShapeAndNoUrlInRecords() = [
  let @deltaResolved = @urDFindResult.state_delta.resolved.url_ref
  let @deltaCaps = @urDFindResult.state_delta.capabilities.url_refs
  let @firstSerialized = @urJsonStringify(@deltaResolved[0].value)
  let @secondSerialized = @urJsonStringify(@deltaResolved[1].value)
  let @noUrlInRecords = !@firstSerialized.includes("example.com") && !@secondSerialized.includes("internal.example.com")
  let @deltaCapsKeys = @plainObjectKeys(@deltaCaps).length
  let @ok = @deltaResolved.length == 2 && @deltaCapsKeys == 1 && @noUrlInRecords
  => @assertOk(@ok, `delta_records=@deltaResolved.length delta_caps=@deltaCapsKeys no_url_leak=@noUrlInRecords`)
]

exe @testUr23DispatchGetWebpageViaRefFetchesViaCapability() = [
  let @urlRefBucket = @urDFindResult.state.resolved.url_ref
  let @okUrlRefEntry = @urDFindEntry(@urlRefBucket, @urDOkRefHandle)
  let @okRefStateExists = @okUrlRefEntry.isDefined() && @okUrlRefEntry != null
  let @webpageBucket = @urDFetchResult.state.resolved.referenced_webpage_content
  let @webpageEntry = @urDFindEntry(@webpageBucket, @urDFetchResult.result.handles[0])
  let @contentOk = @webpageEntry.value.content.includes("STUB-CONTENT-FOR")
  let @sourceLink = @webpageEntry.value.source_url_ref == @urDOkRefHandle
  let @ok = @urDFetchResult.error == null && @okRefStateExists && @contentOk && @sourceLink
  => @assertOk(@ok, `error=@urDFetchResult.error content_ok=@contentOk source_link_ok=@sourceLink`)
]

exe @testUr24DispatchGetWebpageViaRefRejectsMissingCapability() = [
  => @assertEq(@urDMissingResult.error, "url_ref_capability_missing")
]

>> --- Suite ---------------------------------------------------------------

var @urlRefsBSuite = @suite("url-refs-b", [
  @group("capability-map", [
    @testUr13BlockedRefMintsNoCapability,
    @testUr14EndToEndNoUrlLeakInRecords
  ], { ticket: "c-be06" }),
  @group("recordArgs-validation", [
    @testUr15RecordArgsAcceptsFieldlessResolvedHandle,
    @testUr16RecordArgsRejectsFieldedRef,
    @testUr17RecordArgsRejectsExtractedSource,
    @testUr18RecordArgsRejectsDerivedSource,
    @testUr19RecordArgsRejectsSpike42ForgedHandle,
    @testUr20RecordArgsRejectsMismatchedRecordType
  ], { ticket: "c-be06" }),
  @group("dispatch", [
    @testUr21DispatchFindReferencedUrlsMintsRecordsAndCaps,
    @testUr22DispatchStateDeltaShapeAndNoUrlInRecords,
    @testUr23DispatchGetWebpageViaRefFetchesViaCapability,
    @testUr24DispatchGetWebpageViaRefRejectsMissingCapability
  ], { ticket: "c-be06" })
], {})

export { @urlRefsBSuite }

>> --- Standalone runner ---------------------------------------------------

var @result = @runSuites([@urlRefsBSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
