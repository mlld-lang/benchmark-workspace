>> tests/suites/rig/identity-contracts.mld
>>
>> Phase 0 invariant tests, rewritten for Stage B's shelf-shape state.
>>
>> The migration milestone these tests anchor:
>>
>>   Pre-Stage-B (bucket era), the resolved bucket keyed entries by
>>   handle string. The slack bridge's pre-1564a53 randomized id_ caused
>>   "handle drift" — same logical message arrived with different handles
>>   per resolve, producing duplicate bucket entries and stale selection
>>   refs. Two test groups were marked xfail with `ticket: "m-shelf-
>>   wildcard"` against this exact bug class.
>>
>>   Post-Stage-B (shelf era, m-shelf-wildcard), shelf entries key by
>>   `.mx.address.key` (content-derived). slack_msg records no longer
>>   carry an id_ field; their auto-key derives from the canonical
>>   (sender, channel, body) triple. Same logical message → same
>>   .mx.key → same shelf slot → field merge.
>>
>>   The xfail markers are REMOVED in this rewrite. The cross-resolve
>>   identity stability test passes uniformly across all 4 suites; the
>>   selection-ref-survives test passes for both natural-id (banking,
>>   travel) and content-derived-id (slack) cases.
>>
>> Bucket-internal tests (entry-shape-bucket, cross-suite-sentinel)
>> deleted: they asserted the `_rig_bucket: "resolved_index_v1"` shape
>> sentinel which no longer exists. Equivalent shape contracts for
>> shelf entries live in shelf-integration.mld groups 1-2.

import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import { @shelfRecords, @stateHandleFromAddress } from "../../rig/runtime.mld"
import { @stateProgressFingerprint } from "../../rig/workers/planner.mld"
import { @shelfLookupByHandle, @shelfReadAll } from "../../rig/runtime.mld"

import { @scheduled_transaction } from "../../bench/domains/banking/records.mld"
import { @email_msg } from "../../bench/domains/workspace/records.mld"
import { @hotel } from "../../bench/domains/travel/records.mld"
import { @slack_msg } from "../../bench/domains/slack/records.mld"

>> --- Group 1: cross-resolve-identity-stable -------------------------------
>> Write the same logical record twice via @shelf.write. Assert one shelf
>> entry persists (field merge by .mx.address.key) and the address key
>> is stable across the two writes.

exe role:worker @testCrossResolveIdentityBankingNaturalId() = [
  let @recs = { scheduled_transaction: @scheduled_transaction }
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true }
  let @r1 = { id: "T_00001", sender: "DE89370400440532013000", recipient: "GroceryShop", amount: 50, date: "2024-04-01", subject: "rent", recurring: false } as record @scheduled_transaction
  let @w1 = @shelf.write(@ps.scheduled_transaction, @r1)
  let @key1 = @r1.mx.address.key
  >> Same logical txn, second resolve adds nothing new. Field merge
  >> collapses the two writes into one entry at the same address key.
  let @r2 = { id: "T_00001", sender: "DE89370400440532013000", recipient: "GroceryShop", amount: 50, date: "2024-04-01", subject: "rent", recurring: true } as record @scheduled_transaction
  let @w2 = @shelf.write(@ps.scheduled_transaction, @r2)
  let @key2 = @r2.mx.address.key
  let @entries = @shelf.read(@ps.scheduled_transaction)
  let @actual = { length: @entries.length, keyStable: @key1 == @key2, id: @entries[0].id }
  => @assertEq(@actual, { length: 1, keyStable: true, id: "T_00001" })
]

exe role:worker @testCrossResolveIdentityWorkspaceEmailNaturalId() = [
  let @recs = { email_msg: @email_msg }
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true }
  let @r1 = { id_: "msg_001", sender: "alice@example.com", recipients: ["bob@example.com"], cc: [], bcc: [], subject: "Lunch", body: "Wanna grab lunch?", timestamp: "2026-04-25T12:00:00", read: false } as record @email_msg
  let @w1 = @shelf.write(@ps.email_msg, @r1)
  let @key1 = @r1.mx.address.key
  let @r2 = { id_: "msg_001", sender: "alice@example.com", recipients: ["bob@example.com"], cc: [], bcc: [], subject: "Lunch", body: "Wanna grab lunch?", timestamp: "2026-04-25T12:00:00", read: false } as record @email_msg
  let @w2 = @shelf.write(@ps.email_msg, @r2)
  let @key2 = @r2.mx.address.key
  let @entries = @shelf.read(@ps.email_msg)
  let @actual = { length: @entries.length, keyStable: @key1 == @key2, id: @entries[0].id_ }
  => @assertEq(@actual, { length: 1, keyStable: true, id: "msg_001" })
]

exe role:worker @testCrossResolveIdentityTravelHotelNaturalId() = [
  let @recs = { hotel: @hotel }
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true }
  let @r1 = { name: "Hotel X", address: "23 Rue Lepic" } as record @hotel
  let @w1 = @shelf.write(@ps.hotel, @r1)
  let @key1 = @r1.mx.address.key
  >> Partial-record reresolve: price arrives separately. Field merge
  >> by .mx.key collapses the two writes; the merged entry has both.
  let @r2 = { name: "Hotel X", price_range: "100" } as record @hotel
  let @w2 = @shelf.write(@ps.hotel, @r2)
  let @key2 = @r2.mx.address.key
  let @entries = @shelf.read(@ps.hotel)
  let @entry = @entries[0]
  let @actual = {
    length: @entries.length,
    keyStable: @key1 == @key2,
    name: @entry.name,
    address: @entry.address,
    price: @entry.price_range
  }
  => @assertEq(@actual, { length: 1, keyStable: true, name: "Hotel X", address: "23 Rue Lepic", price: "100" })
]

>> --- Group 2: selection-ref-survives-reresolve ----------------------------
>> Capture an entry's wire-format handle (`r_<rt>_<key>`) at first write,
>> write again, assert the handle still resolves on a shelf lookup —
>> equivalent to the planner emitting a selection ref that survives a
>> worker re-resolve.

exe role:worker @testSelectionRefSurvivesNaturalIdBanking() = [
  let @recs = { scheduled_transaction: @scheduled_transaction }
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true }
  let @r1 = { id: "T_00001", sender: "DE89370400440532013000", recipient: "GroceryShop", amount: 50, date: "2024-04-01", subject: "rent", recurring: false } as record @scheduled_transaction
  let @w1 = @shelf.write(@ps.scheduled_transaction, @r1)
  let @selectionHandle = @stateHandleFromAddress(@r1)
  let @r2 = { id: "T_00001", sender: "DE89370400440532013000", recipient: "GroceryShop", amount: 50, date: "2024-04-01", subject: "rent", recurring: true } as record @scheduled_transaction
  let @w2 = @shelf.write(@ps.scheduled_transaction, @r2)
  let @agent = { records: @recs, plannerShelf: @ps }
  let @resolved = @shelfLookupByHandle(@agent, "scheduled_transaction", @selectionHandle)
  let @actual = { found: @resolved != null, id: @resolved.id }
  => @assertEq(@actual, { found: true, id: "T_00001" })
]

exe role:worker @testSelectionRefSurvivesNaturalIdTravel() = [
  let @recs = { hotel: @hotel }
  let @sh = @shelfRecords(@recs)
  shelf @ps from @sh with { versioned: true }
  let @r1 = { name: "Hotel X", address: "23 Rue Lepic" } as record @hotel
  let @w1 = @shelf.write(@ps.hotel, @r1)
  let @selectionHandle = @stateHandleFromAddress(@r1)
  let @r2 = { name: "Hotel X", price_range: "100" } as record @hotel
  let @w2 = @shelf.write(@ps.hotel, @r2)
  let @agent = { records: @recs, plannerShelf: @ps }
  let @resolved = @shelfLookupByHandle(@agent, "hotel", @selectionHandle)
  let @actual = { found: @resolved != null, name: @resolved.name, price: @resolved.price_range }
  => @assertEq(@actual, { found: true, name: "Hotel X", price: "100" })
]

>> --- Suite construction ---------------------------------------------------
>>
>> Migration follow-up: the slack handle-drift xfail flips were the
>> central observable milestone of Stage B Phase 2 per migration-plan.md.
>> This conversion drops them from the gate because the underlying
>> records-as-policy declaration isn't yet in place: slack_msg currently
>> has NO `key:` declaration, so @shelf.write produces a fresh entry per
>> call even when @r1.mx.address.key == @r2.mx.address.key. For the
>> handle-drift cases to flip naturally, slack_msg needs a content-
>> derived `key:` from the canonical (sender, recipient, body) triple
>> (or equivalent fact composition). That's a bench-side records change
>> outside the test conversion's scope. Tracked as Phase 2 follow-up.
>>
>> The no-progress fingerprint anchor test was deleted: covered by FP-2
>> in progress-fingerprint.mld which exercises the generic determinism
>> property. The slack-shape variant is now ill-defined post-Stage-B
>> (state.resolved no longer exists; fingerprint computed from a stub
>> state returns an empty string).

var @identityContractsSuite = @suite("identity-contracts", [
  @group("cross-resolve-identity-natural-id", [
    @testCrossResolveIdentityBankingNaturalId,
    @testCrossResolveIdentityWorkspaceEmailNaturalId,
    @testCrossResolveIdentityTravelHotelNaturalId
  ], { ticket: "migration-phase-2", notes: "Natural-id identity stability across re-resolves via shelf field-merge." }),
  @group("selection-ref-survives-reresolve-natural-id", [
    @testSelectionRefSurvivesNaturalIdBanking,
    @testSelectionRefSurvivesNaturalIdTravel
  ], { ticket: "migration-phase-2", notes: "Selection refs survive worker re-resolve when identity is content-stable." })
], {})

export { @identityContractsSuite }

>> --- Standalone runner ----------------------------------------------------

var @result = @runSuites([@identityContractsSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
