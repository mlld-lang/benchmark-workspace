>> tests/rig/identity-contracts.mld
>>
>> Phase 0.A invariant gate (records-as-policy + bucket→shelf migration).
>> Encodes contracts the migration must preserve. Each contract is checked
>> against today's bucket shape and continues to hold against post-cutover
>> shelf shape.
>>
>> Five contract groups:
>>   1. cross-resolve-identity-stable — same logical entity merged twice
>>      collapses to one entry; primary identity stable; bucket version
>>      increments per write. Natural-id path passes today; handle-drift
>>      path is xfail today (locks the bug class the migration eliminates).
>>   2. selection-ref-survives-reresolve — derive picks an entry, planner
>>      re-resolves, the selection ref still resolves. Same xfail split.
>>   3. no-progress-detector — given a slack-shaped state, the fingerprint
>>      is deterministic across calls (anchors the no-progress signal).
>>   4. entry-shape-contract — bucket entries carry the expected key set
>>      via @assertEntryShape with sentinel autodetection. Migration bumps
>>      the snapshot to shelf form; auto-mode reads _rig_bucket presence.
>>   5. cross-suite-version-equality — every suite-shaped bucket carries
>>      the same _rig_bucket sentinel ("resolved_index_v1" today; shelf
>>      form post-Phase-2). Catches one-suite-stuck-on-old-shape regressions.
>>
>> When the migration's Phase 2 lands, the xfail markers on the
>> handle-drift groups flip to xpass — that's the migration milestone
>> visible in the test runner's xpassNudge output. Per migration-plan.md
>> Phase 2 gate, the xfail removal lands in the same commit as the
>> bucket→shelf collapse.

import { @assertOk, @assertEq } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import {
  @mergeResolvedEntries,
  @updateResolvedState,
  @bucketItems,
  @bucketLength,
  @isResolvedIndexBucket,
  @valueField,
  @emptyState
} from "../../rig/runtime.mld"
import { @stateProgressFingerprint } from "../../rig/workers/planner.mld"

>> --- Shape helpers --------------------------------------------------------
>> @assertEntryShape(parent, entry, mode) — assert the entry carries the
>> expected key set for the parent's storage shape.
>>
>> mode:
>>   "bucket" — assert today's bucket entry shape (handle, key,
>>              identity_field, identity_value, field_values)
>>   "shelf"  — assert post-cutover shelf entry shape (.mx.key, .mx.hash,
>>              field-projected payload). Reserved for post-Phase-2;
>>              today this branch errors.
>>   "auto"   — autodetect via @isResolvedIndexBucket(@parent). If the
>>              parent is an indexed bucket, assert bucket shape; if not
>>              and a future shelf sentinel is present, assert shelf
>>              shape. Otherwise FAIL with unrecognized_state_shape — do
>>              not silently fall through.
>>
>> The hard error in auto-mode is deliberate: a partial-migration commit
>> that produces a container without a recognized sentinel is exactly
>> the bug class we want to surface loudly, not paper over.

exe @bucketEntryShape(entry) = [
  let @keys = @entry.mx.keys
  let @hasHandle = @keys.includes("handle")
  let @hasKey = @keys.includes("key")
  let @hasIdField = @keys.includes("identity_field")
  let @hasIdValue = @keys.includes("identity_value")
  let @hasFieldValues = @keys.includes("field_values")
  let @ok = @hasHandle && @hasKey && @hasIdField && @hasIdValue && @hasFieldValues
  => { ok: @ok, missing: {
    handle: !@hasHandle, key: !@hasKey, identity_field: !@hasIdField,
    identity_value: !@hasIdValue, field_values: !@hasFieldValues
  }}
]

exe @assertEntryShape(parent, entry, mode) = [
  let @parentIsBucket = @isResolvedIndexBucket(@parent)
  let @resolvedMode = when [
    @mode == "bucket" => "bucket"
    @mode == "shelf" => "shelf"
    @mode == "auto" && @parentIsBucket => "bucket"
    * => "unknown"
  ]
  let @bucketCheck = when [
    @resolvedMode == "bucket" => @bucketEntryShape(@entry)
    * => { ok: true, missing: {} }
  ]
  => when [
    @resolvedMode == "unknown" => @assertOk(false, `assertEntryShape: unrecognized_state_shape — parent has no _rig_bucket sentinel and shelf-form is not yet defined; pass mode explicitly or fix the parent shape`)
    @resolvedMode == "shelf" => @assertOk(false, `assertEntryShape: shelf mode reserved for post-Phase-2; not implemented yet`)
    @resolvedMode == "bucket" && !@bucketCheck.ok => @assertEq(@bucketCheck.missing, { handle: false, key: false, identity_field: false, identity_value: false, field_values: false })
    * => @assertOk(true, `bucket entry shape ok`)
  ]
]

>> --- Fixtures -------------------------------------------------------------
>> Natural-id fixtures: identity stable across calls because key/handle
>> are derived from a stable record field. Banking transaction, workspace
>> email, travel hotel.
>>
>> Handle-drift fixture: same logical entity, different handle on second
>> resolve — models the pre-1564a53 slack bridge that minted Date.now()
>> randomized id_ values per resolve. Bucket merge keys by handle, so
>> drifting handles produce duplicate entries. Shelf keys by .mx.key, so
>> the duplicates collapse — that's the property the migration buys.

>> Banking transaction (natural id from transaction_id field).
var @bankingTxn = {
  handle: "r_scheduled_transaction_T_00001",
  key: "T_00001",
  identity_field: "transaction_id",
  identity_value: "T_00001",
  field_values: { transaction_id: "T_00001", amount: 50, recipient: "GroceryShop" },
  value: { transaction_id: "T_00001", amount: 50, recipient: "GroceryShop" }
}

>> Same logical txn, second resolve: amount field updated, identity stable.
var @bankingTxnReresolve = {
  handle: "r_scheduled_transaction_T_00001",
  key: "T_00001",
  identity_field: "transaction_id",
  identity_value: "T_00001",
  field_values: { transaction_id: "T_00001", amount: 50, recipient: "GroceryShop", schedule: "monthly" },
  value: { transaction_id: "T_00001", amount: 50, recipient: "GroceryShop", schedule: "monthly" }
}

>> Workspace email (natural id from message_id).
var @workspaceEmail = {
  handle: "r_email_msg_001",
  key: "msg_001",
  identity_field: "message_id",
  identity_value: "msg_001",
  field_values: { message_id: "msg_001", subject: "Lunch", sender: "alice@example.com" },
  value: { message_id: "msg_001", subject: "Lunch", sender: "alice@example.com" }
}

>> Travel hotel (natural id from name).
var @travelHotel = {
  handle: "r_hotel_HotelX",
  key: "Hotel X",
  identity_field: "name",
  identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: "23 Rue Lepic" },
  value: { name: "Hotel X", address: "23 Rue Lepic" }
}

>> Travel hotel partial-record reresolve: price arrives separately.
var @travelHotelPrice = {
  handle: "r_hotel_HotelX",
  key: "Hotel X",
  identity_field: "name",
  identity_value: "Hotel X",
  field_values: { name: "Hotel X", price_range: "100" },
  value: { name: "Hotel X", price_range: "100" }
}

>> Slack message with handle drift: pre-1564a53 bridge minted a fresh
>> randomized id_ per resolve, so the same logical message arrived with
>> different handles. The bucket keys by handle and produces 2 entries;
>> shelf would key by content and produce 1.
>> The canonical_id field below is the stable shelf-key surrogate
>> (text+sender+channel); shelf would compute it via .mx.key.
var @slackMsgFirstResolve = {
  handle: "r_slack_msg_id_1234567890",
  key: "id_1234567890",
  identity_field: "id_",
  identity_value: "id_1234567890",
  field_values: { id_: "id_1234567890", text: "Hello team", sender: "U_alice", channel: "general" },
  value: { id_: "id_1234567890", text: "Hello team", sender: "U_alice", channel: "general" },
  canonical_id: "general/U_alice/Hello team"
}

var @slackMsgSecondResolve = {
  handle: "r_slack_msg_id_9876543210",
  key: "id_9876543210",
  identity_field: "id_",
  identity_value: "id_9876543210",
  field_values: { id_: "id_9876543210", text: "Hello team", sender: "U_alice", channel: "general" },
  value: { id_: "id_9876543210", text: "Hello team", sender: "U_alice", channel: "general" },
  canonical_id: "general/U_alice/Hello team"
}

>> --- Group 1: cross-resolve-identity-stable (natural-id) ------------------
>> Same logical entity merged twice → length unchanged, identity stable,
>> bucket version increments by 1. Passes today.

exe @testCrossResolveIdentityBankingNaturalId() = [
  let @b1 = @mergeResolvedEntries([], [@bankingTxn])
  let @b2 = @mergeResolvedEntries(@b1, [@bankingTxnReresolve])
  let @items = @bucketItems(@b2)
  let @v1 = @valueField(@b1, "version")
  let @v2 = @valueField(@b2, "version")
  let @actual = {
    length: @items.length,
    identity: @items[0].identity_value,
    handle: @items[0].handle,
    versionDelta: @v2 - @v1
  }
  => @assertEq(@actual, { length: 1, identity: "T_00001", handle: "r_scheduled_transaction_T_00001", versionDelta: 1 })
]

exe @testCrossResolveIdentityWorkspaceEmailNaturalId() = [
  let @b1 = @mergeResolvedEntries([], [@workspaceEmail])
  let @b2 = @mergeResolvedEntries(@b1, [@workspaceEmail])
  let @items = @bucketItems(@b2)
  let @actual = { length: @items.length, identity: @items[0].identity_value }
  => @assertEq(@actual, { length: 1, identity: "msg_001" })
]

exe @testCrossResolveIdentityTravelHotelNaturalId() = [
  let @b1 = @mergeResolvedEntries([], [@travelHotel])
  let @b2 = @mergeResolvedEntries(@b1, [@travelHotelPrice])
  let @items = @bucketItems(@b2)
  let @entry = @items[0]
  let @actual = {
    length: @items.length,
    address: @entry.field_values.address,
    price: @entry.field_values.price_range
  }
  => @assertEq(@actual, { length: 1, address: "23 Rue Lepic", price: "100" })
]

>> --- Group 1b: cross-resolve-identity-stable (handle-drift, xfail) --------
>> Same logical message, different handle per resolve. Today: bucket has 2
>> entries (length=2). Post-Phase-2 (.mx.key keying): length=1.

exe @testCrossResolveIdentitySlackHandleDrift() = [
  let @b1 = @mergeResolvedEntries([], [@slackMsgFirstResolve])
  let @b2 = @mergeResolvedEntries(@b1, [@slackMsgSecondResolve])
  let @items = @bucketItems(@b2)
  >> POST-MIGRATION INVARIANT: same logical entity collapses to 1 entry.
  >> Today this fails (length == 2, both handles present). Migration's
  >> Phase 2 (.mx.key as canonical key) flips this to xpass.
  let @actual = { length: @items.length, canonical: @items[0].canonical_id }
  => @assertEq(@actual, { length: 1, canonical: "general/U_alice/Hello team" })
]

>> --- Group 2: selection-ref-survives-reresolve (natural-id) ---------------
>> Derive picks an entry by handle, planner re-resolves the same record
>> type, the selection ref still finds its target. Today: passes for
>> natural-id because handle is content-derived and stable across calls.

exe @testSelectionRefSurvivesNaturalIdBanking() = [
  let @b1 = @mergeResolvedEntries([], [@bankingTxn])
  let @selectionHandle = @bucketItems(@b1)[0].handle
  let @b2 = @mergeResolvedEntries(@b1, [@bankingTxnReresolve])
  let @byHandle = @valueField(@b2, "by_handle")
  let @resolved = @valueField(@byHandle, @selectionHandle)
  let @actual = { found: @resolved != null, identity: @resolved.identity_value }
  => @assertEq(@actual, { found: true, identity: "T_00001" })
]

exe @testSelectionRefSurvivesNaturalIdTravel() = [
  let @b1 = @mergeResolvedEntries([], [@travelHotel])
  let @selectionHandle = @bucketItems(@b1)[0].handle
  let @b2 = @mergeResolvedEntries(@b1, [@travelHotelPrice])
  let @byHandle = @valueField(@b2, "by_handle")
  let @resolved = @valueField(@byHandle, @selectionHandle)
  let @actual = { found: @resolved != null, name: @resolved.field_values.name, price: @resolved.field_values.price_range }
  => @assertEq(@actual, { found: true, name: "Hotel X", price: "100" })
]

>> --- Group 2b: selection-ref-survives-reresolve (handle-drift, xfail) -----
>> Derive picks slack message by first-resolve handle. Re-resolve mints a
>> different handle for the same logical message. The selection ref now
>> points to a "stale" handle. Today: ref still resolves (the original
>> entry stays in the bucket alongside the new one) BUT it doesn't reflect
>> updated content — split-identity bug. Post-Phase-2 (shelf, .mx.key):
>> the two resolves merge into one, the ref resolves to the merged entry.

exe @testSelectionRefSurvivesHandleDriftSlack() = [
  let @b1 = @mergeResolvedEntries([], [@slackMsgFirstResolve])
  let @selectionHandle = @bucketItems(@b1)[0].handle
  >> Simulate a content update arriving on the second resolve (e.g.,
  >> reactions added). Today the second resolve has a different handle,
  >> so the new content lives at a different key — the selection ref
  >> resolves but to stale content.
  let @slackMsgWithReactions = {
    handle: "r_slack_msg_id_9876543210",
    key: "id_9876543210",
    identity_field: "id_",
    identity_value: "id_9876543210",
    field_values: { id_: "id_9876543210", text: "Hello team", sender: "U_alice", channel: "general", reactions: 5 },
    value: { id_: "id_9876543210", text: "Hello team", sender: "U_alice", channel: "general", reactions: 5 },
    canonical_id: "general/U_alice/Hello team"
  }
  let @b2 = @mergeResolvedEntries(@b1, [@slackMsgWithReactions])
  let @byHandle = @valueField(@b2, "by_handle")
  let @resolved = @valueField(@byHandle, @selectionHandle)
  >> POST-MIGRATION INVARIANT: selection ref reflects current content
  >> after re-resolve. Today the ref resolves to the FIRST entry (no
  >> reactions field) because the second resolve created a new entry at
  >> a drifted handle — stale read. Phase 2 collapses the two resolves
  >> via .mx.key, so the ref reads merged content.
  let @actual = { found: @resolved != null, reactions: @resolved.field_values.reactions }
  => @assertEq(@actual, { found: true, reactions: 5 })
]

>> --- Group 3: no-progress-detector probe ----------------------------------
>> Locks fingerprint determinism for a slack-shaped state (the bug class
>> the no-progress detector was designed to catch). Two byte-identical
>> states must produce equal fingerprints — that's what lets
>> calls_since_progress increment when consecutive worker calls don't
>> change meaningful state. FP-2 in progress-fingerprint.mld locks the
>> property generically; this anchors it for the slack repeat-resolve
>> loop fixture so a future fingerprint-formula change can't silently
>> regress slack's no-progress detection without firing this test.

exe @testNoProgressFingerprintStableForSlackShape() = [
  let @slackBucket = {
    _rig_bucket: "resolved_index_v1",
    order: ["r_slack_msg_id_1234567890"],
    by_handle: { "r_slack_msg_id_1234567890": @slackMsgFirstResolve },
    version: 1,
    planner_cache: { version: 0, entries: [], changed_handles: [] }
  }
  let @s1 = { resolved: { slack_msg: @slackBucket }, extracted: {}, derived: {} }
  let @s2 = { resolved: { slack_msg: @slackBucket }, extracted: {}, derived: {} }
  let @fp1 = @stateProgressFingerprint(@s1)
  let @fp2 = @stateProgressFingerprint(@s2)
  => @assertOk(@fp1 == @fp2 && @fp1 != "", `fp1='@fp1' fp2='@fp2'`)
]

>> --- Group 4: entry-shape-contract ----------------------------------------
>> Walk a freshly-merged bucket per suite shape and assert each entry
>> carries the bucket key set. Migration explicitly bumps this to shelf
>> shape; auto-mode picks via the parent's _rig_bucket sentinel.

exe @testEntryShapeBucketBanking() = [
  let @b1 = @mergeResolvedEntries([], [@bankingTxn])
  let @items = @bucketItems(@b1)
  => @assertEntryShape(@b1, @items[0], "auto")
]

exe @testEntryShapeBucketWorkspace() = [
  let @b1 = @mergeResolvedEntries([], [@workspaceEmail])
  let @items = @bucketItems(@b1)
  => @assertEntryShape(@b1, @items[0], "auto")
]

exe @testEntryShapeBucketTravel() = [
  let @b1 = @mergeResolvedEntries([], [@travelHotel])
  let @items = @bucketItems(@b1)
  => @assertEntryShape(@b1, @items[0], "auto")
]

exe @testEntryShapeBucketSlack() = [
  let @b1 = @mergeResolvedEntries([], [@slackMsgFirstResolve])
  let @items = @bucketItems(@b1)
  => @assertEntryShape(@b1, @items[0], "auto")
]

exe @testEntryShapeAutoErrorsOnUnknownShape() = [
  let @notABucket = { foo: "bar" }
  let @entry = { stuff: "things" }
  let @result = @assertEntryShape(@notABucket, @entry, "auto")
  >> The helper must NOT silently pass; it must report ok=false with
  >> the unrecognized_state_shape message.
  let @hasErrorMessage = @result.detail.includes("unrecognized_state_shape")
  => @assertOk(!@result.ok && @hasErrorMessage, `ok=@result.ok detail='@result.detail'`)
]

>> --- Group 5: cross-suite-version-equality --------------------------------
>> Every suite-shaped bucket carries the same _rig_bucket sentinel.
>> Catches a regression where one suite stops using @mergeResolvedEntries
>> (or its post-migration equivalent) and produces a divergent shape.

exe @testCrossSuiteSentinelBanking() = [
  let @b = @mergeResolvedEntries([], [@bankingTxn])
  => @assertEq(@valueField(@b, "_rig_bucket"), "resolved_index_v1")
]

exe @testCrossSuiteSentinelWorkspace() = [
  let @b = @mergeResolvedEntries([], [@workspaceEmail])
  => @assertEq(@valueField(@b, "_rig_bucket"), "resolved_index_v1")
]

exe @testCrossSuiteSentinelTravel() = [
  let @b = @mergeResolvedEntries([], [@travelHotel])
  => @assertEq(@valueField(@b, "_rig_bucket"), "resolved_index_v1")
]

exe @testCrossSuiteSentinelSlack() = [
  let @b = @mergeResolvedEntries([], [@slackMsgFirstResolve])
  => @assertEq(@valueField(@b, "_rig_bucket"), "resolved_index_v1")
]

>> --- Suite construction ---------------------------------------------------

var @identityContractsSuite = @suite("identity-contracts", [
  @group("cross-resolve-identity-natural-id", [
    @testCrossResolveIdentityBankingNaturalId,
    @testCrossResolveIdentityWorkspaceEmailNaturalId,
    @testCrossResolveIdentityTravelHotelNaturalId
  ], { ticket: "migration-phase-0", notes: "Natural-id identity stability across re-resolves; passes today, must continue passing post-cutover." }),
  @group("cross-resolve-identity-handle-drift", [
    @testCrossResolveIdentitySlackHandleDrift
  ], { xfail: true, ticket: "m-shelf-wildcard", notes: "Handle-drift identity collapse. xfail today (bucket keys by handle); flips to xpass at Phase 2 (.mx.key shelf keying). xfail removal lands in same commit as bucket→shelf collapse per migration-plan.md Phase 2 gate." }),
  @group("selection-ref-survives-reresolve-natural-id", [
    @testSelectionRefSurvivesNaturalIdBanking,
    @testSelectionRefSurvivesNaturalIdTravel
  ], { ticket: "migration-phase-0", notes: "Selection refs survive worker re-resolve when identity is content-stable." }),
  @group("selection-ref-survives-reresolve-handle-drift", [
    @testSelectionRefSurvivesHandleDriftSlack
  ], { xfail: true, ticket: "m-shelf-wildcard", notes: "Selection ref freshness across handle drift. xfail today (ref resolves to stale entry); flips at Phase 2 (single .mx.key-merged entry). Migration milestone marker." }),
  @group("no-progress-detector", [
    @testNoProgressFingerprintStableForSlackShape
  ], { ticket: "c-3438", notes: "Locks fingerprint-stability for the slack repeat-resolve shape — anchors the no-progress signal source." }),
  @group("entry-shape-contract", [
    @testEntryShapeBucketBanking,
    @testEntryShapeBucketWorkspace,
    @testEntryShapeBucketTravel,
    @testEntryShapeBucketSlack,
    @testEntryShapeAutoErrorsOnUnknownShape
  ], { ticket: "migration-phase-0", notes: "Entry shape snapshot via @assertEntryShape sentinel-autodetect. Migration bumps the shape constant; auto-mode picks the right assertion via the parent's _rig_bucket sentinel." }),
  @group("cross-suite-version-equality", [
    @testCrossSuiteSentinelBanking,
    @testCrossSuiteSentinelWorkspace,
    @testCrossSuiteSentinelTravel,
    @testCrossSuiteSentinelSlack
  ], { ticket: "migration-phase-0", notes: "All four suite shapes carry the same _rig_bucket sentinel — catches one-suite-stuck-on-old-shape regressions across the migration." })
], {})

export { @identityContractsSuite }

>> --- Standalone runner ----------------------------------------------------

var @result = @runSuites([@identityContractsSuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
