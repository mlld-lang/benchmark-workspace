>> tests/suites/rig/thin-arrow-and-display.mld
>>
>> Plain-assertion tests for the thin-arrow regression and the display
>> projection contracts (planner-vs-worker visibility, flat-array display
>> shorthand, plain-mode display keys, and checkpoint-restore identity).
>>
>> Source: legacy rig/tests/index.mld, ids strict-thin-arrow,
>> tool-error-envelope-only-fails-on-true, display-projection,
>> display-shorthand-array, display-plain-mode-keys,
>> display-checkpoint-identity, resolve-checkpoint-identity.

import { @assertOk, @assertEq, @assertContains } from "../assert.mld"
import { @suite, @group, @runSuites } from "../runner.mld"
import { @toolCallError, @projectResolvedSummary, @emptyState, @shelfRecords } from "../../rig/runtime.mld"
import { @plannerVisibleState, @workerStateSummary } from "../../rig/orchestration.mld"
import { @resolveRefValue } from "../../rig/intent.mld"
import { @records as @fixtureRecords, @aliceContactRecord, @bobContactRecord, @noteEntryRecord, @contact, @note_entry } from "../fixtures.mld"

>> --- Module-level fixtures -------------------------------------------------

>> Tool return shape for the thin-arrow probe. `validate: "demote"` keeps
>> the planner from auto-rejecting the leaked sentinel field; the contract
>> we're asserting is that the rig serialization simply doesn't see it.
record @thin_arrow_output = {
  data: [leaked: string?, input: string?],
  validate: "demote"
}

>> Workspace contact records use unnamed display arrays such as
>> `[name, { value: "email" }]`. Keep one fixture inline so this suite
>> exercises the exact shorthand the live benchmark depends on.
record @flat_display_contact = {
  facts: [email: string],
  data: [name: string, notes: string?],
  read: [name, { value: "email" }],
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

>> Benchmark suites use plain mode keys (`planner`, `worker`, `default`)
>> rather than the test fixtures' `role:*` form. Keep one record with
>> that spelling so the planner summary cannot silently fall back to
>> `default` and expose hidden content.
record @plain_mode_message = {
  facts: [id_: string, sender: string?],
  data: [subject: string?, body: string?],
  key: id_,
  read: {
    default: [{ value: "id_" }, subject, body],
    role:worker: [{ value: "id_" }, subject, body],
    role:planner: [{ value: "id_" }, subject]
  },
  write: { role:worker: { shelves: { upsert: true, clear: true, remove: true } } }
}

>> Thin-arrow regression probe. If strict mode leaks the tool-slot value
>> back into mlld, the serialized output contains the sentinel string.
exe @thinArrowProbe(x) = [
  -> { leaked: "tool-slot-value", input: @x }
] => record @thin_arrow_output

>> --- Group: thin-arrow + tool error envelope -------------------------------

exe @testStrictThinArrow() = [
  let @serialized = @thinArrowProbe("probe") | @pretty
  => @assertOk(
    !@serialized.includes("tool-slot-value"),
    `serialized=@serialized`
  )
]

>> MCP and adapter bridges often include `error: false` in successful
>> envelopes. The runtime must only short-circuit on `error: true`;
>> otherwise valid tool payloads disappear before they ever reach state.
exe @testToolErrorEnvelopeOnlyFailsOnTrue() = [
  let @success = @toolCallError({ error: false, text: "ok" })
  let @failure = @toolCallError({ error: true, summary: "boom" })
  let @actual = {
    successIsNull: @success == null,
    failureSummary: @failure.summary
  }
  => @assertEq(@actual, { successIsNull: true, failureSummary: "boom" })
]

>> --- Group: display projection ---------------------------------------------
>>
>> Stage B: each display test declares its own shelf, populates it with
>> the records under test, and threads it onto a synthetic agent.

exe role:worker @testDisplayProjection() = [
  let @shelfable = @shelfRecords(@fixtureRecords)
  shelf @ps from @shelfable with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @w1 = @shelf.write(@ps.contact, @aliceContactRecord)
  let @w2 = @shelf.write(@ps.contact, @bobContactRecord)
  let @w3 = @shelf.write(@ps.note_entry, @noteEntryRecord)
  let @agent = { suite: "fixtures", records: @fixtureRecords, plannerShelf: @ps }
  let @plannerSummary = @plannerVisibleState(@agent, @emptyState()) | @pretty
  let @workerSummary = @workerStateSummary(@agent, @emptyState()) | @pretty
  let @actual = {
    plannerHasAlice: @plannerSummary.includes("Alice"),
    plannerHasEmail: @plannerSummary.includes("alice.example"),
    plannerHidesNote: !@plannerSummary.includes("planner-hidden note"),
    workerSeesNote: @workerSummary.includes("planner-hidden note")
  }
  => @assertEq(@actual, {
    plannerHasAlice: true,
    plannerHasEmail: true,
    plannerHidesNote: true,
    workerSeesNote: true
  })
]

exe role:worker @testDisplayShorthandArray() = [
  let @flatRecords = { flat_display_contact: @flat_display_contact }
  shelf @ps from @flatRecords with { versioned: true, projection_cache: ["role:planner"] }
  let @flatRecord = {
    email: "carol.example",
    name: "Carol",
    notes: "plain-display"
  } as record @flat_display_contact
  let @w = @shelf.write(@ps.flat_display_contact, @flatRecord)
  let @agent = { suite: "fixtures", records: @flatRecords, plannerShelf: @ps }
  let @summary = @plannerVisibleState(@agent, @emptyState()) | @pretty
  let @actual = {
    hasName: @summary.includes("Carol"),
    hasEmail: @summary.includes("carol.example")
  }
  => @assertEq(@actual, { hasName: true, hasEmail: true })
]

exe role:worker @testDisplayPlainModeKeys() = [
  let @plainRecords = { plain_mode_message: @plain_mode_message }
  shelf @ps from @plainRecords with { versioned: true, projection_cache: ["role:planner", "role:worker"] }
  let @msg = {
    id_: "msg_1",
    sender: "david.example",
    subject: "Project kickoff agenda",
    body: "planner-must-not-see-this"
  } as record @plain_mode_message
  let @w = @shelf.write(@ps.plain_mode_message, @msg)
  let @agent = { suite: "fixtures", records: @plainRecords, plannerShelf: @ps }
  let @plannerSummary = @plannerVisibleState(@agent, @emptyState()) | @pretty
  let @workerSummary = @workerStateSummary(@agent, @emptyState()) | @pretty
  let @actual = {
    plannerHasSubject: @plannerSummary.includes("Project kickoff agenda"),
    plannerHidesBody: !@plannerSummary.includes("planner-must-not-see-this"),
    workerSeesBody: @workerSummary.includes("planner-must-not-see-this")
  }
  => @assertEq(@actual, {
    plannerHasSubject: true,
    plannerHidesBody: true,
    workerSeesBody: true
  })
]

>> --- Group: identity contract -----------------------------------------------
>>
>> Stage B: identity is content-derived from the record's key field
>> (`.mx.address.key`) rather than from a synthetic envelope. Planner
>> summaries must surface the fact-bearing string id, and `@resolveRefValue`
>> through the shelf must return that same id when the planner asks for
>> the record's key field.

exe role:worker @testDisplayCheckpointIdentity() = [
  let @plainRecords = { plain_mode_message: @plain_mode_message }
  shelf @ps from @plainRecords with { versioned: true, projection_cache: ["role:planner"] }
  let @msg = {
    id_: "msg_1",
    sender: "david.example",
    subject: "Project kickoff agenda",
    body: "planner-must-not-see-this"
  } as record @plain_mode_message
  let @w = @shelf.write(@ps.plain_mode_message, @msg)
  let @agent = { suite: "fixtures", records: @plainRecords, plannerShelf: @ps }
  let @summary = @plannerVisibleState(@agent, @emptyState()) | @pretty
  let @actual = {
    showsStringId: @summary.includes("msg_1"),
    hidesNumericId: !@summary.includes('"id_": 1')
  }
  => @assertEq(@actual, { showsStringId: true, hidesNumericId: true })
]

exe role:worker @testResolveCheckpointIdentity() = [
  let @plainRecords = { plain_mode_message: @plain_mode_message }
  shelf @ps from @plainRecords with { versioned: true }
  let @msg = {
    id_: "msg_1",
    sender: "david.example",
    subject: "Project kickoff agenda",
    body: "planner-must-not-see-this"
  } as record @plain_mode_message
  let @w = @shelf.write(@ps.plain_mode_message, @msg)
  let @agent = { suite: "fixtures", records: @plainRecords, plannerShelf: @ps }
  let @handle = `r_plain_mode_message_@msg.mx.address.key`
  let @resolved = @resolveRefValue(@agent, @emptyState(), {
    source: "resolved",
    record: "plain_mode_message",
    handle: @handle,
    field: "id_"
  })
  let @actual = { ok: @resolved.ok, value: @resolved.value }
  => @assertEq(@actual, { ok: true, value: "msg_1" })
]

>> --- Suite construction ----------------------------------------------------

var @thinArrowAndDisplaySuite = @suite("thin-arrow-and-display", [
  @group("thin-arrow-and-envelope", [
    @testStrictThinArrow,
    @testToolErrorEnvelopeOnlyFailsOnTrue
  ], {}),
  @group("display-projection", [
    @testDisplayProjection,
    @testDisplayShorthandArray,
    @testDisplayPlainModeKeys
  ], {}),
  @group("checkpoint-identity", [
    @testDisplayCheckpointIdentity,
    @testResolveCheckpointIdentity
  ], {})
], {})

export { @thinArrowAndDisplaySuite }

>> --- Standalone runner -----------------------------------------------------

var @result = @runSuites([@thinArrowAndDisplaySuite])
show @result.report
if @result.timingLines.length > 0 [
  show ""
  for @tl in @result.timingLines => show `  @tl`
]
if @result.xpassNudge != "" [ show @result.xpassNudge ]
show ""
show `summary: @result.passes.length pass / @result.fails.length fail (@result.xfails.length xfail, @result.xpasses.length xpass)`
if @result.fails.length > 0 [ bail "suite failed" ]
