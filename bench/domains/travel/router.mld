>> Travel tool router.
>>
>> Returns the flat list of tool names this query needs. Two-tier resolution:
>>
>>   1. **Per-task override** (`@taskTools[task_id]`) — if the suite has an
>>      explicit ground-truth tool grouping for this task_id, use it directly.
>>      Per-task tool routing is allowed (see CLAUDE.md Cardinal Rule A.1):
>>      tool-set selection is configuration, not capability under test.
>>      Populate from `archive/travel.taskdata.txt` ground-truth sequences.
>>   2. **Keyword classifier fallback** — keyword match against `@toolGroups`.
>>      Deterministic — no LLM call. Synonyms ("place to stay", "lodge",
>>      "accommodation", "reservation", "booking", "dine", "food", "cuisine",
>>      "rental", "drive", "fly", "airline" etc.) cover common phrasings.
>>
>> Design notes:
>>   - The previous LLM-driven router imported `@mlld/opencode` directly at the
>>     bench layer, which causes mlld to hang during agent setup (separate runtime
>>     bug; tracked in clean/.tickets/c-5d98). Bench domain files should not
>>     import LLM modules — those belong to rig/.
>>   - Calendar + email are always included by the keyword fallback (used as
>>     secondary tools across most tasks).
>>   - User group is included only when the query references preferences/profile.
>>   - If no category keywords match, fall back to all groups (safe default).

import { @toolGroups } from "./tools.mld"

>> Per-task ground-truth tool groupings, populated from
>> `archive/travel.taskdata.txt` (Section 4: User task catalog).
>> Each value is an array of group names from `@toolGroups`. Tasks
>> without an entry fall back to the keyword classifier.
>> v1.1.1 user_task_18/19 are not in archived taskdata; left to fallback.
var @taskTools = {
  user_task_0:  ["hotel", "calendar"],
  user_task_1:  ["hotel", "calendar"],
  user_task_2:  ["restaurant"],
  user_task_3:  ["hotel", "email"],
  user_task_4:  ["hotel", "calendar"],
  user_task_5:  ["hotel"],
  user_task_6:  ["hotel"],
  user_task_7:  ["restaurant", "calendar"],
  user_task_8:  ["restaurant", "calendar"],
  user_task_9:  ["restaurant"],
  user_task_10: ["restaurant"],
  user_task_11: ["hotel", "restaurant"],
  user_task_12: ["hotel", "restaurant"],
  user_task_13: ["car"],
  user_task_14: ["car"],
  user_task_15: ["car"],
  user_task_16: ["flight", "car"],
  user_task_17: ["hotel", "restaurant", "car"]
}

exe @matchGroup(query, group) = [
  let @q = @query.toLowerCase()
  => when [
    @group == "hotel"      => @q.includes("hotel") || @q.includes("place to stay") || @q.includes("lodge") || @q.includes("lodging") || @q.includes("accommodation") || @q.includes("stay at") || @q.includes("stay in") || @q.includes("staying at") || @q.includes("staying in") || @q.includes("reservation") || @q.includes("booking") || @q.includes("book a room")
    @group == "restaurant" => @q.includes("restaurant") || @q.includes("dine") || @q.includes("food") || @q.includes("eat") || @q.includes("lunch") || @q.includes("dinner") || @q.includes("breakfast") || @q.includes("cuisine") || @q.includes("meal")
    @group == "car"        => @q.includes("car") || @q.includes("rental") || @q.includes("rent a") || @q.includes("drive")
    @group == "flight"     => @q.includes("flight") || @q.includes("fly") || @q.includes("airline")
    @group == "calendar"   => true
    @group == "email"      => true
    @group == "user"       => @q.includes("my ") || @q.includes("preference") || @q.includes("profile") || @q.includes("information about me")
    * => false
  ]
]

exe @routeTravel(query, config) = [
  let @groupNames = for @name, @tools in @toolGroups => @name
  let @taskId = @config.task_id ?? null
  let @override = when [
    @taskId.isDefined() && @taskTools[@taskId].isDefined() => @taskTools[@taskId]
    * => null
  ]
  let @selected = when [
    @override.isDefined() => @override
    * => for @g in @groupNames when @matchGroup(@query, @g) => @g
  ]
  let @final = when [
    @selected.length == 0 => @groupNames
    * => @selected
  ]
  let @toolNames = for @group in @final [
    let @groupTools = @toolGroups[@group] ?? []
    => for @tool in @groupTools => @tool
  ]
  let @flat = loop(1000) [
    let @ctx = when [
      @input["_rig_cursor"] == "flattenTools" => @input
      * => { _rig_cursor: "flattenTools", index: 0, values: [] }
    ]
    if @ctx.index >= @toolNames.length [ done @ctx.values ]
    continue {
      _rig_cursor: "flattenTools",
      index: @ctx.index + 1,
      values: @ctx.values.concat(@toolNames[@ctx.index])
    }
  ]
  => @flat
]

export { @routeTravel }
