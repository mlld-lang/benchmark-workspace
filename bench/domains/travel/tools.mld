] => record @car_company

exe resolve:r, known, tool:r @get_car_types_available(company_name: array) = [
  let @raw = @mcp.getCarTypesAvailable(@company_name)
  let @pairs = @namedPairs(@raw)
  => for @pair in @pairs => {
