exe @stringListItems(raw) = js {
  if (Array.isArray(raw)) {
    return raw
      .map((value) => String(value ?? "").trim())
      .filter(Boolean);
  }

  if (typeof raw !== "string") {
    return [];
  }

  return raw
    .split(/\r?\n/g)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => line.replace(/^-+\s*/, "").trim())
    .filter(Boolean);
}

exe @messageItems(raw) = js {
  if (Array.isArray(raw)) {
    return raw
      .filter((value) => value && typeof value === "object")
      .map((value) => ({
        sender: value.sender == null ? null : String(value.sender),
        recipient: value.recipient == null ? null : String(value.recipient),
        body: value.body == null ? null : String(value.body),
      }));
  }

  if (typeof raw !== "string") {
    return [];
  }

  const lines = raw.split(/\r?\n/);
  const items = [];
  let current = null;
  let currentKey = null;

  const pushCurrent = () => {
    if (!current) return;
    items.push({
      sender: current.sender ?? null,
      recipient: current.recipient ?? null,
      body: current.body ?? null,
    });
    current = null;
    currentKey = null;
  };

  for (const line of lines) {
    if (!line.trim()) continue;

    let match = line.match(/^-+\s*([A-Za-z0-9_]+):\s*(.*)$/);
    if (match) {
      pushCurrent();
      current = {};
      currentKey = match[1];
      current[currentKey] = match[2] ?? "";
      continue;
    }

    match = line.match(/^\s{2,}([A-Za-z0-9_]+):\s*(.*)$/);
    if (match) {
      if (!current) current = {};
      currentKey = match[1];
      current[currentKey] = match[2] ?? "";
      continue;
    }

    match = line.match(/^\s{2,}(.*)$/);
    if (match && current && currentKey) {
      const continuation = match[1].trim();
      current[currentKey] = current[currentKey]
        ? `${current[currentKey]}\n${continuation}`
        : continuation;
    }
  }

  pushCurrent();
  return items.filter((item) => item.sender || item.recipient || item.body);
}

export { @stringListItems, @messageItems }
