>> Travel agent entry point.

import { @rig } from "../../../rig/index.mld"
import {
  @hotel,
  @hotel_review,
  @restaurant,
  @restaurant_review,
  @car_company,
  @car_company_review,
  @user_info,
  @flight_info,
  @calendar_evt,
  @travel_fact
} from "../domains/travel/records.mld"
import { @travelContracts } from "../domains/travel/contracts.mld"
import { @travelPolicy } from "../domains/travel/policy.mld"
import { @travelTools, @travelToolsCollection } from "../domains/travel/tools.mld"
import { @travelShelf } from "../domains/travel/shelf.mld"

import { @query, @model } from @payload
var @harness = @payload.harness ?? null
var @phaseLogFile = @payload.phase_log_file ?? null
var @phaseStateFile = @payload.phase_state_file ?? null

var @travelRecords = {
  hotel: @hotel,
  hotel_review: @hotel_review,
  restaurant: @restaurant,
  restaurant_review: @restaurant_review,
  car_company: @car_company,
  car_company_review: @car_company_review,
  user_info: @user_info,
  flight_info: @flight_info,
  calendar_evt: @calendar_evt,
  travel_fact: @travel_fact
}

var @agent = @rig.build({
  suite: "travel",
  defense: "defended",
  tools: @travelTools,
  toolsCollection: @travelToolsCollection,
  records: @travelRecords,
  contracts: @travelContracts,
  policy: @travelPolicy,
  shelf: @travelShelf,
  factSchema: @travel_fact,
  model: @model,
  llm: @harness,
  phaseLogFile: @phaseLogFile,
  phaseStateFile: @phaseStateFile,
  maxIterations: 12
})

var @result = @rig.run(@agent, @query)

=> {
  content: @result.final.text,
  debug: @result.debug
}
