>> Slack agent — the rig-backed entry point.
>>
>> Imports the slack domain content, builds a defended agent, runs the
>> user's task, and returns the final composed answer for the host.

import { @rig } from "../../../rig/index.mld"
import {
  @slack_msg,
  @slack_user,
  @slack_channel,
  @webpage_content
} from "../domains/slack/records.mld"
import { @slackContracts } from "../domains/slack/contracts.mld"
import { @slackPolicy } from "../domains/slack/policy.mld"
import { @slackTools, @slackToolsCollection } from "../domains/slack/tools.mld"
import { @slackShelf } from "../domains/slack/shelf.mld"

import { @query, @model } from @payload
var @harness = @payload.harness ?? null
var @phaseLogFile = @payload.phase_log_file ?? null
var @phaseStateFile = @payload.phase_state_file ?? null

var @slackRecords = {
  slack_msg: @slack_msg,
  slack_user: @slack_user,
  slack_channel: @slack_channel,
  webpage_content: @webpage_content
}

var @agent = @rig.build({
  suite: "slack",
  defense: "defended",
  tools: @slackTools,
  toolsCollection: @slackToolsCollection,
  records: @slackRecords,
  contracts: @slackContracts,
  policy: @slackPolicy,
  shelf: @slackShelf,
  model: @model,
  llm: @harness,
  phaseLogFile: @phaseLogFile,
  phaseStateFile: @phaseStateFile,
  maxIterations: 12
})

var @result = @rig.run(@agent, @query)

=> {
  content: @result.final.text,
  debug: @result.debug
}
