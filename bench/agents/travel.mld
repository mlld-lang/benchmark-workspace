>> Travel benchmark entrypoint on rig v2.
>>
>> Travel is the widest suite, but the entrypoint stays the same shape
>> as every other suite: catalog in, rig run, host-facing result out.

import { @synthesizedPolicy, @runPhaseLoop } from "../../rig/orchestration.mld"
import { @mergePlannerCatalog, @routeToolCatalog } from "../../rig/tooling.mld"
import { @records } from "../domains/travel/records.mld"
import {
  @tools,
  @get_user_information,
  @get_all_hotels_in_city,
  @get_hotels_prices,
  @get_rating_reviews_for_hotels,
  @get_hotels_address,
  @get_all_restaurants_in_city,
  @get_cuisine_type_for_restaurants,
  @get_restaurants_address,
  @get_rating_reviews_for_restaurants,
  @get_dietary_restrictions_for_all_restaurants,
  @get_contact_information_for_restaurants,
  @get_price_for_restaurants,
  @check_restaurant_opening_hours,
  @get_all_car_rental_companies_in_city,
  @get_car_types_available,
  @get_rating_reviews_for_car_rental,
  @get_car_fuel_options,
  @get_car_rental_address,
  @get_car_price_per_day,
  @search_calendar_events,
  @get_day_calendar_events,
  @get_flight_information,
  @create_calendar_event,
  @cancel_calendar_event,
  @reserve_hotel,
  @reserve_car_rental,
  @reserve_restaurant,
  @send_email
} from "../domains/travel/tools.mld"

import { @query, @model } from @payload

var @defense = @payload.defense ?? "defended"
var @basePolicy = when [
  @defense == "defended" => @synthesizedPolicy(@tools, null)
  * => null
]

var tools @runtimeToolsCollection = {
  get_user_information: { mlld: @get_user_information },
  get_all_hotels_in_city: {
    mlld: @get_all_hotels_in_city,
    expose: ["city"]
  },
  get_hotels_prices: {
    mlld: @get_hotels_prices,
    expose: ["hotel_names"]
  },
  get_rating_reviews_for_hotels: {
    mlld: @get_rating_reviews_for_hotels,
    expose: ["hotel_names"]
  },
  get_hotels_address: {
    mlld: @get_hotels_address,
    expose: ["hotel_name"]
  },
  get_all_restaurants_in_city: {
    mlld: @get_all_restaurants_in_city,
    expose: ["city"]
  },
  get_cuisine_type_for_restaurants: {
    mlld: @get_cuisine_type_for_restaurants,
    expose: ["restaurant_names"]
  },
  get_restaurants_address: {
    mlld: @get_restaurants_address,
    expose: ["restaurant_names"]
  },
  get_rating_reviews_for_restaurants: {
    mlld: @get_rating_reviews_for_restaurants,
    expose: ["restaurant_names"]
  },
  get_dietary_restrictions_for_all_restaurants: {
    mlld: @get_dietary_restrictions_for_all_restaurants,
    expose: ["restaurant_names"]
  },
  get_contact_information_for_restaurants: {
    mlld: @get_contact_information_for_restaurants,
    expose: ["restaurant_names"]
  },
  get_price_for_restaurants: {
    mlld: @get_price_for_restaurants,
    expose: ["restaurant_names"]
  },
  check_restaurant_opening_hours: {
    mlld: @check_restaurant_opening_hours,
    expose: ["restaurant_names"]
  },
  get_all_car_rental_companies_in_city: {
    mlld: @get_all_car_rental_companies_in_city,
    expose: ["city"]
  },
  get_car_types_available: {
    mlld: @get_car_types_available,
    expose: ["company_name"]
  },
  get_rating_reviews_for_car_rental: {
    mlld: @get_rating_reviews_for_car_rental,
    expose: ["company_name"]
  },
  get_car_fuel_options: {
    mlld: @get_car_fuel_options,
    expose: ["company_name"]
  },
  get_car_rental_address: {
    mlld: @get_car_rental_address,
    expose: ["company_name"]
  },
  get_car_price_per_day: {
    mlld: @get_car_price_per_day,
    expose: ["company_name"]
  },
  search_calendar_events: {
    mlld: @search_calendar_events,
    expose: ["query", "date"],
    optional: ["date"]
  },
  get_day_calendar_events: {
    mlld: @get_day_calendar_events,
    expose: ["day"]
  },
  get_flight_information: {
    mlld: @get_flight_information,
    expose: ["departure_city", "arrival_city"]
  },
  create_calendar_event: {
    mlld: @create_calendar_event,
    expose: ["title", "start_time", "end_time", "description", "participants", "location"],
    optional: ["description", "location", "participants"]
  },
  cancel_calendar_event: {
    mlld: @cancel_calendar_event,
    expose: ["event_id"]
  },
  reserve_hotel: {
    mlld: @reserve_hotel,
    expose: ["hotel", "start_day", "end_day"]
  },
  reserve_car_rental: {
    mlld: @reserve_car_rental,
    expose: ["company", "start_time", "end_time"]
  },
  reserve_restaurant: {
    mlld: @reserve_restaurant,
    expose: ["restaurant", "start_time"]
  },
  send_email: {
    mlld: @send_email,
    expose: ["recipients", "subject", "body", "attachments", "cc", "bcc"],
    optional: ["attachments", "cc", "bcc"]
  }
}

var @plannerTools = @mergePlannerCatalog(@tools, @runtimeToolsCollection)

>> Build the runtime agent handle locally. Imported exe return values can
>> flatten executable-bearing members at module boundaries, so the suite
>> entrypoint assembles the full handle shape before calling the phase loop.
var @agent = {
  suite: "travel",
  defense: @defense,
  records: @records,
  tools: @tools,
  routedTools: @routeToolCatalog(@plannerTools),
  toolsCollection: @runtimeToolsCollection,
  model: @model,
  harness: @payload.harness ?? null,
  basePolicy: @basePolicy,
  overrides: {},
  stub: {},
  phaseLogFile: @payload.phase_log_file ?? null,
  phaseStateFile: @payload.phase_state_file ?? null,
  llmCallLogFile: @payload.llm_call_log_file ?? null,
  logLlmCalls: @payload.log_llm_calls ?? false,
  maxIterations: 40
}

var @result = @runPhaseLoop(@agent, @query)
var @plannerIterations = for @event in @result.phase_events when @event.event == "planner_iteration" => @event

=> {
  content: @result.final.text,
  debug: {
    execution_log: @result.execution_log,
    planner_iterations: @plannerIterations,
    phase_events: @result.phase_events,
    last_decision: @result.last_decision
  }
}
