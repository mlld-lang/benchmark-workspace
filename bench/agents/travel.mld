import { @rig } from "../../rig/index.mld"
import { @records } from "../domains/travel/records.mld"
import { @tools, @toolSets } from "../domains/travel/tools.mld"
import { @travelAddendum, @travelDeriveAddendum, @travelComposeAddendum } from "../domains/travel/prompts/planner-addendum.mld"
import { @travelAdviceClassifier } from "../domains/travel/classifiers/advice.mld"
import { @travelToolRouter } from "../domains/travel/classifiers/tool-router.mld"

import { @query, @model } from @payload

>> Classifier fan-out at task entry — one LLM call per classifier in
>> parallel. Output drives:
>>   - @adviceMode → routes compose through @dispatchAdvice with
>>     `role:advice` projection, structurally stripping `review_blob`
>>     and other untrusted-prose fields before any worker LLM call.
>>   - @toolFilter → narrows the planner's tool surface to the families
>>     the task actually needs.
>>
>> Classifiers are validated standalone (100% on synthetic tuning + 100%
>> on AgentDojo eval per bench/tests/travel-classifiers.mld). Dispatch +
>> projection mechanism verified zero-LLM (tests/suites/rig/advice-gate.mld)
>> and live-LLM at the compose level (bench/tests/travel-advice-gate-live.mld).
>> Recommendation-hijack defense verified end-to-end on AgentDojo IT6:
>> 0% ASR across UT3/5/11/17 × IT6.

var @cls = @rig.classify(@query, {
  tools: @travelToolRouter,
  advice: @travelAdviceClassifier
})

exe @flattenSets(setNames, sets) = js {
  if (!Array.isArray(setNames) || setNames.length === 0) return null;
  return setNames.flatMap(n => sets[n] || []);
}

var @defaultSets = ["hotel", "restaurant", "car", "flight", "calendar", "email", "user"]
var @resolvedSets = @cls.tools.tool_sets ?? @defaultSets
var @toolFilter = @flattenSets(@resolvedSets, @toolSets) ?? @flattenSets(@defaultSets, @toolSets)
var @adviceMode = @cls.advice.is_advice ?? false
var @workerModel = @payload.worker_model ?? @model

var @result = @rig.run({
  suite: "travel",
  defense: @payload.defense ?? "defended",
  records: @records,
  tools: @tools,
  model: @model,
  workerModel: @payload.worker_model,
  toolFilter: @toolFilter,
  adviceMode: @adviceMode,
  plannerAddendum: @travelAddendum,
  deriveAddendum: @travelDeriveAddendum,
  composeAddendum: @travelComposeAddendum,
  harness: @payload.harness,
  phaseLogFile: @payload.phase_log_file ?? null,
  phaseStateFile: @payload.phase_state_file ?? null,
  llmCallLogFile: @payload.llm_call_log_file ?? null,
  executionLogFile: @payload.execution_log_file ?? null,
  logLlmCalls: @payload.log_llm_calls ?? false,
  maxIterations: 25
}, @query)

=> {
  content: @result.mx.text,
  debug: @result.mx.debug
}
