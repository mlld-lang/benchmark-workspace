>> Banking benchmark entrypoint on rig v2.
>>
>> The suite file stays intentionally thin: records + tools in, final
>> composed result out. All orchestration, security, and lifecycle work
>> lives in rig.

import { @synthesizedPolicy, @runPhaseLoop } from "../../rig/orchestration.mld"
import { @mergePlannerCatalog, @routeToolCatalog } from "../../rig/tooling.mld"
import { @records } from "../domains/banking/records.mld"
import {
  @tools,
  @get_iban,
  @get_balance,
  @get_user_info,
  @get_most_recent_transactions,
  @get_scheduled_transactions,
  @read_file,
  @send_money,
  @schedule_transaction,
  @update_scheduled_transaction,
  @update_user_info,
  @update_password
} from "../domains/banking/tools.mld"

import { @query, @model } from @payload

var @defense = @payload.defense ?? "defended"
var @basePolicy = when [
  @defense == "defended" => @synthesizedPolicy(@tools, null)
  * => null
]

var tools @runtimeToolsCollection = {
  get_iban: { mlld: @get_iban },
  get_balance: { mlld: @get_balance },
  get_user_info: { mlld: @get_user_info },
  get_most_recent_transactions: {
    mlld: @get_most_recent_transactions,
    expose: ["n"]
  },
  get_scheduled_transactions: { mlld: @get_scheduled_transactions },
  read_file: {
    mlld: @read_file,
    expose: ["file_path"]
  },
  send_money: {
    mlld: @send_money,
    expose: ["recipient", "amount", "subject", "date"]
  },
  schedule_transaction: {
    mlld: @schedule_transaction,
    expose: ["recipient", "amount", "subject", "date", "recurring"]
  },
  update_scheduled_transaction: {
    mlld: @update_scheduled_transaction,
    expose: ["id", "recipient", "amount", "subject", "date", "recurring"],
    optional: ["amount", "subject", "date", "recurring"]
  },
  update_user_info: {
    mlld: @update_user_info,
    expose: ["first_name", "last_name", "street", "city"],
    optional: ["first_name", "last_name", "street", "city"]
  },
  update_password: {
    mlld: @update_password,
    expose: ["password"]
  }
}

var @plannerTools = @mergePlannerCatalog(@tools, @runtimeToolsCollection)

>> Build the runtime agent handle locally. Imported exe return values can
>> lose executable-bearing members like records and tool collections, so
>> the suite entrypoint assembles the final handle shape here before it
>> enters the phase loop.
var @agent = {
  suite: "banking",
  defense: @defense,
  records: @records,
  tools: @tools,
  routedTools: @routeToolCatalog(@plannerTools),
  toolsCollection: @runtimeToolsCollection,
  model: @model,
  harness: @payload.harness ?? null,
  basePolicy: @basePolicy,
  overrides: {},
  stub: {},
  phaseLogFile: @payload.phase_log_file ?? null,
  phaseStateFile: @payload.phase_state_file ?? null,
  llmCallLogFile: @payload.llm_call_log_file ?? null,
  logLlmCalls: @payload.log_llm_calls ?? false,
  maxIterations: 40
}

var @result = @runPhaseLoop(@agent, @query)
var @plannerIterations = for @event in @result.phase_events when @event.event == "planner_iteration" => @event

=> {
  content: @result.final.text,
  debug: {
    execution_log: @result.execution_log,
    planner_iterations: @plannerIterations,
    phase_events: @result.phase_events,
    last_decision: @result.last_decision
  }
}
