>> Workspace benchmark entrypoint on rig v2.
>>
>> Keep the suite surface thin: one authored domain catalog in, phase
>> loop out. Routing, policy synthesis, and live dispatch all run
>> directly from the same `@tools` catalog.

import { @rig } from "../../rig/index.mld"
import { @records } from "../domains/workspace/records.mld"
import { @tools } from "../domains/workspace/tools.mld"
import { @workspaceAddendum } from "../domains/workspace/prompts/planner-addendum.mld"
import { @query, @model } from @payload

var @result = @rig.run({
  suite: "workspace",
  defense: @payload.defense ?? "defended",
  records: @records,
  tools: @tools,
  model: @model,
  harness: @payload.harness,
  plannerAddendum: @workspaceAddendum,
  phaseLogFile: @payload.phase_log_file ?? null,
  phaseStateFile: @payload.phase_state_file ?? null,
  llmCallLogFile: @payload.llm_call_log_file ?? null,
  logLlmCalls: @payload.log_llm_calls ?? false,
  maxIterations: 25
}, @query)

=> {
  content: @result.mx.text,
  debug: @result.mx.debug
}
