>> Workspace adapter regression tests.
>>
>> These stay intentionally small and local: they pin the boundary
>> helpers that translate planner-facing literals into AgentDojo's
>> stricter runtime shapes, without requiring a live MCP server.

import { @isoDate, @asString } from "../domains/workspace/bridge.mld"

exe @status(ok) = when [
  @ok => "PASS"
  * => "FAIL"
]

exe @check(id, ok, detail) = [
  => {
    id: @id,
    status: @status(@ok),
    detail: @detail
  }
]

var @normalizedNaturalDate = @isoDate("April 18th, 2026")
var @normalizedIsoDate = @isoDate("2026-04-18")
var @normalizedNumericId = @asString(33)
var @workspaceRecordsValidated = run sh {
  mlld validate /Users/adam/mlld/clean/bench/domains/workspace/records.mld >/dev/null
  echo ok
}
var @workspaceToolsValidated = run sh {
  mlld validate /Users/adam/mlld/clean/bench/domains/workspace/tools.mld >/dev/null
  echo ok
}
var @workspaceAgentValidated = run sh {
  mlld validate /Users/adam/mlld/clean/bench/agents/workspace.mld >/dev/null
  echo ok
}
var @createCalendarCatalogBlock = run sh {
  sed -n '/  create_calendar_event: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @agentSendEmailBlock = run sh {
  sed -n '/  send_email: {/,/  },/p' /Users/adam/mlld/clean/bench/agents/workspace.mld
}
var @agentCreateCalendarBlock = run sh {
  sed -n '/  create_calendar_event: {/,/  },/p' /Users/adam/mlld/clean/bench/agents/workspace.mld
}
var @agentCreateFileBlock = run sh {
  sed -n '/  create_file: {/,/  },/p' /Users/adam/mlld/clean/bench/agents/workspace.mld
}
var @calendarInputRecordOk = @workspaceRecordsValidated == "ok" &&
  @workspaceToolsValidated == "ok" &&
  @createCalendarCatalogBlock.includes('inputs: @create_calendar_event_inputs') &&
  @createCalendarCatalogBlock.includes('labels: ["execute:w", "calendar:w", "exfil:send"]') &&
  @createCalendarCatalogBlock.includes('authorizable: "role:planner"') &&
  @createCalendarCatalogBlock.includes('description: "Create a calendar event.') &&
  @createCalendarCatalogBlock.includes('instructions: "`start_time` and `end_time` must use YYYY-MM-DD HH:MM."') &&
  !@createCalendarCatalogBlock.includes('operation: {')
var @calendarInputRecordDetail = @createCalendarCatalogBlock
var @agentRuntimeWriteAuthOk = @workspaceAgentValidated == "ok" &&
  @agentSendEmailBlock.includes('authorizable: "role:planner"') &&
  @agentSendEmailBlock.includes('controlArgs: ["recipients", "cc", "bcc"]') &&
  @agentCreateCalendarBlock.includes('authorizable: "role:planner"') &&
  @agentCreateCalendarBlock.includes('controlArgs: ["participants"]')
var @agentRuntimeWriteAuthDetail = `send_email:\n@agentSendEmailBlock\ncreate_calendar_event:\n@agentCreateCalendarBlock`
var @agentZeroControlWriteOk = @workspaceAgentValidated == "ok" &&
  @agentCreateFileBlock.includes('authorizable: "role:planner"') &&
  @agentCreateFileBlock.includes('controlArgs: []')
var @agentZeroControlWriteDetail = @agentCreateFileBlock

var @checks = [
  @check(
    "workspace-iso-date-natural-language",
    @normalizedNaturalDate == "2026-04-18",
    `got=@normalizedNaturalDate`
  ),
  @check(
    "workspace-iso-date-pass-through",
    @normalizedIsoDate == "2026-04-18",
    `got=@normalizedIsoDate`
  ),
  @check(
    "workspace-id-stringification",
    @normalizedNumericId == "33",
    `got=@normalizedNumericId`
  ),
  @check(
    "workspace-create-calendar-input-record",
    @calendarInputRecordOk,
    @calendarInputRecordDetail
  ),
  @check(
    "workspace-agent-runtime-write-auth",
    @agentRuntimeWriteAuthOk,
    @agentRuntimeWriteAuthDetail
  ),
  @check(
    "workspace-agent-runtime-zero-control-write",
    @agentZeroControlWriteOk,
    @agentZeroControlWriteDetail
  )
]

var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Workspace adapter regressions"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail`

if @fails.length > 0 [
  run sh { exit 1 }
]
