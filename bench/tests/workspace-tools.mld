>> Workspace adapter regression tests.
>>
>> Pin the cleaned-up suite shape: one authored domain catalog, one thin
>> agent that routes and dispatches through that same catalog, and no
>> runtime sidecar rebuilds.

import { @isoDate, @asString } from "../domains/workspace/bridge.mld"

exe @status(ok) = when [
  @ok => "PASS"
  * => "FAIL"
]

exe @check(id, ok, detail) = [
  => {
    id: @id,
    status: @status(@ok),
    detail: @detail
  }
]

var @normalizedNaturalDate = @isoDate("April 18th, 2026")
var @normalizedIsoDate = @isoDate("2026-04-18")
var @normalizedNumericId = @asString(33)

var @workspaceRecordsValidated = run sh {
  node /Users/adam/mlld/mlld/bin/mlld-wrapper.cjs validate /Users/adam/mlld/clean/bench/domains/workspace/records.mld >/dev/null && echo ok
}
var @workspaceAgentValidated = run sh {
  node /Users/adam/mlld/mlld/bin/mlld-wrapper.cjs validate /Users/adam/mlld/clean/bench/agents/workspace.mld >/dev/null && echo ok
}

var @workspaceToolsText = run sh {
  cat /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @workspaceAgentText = run sh {
  cat /Users/adam/mlld/clean/bench/agents/workspace.mld
}
var @workspaceRecordsText = run sh {
  cat /Users/adam/mlld/clean/bench/domains/workspace/records.mld
}

var @searchEmailsCatalogBlock = run sh {
  sed -n '/  search_emails: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @getEmailByIdCatalogBlock = run sh {
  sed -n '/  get_email_by_id: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @createCalendarCatalogBlock = run sh {
  sed -n '/  create_calendar_event: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @rescheduleCalendarCatalogBlock = run sh {
  sed -n '/  reschedule_calendar_event: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}
var @shareFileCatalogBlock = run sh {
  sed -n '/  share_file: {/,/  },/p' /Users/adam/mlld/clean/bench/domains/workspace/tools.mld
}

var @calendarInputRecordOk =
  @workspaceRecordsValidated == "ok" &&
  @workspaceRecordsText.includes('optional_benign: [cc, bcc]') &&
  @workspaceRecordsText.includes('optional_benign: [participants]') &&
  @workspaceRecordsText.includes('update: [new_start_time, new_end_time]') &&
  @createCalendarCatalogBlock.includes('inputs: @create_calendar_event_inputs') &&
  @createCalendarCatalogBlock.includes('labels: ["execute:w", "tool:w", "calendar:w", "exfil:send"]') &&
  @createCalendarCatalogBlock.includes('can_authorize: "role:planner"') &&
  !@createCalendarCatalogBlock.includes('operation: {') &&
  @rescheduleCalendarCatalogBlock.includes('inputs: @calendar_reschedule_inputs') &&
  @rescheduleCalendarCatalogBlock.includes('labels: ["execute:w", "tool:w", "calendar:w", "update:w"]') &&
  !@rescheduleCalendarCatalogBlock.includes('operation: {') &&
  @shareFileCatalogBlock.includes('inputs: @share_file_inputs') &&
  @shareFileCatalogBlock.includes('labels: ["execute:w", "tool:w", "exfil:send", "comm:w"]') &&
  !@shareFileCatalogBlock.includes('operation: {')
var @calendarInputRecordDetail = `records=@workspaceRecordsText\n\ncreate=@createCalendarCatalogBlock\n\nreschedule=@rescheduleCalendarCatalogBlock\n\nshare=@shareFileCatalogBlock`

var @workspaceSingleCatalogOk =
  @workspaceToolsText.includes('var tools @tools = {') &&
  !@workspaceToolsText.includes('var tools @toolsCollection = {') &&
  @workspaceToolsText.includes('mlld: @search_emails') &&
  @workspaceToolsText.includes('mlld: @get_email_by_id') &&
  @workspaceToolsText.includes('mlld: @get_current_day') &&
  @workspaceToolsText.includes('mlld: @get_file_by_id') &&
  !@workspaceToolsText.includes('kind: "read"') &&
  !@workspaceToolsText.includes('kind: "write"') &&
  !@workspaceToolsText.includes('semantics:') &&
  !@workspaceToolsText.includes('expose:') &&
  !@workspaceToolsText.includes('optional:')
var @workspaceSingleCatalogDetail = @workspaceToolsText

var @workspaceThinAgentOk =
  @workspaceAgentValidated == "ok" &&
  @workspaceAgentText.includes('tools: @tools') &&
  @workspaceAgentText.includes('routedTools: @routeToolCatalog(@tools)') &&
  !@workspaceAgentText.includes('toolsCollection: @toolsCollection') &&
  !@workspaceAgentText.includes('runtimeTools:') &&
  !@workspaceAgentText.includes('@mergePlannerCatalog') &&
  !@workspaceAgentText.includes('@runtimeToolOverrides') &&
  !@workspaceAgentText.includes('@workspaceMcp') &&
  !@workspaceAgentText.includes('exe @runtime_')
var @workspaceThinAgentDetail = @workspaceAgentText

exe @allChecks() = [
  => [
    @check(
      "workspace-iso-date-natural-language",
      @normalizedNaturalDate == "2026-04-18",
      `got=@normalizedNaturalDate`
    ),
    @check(
      "workspace-iso-date-pass-through",
      @normalizedIsoDate == "2026-04-18",
      `got=@normalizedIsoDate`
    ),
    @check(
      "workspace-id-stringification",
      @normalizedNumericId == "33",
      `got=@normalizedNumericId`
    ),
    @check(
      "workspace-create-calendar-input-record",
      @calendarInputRecordOk,
      @calendarInputRecordDetail
    ),
    @check(
      "BENCH-CAT-1",
      @workspaceSingleCatalogOk,
      @workspaceSingleCatalogDetail
    ),
    @check(
      "workspace-thin-agent",
      @workspaceThinAgentOk,
      @workspaceThinAgentDetail
    )
  ]
]

var @checks = @allChecks()

var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Workspace adapter regressions"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail`

if @fails.length > 0 [
  run sh { exit 1 }
]
