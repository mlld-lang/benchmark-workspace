>> Travel adapter regressions.
>>
>> AgentDojo's travel review and lookup tools can arrive as YAML-ish
>> string maps rather than plain objects. The clean adapter must
>> normalize those strings back into `{ name, value }` pairs so review
>> records and other keyed lookups survive coercion.

import { @namedPairs, @isoDate } from "../domains/travel/bridge.mld"

exe @status(ok) = when [
  @ok => "PASS"
  * => "FAIL"
]

exe @check(id, ok, detail) = [
  => {
    id: @id,
    status: @status(@ok),
    detail: @detail
  }
]

var @quotedReviewPairs = @namedPairs(`Le Marais Boutique: 'Rating: 4.2

  Reviews: Charming boutique hotel in the heart of Le Marais

  Beautifully decorated rooms with modern amenities'
Good Night: 'Rating: 3.1

  Reviews: Cheap but noisy'`)

var @blockScalarPairs = @namedPairs(`Le Marais Boutique: |-
  Rating: 4.2
  Reviews: Charming boutique hotel in the heart of Le Marais
Good Night: |-
  Rating: 3.1
  Reviews: Cheap but noisy`)

var @objectPairs = @namedPairs({
  "Le Marais Boutique": "Rating: 4.2\nReviews: Charming boutique hotel in the heart of Le Marais",
  "Good Night": "Rating: 3.1\nReviews: Cheap but noisy"
})

var @normalizedRangeStart = @isoDate("December 16th", "December 20th 2026")
var @normalizedRangeEnd = @isoDate("December 20th 2026", "December 16th")
var @normalizedIsoDate = @isoDate("2026-12-20", null)

var @travelToolsValidated = run sh {
  node /Users/adam/mlld/mlld/bin/mlld-wrapper.cjs validate /Users/adam/mlld/clean/bench/domains/travel/tools.mld >/dev/null && echo ok
}
var @travelToolsText = run sh {
  cat /Users/adam/mlld/clean/bench/domains/travel/tools.mld
}

var @quotedReviewPairsOk =
  @quotedReviewPairs.length == 2 &&
  @quotedReviewPairs[0].name == "Le Marais Boutique" &&
  @quotedReviewPairs[0].value.includes("Rating: 4.2") &&
  @quotedReviewPairs[0].value.includes("Reviews: Charming boutique hotel") &&
  @quotedReviewPairs[1].name == "Good Night" &&
  @quotedReviewPairs[1].value.includes("Rating: 3.1")

var @blockScalarPairsOk =
  @blockScalarPairs.length == 2 &&
  @blockScalarPairs[0].name == "Le Marais Boutique" &&
  @blockScalarPairs[0].value.includes("Rating: 4.2") &&
  @blockScalarPairs[1].name == "Good Night" &&
  @blockScalarPairs[1].value.includes("Cheap but noisy")

var @objectPairsOk =
  @objectPairs.length == 2 &&
  @objectPairs[0].name == "Le Marais Boutique" &&
  @objectPairs[0].value.includes("Rating: 4.2") &&
  @objectPairs[1].name == "Good Night"

var @travelToolsUseNormalizationOk =
  @travelToolsValidated == "ok" &&
  @travelToolsText.includes('import { @namedPairs, @isoDate } from "./bridge.mld"') &&
  @travelToolsText.includes('let @pairs = @namedPairs(@raw)') &&
  @travelToolsText.includes('let @startDay = @isoDate(@start_day, @end_day)') &&
  @travelToolsText.includes('let @endDay = @isoDate(@end_day, @start_day)')

var @isoDateNormalizationOk =
  @normalizedRangeStart == "2026-12-16" &&
  @normalizedRangeEnd == "2026-12-20" &&
  @normalizedIsoDate == "2026-12-20"

exe @allChecks() = [
  => [
    @check("travel-quoted-review-map-normalization", @quotedReviewPairsOk, `parsed=@quotedReviewPairs`),
    @check("travel-block-scalar-map-normalization", @blockScalarPairsOk, `parsed=@blockScalarPairs`),
    @check("travel-object-map-passthrough", @objectPairsOk, `parsed=@objectPairs`),
    @check("travel-date-range-normalization", @isoDateNormalizationOk, `start=@normalizedRangeStart end=@normalizedRangeEnd iso=@normalizedIsoDate`),
    @check("travel-tools-use-map-normalization", @travelToolsUseNormalizationOk, @travelToolsText)
  ]
]

var @checks = @allChecks()
var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Travel adapter regressions"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail`

if @fails.length > 0 [
  run sh { exit 1 }
]
