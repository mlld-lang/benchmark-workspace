import { @claude } from "@mlld/claude"
import { @opencode } from "../llm/lib/opencode/index.mld"

import {
  @mxEntry,
  @pairsToObject,
  @toolParamNames,
  @toolOptionalArgs,
  @toolPayloadArgs,
  @phaseToolNames
} from "./tooling.mld"
import {
  @resolveRefValue,
  @valueField,
  @stateHandleFromAddress,
  @parseRigHandle,
  @recordDefIdentityField,
  @recordDefFactFields,
  @recordDefFieldIsHandleType,
  @resolvedEntries,
  @resolvedEntryFieldValue
} from "./intent.mld"
import { @appendLlmCall, @serializeLifecycleJson } from "./lifecycle.mld"

>> Shared runtime helpers for the rig loop and per-phase workers.
>> Stage B (records-as-policy + bucket→shelf): state.resolved is gone;
>> resolved records live on @agent.plannerShelf as plain record-coerced
>> values with .mx.address.{record, key, string} for identity. State
>> carries extracted/derived/extract_sources. URL-promotion capabilities
>> live on @agent.urlCapShelf (c-bac4), not in state.

exe llm @llmCall(harness, prompt, config) = when [
  @harness == "stub" => @stubLlmResponse(@config)
  @harness == "opencode" => @opencode(@prompt, @config)
  * => @claude(@prompt, @config)
]

exe @defaultHarness(model) = when [
  @model == "stub" => "stub"
  @model.startsWith("openrouter/") => "opencode"
  @model.startsWith("togetherai/") => "opencode"
  @model.startsWith("cerebras/") => "opencode"
  @model.startsWith("groq/") => "opencode"
  @model.startsWith("fireworks-ai/") => "opencode"
  * => "claude"
]


>> Stub responses are already suite-authored plain data. Serialize one
>> selected fixture exactly once so flow tests exercise the real loop.
exe @stubLlmResponse(config) = js {
  const responses = config?.stubResponses || [];
  const index = Number.isInteger(config?.stubIndex) ? config.stubIndex : 0;
  const picked = responses[index] ?? responses[responses.length - 1] ?? {};
  return JSON.stringify(picked);
}

>> Provider SDK responses can surface session ids through several nested
>> metadata paths. Keep this extractor deliberately non-recursive in
>> mlld terms so provider-specific object graphs cannot trip the
>> interpreter's recursion guard before the agent does any work.
exe @normalizeSessionId(inputValue) = js {
  function normalized(value) {
    if (typeof value !== "string") return null;
    const trimmed = value.trim();
    if (trimmed === "" || trimmed === "undefined" || trimmed === "null") return null;
    return trimmed;
  }

  function pick(value, seen = new Set()) {
    const direct = normalized(value);
    if (direct) return direct;
    if (value == null || typeof value !== "object") return null;
    if (seen.has(value)) return null;
    seen.add(value);

    return (
      pick(value.session_id, seen) ||
      pick(value.sessionId, seen) ||
      pick(value.mx?.sessionId, seen) ||
      pick(value._mlld?.sessionId, seen) ||
      pick(value._mlld?.resume?.sessionId, seen) ||
      pick(value.resume?.sessionId, seen)
    );
  }

  return pick(inputValue);
}

exe @llmSessionId(raw) = [
  >> Raw model text is often just a string completion. Only look through
  >> explicit session-id carrier fields here; otherwise planner retries
  >> can accidentally try to resume from the prior JSON output.
  => when [
    !@raw.isDefined() => null
    @raw.session_id.isDefined() => @normalizeSessionId(@raw.session_id)
    @raw.sessionId.isDefined() => @normalizeSessionId(@raw.sessionId)
    @raw.mx.sessionId.isDefined() => @normalizeSessionId(@raw.mx.sessionId)
    @raw._mlld.sessionId.isDefined() => @normalizeSessionId(@raw._mlld.sessionId)
    @raw._mlld.resume.sessionId.isDefined() => @normalizeSessionId(@raw._mlld.resume.sessionId)
    @raw.resume.sessionId.isDefined() => @normalizeSessionId(@raw.resume.sessionId)
    * => null
  ]
]

exe @normalizePositiveInt(inputValue, fallbackValue) = js {
  const candidate = Number(inputValue);
  if (Number.isInteger(candidate) && candidate > 0) return candidate;
  const fallback = Number(fallbackValue);
  if (Number.isInteger(fallback) && fallback > 0) return fallback;
  return 1;
}

>> Diagnostic logs are intentionally plain JSON. They never participate
>> in authorization, so a JSON round-trip keeps the surface stable.
exe @sanitizeJson(inputValue) = js {
  return JSON.parse(JSON.stringify(inputValue ?? null));
}

exe @jsonSummary(inputValue) = js {
  function unwrap(value) {
    if (value == null || typeof value !== "object") return value;
    if (
      value.mx &&
      typeof value.mx === "object" &&
      Object.prototype.hasOwnProperty.call(value.mx, "data")
    ) {
      return unwrap(value.mx.data);
    }
    if (
      Object.prototype.hasOwnProperty.call(value, "type") &&
      Object.prototype.hasOwnProperty.call(value, "text") &&
      Object.prototype.hasOwnProperty.call(value, "data")
    ) {
      return unwrap(value.data);
    }
    return value;
  }

  try {
    const sanitized = JSON.parse(JSON.stringify(unwrap(inputValue ?? null)));
    return JSON.stringify(sanitized, null, 2);
  } catch (_error) {
    return String(inputValue ?? "");
  }
}

exe @llmLogText(inputValue) = [
  let @text = @stringValue(@inputValue)
  => when [
    @text == null => null
    !@text.isDefined() => null
    @text.length > 20000 => `@text.slice(0, 20000)
...[truncated @text.length chars]`
    * => @text
  ]
]

exe @llmParsedSummary(parsed) = when [
  @parsed == null => null
  !@parsed.isDefined() => null
  @typeof(@parsed) == "string" => @llmLogText(@parsed)
  @parsed.text.isDefined() => @llmLogText(@parsed.text)
  * => {
    status: @parsed.status ?? null,
    schema_name: @parsed.schema_name ?? null,
    name: @parsed.name ?? null,
    provenance: @parsed.provenance ?? null,
    summary: @parsed.summary ?? null,
    count: @parsed.count ?? null,
    record_type: @parsed.record_type ?? null
  }
]

exe @llmCallEntry(phase, prompt, raw, parsed, sessionId, extra) = [
  >> LLM debug entries must stay bounded. Structured raw values can carry
  >> `.mx.sessions`, and parsed worker payloads can carry full tool results.
  >> Log text/previews only; execution logs and opencode sessions remain the
  >> source of truth for deep transcript inspection.
  => {
    phase: @phase,
    prompt: @llmLogText(@prompt),
    raw: @llmLogText(@raw),
    parsed: @llmParsedSummary(@parsed),
    call_kind: @extra.call_kind ?? null,
    session_id: @normalizeSessionId(@sessionId),
    outer_planner_session_id: @normalizeSessionId(@extra.outer_planner_session_id),
    inner_worker_session_id: @normalizeSessionId(@extra.inner_worker_session_id),
    extra: @extra ?? {}
  }
]

exe @appendLlmDebug(agent, entry) = [
  if !@agent.logLlmCalls [ => false ]
  if !@agent.llmCallLogFile.isDefined() [ => false ]
  if !@entry.isDefined() [ => false ]
  @appendLlmCall(@agent.llmCallLogFile, @serializeLifecycleJson(@entry))
  => true
]

exe @structuredData(inputValue) = when [
  @inputValue.mx.data.isDefined() => @inputValue.mx.data
  @inputValue.data.isDefined() => @inputValue.data
  * => @inputValue
]

exe @stringValue(inputValue) = when [
  @inputValue.isDefined() => `@structuredData(@inputValue)`
  * => null
]

exe @arrayItems(values) = when [
  @values.mx.data.items.isDefined() => @values.mx.data.items
  @values.mx.data.length.isDefined() => @values.mx.data
  @values.data.items.isDefined() => @values.data.items
  @values.data.length.isDefined() => @values.data
  @values.items.isDefined() => @values.items
  @typeof(@values) == "array" => @values
  @typeof(@values) == "object" && @values.length.isDefined() && @values.join.isDefined() => @values.slice(0)
  * => []
]

exe @plainObjectKeys(inputValue) = [
  let @target = @structuredData(@inputValue)
  let @mxKeys = for @entry in (@target.mx.entries ?? []) => @entry[0]
  => when [
    @mxKeys.length > 0 => @mxKeys
    @typeof(@target) == "object" => for @entryKey, @entryValue in @target => @entryKey
    * => []
  ]
]

exe @replaceObjectField(objectValue, key, replacementValue) = [
  let @target = @structuredData(@objectValue)
  let @pairs = for @entryKey, @entryValue in @target when @entryKey != @key => {
    key: @entryKey,
    value: @entryValue
  }
  => @pairsToObject(@pairs.concat([{ key: @key, value: @replacementValue }]))
]

exe @recordMeta(recordDef, key) = [
  => @mxEntry(@recordDef.mx.entries, @key)
]

exe @recordTypeName(recordDef) = [
  => @recordMeta(@recordDef, "name")
]

exe @recordKeyField(recordDef) = [
  => @recordMeta(@recordDef, "key")
]

exe @recordFieldDefs(recordDef) = [
  => @recordMeta(@recordDef, "fields") ?? []
]

exe @recordFieldNames(recordDef) = [
  => for @field in @recordFieldDefs(@recordDef) => @field.name
]

exe @nativeRecordFieldValue(recordValue, fieldName) = [
  let @fieldKey = `@fieldName`
  => when [
    @recordValue.mx.data[@fieldKey].isDefined() => @recordValue.mx.data[@fieldKey]
    @recordValue.data[@fieldKey].isDefined() => @recordValue.data[@fieldKey]
    @recordValue[@fieldKey].isDefined() => @recordValue[@fieldKey]
    * => null
  ]
]

>> Records bundle filtered to entries the planner shelf can store. Tool
>> input records (direction="hybrid") are validate-only schemas for write
>> tool dispatch — the shelf primitive rejects them at decl time. Output
>> records (direction="output") are the write/store surface.
exe @shelfRecords(records) = [
  let @keys = for @rt, @rd in (@records ?? {}) [
    let @entries = @rd.mx.entries ?? []
    let @dir = for @e in @entries when @e[0] == "direction" => @e[1]
    => when [
      @dir.length > 0 && @dir[0] == "output" => { key: @rt, value: @rd }
      * => null
    ]
  ]
  let @valid = for @entry in @keys when @entry => @entry
  => @pairsToObject(@valid)
]

>> Look up a resolved record on the planner shelf by handle. The handle is
>> the rig wire-format (`r_<rt>_<key>`); we parse it back to the shelf's
>> stable address and use `.byAddress()` for O(1) lookup. Returns null when
>> the handle is malformed, the slot does not exist, or no record matches.
exe @shelfLookupByHandle(agent, recordName, handle) = [
  if !@agent.plannerShelf.isDefined() [ => null ]
  let @slot = @agent.plannerShelf[@recordName]
  if !@slot.isDefined() [ => null ]
  let @addr = @parseRigHandle(@handle)
  if @addr == null [ => null ]
  if @addr.record != @recordName [ => null ]
  => @slot.byAddress(@addr)
]

>> Read all records of a given type from the planner shelf. Returns an
>> empty array when the slot does not exist or has no entries.
exe @shelfReadAll(agent, recordName) = [
  if !@agent.plannerShelf.isDefined() [ => [] ]
  let @slot = @agent.plannerShelf[@recordName]
  if !@slot.isDefined() [ => [] ]
  => @shelf.read(@slot)
]

>> Coerce raw tool output into an array of record-coerced values, write
>> each to the planner shelf, and return them. The shelf's field-level
>> merge by .mx.key collapses same-key writes (m-shelf-wildcard); callers
>> see the coerced records back so they can mint Path-A handles and build
>> result summaries without a second shelf read.
>>
>> @rawValue may be a single record-shape object or an array. Coercion
>> happens via `as record @recordDef` per item.
exe @writeRecordsToShelf(agent, recordType, recordDef, rawValue) = [
  let @items = when [
    @typeof(@rawValue) == "array" => @rawValue
    @rawValue.isDefined() && @rawValue != null => [@rawValue]
    * => []
  ]
  if @items.length == 0 [ => [] ]
  if !@agent.plannerShelf.isDefined() [ => [] ]
  let @slot = @agent.plannerShelf[@recordType]
  if !@slot.isDefined() [ => [] ]
  let @coercedItems = for @v in @items [
    let @c = @v as record @recordDef
    => @c
  ]
  let @written = for @c in @coercedItems [
    let @w = @shelf.write(@slot, @c)
    => @c
  ]
  => @written
]

>> Synthesize the rig wire-format handles for a list of shelf-coerced
>> records.
exe @recordHandles(records) = [
  let @items = @arrayItems(@records)
  => for @r in @items => @stateHandleFromAddress(@r)
]

exe @previewFields(inputValue) = when [
  !@inputValue.isDefined() => []
  @inputValue.data.items.isDefined() &&
    @typeof(@inputValue.data.items) == "array" &&
    @inputValue.data.items.length > 0 &&
    @typeof(@inputValue.data.items[0]) == "object" => @plainObjectKeys(@inputValue.data.items[0])
  @inputValue.data.isDefined() &&
    @typeof(@inputValue.data) == "array" &&
    @inputValue.data.length > 0 &&
    @typeof(@inputValue.data[0]) == "object" => @plainObjectKeys(@inputValue.data[0])
  @inputValue.items.isDefined() &&
    @typeof(@inputValue.items) == "array" &&
    @inputValue.items.length > 0 &&
    @typeof(@inputValue.items[0]) == "object" => @plainObjectKeys(@inputValue.items[0])
  @typeof(@inputValue) == "array" &&
    @inputValue.length > 0 &&
    @typeof(@inputValue[0]) == "object" => @plainObjectKeys(@inputValue[0])
  @inputValue.data.isDefined() && @typeof(@inputValue.data) == "object" => @plainObjectKeys(@inputValue.data)
  @typeof(@inputValue) == "object" => @plainObjectKeys(@inputValue)
  * => []
]

>> @nullFields — companion to @previewFields. Returns the keys whose value
>> is explicitly null (or undefined) at the same projection level previewFields
>> walks. Used by extract/derive to surface to the planner which schema-declared
>> fields the worker did not fill. The planner reads `null_fields` on the
>> result and pivots (use a different source class for that arg, fetch a
>> richer source, or skip the arg) without having to bounce off rehearse.
exe @nullFields(inputValue) = when [
  !@inputValue.isDefined() => []
  @inputValue.data.items.isDefined() &&
    @typeof(@inputValue.data.items) == "array" &&
    @inputValue.data.items.length > 0 &&
    @typeof(@inputValue.data.items[0]) == "object" => for @k, @v in @inputValue.data.items[0] when @v == null => `@k`
  @inputValue.data.isDefined() &&
    @typeof(@inputValue.data) == "array" &&
    @inputValue.data.length > 0 &&
    @typeof(@inputValue.data[0]) == "object" => for @k, @v in @inputValue.data[0] when @v == null => `@k`
  @inputValue.items.isDefined() &&
    @typeof(@inputValue.items) == "array" &&
    @inputValue.items.length > 0 &&
    @typeof(@inputValue.items[0]) == "object" => for @k, @v in @inputValue.items[0] when @v == null => `@k`
  @typeof(@inputValue) == "array" &&
    @inputValue.length > 0 &&
    @typeof(@inputValue[0]) == "object" => for @k, @v in @inputValue[0] when @v == null => `@k`
  @inputValue.data.isDefined() && @typeof(@inputValue.data) == "object" => for @k, @v in @inputValue.data when @v == null => `@k`
  @typeof(@inputValue) == "object" => for @k, @v in @inputValue when @v == null => `@k`
  * => []
]

exe @displayModeKeys(role) = [
  let @plainRole = when [
    @role == "role:planner" => "planner"
    @role == "role:worker" => "worker"
    @role == "role:advice" => "advice"
    * => @role
  ]
  => [@role, @plainRole]
]

exe @recordDisplayMode(recordDef, role) = [
  let @display = @recordMeta(@recordDef, "read")
  let @modeKeys = @displayModeKeys(@role)
  => when [
    !@display.isDefined() => []
    @display.kind == "named" && @display.modes[@modeKeys[0]].isDefined() => @display.modes[@modeKeys[0]]
    @display.kind == "named" && @display.modes[@modeKeys[1]].isDefined() => @display.modes[@modeKeys[1]]
    @display.kind == "named" && @display.modes.default.isDefined() => @display.modes.default
    @display.kind == "legacy" && @display.entries.isDefined() => @display.entries
    @typeof(@display) == "array" => @display
    * => []
  ]
]

exe @displayEntry(modeEntry) = when [
  @typeof(@modeEntry) == "string" => { kind: "field", field: @modeEntry }
  @modeEntry.ref.isDefined() => { kind: "field", field: @modeEntry.ref }
  @modeEntry.mask.isDefined() => { kind: "mask", field: @modeEntry.mask }
  @modeEntry.handle.isDefined() => { kind: "handle", field: @modeEntry.handle }
  @modeEntry.field.isDefined() => { kind: @modeEntry.kind ?? "field", field: @modeEntry.field }
  * => null
]

exe @maskPreview(maskedValue) = [
  if !@maskedValue.isDefined() [ => null ]
  if @typeof(@maskedValue) == "array" [ => `[masked:@maskedValue.length]` ]
  if @typeof(@maskedValue) == "string" [
    => when [
      @maskedValue.length <= 3 => "***"
      * => `@maskedValue.slice(0, 2)***`
    ]
  ]
  => "[masked]"
]

>> Project a single resolved record through its read mode for the given
>> role. Stage B: entry is the plain record (with .mx.address), not an
>> envelope. Field access goes through @valueField which preserves
>> wrappers.
exe @projectResolvedEntry(recordType, recordDef, recordValue, role) = [
  let @mode = @recordDisplayMode(@recordDef, @role)
  let @plainHandle = @stateHandleFromAddress(@recordValue)
  let @pairs = for @modeEntry in @mode [
    let @display = @displayEntry(@modeEntry)
    if !@display [ => null ]
    let @value = @valueField(@recordValue, @display.field)
    if !@value.isDefined() || @value == null [ => null ]
    let @projectedValue = when [
      @display.kind == "mask" => @maskPreview(@value)
      @display.kind == "handle" => @plainHandle
      * => @value
    ]
    => {
      key: @display.field,
      value: @projectedValue
    }
  ]
  let @visible = for @pair in @pairs when @pair => @pair
  let @visibleFields = @pairsToObject(@visible)
  => {
    handle: @plainHandle,
    record: @recordType,
    ...@visibleFields
  }
]

>> Project all resolved records of every declared type from the planner
>> shelf into role-scoped summaries. Replaces the bucket-walk version.
>> Per-key projection caching is handled by the shelf's
>> projection_cache: ["role:planner"] attribute.
exe @projectResolvedSummary(agent, role) = [
  if !@agent.records.isDefined() [ => {} ]
  let @pairs = for @recordType, @recordDef in @agent.records [
    let @records = @shelfReadAll(@agent, @recordType)
    let @projected = for @r in @records => @projectResolvedEntry(@recordType, @recordDef, @r, @role)
    => {
      key: @recordType,
      value: @projected
    }
  ]
  => @pairsToObject(@pairs)
]

>> Named extract/derive entries keep full native values in state for
>> worker-side ref resolution. Planner summaries should use the schema's
>> display projection when the named result is record-backed, and fall
>> back to attestation-only when no safe display surface exists.
exe @projectNamedRecordFields(recordDef, namedValue, role) = [
  let @mode = @recordDisplayMode(@recordDef, @role)
  let @pairs = for @modeEntry in @mode [
    let @display = @displayEntry(@modeEntry)
    if !@display [ => null ]
    let @value = @nativeRecordFieldValue(@namedValue, @display.field)
    if !@value.isDefined() [ => null ]
    >> Named state does not mint its own handles. If a record uses the
    >> `handle` projection form here, omit that field rather than
    >> inventing a handle-like surrogate for planner-visible state.
    let @projectedValue = when [
      @display.kind == "mask" => @maskPreview(@value)
      @display.kind == "handle" => null
      * => @value
    ]
    if !@projectedValue.isDefined() [ => null ]
    => {
      key: @display.field,
      value: @projectedValue
    }
  ]
  let @visible = for @pair in @pairs when @pair => @pair
  => @pairsToObject(@visible)
]

exe @projectNamedEntry(records, entry, role) = [
  let @named = @structuredData(@entry)
  let @recordDef = when [
    @named.schema_name.isDefined() && @records[@named.schema_name].isDefined() => @records[@named.schema_name]
    * => null
  ]
  let @fieldNames = @previewFields(@named.value)
  let @projectedFields = when [
    @recordDef => @projectNamedRecordFields(@recordDef, @named.value, @role)
    * => {}
  ]
  >> Reserved attestation keys stay top-level. Any planner-visible
  >> record-display fields live under `display` so suite-defined record
  >> fields cannot collide with the framework envelope.
  => when [
    @role == "role:planner" && @plainObjectKeys(@projectedFields).length > 0 => {
      provenance: @named.provenance,
      schema_name: @named.schema_name ?? null,
      fields: @fieldNames,
      selection_refs: @named.selection_refs ?? [],
      display: @projectedFields
    }
    @role == "role:planner" => {
      provenance: @named.provenance,
      schema_name: @named.schema_name ?? null,
      fields: @fieldNames,
      selection_refs: @named.selection_refs ?? []
    }
    * => {
      provenance: @named.provenance,
      schema_name: @named.schema_name ?? null,
      preview_fields: @named.preview_fields ?? @previewFields(@named.value),
      value: @named.value,
      selection_refs: @named.selection_refs ?? []
    }
  ]
]

exe @projectNamedState(records, stateMap, role) = [
  let @bucket = @structuredData(@stateMap)
  let @pairs = for @name in @plainObjectKeys(@bucket) => {
    key: @name,
    value: @projectNamedEntry(@records, @bucket[@name], @role)
  }
  => @pairsToObject(@pairs)
]

exe @plannerVisibleState(agent, state) = [
  => {
    resolved: @projectResolvedSummary(@agent, "role:planner"),
    extracted: @projectNamedState(@agent.records ?? {}, @state.extracted, "role:planner"),
    derived: @projectNamedState(@agent.records ?? {}, @state.derived, "role:planner")
  }
]

exe @workerStateSummary(agent, state) = [
  => {
    resolved: @projectResolvedSummary(@agent, "role:worker"),
    extracted: @projectNamedState(@agent.records ?? {}, @state.extracted, "role:worker"),
    derived: @projectNamedState(@agent.records ?? {}, @state.derived, "role:worker")
  }
]

>> Advice-mode state summary. Projects through `role:advice` so records'
>> data.untrusted fields (e.g. @hotel_review.review_blob) are dropped
>> structurally before any worker LLM call sees the state. This is the
>> primary structural defense against recommendation-hijack attacks per
>> how-we-defend-advice.md — review prose can carry injection text;
>> rating, price, and other fact-classified or trusted-data fields
>> cannot be planted by an attacker.
exe @adviceVisibleState(agent, state) = [
  => {
    resolved: @projectResolvedSummary(@agent, "role:advice"),
    extracted: @projectNamedState(@agent.records ?? {}, @state.extracted, "role:advice"),
    derived: @projectNamedState(@agent.records ?? {}, @state.derived, "role:advice")
  }
]

>> URL-promotion capabilities used to live in state.capabilities.url_refs
>> (c-be06 era). After c-bac4 they live on @agent.urlCapShelf — a typed
>> shelf bounded to @url_capability. State no longer carries capabilities.
exe @rigState(extracted, derived, extractSources) = [
  => {
    extracted: @extracted,
    derived: @derived,
    extract_sources: @extractSources
  }
]

exe @emptyState() = [
  => {
    extracted: {},
    derived: {},
    extract_sources: {}
  }
]

exe @updateNamedState(state, bucket, name, entry) = [
  let @currentBucket = @structuredData(@state[@bucket])
  let @nextBucket = @replaceObjectField(@currentBucket, @name, @entry)
  => when [
    @bucket == "extracted" => @rigState(
      @nextBucket,
      @structuredData(@state.derived),
      @structuredData(@state.extract_sources)
    )
    @bucket == "derived" => @rigState(
      @structuredData(@state.extracted),
      @nextBucket,
      @structuredData(@state.extract_sources)
    )
    * => @state
  ]
]

exe @updateExtractSources(state, sourceKey, extractName) = [
  let @sources = @structuredData(@state.extract_sources)
  let @nextSources = @replaceObjectField(@sources, @sourceKey, @extractName)
  => @rigState(
    @structuredData(@state.extracted),
    @structuredData(@state.derived),
    @nextSources
  )
]

exe @isStructuredRef(inputValue) = when [
  @typeof(@inputValue) == "object" && @inputValue.source.isDefined() => true
  @typeof(@inputValue) == "object" && @inputValue.data.source.isDefined() => true
  @typeof(@inputValue) == "object" && @inputValue.mx.data.source.isDefined() => true
  * => false
]

exe @nonComposeDecisionArgIssues(decision) = [
  let @phase = @decision.phase ?? null
  if !@phase.isDefined() || @phase == "compose" || @phase == "blocked" || @phase == "done" [ => [] ]
  let @argIssues = for @argName, @argValue in (@decision.args ?? {}) [
    => when [
      @typeof(@argValue) == "array" => for @item in @argValue when !@isStructuredRef(@item) => { field: @argName, error: "non_compose_arg_requires_structured_ref" }
      !@isStructuredRef(@argValue) => [{ field: @argName, error: "non_compose_arg_requires_structured_ref" }]
      * => []
    ]
  ]
  let @issues = loop(1000) [
    let @ctx = @input ?? { index: 0, values: [] }
    if @ctx.index >= @argIssues.length [ done @ctx.values ]
    continue {
      index: @ctx.index + 1,
      values: @ctx.values.concat(@argIssues[@ctx.index] ?? [])
    }
  ]
  let @extractIssue = when [
    @phase == "extract" && @decision.tool.isDefined() => []
    @phase == "extract" && !@isStructuredRef(@decision.source) => [{ field: "source", error: "extract_source_requires_structured_ref" }]
    * => []
  ]
  let @deriveIssue = when [
    @phase == "derive" => for @source in (@decision.sources ?? []) when !@isStructuredRef(@source) => { field: "sources", error: "derive_sources_require_structured_refs" }
    * => []
  ]
  => @issues.concat(@extractIssue).concat(@deriveIssue)
]

exe @resolveDispatchArgValue(agent, state, argValue) = [
  => when [
    @typeof(@argValue) == "array" => [
      let @items = for @item in @argValue => @resolveDispatchArgValue(@agent, @state, @item)
      let @errors = for @entry in @items when !@entry.ok => @entry
      if @errors.length > 0 [ => { ok: false, error: "resolve_arg_ref_failed", issues: @errors } ]
      let @values = for @entry in @items => @entry.value
      => { ok: true, value: @values }
    ]
    @isStructuredRef(@argValue) => @resolveRefValue(@agent, @state, @argValue)
    * => { ok: true, value: @argValue }
  ]
]

exe @resolveDispatchArgs(agent, state, args) = [
  let @results = for @argName, @argValue in (@args ?? {}) => {
    key: @argName,
    result: @resolveDispatchArgValue(@agent, @state, @argValue)
  }
  let @errors = for @entry in @results when !@entry.result.ok => {
    arg: @entry.key,
    error: @entry.result.error ?? "resolve_arg_ref_failed",
    detail: @entry.result
  }
  if @errors.length > 0 [ => { ok: false, error: "resolve_arg_ref_failed", issues: @errors } ]
  let @pairs = for @entry in @results => {
    key: @entry.key,
    value: @entry.result.value
  }
  => { ok: true, args: @pairsToObject(@pairs) }
]

exe @validateToolCallArgs(entry, args) = [
  >> Comparison here is purely on metadata names. Cast the arg and param
  >> labels to plain strings so `includes()` behaves consistently.
  let @paramNames = for @paramName in @toolParamNames(@entry) => `@paramName`
  let @optionalArgs = for @optionalArg in @toolOptionalArgs(@entry) => `@optionalArg`
  if @paramNames.length == 0 [ => { ok: true } ]
  if @paramNames.length == 1 && @typeof(@args) != "object" [ => { ok: true } ]
  >> Without an input record, we can't distinguish required from optional
  >> params — the exe handles missing args via @exists(). Skip validation.
  let @hasInputRecord = @entry.inputs.isDefined()
  if !@hasInputRecord [ => { ok: true } ]
  let @argKeys = for @argKey in @plainObjectKeys(@args) => `@argKey`
  let @missing = for @paramName in @paramNames when !@argKeys.includes(@paramName) && !@optionalArgs.includes(@paramName) => @paramName
  let @extra = for @argKey in @argKeys when !@paramNames.includes(@argKey) => @argKey
  => when [
    @missing.length == 0 && @extra.length == 0 => { ok: true }
    * => {
      ok: false,
      error: "tool_arg_validation_failed",
      summary: {
        missing: @missing,
        extra: @extra
      }
    }
  ]
]

exe recursive @callToolWithOptionalPolicy(toolEntry, toolsCollection, toolName, args, policyValue) = [
  let @toolKey = `@toolName`
  let @entry = @toolEntry
  let @argCheck = @validateToolCallArgs(@entry, @args)
  if !@argCheck.ok [ => { error: @argCheck.error, summary: @argCheck.summary, tool: @toolKey } ]
  let @hasInputRecord = @entry.inputs.isDefined()
  let @paramNames = @toolParamNames(@entry)
  let @callableEntry = @toolsCollection[@toolKey].isDefined()
  let @exeParamCount = @typeof(@entry.mlld) == "executable" ? @entry.mlld.mx.params.length : 0
  >> mlld auto-unpacks an object into positional params only when every
  >> declared param is present as a key (partial objects collapse to a
  >> single positional first arg — probe-labeled-exe-unpack.mld). For
  >> multi-param read tools called with a subset of declared params (e.g.
  >> workspace.search_calendar_events(query, date) with only query),
  >> normalize the dispatch args so each declared param is present,
  >> defaulting missing ones to null. Skip for input-record-bearing write
  >> tools — those have validate:"strict" on the record and would reject
  >> the synthesized null fields. Use a fresh name (@dispatchArgs) rather
  >> than rebinding @args (a function parameter).
  let @dispatchArgs = when [
    @typeof(@args) != "object" => @args
    @paramNames.length <= 1 => @args
    @hasInputRecord => @args
    * => [
      let @existingPairs = for @key in @plainObjectKeys(@args) => { key: @key, value: @args[@key] }
      let @missingPairs = for @param in @paramNames when !@args[@param].isDefined() => { key: `@param`, value: null }
      => @pairsToObject(@existingPairs.concat(@missingPairs))
    ]
  ]
  let @hasArgs = @typeof(@dispatchArgs) == "object" && @plainObjectKeys(@dispatchArgs).length > 0

  let @hasPayloadArgs = @hasInputRecord && @toolPayloadArgs(@entry).length > 0
  >> Collection-callable dispatch unpacks an object-shaped @args into the
  >> exe's positional params (verified probe-collection-unpack.mld). Direct
  >> exe call via @entry.mlld does not auto-unpack on policy-redesign, so
  >> multi-param read tools (e.g. workspace.search_calendar_events(query, date))
  >> would receive the entire args object as their first param. Route any
  >> multi-param exe with a callable entry through the collection form,
  >> input-record-bearing or not. Input-record write tools with payload args
  >> still go positional so payload values flow as named args (matching the
  >> existing @hasPayloadArgs branch shape).
  if @exeParamCount > 1 && @callableEntry && !@hasPayloadArgs [
    => when [
      @policyValue.isDefined() && @hasArgs => @toolsCollection[@toolKey](@dispatchArgs) with { policy: @policyValue }
      @policyValue.isDefined() => @toolsCollection[@toolKey]() with { policy: @policyValue }
      @hasArgs => @toolsCollection[@toolKey](@dispatchArgs)
      * => @toolsCollection[@toolKey]()
    ]
  ]

  >> Positional dispatch for single-param and non-collection tools.
  >> m-d9e6 enables @entry.mlld as field access; m-e091 enables calling
  >> the result from a local without false circular-ref detection.
  let @directExe = @entry.mlld
  if @typeof(@directExe) != "executable" [ => { error: "tool_missing_executable", tool: @toolKey } ]
  => when [
    @policyValue.isDefined() && @hasArgs => @directExe(@dispatchArgs) with { policy: @policyValue }
    @policyValue.isDefined() && @paramNames.length == 0 => @directExe() with { policy: @policyValue }
    @policyValue.isDefined() => @directExe(@dispatchArgs) with { policy: @policyValue }
    @hasArgs => @directExe(@dispatchArgs)
    @paramNames.length == 0 => @directExe()
    * => @directExe(@dispatchArgs)
  ]
]

exe recursive @callTool(toolEntry, toolsCollection, toolName, args) = [
  => @callToolWithOptionalPolicy(@toolEntry, @toolsCollection, @toolName, @args, null)
]

exe recursive @callToolWithPolicy(toolEntry, toolsCollection, toolName, args, policyValue) = [
  => @callToolWithOptionalPolicy(@toolEntry, @toolsCollection, @toolName, @args, @policyValue)
]

>> MCP-backed tools surface runtime failures as `ERROR: ...` strings. Turn
>> those into short retry guidance so the planner can correct formatting
>> mistakes instead of treating the text as successful data.
exe @toolRuntimeMessage(toolName, raw) = when [
  @typeof(@raw) == "string" && @raw.startsWith("ERROR:") && @raw.includes("does not match format '%Y-%m-%d'") => `@toolName date args must use YYYY-MM-DD (for example 2026-04-25) or be omitted. Original error: @raw.replace(\"ERROR: \", \"\").trim()`
  @typeof(@raw) == "string" && @raw.startsWith("ERROR:") && @raw.includes("required property") => `@toolName rejected args: @raw.replace(\"ERROR: \", \"\").trim(). Check that arg names match the tool's parameter names.`
  @typeof(@raw) == "string" && @raw.startsWith("ERROR:") && (@raw.includes("Connection") || @raw.includes("ECONNREFUSED") || @raw.includes("timed out")) => `@toolName is unavailable (connection error). Call blocked if no alternative path exists.`
  @typeof(@raw) == "string" && @raw.startsWith("ERROR:") => @raw.replace("ERROR: ", "").trim()
  * => null
]

>> Error logs need the underlying bridge failure, not just the rig-level
>> classification. Collapse common raw error shapes into one readable
>> string so failing flow tests show the actual boundary break.
exe @toolFailureDetail(raw) = when [
  !@raw.isDefined() => null
  @typeof(@raw) == "string" => @raw
  @raw["message"].isDefined() && @typeof(@raw["message"]) == "string" => `@raw["message"]`
  @raw["message"].isDefined() => `@jsonSummary(@raw["message"])`
  @raw["summary"].isDefined() && @typeof(@raw["summary"]) == "string" => `@raw["summary"]`
  @raw["summary"].isDefined() => `@jsonSummary(@raw["summary"])`
  @raw["error"].isDefined() && @raw["error"] != true && @typeof(@raw["error"]) == "string" => `@raw["error"]`
  @raw["error"].isDefined() && @raw["error"] != true => `@jsonSummary(@raw["error"])`
  * => `@jsonSummary(@raw)`
]

>> Runtime bridges sometimes return an object envelope with `error: false`
>> on success. Treat only an explicit boolean `true` as a structured tool
>> failure; checking mere field presence turns valid MCP payloads into
>> false-positive phase errors. Additionally, mlld surfaces policy denials
>> from traced tool calls as { ok: false, error: "policy_denied", ... } —
>> catch that shape so denied dispatches don't proceed to status:"sent".
exe @toolCallError(raw) = when [
  @typeof(@raw) == "object" && @raw["error"] == true => @raw
  @typeof(@raw) == "object" && @raw["ok"] == false && @raw["error"].isDefined() => @raw
  * => null
]

exe @correlatedControlArgsCheck(compiledEntries, controlArgs) = [
  let @selected = for @entry in (@compiledEntries ?? []) when @controlArgs.includes(@entry.arg) => @entry
  let @refs = loop(1000) [
    let @cursor = @input ?? { index: 0, values: [] }
    if @cursor.index >= @selected.length [ done @cursor.values ]
    continue {
      index: @cursor.index + 1,
      values: @cursor.values.concat(@selected[@cursor.index].backing_refs ?? [])
    }
  ]
  let @keys = for @ref in @refs when @ref.record.isDefined() && @ref.handle.isDefined() => `@ref.record:@ref.handle`
  let @unique = loop(1000) [
    let @ctx = @input ?? { index: 0, values: [] }
    if @ctx.index >= @keys.length [ done @ctx.values ]
    let @nextKey = @keys[@ctx.index]
    continue when [
      @ctx.values.includes(@nextKey) => { index: @ctx.index + 1, values: @ctx.values }
      * => { index: @ctx.index + 1, values: @ctx.values.concat([@nextKey]) }
    ]
  ]
  => when [
    @unique.length <= 1 => { ok: true }
    * => {
      ok: false,
      error: "correlate_control_args_cross_record_mixture",
      refs: @refs,
      hint: "All control args for this tool must come from the same resolved record instance. Your args reference values from different records. Use handles from a single resolve result."
    }
  ]
]

exe @plannerHasAnyTools(agent) = [
  let @names = @phaseToolNames(@agent, "resolve").concat(@phaseToolNames(@agent, "extract")).concat(@phaseToolNames(@agent, "execute"))
  => @names.length > 0
]

