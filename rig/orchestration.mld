import {
  @toolCatalogObject,
  @toolKind,
  @routeToolCatalog,
  @synthesizedOperations,
  @synthesizedAuthorizations,
  @hasNovelUrlRisk
} from "./tooling.mld"
import {
  @resetLifecycleFiles,
  @truncateLlmCallLog,
  @truncateExecutionLog
} from "./lifecycle.mld"
import {
  @defaultHarness,
  @plannerVisibleState,
  @workerStateSummary,
  @nonComposeDecisionArgIssues,
  @updateNamedState,
  @updateExtractSources,
  @correlatedControlArgsCheck
} from "./runtime.mld"
import { @runPlannerSession } from "./workers/planner.mld"
import { @standard, @urlDefense, @noNovelUrl } from "@mlld/policy"

>> @noNovelUrl is imported here even though it is not referenced directly:
>> @urlDefense.dataflow.check[0].do holds an exe ref to @noNovelUrl. When
>> @policy.build resolves the check action at dispatch time it looks the
>> name up in the calling module's scope, so the exe has to be visible
>> here for the URL defense to fire. Without this import, dispatch fails
>> with "Command not found: noNovelUrl" on any tool whose suite has
>> @hasNovelUrlRisk == true (e.g. slack's get_webpage).

>> @standard ships labels.{rules, apply, args} for secret/sensitive/
>> trust:untrusted exfil + destructive + privileged blocking, the
>> trust:untrusted+llm → influenced apply rule, and the labels.args:
>> floor for exfil:send / destructive:targeted / extract:r / tool:r.
>> @urlDefense ships dataflow.{enrich, check} for novel-URL defense.
>>
>> Rig overlay adds atop @standard:
>>   labels.risks                    — operation→risk-category map from tool catalog
>>   labels.rules.influenced.deny    — additively widen @standard's influenced+advice
>>                                     deny to also block destructive + exfil
>>   labels.{trusted_tool_output,user_originated}.satisfies
>>                                   — promote custom labels to fact-equivalent for
>>                                     positive checks (transitional alias per
>>                                     spec-label-structure §9.9)
>>   authorizations                  — per-tool planner-authorize / worker-submit
>>   capabilities                    — runtime allow list
>>
>> The advice gate (rig/workers/advice.mld) declares its own module-scope
>> policy with the @noInfluencedAdvice fragment. synthesizedPolicy doesn't
>> add it here — its rule fires automatically on advice-labeled exes
>> called from that module.
>>
>> facts.requirements is auto-derived from labels.args plus kind-tagged
>> fact fields on input records (records.mld). Rig no longer synthesizes
>> per-tool fact requirements.
>>
>> Per the policy redesign migration (MIGRATION-POLICY-REDESIGN.md):
>> @policy.build accepts the new-schema basePolicy data shape directly —
>> no need to declare `policy @p = union(...)` at module scope. Verified
>> via tmp/policy-spike/probe-policy-build-data.mld.
exe @synthesizedPolicy(tools, overridePolicy, options) = [
  let @operations = @synthesizedOperations(@tools)
  let @stdRules = @standard.labels.rules
  let @widenedInfluencedDeny = @stdRules.influenced.deny.concat(["destructive", "exfil"])
  let @rigLabels = {
    ...@stdRules,
    influenced: { deny: @widenedInfluencedDeny }
  }
  let @baseShape = {
    labeling: { unlabeled: "untrusted" },
    capabilities: {
      allow: ["cmd:*", "sh", "js", "node", "fs:r:**", "fs:w:**", "network"]
    },
    labels: {
      risks: @operations,
      rules: @rigLabels,
      apply: @standard.labels.apply,
      args: @standard.labels.args,
      "trusted_tool_output": { satisfies: ["fact:*"] },
      "user_originated":     { satisfies: ["fact:*"] }
    },
    authorizations: @synthesizedAuthorizations(@tools)
  }
  let @withUrl = when [
    @hasNovelUrlRisk(@tools) => { ...@baseShape, dataflow: @urlDefense.dataflow }
    * => @baseShape
  ]
  if !@overridePolicy.isDefined() [ => @withUrl ]
  let @overrideLabels = @overridePolicy.labels ?? {}
  let @overrideAuth = @overridePolicy.authorizations ?? {}
  let @existingDeny = @withUrl.authorizations.deny ?? []
  let @extraDeny = for @t in (@overrideAuth.deny ?? []) when !@existingDeny.includes(@t) => @t
  => {
    ...@withUrl,
    labels: { ...@withUrl.labels, ...@overrideLabels },
    authorizations: {
      ...@withUrl.authorizations,
      deny: @existingDeny.concat(@extraDeny)
    }
  }
]

exe @validateToolCatalog(tools) = [
  let @catalog = @toolCatalogObject(@tools)
  let @issues = for @name, @tool in @catalog => when [
    !@toolKind(@tool).isDefined() => { tool: @name, error: "tool_missing_kind" }
    @toolKind(@tool) == "read" && !@tool.returns.isDefined() => { tool: @name, error: "read_tool_missing_returns_record" }
    @toolKind(@tool) == "write" && !@tool.inputs.isDefined() => { tool: @name, error: "write_tool_missing_inputs" }
    * => null
  ]
  let @realIssues = for @issue in @issues when @issue => @issue
  => when [
    @realIssues.length == 0 => { ok: true }
    * => { ok: false, issues: @realIssues }
  ]
]

exe @prepareOpencodeInnerWorkerHome(dataHome, stateHome, workerDir) = sh {
  set -e

  if [ -n "$workerDir" ]; then
    mkdir -p "$workerDir"
  fi

  if [ -n "$stateHome" ]; then
    mkdir -p "$stateHome"
  fi

  if [ -z "$dataHome" ]; then
    exit 0
  fi

  src="${XDG_DATA_HOME:-$HOME/.local/share}/opencode"
  dst="$dataHome/opencode"
  mkdir -p "$dst"

  if [ -f "$src/auth.json" ]; then
    cp "$src/auth.json" "$dst/auth.json"
  fi

  if [ ! -f "$dst/opencode.db" ] && [ -f "$src/opencode.db" ]; then
    cp "$src/opencode.db" "$dst/opencode.db"
    if [ -f "$src/opencode.db-wal" ]; then
      cp "$src/opencode.db-wal" "$dst/opencode.db-wal"
    fi
    if [ -f "$src/opencode.db-shm" ]; then
      cp "$src/opencode.db-shm" "$dst/opencode.db-shm"
    fi
  fi
}

exe @validateConfig(config) = [
  if !@config.suite.isDefined() [ => { error: "missing_required_field", field: "suite" } ]
  if !@config.records.isDefined() [ => { error: "missing_required_field", field: "records" } ]
  if !@config.tools.isDefined() [ => { error: "missing_required_field", field: "tools" } ]
  if !@config.model.isDefined() [ => { error: "missing_required_field", field: "model" } ]
  let @toolValidation = @validateToolCatalog(@config.tools)
  if !@toolValidation.ok [ => { error: "invalid_tool_catalog", issues: @toolValidation.issues } ]
  let @defense = @config.defense ?? "defended"
  let @overrides = @config.overrides ?? {}
  let @runtimeCollection = @config.toolsCollection ?? @config.tools
  let @basePolicy = when [
    @defense == "defended" => @synthesizedPolicy(@config.tools, @overrides.policy, {})
    * => null
  ]
  => {
    ok: true,
    suite: @config.suite,
    defense: @defense,
    model: @config.model,
    workerModel: @config.workerModel ?? null,
    harness: @config.harness ?? @defaultHarness(@config.model),
    records: @config.records,
    tools: @config.tools,
    routedTools: @routeToolCatalog(@config.tools),
    toolsCollection: @runtimeCollection,
    basePolicy: @basePolicy,
    maxIterations: @config.maxIterations ?? 40,
    overrides: @overrides,
    stub: @overrides.stub ?? {},
    phaseLogFile: @config.phaseLogFile ?? null,
    phaseStateFile: @config.phaseStateFile ?? null,
    executionLogFile: @config.executionLogFile ?? "/tmp/mlld-rig-execution-log.jsonl",
    llmCallLogFile: @config.llmCallLogFile ?? null,
    logLlmCalls: @config.logLlmCalls ?? false,
    innerWorkerDir: @config.innerWorkerDir ?? "/tmp/mlld-rig-inner-workers",
    innerWorkerDataHome: @config.innerWorkerDataHome ?? "/tmp/mlld-rig-inner-worker-data",
    innerWorkerStateHome: @config.innerWorkerStateHome ?? "/tmp/mlld-rig-inner-worker-state",
    opencodePure: @config.opencodePure ?? true,
    plannerAddendum: @config.plannerAddendum ?? "",
    deriveAddendum: @config.deriveAddendum ?? "",
    extractAddendum: @config.extractAddendum ?? "",
    composeAddendum: @config.composeAddendum ?? "",
    toolFilter: @config.toolFilter ?? null,
    adviceMode: @config.adviceMode ?? false
  }
]

exe @runPlanner(agent, query) = [
  @resetLifecycleFiles(@agent.phaseLogFile, @agent.phaseStateFile)
  @truncateLlmCallLog(@agent.llmCallLogFile)
  @truncateExecutionLog(@agent.executionLogFile)
  if @agent.harness == "opencode" [
    @prepareOpencodeInnerWorkerHome(@agent.innerWorkerDataHome, @agent.innerWorkerStateHome, @agent.innerWorkerDir)
  ]
  => @runPlannerSession(@agent, @query)
]

export {
  @validateConfig,
  @synthesizedPolicy,
  @runPlanner,
  @plannerVisibleState,
  @workerStateSummary,
  @nonComposeDecisionArgIssues,
  @updateNamedState,
  @updateExtractSources,
  @correlatedControlArgsCheck
}
