import {
  @resolveAttestation,
  @extractAttestation,
  @deriveAttestation,
  @executeAttestation,
  @composeAttestation
} from "./records.mld"
import {
  @validateConfig,
  @synthesizedPolicy,
  @runPlanner
} from "./orchestration.mld"
import {
  @pairsToObject,
  @toolExecutable,
  @toolParamNames,
  @toolControlArgs,
  @toolPayloadArgs
} from "./tooling.mld"
import { @compileExecuteIntent, @lowerSelectionRef } from "./intent.mld"
exe @rigBuild(config) = [
  let @validated = @validateConfig(@config)
  if !@validated.ok [ => @validated ]
  => @validated
]

exe @prepareAgent(agentOrConfig) = when [
  @agentOrConfig.data.tools.isDefined() && @agentOrConfig.data.records.isDefined() && @agentOrConfig.data.model.isDefined() => @validateConfig(@agentOrConfig.data)
  @agentOrConfig.tools.isDefined() && @agentOrConfig.records.isDefined() && @agentOrConfig.model.isDefined() => @validateConfig(@agentOrConfig)
  * => @validateConfig(@agentOrConfig)
]

exe @rigRun(agent, query) = [
  let @prepared = @prepareAgent(@agent)
  if !@prepared.ok && @prepared.error.isDefined() [
    => {
      text: @prepared.error,
      terminal: "blocked",
      debug: {
        execution_log: [],
        planner_iterations: [],
        phase_events: [],
        last_decision: { phase: "blocked", reason: @prepared.error }
      }
    }
  ]
  let @result = @runPlanner(@prepared, @query)
  let @plannerIterations = for @event in @result.phase_events when @event.event == "planner_iteration" => @event
  => {
    text: @result.final.text,
    terminal: @result.terminal,
    debug: {
      execution_log: @result.execution_log,
      planner_iterations: @plannerIterations,
      phase_events: @result.phase_events,
      last_decision: @result.last_decision
    }
  }
]

var @rig = {
  build: @rigBuild,
  run: @rigRun,
  validateConfig: @validateConfig,
  synthesizePolicy: @synthesizedPolicy,
  compileExecuteIntent: @compileExecuteIntent,
  lowerSelectionRef: @lowerSelectionRef,
  records: {
    resolveAttestation: @resolveAttestation,
    extractAttestation: @extractAttestation,
    deriveAttestation: @deriveAttestation,
    executeAttestation: @executeAttestation,
    composeAttestation: @composeAttestation
  },
  tooling: {
    pairsToObject: @pairsToObject,
    toolExecutable: @toolExecutable,
    toolParamNames: @toolParamNames,
    toolControlArgs: @toolControlArgs,
    toolPayloadArgs: @toolPayloadArgs
  }
}

export {
  @rig,
  @rigBuild,
  @rigRun,
  @resolveAttestation,
  @extractAttestation,
  @deriveAttestation,
  @executeAttestation,
  @composeAttestation
}
