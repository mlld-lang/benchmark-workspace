>> Step 6 guard helpers: verify the v2 retry predicates and hints.

import {
  @plannerPrematureBlocked,
  @prematureBlockedHint,
  @plannerPrematureCompose,
  @prematureComposeHint,
  @plannerExtractBeforeResolve,
  @extractBeforeResolveHint,
  @plannerBlockedAfterExtract,
  @blockedAfterExtractHint,
  @plannerBlockedAfterResolve,
  @blockedAfterResolveHint
} from "../../guards.mld"
import { @plannerHint } from "../../workers/planner.mld"
import { @check } from "../helpers.mld"

var @emptyLog = []
var @extractLog = [{ phase: "extract", summary: "typed payload available" }]
var @resolveLog = [{ phase: "resolve", summary: "grounded contacts" }]
var @prematureComposeOk = @plannerPrematureCompose({ phase: "compose" }, @emptyLog) &&
  @prematureComposeHint().includes("pick resolve first")
var @prematureBlockedOk = @plannerPrematureBlocked({ phase: "blocked", reason: "not sure" }, @emptyLog) &&
  @prematureBlockedHint().includes("Pick a resolve tool")
var @extractBeforeResolveOk = @plannerExtractBeforeResolve({ phase: "extract" }, @emptyLog) &&
  @extractBeforeResolveHint().includes("webpage fetches are the exception")
var @toolBackedExtractOk = !@plannerExtractBeforeResolve({ phase: "extract", tool: "get_webpage" }, @emptyLog)
var @blockedAfterExtractFirstOk = @plannerBlockedAfterExtract({ phase: "blocked", reason: "not sure" }, @extractLog, 1) &&
  @blockedAfterExtractHint().includes("no legal path forward")
var @blockedAfterExtractSecondOk = !@plannerBlockedAfterExtract({ phase: "blocked", reason: "still blocked" }, @extractLog, 2)
var @blockedAfterResolveFirstOk = @plannerBlockedAfterResolve({ phase: "blocked", reason: "unclear" }, @resolveLog, 1) &&
  @blockedAfterResolveHint().includes("canonical structured refs")
var @blockedAfterResolveSecondOk = !@plannerBlockedAfterResolve({ phase: "blocked", reason: "still blocked" }, @resolveLog, 2)
var @knownLiteralLog = [{
  phase: "resolve",
  status: "error",
  summary: "[{\"ok\":false,\"arg\":\"day\",\"error\":\"known_value_not_in_task_text\",\"value\":\"2026-04-14\"}]"
}]
var @knownLiteralAgent = {
  tools: {},
  toolsCollection: {},
  runtimeTools: {},
  routedTools: {
    resolve: {},
    extract: {},
    execute: {}
  }
}
var @knownLiteralHint = @plannerHint(@knownLiteralAgent, { phase: "resolve" }, { execution_log: @knownLiteralLog }, false, false)
var @knownLiteralHintOk = @knownLiteralHint.includes("exact substrings from the task text") &&
  @knownLiteralHint.includes("Do not normalize")
var @knownLiteralHintRetry = @plannerHint(@knownLiteralAgent, { phase: "resolve" }, { execution_log: @knownLiteralLog }, true, false)
var @knownLiteralHintRetryClears = !@knownLiteralHintRetry.isDefined() || @knownLiteralHintRetry == null || @knownLiteralHintRetry == ""

exe @allChecks() = [
  => [
    @check("premature-compose", @prematureComposeOk, @prematureComposeHint()),
    @check("premature-blocked", @prematureBlockedOk, @prematureBlockedHint()),
    @check("extract-before-resolve", @extractBeforeResolveOk, @extractBeforeResolveHint()),
    @check("tool-backed-extract-first", @toolBackedExtractOk, "extract:r tools may run before resolve"),
    @check("blocked-after-extract-first-attempt", @blockedAfterExtractFirstOk, @blockedAfterExtractHint()),
    @check("blocked-after-extract-second-attempt", @blockedAfterExtractSecondOk, "second blocked after extract is accepted"),
    @check("blocked-after-resolve-first-attempt", @blockedAfterResolveFirstOk, @blockedAfterResolveHint()),
    @check("blocked-after-resolve-second-attempt", @blockedAfterResolveSecondOk, "second blocked after resolve is accepted"),
    @check("known-literal-format-hint", @knownLiteralHintOk, @knownLiteralHint),
    @check("known-literal-hint-clears-on-retry", @knownLiteralHintRetryClears, @knownLiteralHintRetry ?? "retry attempt evaluates the new decision instead of replaying the old hint")
  ]
]

var @checks = @allChecks()

var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Rig v2 guards"
for @check in @checks => show `[@check.status] @check.id  @check.detail`

if @fails.length > 0 [
  run sh { exit 1 }
]
