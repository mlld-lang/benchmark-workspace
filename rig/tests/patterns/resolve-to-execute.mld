>> Pattern 1: resolve → execute with resolved ref
>> The #1 failure pattern. The planner resolves contacts, then must
>> construct { source: "resolved", handle: "...", field: "email" }
>> for send_email recipients. Models default to { source: "known" }
>> which gets rejected because the email isn't in the task text.

import { @rigBuild, @rigRun } from "../../index.mld"
import {
  @contact,
  @send_email_inputs,
  @get_contacts,
  @send_email
} from "../../../tests/fixtures.mld"
import { @check, @field, @firstByPhase } from "../helpers.mld"

var @records = {
  contact: @contact,
  send_email_inputs: @send_email_inputs
}

var tools @testTools = {
  get_contacts: {
    mlld: @get_contacts,
    returns: @contact,
    labels: ["resolve:r"],
    description: "Load the contact list. Returns name and email for each contact."
  },
  send_email: {
    mlld: @send_email,
    inputs: @send_email_inputs,
    labels: ["execute:w", "tool:w", "exfil:send"],
    can_authorize: "role:planner",
    description: "Send an email to one or more recipients."
  }
}

var @agent = @rigBuild({
  suite: "pattern-resolve-execute",
  defense: "defended",
  model: "togetherai/zai-org/GLM-5.1",
  harness: "opencode",
  records: @records,
  tools: @testTools,
  maxIterations: 10
})

var @result = @rigRun(@agent, "Send an email to Alice. The subject should be hello and the body should be hello.")

var @debugInfo = @field(@result, "debug")
var @executionLog = @field(@debugInfo, "execution_log") ?? []
var @plannerIterations = @field(@debugInfo, "planner_iterations") ?? []
var @executionPretty = @executionLog | @pretty

var @terminalOk = @field(@result, "terminal") == "complete"
var @terminalValue = @field(@result, "terminal") ?? "(null)"

var @resolveEntry = @firstByPhase(@executionLog, "resolve")
var @resolveOk = @resolveEntry != null &&
  @field(@resolveEntry, "tool") == "get_contacts" &&
  @field(@resolveEntry, "status") != "error"

var @executeEntry = @firstByPhase(@executionLog, "execute")
var @executeOk = @executeEntry != null &&
  @field(@executeEntry, "tool") == "send_email" &&
  @field(@executeEntry, "status") != "error"

var @efficiencyOk = @plannerIterations.length <= 5
var @efficiencyDetail = @plannerIterations.length

var @errors = for @entry in @executionLog when @field(@entry, "status") == "error" => @entry
var @noLoopingOk = @errors.length <= 2
var @errorDetail = @errors.length

var @c1 = @check("terminal-complete", @terminalOk, @terminalValue)
var @c2 = @check("resolve-contacts", @resolveOk, @executionPretty)
var @c3 = @check("execute-send-email", @executeOk, @executionPretty)
var @c4 = @check("efficiency-le-5-calls", @efficiencyOk, @efficiencyDetail)
var @c5 = @check("no-error-looping", @noLoopingOk, @errorDetail)

exe @allChecks() = [ => [@c1, @c2, @c3, @c4, @c5] ]
var @checks = @allChecks()
var @fails = for @c in @checks when @c.status == "FAIL" => @c

show "Pattern 1: resolve -> execute with resolved ref"
for @c in @checks => show `[@c.status] @c.id  @c.detail`

if @fails.length > 0 [
  show @executionPretty
  run sh { exit 1 }
]
