import { @file_entry as @ws_file_entry } from "../../bench/domains/workspace/records.mld"

var @fakeFileRaw = [
  { id_: "26", filename: "report.pdf", content: "...", owner: "alice", size: 1024, last_modified: "2026-04-23", shared_with: [] },
  { id_: "27", filename: "notes.txt", content: "...", owner: "bob", size: 512, last_modified: "2026-04-22", shared_with: ["carol"] }
]
