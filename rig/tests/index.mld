  @executeResultStateEntries[0].identity_value == "42"
var @executeResultHandlePretty = `status=@executeResultHandleResult.result.status handles=@executeResultHandleResult.result.result_handles.length first=@executeResultHandleResult.result.result_handles[0] state_entries=@executeResultStateEntries.length id=@executeResultStateEntries[0].identity_value`

