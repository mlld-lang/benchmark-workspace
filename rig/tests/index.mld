>> Rig v2 invariant tests.
>>
>> This is the fast zero-LLM regression guard the plan calls for. Each
>> assertion names a concrete contract so failures point straight at the
>> broken primitive instead of forcing a full benchmark run to localize
>> the issue.

import {
  @records,
  @tools,
  @sampleState,
  @sampleAgent,
  @get_contacts,
  @get_today,
  @note_entry,
  @send_email,
  @create_note,
  @schedule_meeting,
  @meeting_request_inputs,
  @create_note_inputs,
  @send_email_inputs
} from "./fixtures.mld"
import { @opencodeToolAgentName, @opencodePermissionRules } from "@mlld/opencode"
import { @imported_tools } from "./imported-tools-fixture.mld"
import {
  @mxEntry,
  @renderToolDocs,
  @toolLabels,
  @toolParamNames,
  @toolControlArgs,
  @toolPayloadArgs,
  @toolOptionalArgs,
  @toolUpdateArgs,
  @toolExactArgs,
  @toolOptionalBenign,
  @toolRisk,
  @toolCanAuthorizeRoles,
  @toolInputRecord,
  @toolDescription,
  @phaseCatalog,
  @phaseToolEntry
} from "../tooling.mld"
import { @rigBuild } from "../index.mld"
import {
  @synthesizedPolicy,
  @plannerVisibleState,
  @workerStateSummary,
  @nonComposeDecisionArgIssues,
  @updateNamedState,
  @updateExtractSources,
  @correlatedControlArgsCheck
} from "../orchestration.mld"
import { @compileExecuteIntent, @compileToolArgs, @lowerSelectionRef, @resolveControlRefValue, @resolveRefValue, @roleForArg, @lookupResolvedEntry } from "../intent.mld"
import { @callTool, @toolCallError, @emptyState, @recordTypeName, @llmCallEntry, @mergeResolvedEntries, @updateResolvedState, @projectResolvedSummary, @bucketItems, @bucketLength, @isResolvedIndexBucket, @batchSpecMergeState } from "../runtime.mld"
import { @emptyPlannerRuntime } from "../session.mld"
import { @dispatchResolve } from "../workers/resolve.mld"
import { @dispatchExecute } from "../workers/execute.mld"
import { @coerceExtractAttestation, @dispatchExtract } from "../workers/extract.mld"
import { @coerceDeriveAttestation } from "../workers/derive.mld"
import { @planner, @plannerTools, @stateProgressFingerprint, @plannerNoProgressThreshold, @plannerRuntimeStateWithProgress } from "../workers/planner.mld"

exe @status(ok) = when [
  @ok => "PASS"
  * => "FAIL"
]

exe @check(id, ok, detail) = [
  => {
    id: @id,
    status: @status(@ok),
    detail: @detail
  }
]

exe @field(inputValue, key) = js {
  return inputValue?.[key] ?? null;
}

exe resolve:r, tool:r @search_day_events(query, day) = [
  => {
    value: @day,
    kind: @query
  }
] => record @records.datetime_context

exe @isBlank(value) = when [
  !@value.isDefined() => true
  @value == null => true
  @value == "" => true
  * => false
]

exe @firstIssue(result) = [
  let @issues = @field(@result, "issues") ?? []
  => @issues[0] ?? null
]

exe @nestedFirstIssue(result) = [
  let @first = @firstIssue(@result)
  let @issues = @field(@first, "issues") ?? []
  => @issues[0] ?? null
]

exe @policySummary(result) = [
  let @issues = @field(@result, "issues") ?? []
  let @first = @issues[0] ?? null
  => `valid=@field(@result, "valid") reason=@field(@first, "reason") arg=@field(@first, "arg") phase=@field(@first, "phase")`
]

exe @guardSummary(result) = [
  let @guard = @field(@result, "guard") ?? @result
  => `code=@field(@guard, "code") phase=@field(@guard, "phase") tool=@field(@guard, "tool") field=@field(@guard, "field")`
]

exe @dispatchSummary(result) = [
  let @state = @field(@result, "state")
  let @log = @field(@state, "execution_log") ?? []
  let @response = @field(@result, "result")
  => `error=@field(@result, "error") status=@field(@response, "status") count=@field(@response, "count") record=@field(@response, "record_type") log=@log.length`
]

exe @docSummary(doc) = [
  => `control=@field(@doc, "controlArgs") payload=@field(@doc, "payloadArgs") optional=@field(@doc, "optionalArgs") update=@field(@doc, "update") exact=@field(@doc, "exactArgs")`
]

exe @capturedDenied() = [
  => { guard: @mx.guard ?? null }
]

exe @policyBuildInvalid(policyResult) = [
  let @issues = when [
    @field(@policyResult, "issues").isDefined() => @field(@policyResult, "issues")
    * => []
  ]
  => {
    error: "policy_build_invalid",
    issues: @issues
  }
]

>> Execute-time policy application is most reliable when it lands on a
>> local wrapper exe instead of on an imported callable. The wrapper is
>> intentionally thin: it preserves native mlld args and only relocates
>> the policy boundary to the caller's module.
exe @runtime_create_note(content) = [
  => @create_note(@content)
]

>> Policy-bearing execute calls still need a wrapper whose declared
>> parameters match the tool catalog metadata exactly.
exe @runtime_schedule_meeting(title, start_time, end_time, participants: array) = [
  let @participantsValue = @exists(@participants) ? @participants : null
  => {
    ok: true,
    title: @title,
    start_time: @start_time,
    end_time: @end_time,
    participants: @participantsValue
  }
]

>> Workspace contact records use unnamed display arrays such as
>> `[name, { ref: "email" }]`. Keep one fixture inline here so the
>> invariant suite exercises the exact shorthand that the live benchmark
>> depends on.
record @flat_display_contact = {
  facts: [email: string],
  data: [name: string, notes: string?],
  display: [name, { ref: "email" }]
}

>> Benchmark suites use plain mode keys (`planner`, `worker`, `default`)
>> rather than the test fixtures' `role:*` form. Keep one record with
>> that spelling here so the planner summary cannot silently fall back
>> to `default` and expose hidden content.
record @plain_mode_message = {
  facts: [id_: string, sender: string?],
  data: [subject: string?, body: string?],
  key: id_,
  display: {
    default: [{ ref: "id_" }, subject, body],
    worker: [{ ref: "id_" }, subject, body],
    planner: [{ ref: "id_" }, subject]
  }
}

>> Named extract/derive results should use record display when their
>> schema is a real record. This keeps the planner on a declared safe
>> surface while workers still resolve full fields from state later.
record @named_display_extract = {
  facts: [id_: string],
  data: [subject: string, body: string, note: string?],
  key: id_,
  display: {
    planner: [{ ref: "id_" }, subject],
    worker: [{ ref: "id_" }, subject, body, note]
  }
}

record @thin_arrow_output = {
  data: [leaked: string?, input: string?],
  validate: "demote"
}

record @string_id_holder = {
  facts: [id_: string]
}

record @shared_file_entry = {
  facts: [id_: string, shared_with: array?],
  data: [filename: string?],
  key: id_,
  display: {
    role:planner: [{ ref: "id_" }, filename, { ref: "shared_with" }],
    role:worker: [{ ref: "id_" }, filename, { ref: "shared_with" }]
  }
}

record @local_meeting_request_inputs = {
  facts: [participants: array?],
  data: [title: string, start_time: string, end_time: string],
  optional_benign: [participants],
  validate: "strict"
}

var @approvedRecipients = ["ada@example.com"]
var @blockedSubjects = ["blocked subject"]
var known @approvedRecipient = "ada@example.com"
var known @rejectedRecipient = "mallory@example.com"

record @allowlisted_send_email_inputs = {
  facts: [recipient: string],
  data: [subject: string],
  allowlist: { recipient: @approvedRecipients },
  validate: "strict"
}

record @blocked_subject_send_inputs = {
  facts: [],
  data: [subject: string],
  blocklist: { subject: @blockedSubjects },
  validate: "strict"
}

record @profile_update_inputs = {
  facts: [],
  data: [city: string?, street: string?],
  update: [city, street],
  validate: "strict"
}

record @password_change_inputs = {
  facts: [],
  data: [password: string],
  exact: [password],
  validate: "strict"
}

exe @runtime_allowlisted_send_email(recipient, subject) = [
  => {
    recipient: @recipient,
    subject: @subject
  }
]

exe @runtime_blocked_subject_send(subject) = [
  => {
    subject: @subject
  }
]

exe @runtime_update_profile(city, street) = [
  => {
    city: @city,
    street: @street
  }
]

exe @runtime_change_password(password) = [
  => {
    password: @password
  }
]

>> Thin-arrow regression from the v1 smoke. If strict mode leaks the
>> tool-slot value back into mlld, the serialized output contains the
>> sentinel string and this check trips immediately.
exe @thinArrowProbe(x) = [
  -> { leaked: "tool-slot-value", input: @x }
] => record @thin_arrow_output

>> Runtime regression for single-parameter direct tool dispatch. Numeric-
>> looking string ids must remain strings all the way into the executable
>> boundary; otherwise benchmark tools like `get_email_by_id("33")` fail
>> their parameter validation before the tool body even runs.
exe resolve:r, tool:r @get_numeric_note(note_id: string) = [
  => { id_: @note_id, title: "Todo", content: "Existing note body" }
] => record @note_entry with { controlArgs: ["note_id"] }

var tools @thinArrowToolCollection = {
  thin_arrow_probe: { mlld: @thinArrowProbe }
}

var tools @numericDispatchToolCollection = {
  get_numeric_note: {
    mlld: @get_numeric_note,
    returns: @note_entry,
    labels: ["resolve:r"],
    description: "Load one note by a numeric-looking string id."
  }
}

exe @serialize(v) = [ => @v | @pretty ]

>> Tactical guard against value-to-string coercion recursing into
>> The raw policy builder now requires an active caller role before it
>> accepts planner authorizations. Keep the baseline under a
>> `role:planner` helper so the test exercises the shipped contract
>> rather than top-level unlabeled evaluation.
exe role:planner @policyBuildAsPlanner(toolCatalog, basePolicy) = [
  let @built = @policy.build(
    { allow: { create_note: true } },
    @toolCatalog,
    { task: "create a note", basePolicy: @basePolicy }
  )
  => @built
]

exe role:planner @buildAllowedToolPolicy(toolName, toolCatalog, basePolicy, task) = [
  let @built = @policy.build(
    { allow: { [@toolName]: true } },
    @toolCatalog,
    { task: @task, basePolicy: @basePolicy }
  )
  => @built
]

exe @collectionRoundtrip(toolCatalog, basePolicy) = [
  let @built = @policyBuildAsPlanner(@toolCatalog, @basePolicy)
  => @built.valid
]

>> Runtime primitive baseline — verifies @policy.build itself accepts a
>> reasonable hand-constructed base policy before the rig synthesizer is
>> even involved.
var @manualBasePolicy = {
  defaults: { rules: ["no-send-to-unknown"] },
  operations: { "exfil:send": ["send_email"] },
  labels: { influenced: { deny: ["exfil"] } },
  authorizations: {
    deny: [],
    can_authorize: { "role:planner": ["create_note", "send_email"] }
  }
}

>> Keep the raw `@policy.build` baseline on a tiny dedicated tool
>> collection. The runtime dispatch catalog intentionally omits planner
>> authorization metadata, while the policy builder now expects the
>> planner-facing role surface to be present on the collection it
>> validates.
var tools @policyBuildToolCollection = {
  send_email: {
    mlld: @send_email,
    inputs: @send_email_inputs,
    labels: ["execute:w", "tool:w", "exfil:send"],
    can_authorize: "role:planner"
  },
  create_note: {
    mlld: @create_note,
    inputs: @create_note_inputs,
    labels: ["execute:w", "tool:w"],
    can_authorize: "role:planner"
  }
}

var @policyRuntime = @policyBuildAsPlanner(@policyBuildToolCollection, @manualBasePolicy)

var @numericStringIdRecord = {
  id_: "33"
} as record @string_id_holder
var @numericStringIdValue = @numericStringIdRecord.id_
var @wrappedToolNameRecord = {
  id_: "get_numeric_note"
} as record @string_id_holder
var @wrappedToolNameValue = @wrappedToolNameRecord.id_
var @importedReadParamNames = @toolParamNames(@imported_tools.search_alpha)
var @importedDayParamNames = @toolParamNames(@imported_tools.get_day)
var @importedWriteParamNames = @toolParamNames(@imported_tools.send_alpha)
var @importedToolParamRoundtripDetail = `read=@importedReadParamNames day=@importedDayParamNames write=@importedWriteParamNames`
var @importedToolParamRoundtripOk =
  @importedReadParamNames.length == 2 &&
  @importedReadParamNames[0] == "query" &&
  @importedReadParamNames[1] == "sender" &&
  @importedDayParamNames.length == 1 &&
  @importedDayParamNames[0] == "day" &&
  @importedWriteParamNames.length == 3 &&
  @importedWriteParamNames[0] == "recipient" &&
  @importedWriteParamNames[1] == "subject" &&
  @importedWriteParamNames[2] == "body"
var @fixtureReadDispatchResult = @callTool(
  @tools.get_contacts,
  @tools,
  "get_contacts",
  {}
)
var @builtFixtureAgent = @rigBuild({
  suite: "fixture-build",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools
})
var @builtFixtureReadDispatchResult = @callTool(
  @builtFixtureAgent.tools.get_contacts,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {}
)
>> Regression for the routed-catalog drift that left live workers with a
>> phase catalog they could inspect but not actually dispatch through.
>> The phase helpers must return native callable tool entries, not just
>> doc-shaped copies.
var @resolvePhaseCatalog = @phaseCatalog(@builtFixtureAgent, "resolve")
var @phaseCatalogDispatchResult = @callTool(
  @resolvePhaseCatalog.get_contacts,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {}
)
var @phaseToolEntryValue = @phaseToolEntry(@builtFixtureAgent, "resolve", "get_contacts")
var @phaseToolEntryDispatchResult = @callTool(
  @phaseToolEntryValue,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {}
)
>> Regression for the null-check bug in phase workers. Successful read
>> payloads must stay on the success path when dispatched through the
>> real resolve worker, not get reclassified as tool runtime errors.
var @dispatchResolveResult = @dispatchResolve(
  @builtFixtureAgent,
  @emptyState(),
  {
    phase: "resolve",
    tool: "get_contacts",
    args: {},
    purpose: "ground the contact list"
  },
  "Find Alice in my contacts."
)
>> Regression for arg-less resolve tools that return one keyed record.
>> This mirrors workspace `get_current_day` without depending on MCP.
var @dispatchScalarResolveResult = @dispatchResolve(
  @builtFixtureAgent,
  @emptyState(),
  {
    phase: "resolve",
    tool: "get_today",
    args: {},
    purpose: "ground one synthetic day context"
  },
  "What day is it?"
)
exe llm @testPlannerResolve(prompt, config) = [
  => @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.args)
]
var @plannerResolveDispatchResult = @testPlannerResolve("test", {
  args: { tool: "get_today", args: {}, purpose: "ground one synthetic day context" }
}) with {
  session: @planner,
  seed: { agent: @builtFixtureAgent, query: "What day is it?", state: @emptyState(), runtime: @emptyPlannerRuntime() }
}
var @plannerExtractFixtureAgent = @rigBuild({
  suite: "fixture-planner-extract",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  overrides: {
    stub: {
      extract: [{
        status: "ok",
        schema_name: "contact",
        name: "contact_details",
        provenance: "extracted",
        preview_fields: ["email", "name"],
        payload: {
          email: "alice.example",
          name: "Alice",
          notes: "planner-hidden note"
        }
      }]
    }
  }
})
exe llm @testPlannerExtractChain(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.resolveArgs)
  let @stateAfterResolve = @planner.state
  let @resolvedEmail = @resolveRefValue(@stateAfterResolve, @config.refValue)
  let @extractResult = @callTool(@plannerTools.extract, @plannerTools, "extract", @config.extractArgs)
  let @stateAfterExtract = @planner.state
  => {
    resolveResult: @resolveResult,
    stateAfterResolve: @stateAfterResolve,
    resolvedEmail: @resolvedEmail,
    extractResult: @extractResult,
    stateAfterExtract: @stateAfterExtract
  }
]
var @extractChainResult = @testPlannerExtractChain("test", {
  resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
  refValue: { source: "resolved", record: "contact", handle: "r_contact_alice.example", field: "email" },
  extractArgs: {
    source: { source: "resolved", record: "contact", handle: "r_contact_alice.example" },
    schema: { email: "string", name: "string" },
    name: "contact_details",
    purpose: "inspect one resolved contact"
  }
}) with {
  session: @planner,
  seed: { agent: @plannerExtractFixtureAgent, query: "Find Alice in my contacts.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
}
var @plannerResolveContactsResult = @extractChainResult.resolveResult
var @plannerStateAfterContactResolve = @extractChainResult.stateAfterResolve
var @plannerResolvedContactEmail = @extractChainResult.resolvedEmail
var @plannerExtractDispatchResult = @extractChainResult.extractResult
var @plannerStateAfterContactExtract = @extractChainResult.stateAfterExtract
var @sessionFinalState = @extractChainResult.mx.sessions.planner
var @sessionFinalStateOk =
  @sessionFinalState.isDefined() &&
  @sessionFinalState.runtime.tool_calls == 2 &&
  @sessionFinalState.state.resolved.contact.length == 2

exe llm @testPlannerTextResult(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.args)
  => "planner final text"
]
var @plannerTextResult = @testPlannerTextResult("test", {
  args: { tool: "get_today", args: {}, purpose: "ground one synthetic day context" }
}) with {
  session: @planner,
  seed: { agent: @builtFixtureAgent, query: "What day is it?", state: @emptyState(), runtime: @emptyPlannerRuntime() }
}
var @llmCallEntrySessionLog = @llmCallEntry("planner", "prompt", @plannerTextResult, null, "ses_debug", {
  call_kind: "outer_planner",
  outer_planner_session_id: "ses_debug"
})
var @llmCallEntrySessionLogPretty = @llmCallEntrySessionLog | @pretty
var @llmCallEntryOmitsSessionSnapshotOk =
  @field(@llmCallEntrySessionLog, "raw") == "planner final text" &&
  @field(@llmCallEntrySessionLog, "session_id") == "ses_debug" &&
  !@llmCallEntrySessionLogPretty.includes("sessions")
var @llmCallEntryOmitsSessionSnapshotDetail =
  `raw=@field(@llmCallEntrySessionLog, "raw") log=@llmCallEntrySessionLogPretty`

>> c-ut8r / m-5178: resolved values must retain factsources after session boundary.
>> The session stores state via @planner.set(); reading it back via @planner.state
>> must preserve StructuredValue metadata on identity_value, field_values, and value
>> fields. Without this, handle-type input records reject control args at dispatch.
var @sessionResolvedEntry = @sessionFinalState.state.resolved.contact[0]
var @sessionIdentityFs = @sessionResolvedEntry.identity_value.mx.factsources ?? []
var @sessionFieldFs = @sessionResolvedEntry.field_values.email.mx.factsources ?? []
var @sessionValueFs = @sessionResolvedEntry.value.email.mx.factsources ?? []
var @sessionResolvedEmailFs = @plannerResolvedContactEmail.value.mx.factsources ?? []
var @sessionFsOk =
  @sessionIdentityFs.length > 0 &&
  @sessionFieldFs.length > 0 &&
  @sessionValueFs.length > 0 &&
  @sessionResolvedEmailFs.length > 0
var @sessionFsPretty = `identity=@sessionIdentityFs.length field=@sessionFieldFs.length value=@sessionValueFs.length resolved=@sessionResolvedEmailFs.length`
var @plannerDeriveFixtureAgent = @rigBuild({
  suite: "fixture-planner-derive",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  overrides: {
    stub: {
      derive: [{
        status: "derived",
        schema_name: "action_items",
        name: "action_items",
        provenance: "derived",
        payload: {
          items: [{
            person_name: "Alice",
            task_description: "Send the launch update",
            deadline: "2026-04-23"
          }]
        },
        summary: "derived action_items"
      }],
      extract: [{
        status: "extracted",
        schema_name: "inline-schema",
        name: "action_items_copy",
        provenance: "extracted",
        preview_fields: ["person_name", "task_description", "deadline"],
        payload: {
          person_name: "Alice",
          task_description: "Send the launch update",
          deadline: "2026-04-23"
        },
        summary: "extracted action_items_copy"
      }]
    }
  }
})
exe llm @testPlannerDeriveChain(prompt, config) = [
  let @resolveResult = @callTool(@plannerTools.resolve, @plannerTools, "resolve", @config.resolveArgs)
  let @deriveResult = @callTool(@plannerTools.derive, @plannerTools, "derive", @config.deriveArgs)
  let @extractDerivedResult = @callTool(@plannerTools.extract, @plannerTools, "extract", @config.extractArgs)
  => {
    resolveResult: @resolveResult,
    deriveResult: @deriveResult,
    extractDerivedResult: @extractDerivedResult
  }
]
var @deriveChainResult = @testPlannerDeriveChain("test", {
  resolveArgs: { tool: "get_contacts", args: {}, purpose: "ground the contact list" },
  deriveArgs: {
    sources: [{ source: "resolved", record: "contact" }],
    goal: "Extract the action items into a typed array",
    schema_name: "action_items",
    name: "action_items",
    purpose: "prepare one action-item worklist"
  },
  extractArgs: {
    source: { source: "derived", name: "action_items" },
    schema: { person_name: "string", task_description: "string", deadline: "string" },
    name: "action_items_copy",
    purpose: "inspect the derived action items"
  }
}) with {
  session: @planner,
  seed: { agent: @plannerDeriveFixtureAgent, query: "Email each person in the TODO list.", state: @emptyState(), runtime: @emptyPlannerRuntime() }
}
var @plannerDeriveResolveResult = @deriveChainResult.resolveResult
var @plannerDeriveDispatchResult = @deriveChainResult.deriveResult
var @plannerExtractDerivedResult = @deriveChainResult.extractDerivedResult
