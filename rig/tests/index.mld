    suite: "fixtures",
    records: { plain_mode_message: @plain_mode_message }
  },
  @checkpointRestoredState
) | @pretty
var @checkpointRestoredOk = @checkpointRestoredSummary.includes('"id_": "msg_1"') &&
  !@checkpointRestoredSummary.includes('"id_": 1')
var @checkpointResolvedValue = @resolveRefValue(
  @checkpointRestoredState,
  {
    source: "resolved",
    record: "plain_mode_message",
    handle: "r_plain_mode_message_msg_1",
