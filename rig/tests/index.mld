var @wrappedMxDecisionPretty = `count=@wrappedMxDecisionIssues.length`
var @plannerArgShapePretty = `raw=@rawScalarDecisionPretty structured=@structuredDecisionPretty wrappedData=@wrappedDataDecisionPretty wrappedMx=@wrappedMxDecisionPretty`
