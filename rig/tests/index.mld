  }
)
var @namedStateLogPretty = `log=@namedStateLogEntries.length`
var @namedStateLogEntries = @field(@namedStateLogRetained, "execution_log") ?? []
var @namedStateLogOk = @namedStateLogEntries.length == 1 &&
  @field(@namedStateLogEntries[0], "tool") == "search_emails" &&
  @field(@namedStateLogEntries[0], "summary") == "resolved 1 email_msg record(s)"

>> Array-shaped named payloads should surface item field names to the
>> planner without leaking payload values. This keeps repeated derive /
>> execute workflows structurally usable while preserving the no-payload
>> planner summary invariant.
var @arrayPayloadMarker = "ARRAY_PAYLOAD_SECRET_MARKER"
var @arrayNamedState = {
  resolved: {},
  extracted: {},
  derived: {
    email_plan: {
      provenance: "derived",
      schema_name: "inline-schema",
      preview_fields: [],
      value: [{
        email_address: "david.lee@bluesparrowtech.com",
        subject: "Task assignment",
        body: @arrayPayloadMarker
      }]
    }
  },
  execution_log: [],
  phase_events: []
}
var @arrayPlannerSummary = @plannerVisibleState(
  {
    suite: "fixtures",
    records: {}
  },
  @arrayNamedState
) | @pretty
var @arrayWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @arrayNamedState
) | @pretty
var @arrayPreviewPretty = `planner=@arrayPlannerSummary`
var @arrayPreviewOk = @arrayPlannerSummary.includes('"email_address"') &&
  @arrayPlannerSummary.includes('"subject"') &&
  @arrayPlannerSummary.includes('"body"') &&
  !@arrayPlannerSummary.includes(@arrayPayloadMarker) &&
  @arrayWorkerSummary.includes(@arrayPayloadMarker)

var @wrappedArrayNamedState = {
  resolved: {},
  extracted: {},
  derived: {
    todo_items: {
      provenance: "derived",
      schema_name: "todo_items",
      preview_fields: [],
      value: {
        items: [{
          person_name: "David",
          task: "Coordinate with the development team.",
          deadline: "2026-04-22",
          note: @arrayPayloadMarker
        }]
      }
    }
  },
  execution_log: [],
  phase_events: []
}
var @wrappedArrayPlannerSummary = @plannerVisibleState(
  {
    suite: "fixtures",
    records: {}
  },
  @wrappedArrayNamedState
) | @pretty
var @wrappedArrayWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @wrappedArrayNamedState
) | @pretty
var @wrappedArrayPreviewPretty = `planner=@wrappedArrayPlannerSummary`
var @wrappedArrayPreviewOk = @wrappedArrayPlannerSummary.includes('"person_name"') &&
  @wrappedArrayPlannerSummary.includes('"task"') &&
  @wrappedArrayPlannerSummary.includes('"deadline"') &&
  !@wrappedArrayPlannerSummary.includes(@arrayPayloadMarker) &&
  @wrappedArrayWorkerSummary.includes(@arrayPayloadMarker)

>> Live planner/worker outputs carry runtime metadata, but execution-log
>> entries are diagnostic-only state. Flatten just the appended log
>> entry so later planner prompts and debug payloads keep the full log
>> instead of carrying wrapper metadata forward.
var @wrappedLogState = {
  resolved: {},
  extracted: {},
  derived: {},
  execution_log: [
    {
      phase: "resolve",
      tool: "seed",
      summary: "seed",
      session_id: null
    }
  ],
  phase_events: []
}
var @wrappedLogRetained = @appendExecutionLog(@wrappedLogState, {
  phase: "extract",
  name: @factValue,
  summary: @factValue,
  session_id: @factValue
})
var @wrappedLogEntries = @field(@wrappedLogRetained, "execution_log") ?? []
var @wrappedLogPretty = `log=@wrappedLogEntries.length metadata=@field(@wrappedLogEntries[1], "metadata")`
var @wrappedLogValue = `@factValue`
var @wrappedLogOk = @wrappedLogEntries.length == 2 &&
  @field(@wrappedLogEntries[1], "phase") == "extract" &&
  @field(@wrappedLogEntries[1], "name") == @wrappedLogValue &&
  @field(@wrappedLogEntries[1], "summary") == @wrappedLogValue &&
  @field(@wrappedLogEntries[1], "session_id") == @wrappedLogValue &&
  @isBlank(@field(@wrappedLogEntries[1], "metadata"))

exe @allChecks() = [
  => [
  @check("policy-build-runtime", @policyBuildRuntimeOk, @policyBuildRuntimeDetail),
  @check("CAT-1", @catalogTransparentInputRecordOk, @catalogTransparentInputRecordDetail),
  @check("CAT-2", @catalogTransparentMetadataOk, @catalogTransparentMetadataDetail),
  @check("AUTH-1", @canAuthorizeSurfaceOk, @canAuthorizeSurfaceDetail),
  @check("AUTH-2", @hardDeniedSurfaceOk, @hardDeniedSurfaceDetail),
  @check("AUTH-3", @legacyAuthorizableKeyOk, `scan=@legacyAuthorizableScan`),
  @check("BENCH-CAT-1", @workspaceBenchCatalogOk, @workspaceBenchCatalogDetail),
  @check("BENCH-CAT-2", @bankingBenchCatalogOk, @bankingBenchCatalogDetail),
  @check("BENCH-CAT-3", @slackBenchCatalogOk, @slackBenchCatalogDetail),
  @check("BENCH-CAT-4", @travelBenchCatalogOk, @travelBenchCatalogDetail),
  @check("PLANNER-ARCH-1", @singlePlannerArchitectureOk, @singlePlannerArchitectureDetail),
  @check("PLANNER-ARCH-2", @singlePlannerRunnerOk, @singlePlannerRunnerDetail),
  @check("POL-ROUNDTRIP-1", @collectionRoundtripOk, "policy.build succeeded inside a wrapper exe"),
  @check("POL-ROUNDTRIP-2", @policySectionRoundtripOk, @policySectionRoundtripDetail),
  @check("synthesized-policy-shape", @syntheticPolicyOk, @syntheticPolicyDetail),
  @check("collection-roundtrip", @collectionRoundtripOk, "policy.build succeeded inside a wrapper exe"),
  @check("tool-metadata-access", @toolMetadataOk, @toolMetadataDetail),
  @check("wrapped-arg-name-role-classification", @wrappedArgNameRoleOk, @wrappedArgNameRoleDetail),
  @check("imported-var-tools-preserve-param-metadata", @importedToolParamRoundtripOk, @importedToolParamRoundtripDetail),
  @check("input-record-tool-metadata", @inputRecordToolMetadataOk, @inputRecordToolMetadataDetail),
  @check("factsource-roundtrip", @factsourceOk, @factsourceDetail),
  @check("tool-docs-control-args", @toolDocsOk, @toolDocsDetail),
  @check("input-record-tool-docs", @inputRecordToolDocsOk, @inputRecordToolDocsDetail),
  @check("policy-sections", @policySectionsOk, @policySectionsDetail),
  @check("input-record-allow-omits-optional-fact", @optionalMeetingPolicyOk, @optionalMeetingPolicyPretty),
  @check("fixture-read-dispatch", @fixtureReadDispatchOk, @fixtureReadDispatchPretty),
  @check("built-agent-read-dispatch", @builtFixtureReadDispatchOk, @builtFixtureReadDispatchPretty),
  @check("phase-catalog-preserves-callability", @phaseCatalogDispatchOk, @phaseCatalogDispatchPretty),
  @check("phase-tool-entry-preserves-callability", @phaseToolEntryDispatchOk, @phaseToolEntryDispatchPretty),
  @check("resolve-worker-success-path", @dispatchResolveOk, @dispatchResolvePretty),
  @check("resolve-worker-scalar-keyed-path", @dispatchScalarResolveOk, @dispatchScalarResolvePretty),
  @check("planner-tool-collection-dispatch-does-not-recurse", @plannerResolveDispatchOk, @plannerResolveDispatchPretty),
  @check("planner-session-state-persists-across-direct-planner-tool-calls", @plannerResolveContactsOk, @plannerResolveContactsPretty),
  @check("planner-session-resolved-handle-remains-readable-after-direct-resolve", @plannerResolvedContactEmailOk, @plannerResolvedContactEmailPretty),
  @check("planner-source-backed-extract-works-on-direct-planner-tool-path", @plannerExtractDispatchOk, @plannerExtractDispatchPretty),
  @check("read-tool-docs-classify-all-read-params-as-control", @readArgDocOk, @readArgDocPretty),
  @check("resolve-worker-accepts-read-tool-params-without-legacy-controlArgs", @dispatchReadArgResolveOk, @dispatchReadArgResolvePretty),
  @check("execute-worker-zero-control-arg-policy", @dispatchCreateNoteOk, @dispatchCreateNotePretty),
  @check("execute-worker-optional-fact-omission", @dispatchOptionalMeetingOk, @dispatchOptionalMeetingPretty),
  @check("known-datetime-canonicalization", @dispatchNaturalDatetimeMeetingOk, @dispatchNaturalDatetimeMeetingPretty),
  @check("execute-worker-known-control-arg-policy", @dispatchKnownParticipantMeetingOk, @dispatchKnownParticipantMeetingPretty),
  @check("execute-worker-collection-input-record-policy", @dispatchKnownParticipantMeetingCollectionOk, @dispatchKnownParticipantMeetingCollectionPretty),
  @check("execute-worker-collection-derived-payload-policy", @dispatchKnownParticipantMeetingCollectionDerivedPayloadOk, @dispatchKnownParticipantMeetingCollectionDerivedPayloadPretty),
  @check("input-record-allowlist-pass", @dispatchAllowlistAllowedOk, @dispatchAllowlistAllowedPretty),
  @check("input-record-allowlist-reject", @dispatchAllowlistRejectedOk, @dispatchAllowlistRejectedPretty),
  @check("input-record-blocklist-reject", @dispatchBlocklistRejectedOk, @dispatchBlocklistRejectedPretty),
  @check("input-record-update-rejects-empty-dispatch", @dispatchUpdateMissingOk, @dispatchUpdateMissingPretty),
  @check("input-record-exact-requires-task-literal", @dispatchExactRejectedOk, @dispatchExactRejectedPretty),
  @check("single-arg-direct-dispatch-keeps-string-ids", @numericDispatchOk, @numericDispatchPretty),
  @check("single-arg-built-agent-dispatch-keeps-string-ids", @builtNumericDispatchOk, @builtNumericDispatchPretty),
  @check("wrapped-tool-name-built-agent-dispatch-keeps-string-ids", @wrappedToolNameDispatchOk, @wrappedToolNameDispatchPretty),
  @check("tool-error-envelope-only-fails-on-true", @toolEnvelopeOk, @toolEnvelopeDetail),
  @check("strict-thin-arrow", @thinArrowOk, @thinArrowSerialized),
  @check("display-projection", @displayProjectionOk, @displayProjectionDetail),
  @check("display-shorthand-array", @flatDisplayOk, @flatDisplaySummary),
  @check("display-plain-mode-keys", @plainModeOk, `planner=@plainModePlannerSummary worker=@plainModeWorkerSummary`),
  @check("display-checkpoint-identity", @checkpointRestoredOk, @checkpointRestoredSummary),
  @check("resolve-checkpoint-identity", @checkpointResolvedOk, @checkpointResolvedDetail),
  @check("execute-proof-chain", @proofChainOk, @proofChainPolicyPretty),
  @check("correlate-control-args", @correlateOk, @correlatePretty),
  @check("lowering-selection-ref", @selectionLoweredOk, @selectionLoweredPretty),
  @check("derived-control-arg-rejected", @firewallOk, @firewallPretty),
  @check("derived-resolve-control-arg-rejected", @resolveControlFirewallOk, @resolveControlFirewallPretty),
  @check("firewall-derived-to-control", @firewallOk, @firewallPretty),
  @check("allow-with-control-args", @allowOk, @allowPretty),
  @check("source-class-mismatch", @wrongSourceOk, @wrongSourcePretty),
  @check("array-control-proof", @perElementOk, @perElementPretty),
  @check("selection-keyed-control", @selectionKeyedOk, @selectionKeyedPretty),
  @check("planner-arg-shape", @plannerArgShapeOk, @plannerArgShapePretty),
  @check("scalar-extract-payload", @scalarExtractOk, `attestation=@scalarExtractPretty planner=@scalarExtractPlannerSummary worker=@scalarExtractWorkerSummary`),
  @check("planner-named-state-hides-tainted-values", @taintedPlannerProjectionOk, @taintedPlannerSummary),
  @check("worker-named-state-retains-tainted-values", @taintedWorkerProjectionOk, @taintedWorkerSummary),
  @check("execute-compile-reads-extracted-state", @extractedPayloadCompileOk, @extractedPayloadCompilePretty),
  @check("execute-compile-reads-derived-state", @derivedPayloadCompileOk, @derivedPayloadCompilePretty),
  @check("record-backed-named-state-projects-display", @recordBackedDisplayOk, @recordBackedDisplayPretty),
  @check("named-state-retains-prior-results", @namedStateOk, `planner=@namedStatePlannerSummary worker=@namedStateWorkerSummary`),
  @check("named-state-retains-execution-log", @namedStateLogOk, @namedStateLogPretty),
  @check("named-array-preview-fields", @arrayPreviewOk, @arrayPreviewPretty),
  @check("wrapped-array-preview-fields", @wrappedArrayPreviewOk, @wrappedArrayPreviewPretty),
  @check("execution-log-flattens-diagnostic-wrappers", @wrappedLogOk, @wrappedLogPretty)
  ]
]

var @checks = @allChecks()

var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Rig v2 invariant tests"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail`

if @fails.length > 0 [
  run sh { exit 1 }
]
