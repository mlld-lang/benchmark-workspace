)
var @proofChainEntries = @field(@proofChainAttempt, "compiled_entries") ?? []
var @proofChainMatches = for @entry in @proofChainEntries when @field(@entry, "arg") == "note_id" => @entry
var @proofChainEntry = @proofChainMatches[0]
var @proofChainAttestations = @field(@proofChainEntry, "flat_attestations") ?? []
var @proofChainPolicyPretty = `attestations=@proofChainAttestations`
var @proofChainFactRef = "fact:@@note_entry.id_[0]"
var @proofChainOk = @proofResolvedControl.ok &&
  @proofResolvedAttestations.includes(@proofChainFactRef) &&
  @proofWeakenedControl.ok &&
  @proofWeakenedAttestations.length == 0 &&
  @proofChainAttempt.ok &&
