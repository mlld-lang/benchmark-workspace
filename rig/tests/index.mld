]

var @checks = @allChecks()

var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check
>> xfail/ prefix marks tests that capture a known regression: the test
>> stays in the suite to document the bug + lock in the fix when it ships,
>> but doesn't block the gate. Failure of a non-xfail test still exits 1.
var @realFails = for @check in @fails when !@check.id.startsWith("xfail/") => @check
var @xfails = for @check in @fails when @check.id.startsWith("xfail/") => @check
>> xpasses: xfail tests that started passing — flip them out of xfail when this fires
var @xpasses = for @check in @passes when @check.id.startsWith("xfail/") => @check

show "Rig v2 invariant tests"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail (@xfails.length xfail, @xpasses.length xpass-flip-pending)`

if @realFails.length > 0 [
  run sh { exit 1 }
]
