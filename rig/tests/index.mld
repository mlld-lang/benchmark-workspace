  }
)
var @checkpointResolvedOk = @checkpointResolvedValue.ok &&
  @field(@checkpointResolvedValue, "value") == "msg_1"
var @checkpointResolvedDetail = @checkpointResolvedValue | @pretty

var @selectionLoweredPretty = @selectionLowered | @pretty
var @selectionLoweredOk = @selectionLowered.ok &&
  @field(@field(@selectionLowered, "ref"), "source") == "resolved" &&
  @field(@field(@selectionLowered, "ref"), "handle") == "r_contact_alice.example"

var @firewallPretty = @firewallAttempt | @pretty
var @firewallOk = !@firewallAttempt.ok && @firewallPretty.includes("payload_only_source_in_control_arg")

var @resolveControlFirewallPretty = @resolveControlFirewallAttempt | @pretty
