var @selectionKeyedPretty = @selectionKeyedAttempt | @pretty
var @selectionKeyedOk = @selectionKeyedAttempt.ok

>> Proof-chain invariant: resolved fact-bearing values must carry their
>> factsource attestations all the way into the execute compiler's flat
>> policy intent. This is the core resolved -> execute security path.
var @proofChainRef = {
  source: "resolved",
  record: "note_entry",
  handle: "r_note_entry_note_1",
  field: "id_"
}
var @proofResolvedControl = @resolveControlRefValue(@sampleState, @proofChainRef)
var @proofResolvedAttestations = @field(@proofResolvedControl, "policy_attestations") ?? []
var @weakenedState = {
  resolved: {
    note_entry: [{
      handle: "r_note_entry_note_1",
      key: "note_1",
      value: { id_: "note_1", title: "Todo", content: "Existing note body" },
      field_values: { id_: "note_1", title: "Todo", content: "Existing note body" }
    }]
  },
  extracted: {},
  derived: {},
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @proofWeakenedControl = @resolveControlRefValue(@weakenedState, @proofChainRef)
var @proofWeakenedAttestations = @field(@proofWeakenedControl, "policy_attestations") ?? []
var @proofChainAttempt = @compileExecuteIntent(
  @sampleState,
  @tools,
  {
    phase: "execute",
    operation: "append_note",
    args: {
      note_id: @proofChainRef,
      content: { source: "known", value: "append a status line" }
    }
  },
  "append a status line"
)
var @proofChainEntries = @field(@proofChainAttempt, "compiled_entries") ?? []
var @proofChainMatches = for @entry in @proofChainEntries when @field(@entry, "arg") == "note_id" => @entry
var @proofChainEntry = @proofChainMatches[0]
var @proofChainAttestations = @field(@proofChainEntry, "flat_attestations") ?? []
var @proofChainPolicyPretty = @field(@proofChainAttempt, "policy_intent") | @pretty
var @proofChainFactRef = "fact:@@note_entry.id_"
var @proofChainOk = @proofResolvedControl.ok &&
  @proofResolvedAttestations.includes(@proofChainFactRef) &&
  @proofWeakenedControl.ok &&
  @proofWeakenedAttestations.length == 0 &&
  @proofChainAttempt.ok &&
  @proofChainPolicyPretty.includes(@proofChainFactRef)

>> Dispatch-time correlate-control-args invariant: once execute intent
>> compilation has produced concrete backing refs for control args, the
>> correlate check must reject mixed resolved records.
exe execute:w, comm:w, tool:w @share_note_with_contact(note_id, recipient) = [
  => {
    note_id: @note_id,
    recipient: @recipient
  }
] with { controlArgs: ["note_id", "recipient"], correlateControlArgs: true }

var @correlateTools = {
  share_note_with_contact: {
    kind: "write",
    mlld: @share_note_with_contact,
    operation: {
      controlArgs: ["note_id", "recipient"],
      payloadArgs: [],
      risk: ["comm:w"],
      authorizable: true,
      semantics: "Share one note with one recipient.",
      correlateControlArgs: true
    }
  }
}

var @correlateIntent = @compileExecuteIntent(
  @sampleState,
  @correlateTools,
  {
    phase: "execute",
    operation: "share_note_with_contact",
    args: {
      note_id: {
        source: "resolved",
        record: "note_entry",
        handle: "r_note_entry_note_1",
        field: "id_"
      },
      recipient: {
        source: "resolved",
        record: "contact",
        handle: "r_contact_alice.example",
        field: "email"
      }
    }
  },
  "Share note_1 with alice.example."
)
var @correlateEntries = @field(@correlateIntent, "compiled_entries") ?? []
var @correlateControlArgs = ["note_id", "recipient"]
var @correlateCheck = @correlatedControlArgsCheck(@correlateEntries, @correlateControlArgs)
var @correlatePretty = @correlateCheck | @pretty
var @correlateOk = @correlateIntent.ok &&
  !@field(@correlateCheck, "ok") &&
  @field(@correlateCheck, "error") == "correlate_control_args_cross_record_mixture"

var @rawScalarDecisionPretty = @rawScalarDecisionIssues | @pretty
var @structuredDecisionPretty = @structuredDecisionIssues | @pretty
var @plannerArgShapePretty = `raw=@rawScalarDecisionPretty structured=@structuredDecisionPretty`
var @plannerArgShapeOk = @rawScalarDecisionIssues.length == 1 &&
  @field(@rawScalarDecisionIssues[0], "field") == "message_id" &&
  @structuredDecisionIssues.length == 0

>> Source-backed `schema: "text"` extracts are valid benchmark behavior.
>> Keep a direct regression here so the worker coercer cannot silently
>> demote scalar payloads back to null and strand the planner in a
>> resolve/extract loop.
var @scalarExtractAttestation = @coerceExtractAttestation({
  status: "extracted",
  schema_name: "text",
  name: "body_text",
  provenance: "extracted",
  preview_fields: [],
  payload: "bounded text payload"
})
var @scalarExtractState = {
  resolved: {},
  extracted: {
    body_text: {
      provenance: "extracted",
      schema_name: "text",
      preview_fields: [],
      value: @field(@scalarExtractAttestation, "payload")
    }
  },
  derived: {},
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @scalarExtractPlannerSummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @scalarExtractState
) | @pretty
var @scalarExtractWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @scalarExtractState
) | @pretty
var @scalarExtractPretty = @scalarExtractAttestation | @pretty
var @scalarExtractOk = @field(@scalarExtractAttestation, "payload") == "bounded text payload" &&
  !@scalarExtractPlannerSummary.includes('"bounded text payload"') &&
  @scalarExtractPlannerSummary.includes('"fields": []') &&
  @scalarExtractWorkerSummary.includes('"bounded text payload"')

>> Security invariant: planner-facing named-state projection must never
>> include payload values from extracted or derived state. The planner
>> only needs schema/field structure so it can emit refs by name.
var @taintedExtractMarker = "ATTACKER_INJECTED_PAYLOAD_MARKER"
var @taintedDerivedMarker = "DERIVED_ATTACK_PAYLOAD_MARKER"
var @stateWithTaintedNamedValues = {
  resolved: {},
  extracted: {
    email_task: {
      provenance: "extracted",
      schema_name: "email_task_payload",
      preview_fields: ["body", "metadata"],
      value: {
        body: `legitimate preamble @taintedExtractMarker continues here`,
        metadata: {
          nested: `nested @taintedExtractMarker content`
        }
      }
    }
  },
  derived: {
    ranked_choice: {
      provenance: "derived",
      schema_name: "inline-schema",
      preview_fields: ["body", "nested"],
      value: {
        body: `derived preamble @taintedDerivedMarker continues here`,
        nested: {
          note: `nested @taintedDerivedMarker content`
        }
      },
      selection_refs: [{
        source: "selection",
        backing: {
          record: "contact",
          handle: "r_contact_alice.example"
        }
      }]
    }
  },
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @taintedPlannerSummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @stateWithTaintedNamedValues
) | @pretty
var @taintedWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @stateWithTaintedNamedValues
) | @pretty
var @taintedPlannerProjectionOk = !@taintedPlannerSummary.includes(@taintedExtractMarker) &&
  !@taintedPlannerSummary.includes(@taintedDerivedMarker) &&
  @taintedPlannerSummary.includes('"schema_name": "email_task_payload"') &&
  @taintedPlannerSummary.includes('"schema_name": "inline-schema"') &&
  @taintedPlannerSummary.includes('"selection_refs"')
var @taintedWorkerProjectionOk = @taintedWorkerSummary.includes(@taintedExtractMarker) &&
  @taintedWorkerSummary.includes(@taintedDerivedMarker)
var @extractedPayloadCompile = @compileExecuteIntent(
  @stateWithTaintedNamedValues,
  @tools,
  {
    phase: "execute",
    operation: "create_note",
    args: {
      content: { source: "extracted", name: "email_task", field: "body" }
    }
  },
  "create a note from extracted content"
)
var @derivedPayloadCompile = @compileExecuteIntent(
  @stateWithTaintedNamedValues,
  @tools,
  {
    phase: "execute",
    operation: "create_note",
    args: {
      content: { source: "derived", name: "ranked_choice", field: "body" }
    }
  },
  "create a note from derived content"
)
var @extractedPayloadCompileOk = @extractedPayloadCompile.ok &&
  @field(@field(@extractedPayloadCompile, "compiled_args"), "content").includes(@taintedExtractMarker)
var @derivedPayloadCompileOk = @derivedPayloadCompile.ok &&
  @field(@field(@derivedPayloadCompile, "compiled_args"), "content").includes(@taintedDerivedMarker)
var @extractedPayloadCompilePretty = @extractedPayloadCompile | @pretty
var @derivedPayloadCompilePretty = @derivedPayloadCompile | @pretty

var @recordBackedMarker = "RECORD_BACKED_BODY_MARKER"
var @recordBackedNestedMarker = "RECORD_BACKED_NOTE_MARKER"
>> Deliberately hostile preview_fields prove planner summaries derive
>> field names from the live value rather than trusting stored metadata.
var @recordBackedNamedState = {
  resolved: {},
  extracted: {
    selected_message: {
      provenance: "extracted",
      schema_name: "named_display_extract",
      preview_fields: ["Quarterly update", @recordBackedMarker, @recordBackedNestedMarker],
      value: {
        id_: "msg_42",
        subject: "Quarterly update",
        body: `line one
middle @recordBackedMarker
line end @recordBackedMarker`,
        note: `nested field @recordBackedNestedMarker`
      } as record @named_display_extract
    }
  },
  derived: {},
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @recordBackedPlannerSummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: {
      named_display_extract: @named_display_extract
    }
  },
  @recordBackedNamedState
) | @pretty
var @recordBackedCompile = @compileExecuteIntent(
  @recordBackedNamedState,
  @tools,
  {
    phase: "execute",
    operation: "create_note",
    args: {
      content: { source: "extracted", name: "selected_message", field: "body" }
    }
  },
  "create a note from the hidden body"
)
var @recordBackedDisplayOk = @recordBackedPlannerSummary.includes('"display"') &&
  @recordBackedPlannerSummary.includes('"Quarterly update"') &&
  @recordBackedPlannerSummary.includes('"id_": "msg_42"') &&
  !@recordBackedPlannerSummary.includes(@recordBackedMarker) &&
  !@recordBackedPlannerSummary.includes(@recordBackedNestedMarker) &&
  !@recordBackedPlannerSummary.includes('"Quarterly update","RECORD_BACKED_BODY_MARKER"') &&
  @recordBackedCompile.ok &&
  @field(@field(@recordBackedCompile, "compiled_args"), "content").includes(@recordBackedMarker) &&
  !@field(@field(@recordBackedCompile, "compiled_args"), "content").includes(@recordBackedNestedMarker)
var @recordBackedDisplayPretty = `planner=@recordBackedPlannerSummary compile=@recordBackedCompile`

>> Named extract/derive results are updated incrementally through the
>> planner loop. Keep a focused regression here so adding a later named
>> result cannot demote the earlier ones back to null in the planner
>> summary.
var @namedStateBodyMarker = "ATTACKER_INJECTED_BODY_MARKER"
var @namedStateTitleMarker = "ATTACKER_INJECTED_TITLE_MARKER"
var @namedStateRoomMarker = "ATTACKER_INJECTED_ROOM_MARKER"
var @namedStateBase = {
  resolved: {},
  extracted: {},
  derived: {},
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @namedStateAfterFirstExtract = @updateNamedState(
  @namedStateBase,
  "extracted",
  "meeting_invitation_body",
  {
    provenance: "extracted",
    schema_name: "text",
    preview_fields: [],
    value: @namedStateBodyMarker
  }
)
var @namedStateAfterDerive = @updateNamedState(
  @namedStateAfterFirstExtract,
  "derived",
  "event_details",
  {
    provenance: "derived",
    schema_name: "inline-schema",
    preview_fields: ["event_title", "start_time"],
    value: {
      event_title: @namedStateTitleMarker,
      start_time: "2026-05-12T09:00:00",
      room_note: @namedStateRoomMarker
    }
  }
)
var @namedStateAfterSecondExtract = @updateNamedState(
  @namedStateAfterDerive,
  "extracted",
  "room_context",
  {
    provenance: "extracted",
    schema_name: "inline-schema",
    preview_fields: ["room_name"],
    value: {
      room_name: @namedStateRoomMarker
    }
  }
)
var @namedStatePlannerSummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @namedStateAfterSecondExtract
) | @pretty
var @namedStateWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @namedStateAfterSecondExtract
) | @pretty
var @namedStateExecutionLogPretty = @field(@namedStateAfterSecondExtract, "execution_log") | @pretty
var @namedStateOk = @namedStatePlannerSummary.includes('"meeting_invitation_body"') &&
  !@namedStatePlannerSummary.includes(@namedStateBodyMarker) &&
  !@namedStatePlannerSummary.includes(@namedStateTitleMarker) &&
  !@namedStatePlannerSummary.includes(@namedStateRoomMarker) &&
  @namedStateWorkerSummary.includes(@namedStateBodyMarker) &&
  @namedStateWorkerSummary.includes(@namedStateTitleMarker) &&
  @namedStateWorkerSummary.includes(@namedStateRoomMarker)

>> Array-valued state fields often pass through helper exe parameters as
>> object-like collections. Keep a direct regression for execution-log
>> retention so source-backed extract/derive updates cannot silently
>> erase earlier phase history and trip planner guards later.
var @namedStateWithExecutionLog = {
  resolved: {},
  extracted: {},
  derived: {},
  execution_log: [
    {
      phase: "resolve",
      tool: "search_emails",
      summary: "resolved 1 email_msg record(s)",
      session_id: null
    }
  ],
  planner_session_id: null,
  phase_events: []
}
var @namedStateLogRetained = @updateNamedState(
  @namedStateWithExecutionLog,
  "extracted",
  "meeting_invitation_body",
  {
    provenance: "extracted",
    value: @namedStateBodyMarker
  }
)
var @namedStateLogPretty = @field(@namedStateLogRetained, "execution_log") | @pretty
var @namedStateLogEntries = @field(@namedStateLogRetained, "execution_log") ?? []
var @namedStateLogOk = @namedStateLogEntries.length == 1 &&
  @field(@namedStateLogEntries[0], "tool") == "search_emails" &&
  @field(@namedStateLogEntries[0], "summary") == "resolved 1 email_msg record(s)"

>> Live planner/worker outputs carry runtime metadata, but execution-log
>> entries are diagnostic-only state. Flatten just the appended log
>> entry so later planner prompts and debug payloads keep the full log
>> instead of carrying wrapper metadata forward.
var @wrappedLogState = {
  resolved: {},
  extracted: {},
  derived: {},
  execution_log: [
    {
      phase: "resolve",
      tool: "seed",
      summary: "seed",
      session_id: null
    }
  ],
  planner_session_id: null,
  phase_events: []
}
var @wrappedLogRetained = @appendExecutionLog(@wrappedLogState, {
  phase: "extract",
  name: @factValue,
  summary: @factValue,
  session_id: @factValue
})
var @wrappedLogEntries = @field(@wrappedLogRetained, "execution_log") ?? []
var @wrappedLogPretty = @field(@wrappedLogRetained, "execution_log") | @pretty
var @wrappedLogValue = `@factValue`
var @wrappedLogOk = @wrappedLogEntries.length == 2 &&
  @field(@wrappedLogEntries[1], "phase") == "extract" &&
  @field(@wrappedLogEntries[1], "name") == @wrappedLogValue &&
  @field(@wrappedLogEntries[1], "summary") == @wrappedLogValue &&
  @field(@wrappedLogEntries[1], "session_id") == @wrappedLogValue &&
  !@wrappedLogPretty.includes('"metadata"')

var @checks = [
  @check("policy-build-runtime", @policyBuildRuntimeOk, @policyBuildRuntimeDetail),
  @check("synthesized-policy-shape", @syntheticPolicyOk, @syntheticPolicyDetail),
  @check("collection-roundtrip", @collectionRoundtripOk, "policy.build succeeded inside a wrapper exe"),
  @check("tool-metadata-access", @toolMetadataOk, @toolMetadataDetail),
  @check("input-record-tool-metadata", @inputRecordToolMetadataOk, @inputRecordToolMetadataDetail),
  @check("factsource-roundtrip", @factsourceOk, @factsourceDetail),
  @check("tool-docs-control-args", @toolDocsOk, @toolDocsDetail),
  @check("input-record-tool-docs", @inputRecordToolDocsOk, @inputRecordToolDocsDetail),
  @check("input-record-allow-rejected", @optionalMeetingPolicyOk, @optionalMeetingPolicyPretty),
  @check("fixture-read-dispatch", @fixtureReadDispatchOk, @fixtureReadDispatchPretty),
  @check("built-agent-read-dispatch", @builtFixtureReadDispatchOk, @builtFixtureReadDispatchPretty),
  @check("phase-catalog-preserves-callability", @phaseCatalogDispatchOk, @phaseCatalogDispatchPretty),
  @check("phase-tool-entry-preserves-callability", @phaseToolEntryDispatchOk, @phaseToolEntryDispatchPretty),
  @check("resolve-worker-success-path", @dispatchResolveOk, @dispatchResolvePretty),
  @check("resolve-worker-scalar-keyed-path", @dispatchScalarResolveOk, @dispatchScalarResolvePretty),
  @check("execute-worker-zero-control-arg-policy", @dispatchCreateNoteOk, @dispatchCreateNotePretty),
  @check("execute-worker-optional-fact-omission", @dispatchOptionalMeetingOk, @dispatchOptionalMeetingPretty),
  @check("single-arg-direct-dispatch-keeps-string-ids", @numericDispatchOk, @numericDispatchPretty),
  @check("tool-error-envelope-only-fails-on-true", @toolEnvelopeOk, @toolEnvelopeDetail),
  @check("strict-thin-arrow", @thinArrowOk, @thinArrowSerialized),
  @check("display-projection", @displayProjectionOk, @displayProjectionDetail),
  @check("display-shorthand-array", @flatDisplayOk, @flatDisplaySummary),
  @check("display-plain-mode-keys", @plainModeOk, `planner=@plainModePlannerSummary worker=@plainModeWorkerSummary`),
  @check("display-checkpoint-identity", @checkpointRestoredOk, @checkpointRestoredSummary),
  @check("resolve-checkpoint-identity", @checkpointResolvedOk, @checkpointResolvedDetail),
  @check("execute-proof-chain", @proofChainOk, @proofChainPolicyPretty),
  @check("correlate-control-args", @correlateOk, @correlatePretty),
  @check("lowering-selection-ref", @selectionLoweredOk, @selectionLoweredPretty),
  @check("derived-control-arg-rejected", @firewallOk, @firewallPretty),
  @check("derived-resolve-control-arg-rejected", @resolveControlFirewallOk, @resolveControlFirewallPretty),
  @check("firewall-derived-to-control", @firewallOk, @firewallPretty),
  @check("allow-with-control-args", @allowOk, @allowPretty),
  @check("source-class-mismatch", @wrongSourceOk, @wrongSourcePretty),
  @check("array-control-proof", @perElementOk, @perElementPretty),
  @check("selection-keyed-control", @selectionKeyedOk, @selectionKeyedPretty),
  @check("planner-arg-shape", @plannerArgShapeOk, @plannerArgShapePretty),
  @check("scalar-extract-payload", @scalarExtractOk, `attestation=@scalarExtractPretty planner=@scalarExtractPlannerSummary worker=@scalarExtractWorkerSummary`),
  @check("planner-named-state-hides-tainted-values", @taintedPlannerProjectionOk, @taintedPlannerSummary),
  @check("worker-named-state-retains-tainted-values", @taintedWorkerProjectionOk, @taintedWorkerSummary),
  @check("execute-compile-reads-extracted-state", @extractedPayloadCompileOk, @extractedPayloadCompilePretty),
  @check("execute-compile-reads-derived-state", @derivedPayloadCompileOk, @derivedPayloadCompilePretty),
  @check("record-backed-named-state-projects-display", @recordBackedDisplayOk, @recordBackedDisplayPretty),
  @check("named-state-retains-prior-results", @namedStateOk, `planner=@namedStatePlannerSummary worker=@namedStateWorkerSummary`),
  @check("named-state-retains-execution-log", @namedStateLogOk, @namedStateLogPretty),
  @check("execution-log-flattens-diagnostic-wrappers", @wrappedLogOk, @wrappedLogPretty)
]

var @passes = for @check in @checks when @check.status == "PASS" => @check
var @fails = for @check in @checks when @check.status == "FAIL" => @check

show "Rig v2 invariant tests"
show ""
for @check in @checks => show `[@check.status] @check.id  @check.detail`
show ""
show `summary: @passes.length pass / @fails.length fail`

if @fails.length > 0 [
  run sh { exit 1 }
]
