>> ── c-0a6b: known-value task-text token match ──
>> A 2-digit numeric literal must not launder past @knownInTask by
>> matching inside a longer number or date component. The failing bug:
>> planner passed { source: "known", value: "24" } for event_id, and the
>> substring "24" appeared only inside the date "2026-04-24". Fix enforces
>> token-boundary matching for numeric literals.
var @c0a6bSubstringCompile = @compileExecuteIntent(
  @ut8State,
  @ut8CollectionTools,
  {
    phase: "execute",
    operation: "add_calendar_event_participants",
    args: {
      event_id: { source: "known", value: "24" },
      participants: [{ source: "known", value: "bob@test.com" }]
    }
  },
  "Please add bob@test.com to the 'Introductory meeting' event on 2026-04-24."
)
var @c0a6bSubstringIssue = for @issue in (@c0a6bSubstringCompile.issues ?? []) when @issue.error == "known_value_not_in_task_text" && @issue.value == "24" => @issue
var @c0a6bSubstringOk = @c0a6bSubstringCompile.ok == false && @c0a6bSubstringIssue.length == 1
var @c0a6bSubstringPretty = `ok=@c0a6bSubstringCompile.ok issues=@c0a6bSubstringCompile.issues.length rejected_value=@c0a6bSubstringIssue[0].value`

>> Positive case: the same numeric value is accepted when it appears as a
>> standalone token ("event 24 now"), proving the fix does not break
>> legitimate user-typed id intent.
var @c0a6bTokenCompile = @compileExecuteIntent(
  @ut8State,
  @ut8CollectionTools,
  {
    phase: "execute",
    operation: "add_calendar_event_participants",
    args: {
      event_id: { source: "known", value: "24" },
      participants: [{ source: "known", value: "bob@test.com" }]
    }
  },
  "Add bob@test.com to event 24 please."
)
var @c0a6bTokenOk = @c0a6bTokenCompile.ok == true
var @c0a6bTokenPretty = `ok=@c0a6bTokenCompile.ok`

>> ============================================================
>> STATE-PROJECTION CONTRACT (c-63fe rework regression guard)
>> ============================================================
>>
>> The OOM agent's investigation (c-63fe notes 2026-04-25) identified
>> @mergeResolvedEntries (O(existing × incoming) filter+concat) and
>> @plannerVisibleState (rebuilds all projections every iteration) as
>> the dominant memory + time cost on travel-shaped workloads. The
>> indexed-prototype at /Users/adam/mlld/mlld/tmp/rig-memory-repro/
>> showed 10x improvement (250-row/1000-entries: baseline aborted at
>> 1.7GB; prototype 12.3s @ 1.04GB).
>>
>> These assertions lock in the BEHAVIORAL CONTRACT any rework must
>> preserve. They run cheap (no LLM, synthetic state) and catch
>> correctness regressions if the merge or projection path changes
>> shape. Performance harness lives separately (tmp/).
>>
>> Contract:
>>   1. mergeResolvedEntries dedups by handle; on collision, non-null
>>      incoming fields win and existing fields are preserved when
>>      incoming is null/undefined (c-5a24 — partial-record resolves
>>      accumulate instead of clobbering)
>>   2. updateResolvedState only mutates the named record bucket
>>   3. plannerVisibleState is idempotent given identical state
>>   4. After update, projection includes the new entries
>>   5. Family expansion sees the up-to-date state
>>   6. factsources survive projection so policy compile still works

var @spA1Existing = [
  { handle: "h1", key: "k1", identity_field: "name", identity_value: "alpha", field_values: { name: "alpha", city: "Paris" } },
  { handle: "h2", key: "k2", identity_field: "name", identity_value: "beta",  field_values: { name: "beta",  city: "Paris" } }
]
var @spA1Incoming = [
  { handle: "h1", key: "k1", identity_field: "name", identity_value: "alpha-updated", field_values: { name: "alpha-updated", city: "Paris" } },
  { handle: "h3", key: "k3", identity_field: "name", identity_value: "gamma", field_values: { name: "gamma", city: "Paris" } }
]
var @spA1Merged = @mergeResolvedEntries(@spA1Existing, @spA1Incoming)
var @spA1H1Matches = for @e in @spA1Merged when @e.handle == "h1" => @e.identity_value
var @spA1H2Matches = for @e in @spA1Merged when @e.handle == "h2" => @e.identity_value
var @spA1H3Matches = for @e in @spA1Merged when @e.handle == "h3" => @e.identity_value
var @spA1H1 = @spA1H1Matches[0]
var @spA1H2 = @spA1H2Matches[0]
var @spA1H3 = @spA1H3Matches[0]
var @spA1Ok =
  @spA1Merged.length == 3 &&
  @spA1H1 == "alpha-updated" &&
  @spA1H2 == "beta" &&
  @spA1H3 == "gamma"
var @spA1Pretty = `merged.length=@spA1Merged.length h1=@spA1H1 h2=@spA1H2 h3=@spA1H3`

var @spA2Empty = @mergeResolvedEntries([], @spA1Incoming)
var @spA2Ok = @spA2Empty.length == 2 && @spA2Empty[0].handle == "h1" && @spA2Empty[1].handle == "h3"
var @spA2Pretty = `from-empty.length=@spA2Empty.length`

var @spA3Unchanged = @mergeResolvedEntries(@spA1Existing, [])
var @spA3Ok = @spA3Unchanged.length == 2 && @spA3Unchanged[0].handle == "h1" && @spA3Unchanged[1].handle == "h2"
var @spA3Pretty = `no-incoming.length=@spA3Unchanged.length`

>> Two incoming with same handle: last wins
var @spA4DupIncoming = [
  { handle: "h9", key: "k9", identity_field: "name", identity_value: "first",  field_values: { name: "first" } },
  { handle: "h9", key: "k9", identity_field: "name", identity_value: "second", field_values: { name: "second" } }
]
var @spA4Merged = @mergeResolvedEntries([], @spA4DupIncoming)
var @spA4Ok = @spA4Merged.length == 1 && @spA4Merged[0].identity_value == "second"
var @spA4Pretty = `dup-incoming.length=@spA4Merged.length last=@spA4Merged[0].identity_value`

>> c-5a24: partial-field merge — disjoint fields from successive resolves
>> with the same handle accumulate. Travel's get_hotels_address +
>> get_hotels_prices canonical sequence.
var @spA5AddressEntry = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: "23 Rue Lepic" }
}
var @spA5PriceEntry = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", price_range: "100" }
}
var @spA5Bucket1 = @mergeResolvedEntries([], [@spA5AddressEntry])
var @spA5Bucket2 = @mergeResolvedEntries(@spA5Bucket1, [@spA5PriceEntry])
var @spA5Items = @bucketItems(@spA5Bucket2)
var @spA5Entry = @spA5Items[0]
var @spA5Ok =
  @spA5Items.length == 1 &&
  @spA5Entry.field_values.address == "23 Rue Lepic" &&
  @spA5Entry.field_values.price_range == "100" &&
  @spA5Entry.field_values.name == "Hotel X"
var @spA5Pretty = `address=@spA5Entry.field_values.address price=@spA5Entry.field_values.price_range`

>> c-5a24: null incoming doesn't clobber existing field.
var @spA6Existing = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: "23 Rue Lepic" }
}
var @spA6IncomingNull = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: null }
}
var @spA6Bucket1 = @mergeResolvedEntries([], [@spA6Existing])
var @spA6Bucket2 = @mergeResolvedEntries(@spA6Bucket1, [@spA6IncomingNull])
var @spA6Items = @bucketItems(@spA6Bucket2)
var @spA6Ok = @spA6Items[0].field_values.address == "23 Rue Lepic"
var @spA6Pretty = `address=@spA6Items[0].field_values.address (existing preserved)`

>> c-5a24: non-null incoming overrides existing field.
var @spA7OldEntry = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: "OLD" }
}
var @spA7NewEntry = {
  handle: "h-hotel", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  field_values: { name: "Hotel X", address: "NEW" }
}
var @spA7Bucket1 = @mergeResolvedEntries([], [@spA7OldEntry])
var @spA7Bucket2 = @mergeResolvedEntries(@spA7Bucket1, [@spA7NewEntry])
var @spA7Items = @bucketItems(@spA7Bucket2)
var @spA7Ok = @spA7Items[0].field_values.address == "NEW"
var @spA7Pretty = `address=@spA7Items[0].field_values.address (incoming wins)`

>> c-5a24: worker projection sees both fields after partial-record merge.
>> This is the end-to-end shape compose actually consumes.
record @spA8Hotel = {
  facts: [name: string],
  data: { trusted: [address: string?, price_range: string?] },
  key: name,
  display: {
    worker: [{ ref: "name" }, address, price_range],
    planner: [{ ref: "name" }, address, price_range]
  }
}
var @spA8Records = { hotel: @spA8Hotel }
var @spA8AddressEntry = {
  handle: "r_hotel_HotelX", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  value: { name: "Hotel X", address: "23 Rue Lepic" },
  field_values: { name: "Hotel X", address: "23 Rue Lepic" }
}
var @spA8PriceEntry = {
  handle: "r_hotel_HotelX", key: "Hotel X", identity_field: "name", identity_value: "Hotel X",
  value: { name: "Hotel X", price_range: "100" },
  field_values: { name: "Hotel X", price_range: "100" }
}
var @spA8Bucket1 = @mergeResolvedEntries([], [@spA8AddressEntry])
var @spA8Bucket2 = @mergeResolvedEntries(@spA8Bucket1, [@spA8PriceEntry])
var @spA8State = { resolved: { hotel: @spA8Bucket2 }, extracted: {}, derived: {}, extract_sources: {} }
var @spA8Summary = @workerStateSummary({ records: @spA8Records }, @spA8State)
var @spA8Hotel0 = @spA8Summary.resolved.hotel[0]
var @spA8Ok =
  @spA8Hotel0.address == "23 Rue Lepic" &&
  @spA8Hotel0.price_range == "100"
var @spA8Pretty = `worker.address=@spA8Hotel0.address worker.price_range=@spA8Hotel0.price_range`

>> updateResolvedState: only the named bucket mutates
var @spB1State = {
  resolved: {
    contact: [{ handle: "c1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice" } }],
    other: [{ handle: "o1", key: "x", identity_field: "name", identity_value: "x", field_values: { name: "x" } }]
  },
  extracted: { ext1: { provenance: "extracted", value: "preserved" } },
  derived: { der1: { provenance: "derived", value: "preserved" } },
  extract_sources: { src1: "name1" }
}
var @spB1NewContacts = [
  { handle: "c2", key: "bob", identity_field: "name", identity_value: "bob", field_values: { name: "bob" } }
]
var @spB1Updated = @updateResolvedState(@spB1State, "contact", @spB1NewContacts)
var @spB1Ok =
  @spB1Updated.resolved.contact.length == 2 &&
  @spB1Updated.resolved.other.length == 1 &&
  @spB1Updated.extracted.ext1.value == "preserved" &&
  @spB1Updated.derived.der1.value == "preserved" &&
  @spB1Updated.extract_sources.src1 == "name1"
var @spB1Pretty = `contact=@spB1Updated.resolved.contact.length other=@spB1Updated.resolved.other.length ext.preserved=@spB1Updated.extracted.ext1.value`

>> c-eda4: parallel resolve_batch state-merge contract.
>>
>> Two specs in a batch run in parallel against the same initial state.
>> Each returns a phaseResult.state = initial + thatSpecsWrites. Phase B
>> settle must accumulate per-record-bucket atop a running cumulative
>> state via @batchSpecMergeState. Pre-fix: second spec's settle wiped
>> first spec's writes.
var @spB2Initial = @emptyState()
var @spB2HotelEntries = [
  { handle: "r_hotel_A", key: "Hotel A", identity_field: "name", identity_value: "Hotel A", field_values: { name: "Hotel A" } }
]
var @spB2RestEntries = [
  { handle: "r_restaurant_X", key: "X", identity_field: "name", identity_value: "X", field_values: { name: "X" } },
  { handle: "r_restaurant_Y", key: "Y", identity_field: "name", identity_value: "Y", field_values: { name: "Y" } }
]
var @spB2HotelSpecState = @updateResolvedState(@spB2Initial, "hotel", @spB2HotelEntries)
var @spB2RestSpecState  = @updateResolvedState(@spB2Initial, "restaurant", @spB2RestEntries)
var @spB2HotelPhaseResult = { state: @spB2HotelSpecState, result: { record_type: "hotel", count: 1, handles: ["r_hotel_A"], summary: "" } }
var @spB2RestPhaseResult  = { state: @spB2RestSpecState,  result: { record_type: "restaurant", count: 2, handles: ["r_restaurant_X", "r_restaurant_Y"], summary: "" } }
var @spB2Agent = { records: {} }
var @spB2After1 = @batchSpecMergeState(@spB2Initial, @spB2HotelPhaseResult, @spB2Agent)
var @spB2After2 = @batchSpecMergeState(@spB2After1, @spB2RestPhaseResult, @spB2Agent)
var @spB2HotelLen = @bucketLength(@spB2After2.resolved.hotel ?? {})
var @spB2RestLen  = @bucketLength(@spB2After2.resolved.restaurant ?? {})
var @spB2Ok = @spB2HotelLen == 1 && @spB2RestLen == 2
var @spB2Pretty = `hotels=@spB2HotelLen restaurants=@spB2RestLen (both survive parallel settle)`

>> c-eda4: error spec leaves cumulative state unchanged.
var @spB3ErrPhaseResult = { error: "intent_compile_failed", state: @spB2Initial, result: {} }
var @spB3After = @batchSpecMergeState(@spB2After2, @spB3ErrPhaseResult, @spB2Agent)
var @spB3HotelLen = @bucketLength(@spB3After.resolved.hotel ?? {})
var @spB3RestLen  = @bucketLength(@spB3After.resolved.restaurant ?? {})
var @spB3Ok = @spB3HotelLen == 1 && @spB3RestLen == 2
var @spB3Pretty = `errspec.hotels=@spB3HotelLen errspec.restaurants=@spB3RestLen (unchanged on error)`

>> c-eda4: same record-type from two specs accumulates field-level via
>> @mergeResolvedEntries (relies on c-5a24 field merge).
var @spB4HotelAddrEntry = { handle: "r_hotel_A", key: "Hotel A", identity_field: "name", identity_value: "Hotel A", field_values: { name: "Hotel A", address: "1 Rue X" } }
var @spB4HotelPriceEntry = { handle: "r_hotel_A", key: "Hotel A", identity_field: "name", identity_value: "Hotel A", field_values: { name: "Hotel A", price_range: "100" } }
var @spB4HotelAddrState  = @updateResolvedState(@spB2Initial, "hotel", [@spB4HotelAddrEntry])
var @spB4HotelPriceState = @updateResolvedState(@spB2Initial, "hotel", [@spB4HotelPriceEntry])
var @spB4HotelAddrPR = { state: @spB4HotelAddrState, result: { record_type: "hotel", count: 1, handles: ["r_hotel_A"] } }
var @spB4HotelPricePR = { state: @spB4HotelPriceState, result: { record_type: "hotel", count: 1, handles: ["r_hotel_A"] } }
var @spB4After1 = @batchSpecMergeState(@spB2Initial, @spB4HotelAddrPR, @spB2Agent)
var @spB4After2 = @batchSpecMergeState(@spB4After1, @spB4HotelPricePR, @spB2Agent)
var @spB4Items = @bucketItems(@spB4After2.resolved.hotel)
var @spB4Entry = @spB4Items[0]
var @spB4Ok =
  @spB4Items.length == 1 &&
  @spB4Entry.field_values.address == "1 Rue X" &&
  @spB4Entry.field_values.price_range == "100"
var @spB4Pretty = `same-record-type-merge: addr=@spB4Entry.field_values.address price=@spB4Entry.field_values.price_range`

>> plannerVisibleState idempotency: same state → same projection.
>> Compare structurally on resolved bucket keys + per-bucket handles.
var @spC1State = @updateResolvedState(@emptyState(), "contact", [
  { handle: "spc1-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice" }, value: { name: "alice" } },
  { handle: "spc1-h2", key: "bob",   identity_field: "name", identity_value: "bob",   field_values: { name: "bob" },   value: { name: "bob" } }
])
var @spC1Vis1 = @plannerVisibleState(@builtFixtureAgent, @spC1State)
var @spC1Vis2 = @plannerVisibleState(@builtFixtureAgent, @spC1State)
var @spC1V1Contacts = @spC1Vis1.resolved.contact ?? []
var @spC1V2Contacts = @spC1Vis2.resolved.contact ?? []
var @spC1V1Handles = for @e in @spC1V1Contacts => @e.handle
var @spC1V2Handles = for @e in @spC1V2Contacts => @e.handle
var @spC1Ok =
  @spC1V1Contacts.length == 2 &&
  @spC1V2Contacts.length == 2 &&
  @spC1V1Handles[0] == @spC1V2Handles[0] &&
  @spC1V1Handles[1] == @spC1V2Handles[1]
var @spC1Pretty = `len=@spC1V1Contacts.length handles_match=@spC1Ok`

>> plannerVisibleState invalidation: after update, new entries appear
var @spC2Before = @plannerVisibleState(@sampleAgent, @emptyState())
var @spC2State1 = @updateResolvedState(@emptyState(), "contact", [
  { handle: "spc2-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "a@x.com" }, value: { name: "alice", email: "a@x.com" } }
])
var @spC2After1 = @plannerVisibleState(@sampleAgent, @spC2State1)
var @spC2State2 = @updateResolvedState(@spC2State1, "contact", [
  { handle: "spc2-h2", key: "bob", identity_field: "name", identity_value: "bob", field_values: { name: "bob", email: "b@x.com" } }
])
var @spC2After2 = @plannerVisibleState(@sampleAgent, @spC2State2)
var @spC2BeforeContacts = @spC2Before.resolved.contact ?? []
var @spC2After1Contacts = @spC2After1.resolved.contact ?? []
var @spC2After2Contacts = @spC2After2.resolved.contact ?? []
var @spC2BeforeCount = @spC2BeforeContacts.length
var @spC2After1Count = @spC2After1Contacts.length
var @spC2After2Count = @spC2After2Contacts.length
var @spC2Ok =
  @spC2BeforeCount == 0 &&
  @spC2After1Count == 1 &&
  @spC2After2Count == 2
var @spC2Pretty = `empty=@spC2BeforeCount after_first=@spC2After1Count after_second=@spC2After2Count`

>> Family expansion sees up-to-date state after multiple updates
var @spD1Step1 = @updateResolvedState(@emptyState(), "contact", [
  { handle: "spd1-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "a@x.com" }, value: { name: "alice", email: "a@x.com" } }
])
var @spD1Step2 = @updateResolvedState(@spD1Step1, "contact", [
  { handle: "spd1-h2", key: "bob", identity_field: "name", identity_value: "bob", field_values: { name: "bob", email: "b@x.com" }, value: { name: "bob", email: "b@x.com" } },
  { handle: "spd1-h3", key: "carol", identity_field: "name", identity_value: "carol", field_values: { name: "carol", email: "c@x.com" }, value: { name: "carol", email: "c@x.com" } }
])
var @spD1Step3 = @updateResolvedState(@spD1Step2, "contact", [
  { handle: "spd1-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "alice@new.com" }, value: { name: "alice", email: "alice@new.com" } }
])
var @spD1Family = @resolveRefValue(@spD1Step3, { source: "resolved", record: "contact" })
var @spD1Names = for @v in (@spD1Family.value ?? []) => `@v.name`
var @spD1Emails = for @v in (@spD1Family.value ?? []) => `@v.email`
var @spD1Ok =
  @spD1Family.ok == true &&
  @spD1Names.length == 3 &&
  @spD1Emails.includes("alice@new.com") &&
  @spD1Emails.includes("b@x.com") &&
  @spD1Emails.includes("c@x.com") &&
  !@spD1Emails.includes("a@x.com")
var @spD1Pretty = `count=@spD1Names.length names=@spD1Names emails=@spD1Emails`

>> Whole-record ref: { source: "resolved", record, handle } returns
>> the full value with all fields. Covers GPT spec #3.
var @spD2State = @updateResolvedState(@emptyState(), "contact", [
  { handle: "spd2-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "a@x.com", phone: "555-1" }, value: { name: "alice", email: "a@x.com", phone: "555-1" } }
])
var @spD2WholeRef = @resolveRefValue(@spD2State, { source: "resolved", record: "contact", handle: "spd2-h1" })
var @spD2Ok =
  @spD2WholeRef.ok == true &&
  `@spD2WholeRef.value.name` == "alice" &&
  `@spD2WholeRef.value.email` == "a@x.com" &&
  `@spD2WholeRef.value.phone` == "555-1"
var @spD2Pretty = `whole=@spD2WholeRef.value`

>> Field-path with array index: items[0].name. Covers GPT spec #4.
>> Required for derive-result references like { source: "derived",
>> name: "X", field: "items[0].body" } from c-4a08 family.
var @spD3State = @updateResolvedState(@emptyState(), "container", [
  { handle: "spd3-h1", key: "c1", identity_field: "id", identity_value: "c1", field_values: { id: "c1", items: [{ name: "first", price: 10 }, { name: "second", price: 20 }] }, value: { id: "c1", items: [{ name: "first", price: 10 }, { name: "second", price: 20 }] } }
])
var @spD3FieldZero = @resolveRefValue(@spD3State, { source: "resolved", record: "container", handle: "spd3-h1", field: "items[0].name" })
var @spD3FieldOne  = @resolveRefValue(@spD3State, { source: "resolved", record: "container", handle: "spd3-h1", field: "items[1].price" })
var @spD3Ok =
  @spD3FieldZero.ok == true &&
  `@spD3FieldZero.value` == "first" &&
  @spD3FieldOne.ok == true &&
  `@spD3FieldOne.value` == "20"
var @spD3Pretty = `items[0].name=@spD3FieldZero.value items[1].price=@spD3FieldOne.value`

>> #7 worker-summary-no-planner-cache-leak — explicit contract that
>> planner-visible state hides worker-only fields. After indexed
>> rework, planner_cache must store ONLY this projection (never the
>> worker view, which contains untrusted/raw content). @message_entry
>> has facts: [id_, sender] and data: [body, subject]. role:planner
>> sees [{ref:id_}, {ref:sender}]; role:worker also sees subject + body.
var @spE1MsgState = @updateResolvedState(@emptyState(), "message_entry", [
  { handle: "spe1-h1", key: "m1", identity_field: "id_", identity_value: "m1",
    field_values: { id_: "m1", sender: "alice", subject: "Hi there", body: "secret-body-content" },
    value: { id_: "m1", sender: "alice", subject: "Hi there", body: "secret-body-content" } }
])
var @spE1Planner = @plannerVisibleState(@builtFixtureAgent, @spE1MsgState)
var @spE1Worker = @workerStateSummary(@builtFixtureAgent, @spE1MsgState)
var @spE1PlMsgs = @spE1Planner.resolved.message_entry ?? []
var @spE1WkMsgs = @spE1Worker.resolved.message_entry ?? []
var @spE1PlMsg = @spE1PlMsgs[0]
var @spE1WkMsg = @spE1WkMsgs[0]
var @spE1PlannerKeys = @spE1PlMsg.mx.keys
var @spE1WorkerKeys = @spE1WkMsg.mx.keys
var @spE1Ok =
  @spE1PlMsgs.length == 1 &&
  @spE1WkMsgs.length == 1 &&
  @spE1PlannerKeys.includes("id_") &&
  @spE1PlannerKeys.includes("sender") &&
  !@spE1PlannerKeys.includes("body") &&
  !@spE1PlannerKeys.includes("subject") &&
  @spE1WorkerKeys.includes("body") &&
  @spE1WorkerKeys.includes("subject")
var @spE1Pretty = `planner_keys=@spE1PlannerKeys worker_keys=@spE1WorkerKeys`

>> #9 legacy-array-bucket-compatible — current state.resolved buckets
>> are plain arrays. After indexed rework lands with adapter helpers,
>> the SAME array-shaped input must still flow through @resolvedEntries
>> + @lookupResolvedEntry + family expansion. This test runs against
>> the current shape today; once indexed bucket lands, it serves as
>> the regression guard for the legacy adapter path.
var @spE2LegacyBucket = [
  { handle: "spe2-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "a@x.com" }, value: { name: "alice", email: "a@x.com" } },
  { handle: "spe2-h2", key: "bob",   identity_field: "name", identity_value: "bob",   field_values: { name: "bob",   email: "b@x.com" }, value: { name: "bob",   email: "b@x.com" } }
]
var @spE2State = {
  resolved: { contact: @spE2LegacyBucket },
  extracted: {},
  derived: {},
  extract_sources: {}
}
var @spE2Whole = @resolveRefValue(@spE2State, { source: "resolved", record: "contact", handle: "spe2-h1" })
var @spE2Field = @resolveRefValue(@spE2State, { source: "resolved", record: "contact", handle: "spe2-h2", field: "email" })
var @spE2Family = @resolveRefValue(@spE2State, { source: "resolved", record: "contact" })
var @spE2FamilyEmails = for @v in (@spE2Family.value ?? []) => `@v.email`
var @spE2Ok =
  @spE2Whole.ok == true &&
  `@spE2Whole.value.name` == "alice" &&
  @spE2Field.ok == true &&
  `@spE2Field.value` == "b@x.com" &&
  @spE2Family.ok == true &&
  @spE2FamilyEmails.length == 2 &&
  @spE2FamilyEmails.includes("a@x.com") &&
  @spE2FamilyEmails.includes("b@x.com")
var @spE2Pretty = `whole=@spE2Whole.value.name field=@spE2Field.value family_emails=@spE2FamilyEmails`

>> E3 indexed-bucket-adapter — c-63fe Phase 1 readiness. Hand-build a
>> bucket in the indexed shape and verify the adapter helpers in
>> intent.mld route reads through the indexed path. When Phase 2
>> @updateResolvedState ships and writes this shape, the same reads
>> will keep working. Until then, the adapter is dormant on real state.
var @spE3IndexedBucket = {
  _rig_bucket: "resolved_index_v1",
  order: ["spe3-h1", "spe3-h2"],
  by_handle: {
    "spe3-h1": { handle: "spe3-h1", key: "alice", identity_field: "name", identity_value: "alice", field_values: { name: "alice", email: "a@x.com" }, value: { name: "alice", email: "a@x.com" } },
    "spe3-h2": { handle: "spe3-h2", key: "bob",   identity_field: "name", identity_value: "bob",   field_values: { name: "bob",   email: "b@x.com" }, value: { name: "bob",   email: "b@x.com" } }
  },
  version: 2,
  planner_cache: { version: 0, entries: [] }
}
var @spE3State = {
  resolved: { contact: @spE3IndexedBucket },
  extracted: {},
  derived: {},
  extract_sources: {}
}
var @spE3Whole = @resolveRefValue(@spE3State, { source: "resolved", record: "contact", handle: "spe3-h1" })
var @spE3Field = @resolveRefValue(@spE3State, { source: "resolved", record: "contact", handle: "spe3-h2", field: "email" })
var @spE3Family = @resolveRefValue(@spE3State, { source: "resolved", record: "contact" })
var @spE3FamilyEmails = for @v in (@spE3Family.value ?? []) => `@v.email`
var @spE3Ok =
  @spE3Whole.ok == true &&
  `@spE3Whole.value.name` == "alice" &&
  @spE3Field.ok == true &&
  `@spE3Field.value` == "b@x.com" &&
  @spE3Family.ok == true &&
  @spE3FamilyEmails.length == 2 &&
  @spE3FamilyEmails.includes("a@x.com") &&
  @spE3FamilyEmails.includes("b@x.com")
var @spE3Pretty = `whole=@spE3Whole.value.name field=@spE3Field.value family_emails=@spE3FamilyEmails`

>> ============================================================================
>> c-3438 (B): @stateProgressFingerprint regression tests
>> ============================================================================
>> The fingerprint detects no-progress loops by computing a stable hash of
>> the meaningful state. Two fingerprints are equal iff the planner has not
>> made any of these changes: new resolved handle, new field on existing
>> handle, new bucket version, new extract/derive name with payload, or
>> empty→non-empty extract/derive flip.

>> FP-1: empty state produces empty fingerprint
var @fpEmptyState = { resolved: {}, extracted: {}, derived: {} }
var @fpEmpty = @stateProgressFingerprint(@fpEmptyState)
var @fpEmptyOk = @fpEmpty == ""
var @fpEmptyPretty = `'@fpEmpty'`

>> FP-2: deterministic — same state, same fingerprint
var @fpDetState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } }
      }
    }
  },
  extracted: {},
  derived: {}
}
var @fpDet1 = @stateProgressFingerprint(@fpDetState)
var @fpDet2 = @stateProgressFingerprint(@fpDetState)
var @fpDetOk = @fpDet1 == @fpDet2 && @fpDet1 != ""
var @fpDetPretty = `'@fpDet1' == '@fpDet2'`

>> FP-3: new resolved handle changes fingerprint
var @fpAddHandleState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } },
        "r_hotel_B": { value: { data: { name: "B", price: 200 } } }
      }
    }
  },
  extracted: {},
  derived: {}
}
var @fpAddHandle = @stateProgressFingerprint(@fpAddHandleState)
var @fpAddHandleOk = @fpAddHandle != @fpDet1
var @fpAddHandlePretty = `before='@fpDet1' after='@fpAddHandle' differ=@fpAddHandleOk`

>> FP-4: new field on existing handle changes fingerprint (the dominant
>> travel pattern — prices/ratings landing on already-resolved records)
var @fpFieldGrowState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100, rating: 4.5 } } }
      }
    }
  },
  extracted: {},
  derived: {}
}
var @fpFieldGrow = @stateProgressFingerprint(@fpFieldGrowState)
var @fpFieldGrowOk = @fpFieldGrow != @fpDet1
var @fpFieldGrowPretty = `before='@fpDet1' after='@fpFieldGrow' differ=@fpFieldGrowOk`

>> FP-5: bucket version bump changes fingerprint
var @fpVersionBumpState = {
  resolved: {
    hotel: {
      version: 2,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } }
      }
    }
  },
  extracted: {},
  derived: {}
}
var @fpVersionBump = @stateProgressFingerprint(@fpVersionBumpState)
var @fpVersionBumpOk = @fpVersionBump != @fpDet1
var @fpVersionBumpPretty = `before='@fpDet1' after='@fpVersionBump' differ=@fpVersionBumpOk`

>> FP-6: derive with selection_refs counts as progress
var @fpDeriveWithSelState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } }
      }
    }
  },
  extracted: {},
  derived: {
    "best_hotel": {
      preview_fields: ["name", "rating"],
      selection_refs: [{ source: "selection", backing: { record: "hotel", handle: "r_hotel_A" } }]
    }
  }
}
var @fpDeriveWithSel = @stateProgressFingerprint(@fpDeriveWithSelState)
var @fpDeriveWithSelOk = @fpDeriveWithSel != @fpDet1
var @fpDeriveWithSelPretty = `before='@fpDet1' after='@fpDeriveWithSel' differ=@fpDeriveWithSelOk`

>> FP-7 (regression for UT10): a derive that returned empty (preview_fields
>> = ["items"] only, no selection_refs) must NOT count as progress. The
>> planner re-deriving an empty result repeatedly is precisely the no-progress
>> loop the warning is supposed to detect. Earlier fingerprint logic treated
>> ["items"] as non-empty preview, suppressing the warning.
var @fpDeriveItemsState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } }
      }
    }
  },
  extracted: {},
  derived: {
    "empty_derive": {
      preview_fields: ["items"],
      selection_refs: []
    }
  }
}
var @fpDeriveItems = @stateProgressFingerprint(@fpDeriveItemsState)
>> Compare against state with the SAME derive but absent — both should signal
>> "empty payload" so the fingerprints can differ slightly (name presence)
>> but the empty-payload derive must read as 0 not 1
var @fpDeriveItemsHasZero = @fpDeriveItems.includes("D:empty_derive:0")
var @fpDeriveItemsOk = @fpDeriveItemsHasZero
var @fpDeriveItemsPretty = `'@fpDeriveItems' has D:empty_derive:0 = @fpDeriveItemsHasZero`

>> FP-8: extract with non-empty payload counts as progress
var @fpExtractWithDataState = {
  resolved: {
    hotel: {
      version: 1,
      by_handle: {
        "r_hotel_A": { value: { data: { name: "A", price: 100 } } }
      }
    }
  },
  extracted: {
    "hotel_address": {
      preview_fields: ["street", "city"],
      selection_refs: []
    }
  },
  derived: {}
}
var @fpExtractWithData = @stateProgressFingerprint(@fpExtractWithDataState)
var @fpExtractWithDataOk = @fpExtractWithData != @fpDet1 && @fpExtractWithData.includes("E:hotel_address:1")
var @fpExtractWithDataPretty = `differ=@fpExtractWithDataOk fp='@fpExtractWithData'`

>> ============================================================================
>> @plannerRuntime schema round-trip — c-3438 (B) schema fix.
>> ============================================================================
>> Earlier the @plannerRuntime record didn't declare progress_fingerprint
>> or calls_since_progress; the fields were silently stripped on session
>> writes (m-f780 still preserved them as raw JSON, but the schema-shaped
>> object lost them). This test asserts the schema round-trip preserves
>> the new fields so future schema edits can't regress this.
var @prRuntime = @plannerRuntimeStateWithProgress(5, 1, null, { phase: "resolve" }, "FP_TEST_VALUE", 3)
var @prRoundtripOk =
  @prRuntime.tool_calls == 5 &&
  @prRuntime.invalid_calls == 1 &&
  @prRuntime.progress_fingerprint == "FP_TEST_VALUE" &&
  @prRuntime.calls_since_progress == 3
var @prRoundtripPretty = `tool_calls=@prRuntime.tool_calls fp='@prRuntime.progress_fingerprint' csp=@prRuntime.calls_since_progress`

>> ============================================================================
>> Unicode hyphen normalization (c-bd28) — EXPECTED TO FAIL until c-bd28 ships.
>> Captures the regression that bit TR-UT15 (and TR-UT13's compose-output
>> variant): worker LLMs autocorrect ASCII hyphen (U+002D) to non-breaking
>> hyphen (U+2011) in product-name selection_ref handles. The validator
>> should canonicalize known dash variants (U+2010-2014, U+2212) to ASCII
>> on the comparison path while preserving the stored handle.
>> ============================================================================
>> Build a state where the resolved bucket contains a handle with ASCII hyphen.
var @uhState = @updateResolvedState(@emptyState(), "car_company_review", [
  { handle: "r_car_company_review_SunSet Rent-A-Car", key: "SunSet Rent-A-Car", field_values: { name: "SunSet Rent-A-Car", rating: 4.5 }, value: { name: "SunSet Rent-A-Car", rating: 4.5 } }
], @records.contact)
>> Construct a selection_ref using a Unicode-hyphen handle (what worker emits).
var @uhRef = {
  source: "selection",
  backing: { record: "car_company_review", handle: "r_car_company_review_SunSet Rent‑A‑Car" }
}
var @uhResult = @lowerSelectionRef(@uhState, @uhRef)
var @uhOk = @uhResult.ok == true
var @uhPretty = `lookup(unicode-hyphen handle on ascii-handle bucket) ok=@uhResult.ok error=@uhResult.error`

exe @allChecks() = [
  => [
  @check("policy-build-runtime", @policyBuildRuntimeOk, @policyBuildRuntimeDetail),
  @check("CAT-1", @catalogTransparentInputRecordOk, @catalogTransparentInputRecordDetail),
  @check("CAT-2", @catalogTransparentMetadataOk, @catalogTransparentMetadataDetail),
  @check("AUTH-1", @canAuthorizeSurfaceOk, @canAuthorizeSurfaceDetail),
  @check("AUTH-2", @hardDeniedSurfaceOk, @hardDeniedSurfaceDetail),
  @check("AUTH-3", @legacyAuthorizableKeyOk, `scan=@legacyAuthorizableScan`),
  @check("BENCH-CAT-1", @workspaceBenchCatalogOk, @workspaceBenchCatalogDetail),
  @check("BENCH-CAT-2", @bankingBenchCatalogOk, @bankingBenchCatalogDetail),
  @check("BENCH-CAT-3", @slackBenchCatalogOk, @slackBenchCatalogDetail),
  @check("BENCH-CAT-4", @travelBenchCatalogOk, @travelBenchCatalogDetail),
  @check("PLANNER-ARCH-1", @singlePlannerArchitectureOk, @singlePlannerArchitectureDetail),
  @check("PLANNER-ARCH-2", @singlePlannerRunnerOk, @singlePlannerRunnerDetail),
  @check("PLANNER-ARCH-3", @opencodePlannerToolSurfaceOk, @opencodePlannerToolSurfaceDetail),
  @check("PLANNER-ARCH-4", @plannerToolUninitializedOk, @plannerToolUninitializedDetail),
  @check("POL-ROUNDTRIP-1", @collectionRoundtripOk, "policy.build succeeded inside a wrapper exe"),
  @check("POL-ROUNDTRIP-2", @policySectionRoundtripOk, @policySectionRoundtripDetail),
  @check("synthesized-policy-shape", @syntheticPolicyOk, @syntheticPolicyDetail),
  @check("collection-roundtrip", @collectionRoundtripOk, "policy.build succeeded inside a wrapper exe"),
  @check("tool-metadata-access", @toolMetadataOk, @toolMetadataDetail),
  @check("wrapped-arg-name-role-classification", @wrappedArgNameRoleOk, @wrappedArgNameRoleDetail),
  @check("imported-var-tools-preserve-param-metadata", @importedToolParamRoundtripOk, @importedToolParamRoundtripDetail),
  @check("input-record-tool-metadata", @inputRecordToolMetadataOk, @inputRecordToolMetadataDetail),
  @check("factsource-roundtrip", @factsourceOk, @factsourceDetail),
  @check("tool-docs-control-args", @toolDocsOk, @toolDocsDetail),
