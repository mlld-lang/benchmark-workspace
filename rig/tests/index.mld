>> Dispatch-time correlate-control-args invariant: once execute intent
>> compilation has produced concrete backing refs for control args, the
>> correlate check must reject mixed resolved records.
exe execute:w, comm:w, tool:w @share_note_with_contact(note_id, recipient) = [
  => {
    note_id: @note_id,
    recipient: @recipient
  }
]

record @share_note_with_contact_inputs = {
  facts: [note_id: string, recipient: string],
  data: [],
  correlate: true,
  validate: "strict"
}

var tools @correlateTools = {
  share_note_with_contact: {
    mlld: @share_note_with_contact,
    inputs: @share_note_with_contact_inputs,
    labels: ["execute:w", "tool:w", "comm:w"],
    can_authorize: "role:planner",
    description: "Share one note with one recipient."
  }
}

var @correlateIntent = @compileExecuteIntent(
  @sampleState,
  @correlateTools,
  {
    phase: "execute",
    operation: "share_note_with_contact",
    args: {
      note_id: {
        source: "resolved",
        record: "note_entry",
        handle: "r_note_entry_note_1",
        field: "id_"
      },
      recipient: {
        source: "resolved",
        record: "contact",
        handle: "r_contact_alice.example",
        field: "email"
      }
    }
  },
  "Share note_1 with alice.example."
)
var @correlateEntries = @field(@correlateIntent, "compiled_entries") ?? []
var @correlateControlArgs = ["note_id", "recipient"]
var @correlateCheck = @correlatedControlArgsCheck(@correlateEntries, @correlateControlArgs)
var @correlatePretty = `error=@field(@correlateCheck, "error")`
var @correlateOk = @correlateIntent.ok &&
  !@field(@correlateCheck, "ok") &&
  @field(@correlateCheck, "error") == "correlate_control_args_cross_record_mixture"

