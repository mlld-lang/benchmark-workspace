>> Source-backed `schema: "text"` extracts are valid benchmark behavior.
>> Keep a direct regression here so the worker coercer cannot silently
>> demote scalar payloads back to null and strand the planner in a
>> resolve/extract loop.
var @scalarExtractAttestation = @coerceExtractAttestation({
  status: "extracted",
  schema_name: "text",
  name: "body_text",
  provenance: "extracted",
  preview_fields: [],
  payload: "bounded text payload"
})
var @scalarExtractState = {
  resolved: {},
  extracted: {
    body_text: {
      provenance: "extracted",
      schema_name: "text",
      preview_fields: [],
      value: @field(@scalarExtractAttestation, "payload")
    }
  },
  derived: {},
  extract_sources: {}
}
var @scalarExtractPlannerSummary = @plannerVisibleState(
  {
    suite: "fixtures",
    records: {}
  },
  @scalarExtractState
) | @pretty
var @scalarExtractWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: {}
  },
  @scalarExtractState
) | @pretty
var @scalarExtractPretty = `payload=@field(@scalarExtractAttestation, "payload")`
var @scalarExtractOk = @field(@scalarExtractAttestation, "payload") == "bounded text payload" &&
  !@scalarExtractPlannerSummary.includes('"bounded text payload"') &&
  @scalarExtractPlannerSummary.includes('"fields": []') &&
  @scalarExtractWorkerSummary.includes('"bounded text payload"')

>> Degenerate worker outputs must coerce to null so the dispatcher's
>> `if @attestation == null` check fires `extract_empty_response`. Without
>> this, the planner saw success-shaped envelopes with empty preview_fields
>> and reported "extract returned null" without an actionable error
>> (c-ad66, c-eeb6, c-32db family).
var @rawDegenNull = null
var @rawDegenEmpty = ""
var @rawDegenNullStr = "null"
var @rawDegenPayloadNull = ::{"status":"extracted","payload":null}::
var @rawDegenPayloadEmpty = ::{"status":"extracted","payload":{}}::
var @rawDegenPayloadMissing = ::{"status":"extracted","preview_fields":["x"]}::
var @degenerateRawNull = @coerceExtractAttestation(@rawDegenNull)
var @degenerateRawEmpty = @coerceExtractAttestation(@rawDegenEmpty)
var @degenerateRawNullStr = @coerceExtractAttestation(@rawDegenNullStr)
var @degeneratePayloadNull = @coerceExtractAttestation(@rawDegenPayloadNull)
var @degeneratePayloadEmpty = @coerceExtractAttestation(@rawDegenPayloadEmpty)
var @degeneratePayloadMissing = @coerceExtractAttestation(@rawDegenPayloadMissing)
var @degenerateExtractOk =
  @degenerateRawNull == null &&
  @degenerateRawEmpty == null &&
  @degenerateRawNullStr == null &&
  @degeneratePayloadNull == null &&
  @degeneratePayloadEmpty == null &&
  @degeneratePayloadMissing == null
var @degenerateExtractPretty = `null=@degenerateRawNull empty=@degenerateRawEmpty null_str=@degenerateRawNullStr payload_null=@degeneratePayloadNull payload_empty=@degeneratePayloadEmpty payload_missing=@degeneratePayloadMissing`

>> Valid worker outputs must NOT be rejected by the degeneracy check.
>> Includes scalar payload (text-shape extracts), markdown-fenced JSON,
>> and partial envelopes (validate: "demote" on @extractAttestation).
var @rawValidClean = ::{"status":"extracted","payload":{"description":"hi"}}::
var @rawValidScalar = ::{"status":"extracted","preview_fields":[],"payload":"raw text body"}::
var @rawValidFenced = "```json\n{\"status\":\"extracted\",\"payload\":{\"x\":1}}\n```"
var @validRawClean = @coerceExtractAttestation(@rawValidClean)
var @validRawScalar = @coerceExtractAttestation(@rawValidScalar)
var @validRawFenced = @coerceExtractAttestation(@rawValidFenced)
var @validExtractOk =
  @validRawClean != null &&
  @validRawScalar != null &&
  @validRawFenced != null
var @validExtractPretty = `clean=@typeof(@validRawClean) scalar=@typeof(@validRawScalar) fenced=@typeof(@validRawFenced)`

>> Mirror the same hardening on derive. Selection-only goals are valid
>> with empty payload IF selection_refs has entries.
var @rawDegenDerive = "null"
var @rawDegenDerivePayload = ::{"status":"derived","payload":null}::
var @rawValidDerive = ::{"status":"derived","payload":{"x":1}}::
var @rawValidDeriveSelOnly = ::{"status":"derived","payload":{},"selection_refs":[{"source":"selection","backing":{"record":"hotel","handle":"r_hotel_1"}}]}::
var @degenerateDeriveRaw = @coerceDeriveAttestation(@rawDegenDerive)
var @degenerateDerivePayload = @coerceDeriveAttestation(@rawDegenDerivePayload)
var @validDerivePayload = @coerceDeriveAttestation(@rawValidDerive)
var @validDeriveSelectionOnly = @coerceDeriveAttestation(@rawValidDeriveSelOnly)
var @degenerateDeriveOk =
  @degenerateDeriveRaw == null &&
  @degenerateDerivePayload == null &&
  @validDerivePayload != null &&
  @validDeriveSelectionOnly != null
var @degenerateDerivePretty = `raw_null=@degenerateDeriveRaw payload_null=@degenerateDerivePayload valid=@typeof(@validDerivePayload) selection_only=@typeof(@validDeriveSelectionOnly)`

