    description: "Stub create file."
  }
}

var @executeResultHandleAgent = @rigBuild({
  suite: "fixture-result-handles",
  defense: "defended",
  model: "stub",
  records: { file_entry: @ws_file_entry, file_create_inputs: @test_file_create_inputs },
  tools: @executeResultHandleTools
})

var @executeResultHandleDecision = {
  phase: "execute",
  operation: "create_file",
  args: {
    filename: { source: "known", value: "test.txt" },
    content: { source: "known", value: "hello world" }
  }
}

exe role:planner @probeExecuteResultHandles(agent, state, decision, query) = [
  => @dispatchExecute(@agent, @state, @decision, @query)
]

var @executeResultHandleResult = @probeExecuteResultHandles(
  @executeResultHandleAgent,
  @emptyState(),
