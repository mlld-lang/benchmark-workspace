>> Rig v2 invariant tests.
>>
>> This is the fast zero-LLM regression guard the plan calls for. Each
>> assertion names a concrete contract so failures point straight at the
>> broken primitive instead of forcing a full benchmark run to localize
>> the issue.

import {
  @records,
  @tools,
  @toolsCollection,
  @sampleState,
  @sampleAgent,
  @get_contacts,
  @get_today,
  @note_entry,
  @send_email,
  @create_note,
  @schedule_meeting,
  @meeting_request_inputs
} from "./fixtures.mld"
import {
  @renderToolDocs,
  @toolLabels,
  @toolParamNames,
  @toolControlArgs,
  @toolPayloadArgs,
  @toolOptionalArgs,
  @toolRisk,
  @toolAuthorizableRoles,
  @phaseCatalog,
  @phaseToolEntry
} from "../tooling.mld"
import { @rigBuild } from "../index.mld"
import {
  @synthesizedPolicy,
  @plannerStateSummary,
  @workerStateSummary,
  @nonComposeDecisionArgIssues,
  @updateNamedState,
  @appendExecutionLog,
  @correlatedControlArgsCheck
} from "../orchestration.mld"
import { @compileExecuteIntent, @compileToolArgs, @lowerSelectionRef, @resolveControlRefValue, @resolveRefValue } from "../intent.mld"
import { @callTool, @toolCallError, @emptyState } from "../runtime.mld"
import { @dispatchResolve } from "../workers/resolve.mld"
import { @dispatchExecute } from "../workers/execute.mld"
import { @coerceExtractAttestation } from "../workers/extract.mld"

exe @status(ok) = when [
  @ok => "PASS"
  * => "FAIL"
]

exe @check(id, ok, detail) = [
  => {
    id: @id,
    status: @status(@ok),
    detail: @detail
  }
]

exe @field(inputValue, key) = js {
  return inputValue?.[key] ?? null;
}

>> Execute-time policy application is most reliable when it lands on a
>> local wrapper exe instead of on an imported callable. The wrapper is
>> intentionally thin: it preserves native mlld args and only relocates
>> the policy boundary to the caller's module.
exe @runtime_create_note(content) = [
  => @create_note(@content)
]

exe @runtime_schedule_meeting(request) = [
  let @participantsValue = @exists(@request.participants) ? @request.participants : null
  => @schedule_meeting(@request.title, @request.start_time, @request.end_time, @participantsValue)
]

>> Workspace contact records use unnamed display arrays such as
>> `[name, { ref: "email" }]`. Keep one fixture inline here so the
>> invariant suite exercises the exact shorthand that the live benchmark
>> depends on.
record @flat_display_contact = {
  facts: [email: string],
  data: [name: string, notes: string?],
  display: [name, { ref: "email" }]
}

>> Benchmark suites use plain mode keys (`planner`, `worker`, `default`)
>> rather than the test fixtures' `role:*` form. Keep one record with
>> that spelling here so the planner summary cannot silently fall back
>> to `default` and expose hidden content.
record @plain_mode_message = {
  facts: [id_: string, sender: string?],
  data: [subject: string?, body: string?],
  key: id_,
  display: {
    default: [{ ref: "id_" }, subject, body],
    worker: [{ ref: "id_" }, subject, body],
    planner: [{ ref: "id_" }, subject]
  }
}

>> Named extract/derive results should use record display when their
>> schema is a real record. This keeps the planner on a declared safe
>> surface while workers still resolve full fields from state later.
record @named_display_extract = {
  facts: [id_: string],
  data: [subject: string, body: string, note: string?],
  key: id_,
  display: {
    planner: [{ ref: "id_" }, subject],
    worker: [{ ref: "id_" }, subject, body, note]
  }
}

record @thin_arrow_output = {
  data: [leaked: string?, input: string?],
  validate: "demote"
}

record @string_id_holder = {
  facts: [id_: string]
}

record @local_meeting_request_inputs = {
  facts: [participants: array?],
  data: [title: string, start_time: string, end_time: string],
  validate: "strict"
}

>> Thin-arrow regression from the v1 smoke. If strict mode leaks the
>> tool-slot value back into mlld, the serialized output contains the
>> sentinel string and this check trips immediately.
exe @thinArrowProbe(x) = [
  -> { leaked: "tool-slot-value", input: @x }
] => record @thin_arrow_output

>> Runtime regression for single-parameter direct tool dispatch. Numeric-
>> looking string ids must remain strings all the way into the executable
>> boundary; otherwise benchmark tools like `get_email_by_id("33")` fail
>> their parameter validation before the tool body even runs.
exe resolve:r, tool:r @get_numeric_note(note_id: string) = [
  => { id_: @note_id, title: "Todo", content: "Existing note body" }
] => record @note_entry with { controlArgs: ["note_id"] }

var tools @thinArrowToolCollection = {
  thin_arrow_probe: { mlld: @thinArrowProbe }
}

var tools @numericDispatchToolCollection = {
  get_numeric_note: {
    mlld: @get_numeric_note,
    labels: ["resolve:r"],
    expose: ["note_id"],
    controlArgs: ["note_id"]
  }
}

exe @serialize(v) = [ => @v | @pretty ]

>> The raw policy builder now requires an active caller role before it
>> accepts planner authorizations. Keep the baseline under a
>> `role:planner` helper so the test exercises the shipped contract
>> rather than top-level unlabeled evaluation.
exe role:planner @policyBuildAsPlanner(toolCatalog, basePolicy) = [
  let @built = @policy.build(
    { allow: { create_note: true } },
    @toolCatalog,
    { task: "create a note", basePolicy: @basePolicy }
  )
  => @built
]

exe @collectionRoundtrip(toolCatalog, basePolicy) = [
  let @built = @policyBuildAsPlanner(@toolCatalog, @basePolicy)
  => @built.valid
]

>> Runtime primitive baseline — verifies @policy.build itself accepts a
>> reasonable hand-constructed base policy before the rig synthesizer is
>> even involved.
var @manualBasePolicy = {
  defaults: { rules: ["no-send-to-unknown"] },
  operations: { "exfil:send": ["send_email"] },
  labels: { influenced: { deny: ["exfil"] } },
  authorizations: {
    deny: [],
    authorizable: { "role:planner": ["create_note", "send_email"] }
  }
}

>> Keep the raw `@policy.build` baseline on a tiny dedicated tool
>> collection. The runtime dispatch catalog intentionally omits planner
>> authorization metadata, while the policy builder now expects the
>> planner-facing role surface to be present on the collection it
>> validates.
var tools @policyBuildToolCollection = {
  send_email: {
    mlld: @send_email,
    labels: ["execute:w", "tool:w", "exfil:send"],
    authorizable: "role:planner",
    controlArgs: ["recipients"]
  },
  create_note: {
    mlld: @create_note,
    labels: ["execute:w", "tool:w"],
    authorizable: "role:planner"
  }
}

var @policyRuntime = @policyBuildAsPlanner(@policyBuildToolCollection, @manualBasePolicy)

var @numericStringIdRecord = {
  id_: "33"
} as record @string_id_holder
var @numericStringIdValue = @numericStringIdRecord.id_
var @fixtureReadDispatchResult = @callTool(
  @tools.get_contacts,
  @toolsCollection,
  "get_contacts",
  {},
  null
)
var @builtFixtureAgent = @rigBuild({
  suite: "fixture-build",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  toolsCollection: @toolsCollection
})
var @builtFixtureReadDispatchResult = @callTool(
  @builtFixtureAgent.tools.get_contacts,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {},
  null
)
>> Regression for the routed-catalog drift that left live workers with a
>> phase catalog they could inspect but not actually dispatch through.
>> The phase helpers must return native callable tool entries, not just
>> doc-shaped copies.
var @resolvePhaseCatalog = @phaseCatalog(@builtFixtureAgent, "resolve")
var @phaseCatalogDispatchResult = @callTool(
  @resolvePhaseCatalog.get_contacts,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {},
  null
)
var @phaseToolEntryValue = @phaseToolEntry(@builtFixtureAgent, "resolve", "get_contacts")
var @phaseToolEntryDispatchResult = @callTool(
  @phaseToolEntryValue,
  @builtFixtureAgent.toolsCollection,
  "get_contacts",
  {},
  null
)
>> Regression for the null-check bug in phase workers. Successful read
>> payloads must stay on the success path when dispatched through the
>> real resolve worker, not get reclassified as tool runtime errors.
var @dispatchResolveResult = @dispatchResolve(
  @builtFixtureAgent,
  @emptyState(),
  {
    phase: "resolve",
    tool: "get_contacts",
    args: {},
    purpose: "ground the contact list"
  },
  "Find Alice in my contacts."
)
>> Regression for arg-less resolve tools that return one keyed record.
>> This mirrors workspace `get_current_day` without depending on MCP.
var @dispatchScalarResolveResult = @dispatchResolve(
  @builtFixtureAgent,
  @emptyState(),
  {
    phase: "resolve",
    tool: "get_today",
    args: {},
    purpose: "ground one synthetic day context"
  },
  "What day is it?"
)
>> The execute regressions use a local runtime bridge so the policy
>> boundary lands on caller-local wrappers rather than on imported tool
>> exes. That keeps the invariant focused on rig's compile/dispatch
>> logic instead of mlld's current imported-policy edge case.
var tools @localExecuteRuntimeTools = {
  create_note: {
    mlld: @runtime_create_note,
    authorizable: "role:planner",
    controlArgs: [],
    expose: ["content"]
  },
  schedule_meeting: {
    mlld: @schedule_meeting,
    authorizable: "role:planner",
    inputs: @local_meeting_request_inputs
  }
}

var @localExecuteRuntimeOverrides = {
  schedule_meeting: {
    mlld: @runtime_schedule_meeting,
    expose: ["title", "start_time", "end_time", "participants"],
    optional: ["participants"],
    direct: true
  }
}

var @builtExecuteFixtureAgent = @rigBuild({
  suite: "fixture-execute-build",
  defense: "defended",
  model: "stub",
  records: @records,
  tools: @tools,
  toolsCollection: @localExecuteRuntimeTools,
  runtimeTools: @localExecuteRuntimeOverrides
})

var @dispatchCreateNoteResult = @dispatchExecute(
  @builtExecuteFixtureAgent,
  @emptyState(),
  {
    phase: "execute",
    operation: "create_note",
    args: {
      content: { source: "known", value: "Demo note body" }
    }
  },
  "Create a note with content Demo note body."
)

var @dispatchOptionalMeetingResult = @dispatchExecute(
  @builtExecuteFixtureAgent,
  @emptyState(),
  {
    phase: "execute",
    operation: "schedule_meeting",
    args: {
      title: { source: "known", value: "Solo focus block" },
      start_time: { source: "known", value: "2026-04-14 09:00" },
      end_time: { source: "known", value: "2026-04-14 10:00" }
    }
  },
  "Create Solo focus block from 2026-04-14 09:00 to 2026-04-14 10:00."
)
var @numericDispatchResult = @callTool(
  {
    kind: "read",
    mlld: @get_numeric_note,
    returns: @note_entry,
    labels: ["resolve:r"],
    semantics: "Load one note by a numeric-looking string id."
  },
  @numericDispatchToolCollection,
  "get_numeric_note",
  { note_id: @numericStringIdValue },
  null
)

>> Synthesized policy coverage.
var @syntheticPolicy = @synthesizedPolicy(@tools, null)
var @plannerAuth = @syntheticPolicy.authorizations.authorizable["role:planner"] ?? []
var @denyList = @syntheticPolicy.authorizations.deny ?? []
var @defaultRules = @syntheticPolicy.defaults.rules ?? []

>> Runtime metadata probes.
var @renderedDocs = @renderToolDocs(@tools)
var @sendDocs = for @entry in @renderedDocs when @field(@entry, "name") == "send_email" => @entry
var @sendDoc = @sendDocs[0]
>> Access runtime metadata through the catalog helpers here. Imported exe
>> metadata on its own can pick up extra module-level taint, while the
>> catalog entry preserves the tool-local surface the framework relies on.
var @crossModuleLabels = @toolLabels(@tools.send_email)
var @sendParams = @toolParamNames(@tools.send_email)
var @sendControlArgs = @toolControlArgs(@tools.send_email)
var @meetingParams = @toolParamNames(@tools.schedule_meeting)
var @meetingControlArgs = @toolControlArgs(@tools.schedule_meeting)
var @meetingPayloadArgs = @toolPayloadArgs(@tools.schedule_meeting)
var @meetingOptionalArgs = @toolOptionalArgs(@tools.schedule_meeting)
var @meetingRisk = @toolRisk(@tools.schedule_meeting)
var @meetingAuthorizableRoles = @toolAuthorizableRoles(@tools.schedule_meeting)
var @factValue = @get_contacts()[0].email

var @meetingDocs = for @entry in @renderedDocs when @field(@entry, "name") == "schedule_meeting" => @entry
var @meetingDoc = @meetingDocs[0]

var @meetingBasePolicy = {
  defaults: { rules: ["no-send-to-unknown"] },
  operations: { "exfil:send": ["schedule_meeting"] },
  labels: { influenced: { deny: ["exfil"] } },
  authorizations: {
    deny: [],
    authorizable: { "role:planner": ["schedule_meeting"] }
  }
}

var known @approvedMeetingParticipant = "alice.example"

>> Keep one local `var tools` collection here for direct input-record
>> dispatch regressions. Imported plain catalogs are fine for helper
>> extraction, but direct policy-bearing tool calls should exercise the
>> runtime on a same-file surfaced collection so the test only covers the
>> input-record contract, not cross-module collection identity.
var @localMeetingTools = {
  schedule_meeting: @tools.schedule_meeting
}

exe role:planner @buildOptionalMeetingPolicy() = [
  => @policy.build(
    { allow: { schedule_meeting: true } },
    @localMeetingTools,
    { task: "Schedule a solo focus block.", basePolicy: @meetingBasePolicy }
  )
]

var @optionalMeetingPolicy = @buildOptionalMeetingPolicy()

>> Display projection coverage.
var @plannerSummary = @plannerStateSummary(@sampleAgent, @sampleState) | @pretty
var @workerSummary = @workerStateSummary(@sampleAgent, @sampleState) | @pretty

>> Intent compiler / source-class coverage.
var @selectionLowered = @lowerSelectionRef(@sampleState, {
  source: "selection",
  backing: { record: "contact", handle: "r_contact_alice.example" }
})

var @firewallAttempt = @compileExecuteIntent(
  @sampleState,
  @tools,
  {
    phase: "execute",
    operation: "send_email",
    args: {
      recipients: [{ source: "derived", name: "top_contact", field: "body" }],
      subject: { source: "known", value: "hello" },
      body: { source: "known", value: "hello" }
    }
  },
  "send hello"
)

>> Read-phase selectors are control args too. Reject derived/extracted
>> refs here so the planner cannot launder untrusted content into a
>> subsequent resolve tool call.
var @resolveControlFirewallAttempt = @compileToolArgs(
  @sampleState,
  @tools.get_note,
  {
    note_id: { source: "derived", name: "top_contact", field: "body" }
  },
  "load note_1"
)

var @allowAttempt = @compileExecuteIntent(
  @sampleState,
  @tools,
  {
    phase: "execute",
    operation: "send_email",
    args: {
      recipients: { source: "allow" },
      subject: { source: "known", value: "hello" },
      body: { source: "known", value: "hello" }
    }
  },
  "send hello"
)

var @wrongSourceAttempt = @resolveRefValue(@sampleState, {
  source: "resolved",
  record: "summary",
  handle: "summary_1",
  field: "summary"
})

var @perElementAttempt = @compileExecuteIntent(
  @sampleState,
  @tools,
  {
    phase: "execute",
    operation: "send_email",
    args: {
      recipients: [
        { source: "resolved", record: "contact", handle: "r_contact_alice.example", field: "email" },
        { source: "resolved", record: "contact", handle: "missing", field: "email" }
      ],
      subject: { source: "known", value: "hello" },
      body: { source: "known", value: "hello" }
    }
  },
  "send hello"
)

>> Keyed resolved records are allowed as fieldless selection refs in
>> control-arg positions. The compiler should recover the record's
>> declared identity field (`note_id` here) without forcing the planner
>> to spell the field name back out.
var @selectionKeyedAttempt = @compileExecuteIntent(
  @sampleState,
  @tools,
  {
    phase: "execute",
    operation: "append_note",
    args: {
      note_id: {
        source: "selection",
        backing: {
          record: "note_entry",
          handle: "r_note_entry_note_1"
        }
      },
      content: { source: "known", value: "append a status line" }
    }
  },
  "append a status line"
)

>> Canonical planner args are a planner-loop contract, not just an
>> execute-time policy concern. Catch raw scalar leakage here so the
>> retry hint stays deterministic and benchmark runs do not depend on
>> provider-specific leniency.
var @rawScalarDecisionIssues = @nonComposeDecisionArgIssues({
  phase: "extract",
  tool: "get_message_body",
  args: {
    message_id: "msg_1"
  }
})
var @structuredDecisionIssues = @nonComposeDecisionArgIssues({
  phase: "extract",
  tool: "get_message_body",
  args: {
    message_id: { source: "known", value: "msg_1" }
  }
})

var @policyBuildRuntimeOk = @policyRuntime.valid == true
var @policyBuildRuntimeDetail = `valid=@policyRuntime.valid`

var @syntheticPolicyOk = @defaultRules.includes("no-send-to-unknown") &&
  @defaultRules.includes("untrusted-llms-get-influenced") &&
  @defaultRules.includes("no-novel-urls") &&
  @plannerAuth.includes("send_email") &&
  @plannerAuth.includes("schedule_meeting") &&
  @denyList.includes("update_password")
var @syntheticPolicyDetail = `rules=@defaultRules deny=@denyList planner=@plannerAuth`

var @collectionRoundtripOk = @collectionRoundtrip(@policyBuildToolCollection, @manualBasePolicy) == true
var @toolMetadataOk = @sendParams.length == 3 &&
  @sendControlArgs.includes("recipients") &&
  @crossModuleLabels.includes("execute:w")
var @toolMetadataDetail = `params=@sendParams.length control=@sendControlArgs labels=@crossModuleLabels`

var @factsourceOk = @factValue.mx.factsources.isDefined()
var @factsourceDetail = `factsources=@factValue.mx.factsources`

var @toolDocsOk = @field(@sendDoc, "controlArgs").includes("recipients") &&
  @field(@sendDoc, "payloadArgs").includes("subject") &&
  @field(@sendDoc, "semantics").includes("email")
var @toolDocsDetail = @sendDoc | @pretty

var @inputRecordToolMetadataOk = @meetingParams.length == 4 &&
  @meetingControlArgs.includes("participants") &&
  @meetingPayloadArgs.includes("title") &&
  @meetingPayloadArgs.includes("start_time") &&
  @meetingOptionalArgs.includes("participants") &&
  @meetingRisk.includes("calendar:w") &&
  @meetingRisk.includes("exfil:send") &&
  @meetingAuthorizableRoles.includes("role:planner")
var @inputRecordToolMetadataDetail = `params=@meetingParams control=@meetingControlArgs payload=@meetingPayloadArgs optional=@meetingOptionalArgs risk=@meetingRisk roles=@meetingAuthorizableRoles`

var @inputRecordToolDocsOk = @field(@meetingDoc, "controlArgs").includes("participants") &&
  @field(@meetingDoc, "payloadArgs").includes("title") &&
  @field(@meetingDoc, "optionalArgs").includes("participants") &&
  @field(@meetingDoc, "description").includes("personal event")
var @inputRecordToolDocsDetail = @meetingDoc | @pretty

var @optionalMeetingPolicyPretty = @optionalMeetingPolicy | @pretty
var @optionalMeetingPolicyOk = @optionalMeetingPolicy.valid == false

var @numericDispatchPretty = @numericDispatchResult | @pretty
var @numericDispatchOk = @field(@numericDispatchResult, "id_") == "33"
var @fixtureReadDispatchPretty = @fixtureReadDispatchResult | @pretty
var @fixtureReadDispatchOk = @typeof(@fixtureReadDispatchResult) == "array" &&
  @fixtureReadDispatchResult.length == 2
var @builtFixtureReadDispatchPretty = @builtFixtureReadDispatchResult | @pretty
var @builtFixtureReadDispatchOk = @typeof(@builtFixtureReadDispatchResult) == "array" &&
  @builtFixtureReadDispatchResult.length == 2
var @phaseCatalogDispatchPretty = @phaseCatalogDispatchResult | @pretty
var @phaseCatalogDispatchOk = @typeof(@phaseCatalogDispatchResult) == "array" &&
  @phaseCatalogDispatchResult.length == 2
var @phaseToolEntryDispatchPretty = @phaseToolEntryDispatchResult | @pretty
var @phaseToolEntryDispatchOk = @typeof(@phaseToolEntryDispatchResult) == "array" &&
  @phaseToolEntryDispatchResult.length == 2
var @dispatchResolvePretty = @dispatchResolveResult | @pretty
var @dispatchResolveOk =
  @dispatchResolveResult["error"] == null &&
  @dispatchResolveResult.result.status == "resolved" &&
  @dispatchResolveResult.result.count == 2
var @dispatchScalarResolvePretty = @dispatchScalarResolveResult | @pretty
var @dispatchScalarResolveOk =
  @dispatchScalarResolveResult["error"] == null &&
  @dispatchScalarResolveResult.result.status == "resolved" &&
  @dispatchScalarResolveResult.result.count == 1 &&
  @dispatchScalarResolveResult.result.record_type == "datetime_context"
var @dispatchCreateNotePretty = @dispatchCreateNoteResult | @pretty
var @dispatchCreateNoteOk =
  @dispatchCreateNoteResult["error"] == null &&
  @dispatchCreateNoteResult.result.status == "sent" &&
  @dispatchCreateNoteResult.state.execution_log.length == 1
var @dispatchOptionalMeetingPretty = @dispatchOptionalMeetingResult | @pretty
var @dispatchOptionalMeetingOk =
  @dispatchOptionalMeetingResult["error"] == null &&
  @dispatchOptionalMeetingResult.result.status == "sent" &&
  @dispatchOptionalMeetingResult.state.execution_log.length == 1

>> MCP and adapter bridges often include `error: false` in successful
>> envelopes. The runtime must only short-circuit on `error: true`;
>> otherwise valid tool payloads disappear before they ever reach state.
var @toolEnvelopeSuccess = @toolCallError({
  error: false,
  text: "ok"
})
var @toolEnvelopeFailure = @toolCallError({
  error: true,
  summary: "boom"
})
var @toolEnvelopeOk = @toolEnvelopeSuccess == null &&
  @field(@toolEnvelopeFailure, "summary") == "boom"
var @toolEnvelopeDetail = `success=@toolEnvelopeSuccess failure=@toolEnvelopeFailure`

var @thinArrowSerialized = @serialize(@thinArrowProbe("probe"))
var @thinArrowOk = !@thinArrowSerialized.includes("tool-slot-value")

var @displayProjectionOk = @plannerSummary.includes("Alice") &&
  @plannerSummary.includes("alice.example") &&
  !@plannerSummary.includes("planner-hidden note") &&
  @workerSummary.includes("planner-hidden note")
var @displayProjectionDetail = `planner=@plannerSummary worker=@workerSummary`

var @flatDisplayRecord = {
  email: "carol.example",
  name: "Carol",
  notes: "plain-display"
} as record @flat_display_contact
var @flatDisplaySummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: { flat_display_contact: @flat_display_contact }
  },
  {
    resolved: {
      flat_display_contact: [{
        handle: "r_flat_display_contact_carol.example",
        key: "carol.example",
        value: @flatDisplayRecord,
        field_values: {
          email: @flatDisplayRecord.email,
          name: @flatDisplayRecord.name,
          notes: @flatDisplayRecord.notes
        }
      }]
    },
    extracted: {},
    derived: {},
    execution_log: [],
    planner_session_id: null,
    phase_events: []
  }
) | @pretty
var @flatDisplayOk = @flatDisplaySummary.includes("Carol") &&
  @flatDisplaySummary.includes("carol.example")

var @plainModeRecord = {
  id_: "msg_1",
  sender: "david.example",
  subject: "Project kickoff agenda",
  body: "planner-must-not-see-this"
} as record @plain_mode_message
var @plainModePlannerSummary = @plannerStateSummary(
  {
    suite: "fixtures",
    records: { plain_mode_message: @plain_mode_message }
  },
  {
    resolved: {
      plain_mode_message: [{
        handle: "r_plain_mode_message_msg_1",
        key: "msg_1",
        value: @plainModeRecord,
        field_values: {
          id_: @plainModeRecord.id_,
          sender: @plainModeRecord.sender,
          subject: @plainModeRecord.subject,
          body: @plainModeRecord.body
        }
      }]
    },
    extracted: {},
    derived: {},
    execution_log: [],
    planner_session_id: null,
    phase_events: []
  }
) | @pretty
var @plainModeWorkerSummary = @workerStateSummary(
  {
    suite: "fixtures",
    records: { plain_mode_message: @plain_mode_message }
  },
  {
    resolved: {
      plain_mode_message: [{
        handle: "r_plain_mode_message_msg_1",
        key: "msg_1",
        value: @plainModeRecord,
        field_values: {
          id_: @plainModeRecord.id_,
          sender: @plainModeRecord.sender,
          subject: @plainModeRecord.subject,
          body: @plainModeRecord.body
        }
      }]
    },
    extracted: {},
    derived: {},
    execution_log: [],
    planner_session_id: null,
    phase_events: []
  }
) | @pretty
var @plainModeOk = @plainModePlannerSummary.includes("Project kickoff agenda") &&
  !@plainModePlannerSummary.includes("planner-must-not-see-this") &&
  @plainModeWorkerSummary.includes("planner-must-not-see-this")

>> Checkpoint restore can materialize resolved entries as plain objects
>> that keep both the synthetic numeric `key` and the original fact value
>> under `identity_value` / `value.data`. Planner summaries must keep
>> showing the fact-bearing string id, otherwise the planner emits raw
>> numeric args instead of structured resolved refs for follow-up tools.
var @checkpointRestoredState = {
  resolved: {
    plain_mode_message: [{
      handle: "r_plain_mode_message_msg_1",
      key: 1,
      value: {
        id_: 1,
        sender: "david.example",
        subject: "Project kickoff agenda",
        body: "planner-must-not-see-this",
        data: {
          id_: "msg_1",
          sender: "david.example",
          subject: "Project kickoff agenda",
          body: "planner-must-not-see-this"
        }
      },
      identity_field: "id_",
      identity_value: "msg_1",
      field_values: {
        id_: 1,
        sender: "david.example",
        subject: "Project kickoff agenda",
        body: "planner-must-not-see-this"
      }
    }]
  },
  extracted: {},
  derived: {},
  execution_log: [],
  planner_session_id: null,
  phase_events: []
}
var @checkpointRestoredSummary = @plannerStateSummary(
