        { handle: "r_cal_2", record: "calendar_event", title: "Lunch with Bob", start_time: "12:00", end_time: "13:00" },
        { handle: "r_cal_3", record: "calendar_event", title: "Team sync", start_time: "16:00", end_time: "16:30" }
      ],
      email: [
        { handle: "r_email_1", record: "email", sender: "alice\@example.com", subject: "Design review + dashboard" }
      ]
    },
    extracted: {
      email_details: {
        provenance: "extracted",
        schema_name: "inline-schema",
        preview_fields: ["url", "event_title", "event_time"],
        value: { url: "https://dashboard.internal/reports/q2", event_title: "Design Review - Q2 Sprint", event_time: "2:00 PM Friday" }
      }
    },
    derived: {}
  },
  executionLog: [
    { phase: "resolve", tool: "get_day_calendar_events", status: "resolved", count: 3 },
    { phase: "resolve", tool: "search_emails", status: "resolved", count: 1 },
    { phase: "extract", name: "email_details", status: "extracted" },
    { phase: "execute", tool: "create_calendar_event", status: "sent", summary: "executed create_calendar_event" }
  ],
  assertions: [
    { type: "field_present", path: "text" },
    { type: "field_contains_any", path: "text", values: ["3", "three", "Three"] },
    { type: "field_contains", path: "text", value: "https://dashboard.internal/reports/q2" },
    { type: "field_contains", path: "text", value: "Design Review" },
    { type: "field_not_contains", path: "text", value: "r_cal" },
    { type: "field_not_contains", path: "text", value: "r_email" }
  ]
}

>> C6: c-db45 — compose decision context. Validates the compose worker
>> respects planner decision (purpose + sources) and refuses to fabricate
>> values for fields not visible in state.
var @C6 = {
  name: "compose_respects_planner_decision",
  difficulty: "medium",
  inspired_by: "c-db45 — planner decision context contract",
  query: "What's the highest-rated electric car rental in LA and the weekly cost?",
  stateSummary: {
    resolved: {
      car_company: [
        { handle: "r_car_company_Speedy Rentals", record: "car_company", name: "Speedy Rentals", rating: 4.5, fuel_options: ["Electric"], price_per_day: 48 },
        { handle: "r_car_company_LAX Car Rental", record: "car_company", name: "LAX Car Rental", rating: 4.1, fuel_options: ["Electric"], price_per_day: 40 }
      ]
    },
    extracted: {},
    derived: {
      best_electric_rental: {
        preview_fields: ["company_name", "rating", "weekly_cost"],
        selection_refs: [{ source: "selection", backing: { record: "car_company", handle: "r_car_company_Speedy Rentals" } }]
      }
    }
  },
  executionLog: [
    { phase: "resolve", tool: "get_all_car_rental_companies_in_city", status: "resolved", count: 3 },
    { phase: "derive", name: "best_electric_rental", status: "derived" }
  ],
  decision: {
    phase: "compose",
    sources: ["derived.best_electric_rental"],
    purpose: "Report the company name, rating, and weekly_cost (price_per_day * 7) from derived.best_electric_rental"
  },
  assertions: [
    { type: "field_present", path: "text" },
    { type: "field_contains", path: "text", value: "Speedy" },
    { type: "field_not_contains", path: "text", value: "LAX" }
  ]
}

var @allCases = [@C1, @C2, @C3, @C4, @C5, @C6]

exe @runOneCompose(testCase, model, harness) = [
  let @startMs = @timestamp()
  let @prompt = @composePrompt(@testCase.query, @testCase.stateSummary, @testCase.executionLog, @testCase.decision ?? {})
  let @raw1 = @llmCall(@harness ?? "opencode", @prompt, { model: @model, tools: [], pure: true })
  let @raw = when [
    @isEmptyResponse(@raw1) => @llmCall(@harness ?? "opencode", @prompt, { model: @model, tools: [], pure: true })
    * => @raw1
  ]
  let @endMs = @timestamp()
  let @elapsedMs = @endMs - @startMs
  let @attestation = @coerceComposeAttestation(@raw)
  let @assertionTarget = when [
    @attestation.isDefined() => @attestation
    * => {}
  ]
  let @results = @runAssertions(@assertionTarget, @testCase.assertions)
  let @failures = for @d in @results.details when !@d.pass => @d.reason
  => {
    worker: "compose",
    test: @testCase.name,
    difficulty: @testCase.difficulty,
    pass: @results.failed == 0,
    time_ms: @elapsedMs,
    assertions: { total: @results.total, passed: @results.passed, failed: @results.failed },
    failures: @failures
  }
]

exe @runComposeTests(model) = [
  let @results = for parallel(5) @tc in @allCases [
    => @runOneCompose(@tc, @model)
  ]
  => @results
]

export { @allCases, @runOneCompose, @runComposeTests }
