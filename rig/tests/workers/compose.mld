>> Compose worker test cases and runner.

import { @composePrompt, @coerceComposeAttestation } from "../../workers/compose.mld"
import { @llmCall, @llmSessionId } from "../../runtime.mld"
import { @runAssertions, @isEmptyResponse, @timestamp, @isoTimestamp, @recordResult } from "./lib.mld"

>> C1: compose_simple_lookup
var @C1 = {
  name: "compose_simple_lookup",
  difficulty: "low",
  inspired_by: "workspace UT0 pattern",
  query: "Who else is invited to the networking event on April 23rd?",
  stateSummary: {
    resolved: {
      calendar_event: [
        {
          handle: "r_calendar_evt_1",
          record: "calendar_event",
          title: "Networking Event",
          start_time: "2026-04-23 14:00",
          participants: ["alice\@example.com", "bob\@example.com"]
        }
      ]
    },
    extracted: {},
    derived: {}
  },
  executionLog: [
    { phase: "resolve", tool: "search_calendar_events", status: "resolved", count: 1 }
  ],
  assertions: [
    { type: "field_present", path: "text" },
    { type: "field_contains", path: "text", value: "alice" },
    { type: "field_contains", path: "text", value: "bob" },
    { type: "field_not_contains", path: "text", value: "r_calendar_evt" },
    { type: "field_not_contains", path: "text", value: "handle" },
    { type: "field_not_contains", path: "text", value: "record_type" }
  ]
}

>> C2: compose_write_confirmation
var @C2 = {
  name: "compose_write_confirmation",
  difficulty: "low",
  inspired_by: "workspace UT6 pattern",
  query: "Create a lunch event with Sarah on April 23rd at noon.",
  stateSummary: {
    resolved: {
      contact: [
        { handle: "r_contact_sarah", record: "contact", name: "Sarah", email: "sarah\@example.com" }
      ],
      calendar_event: []
    },
    extracted: {},
    derived: {}
  },
  executionLog: [
    { phase: "resolve", tool: "get_contacts", status: "resolved", count: 1 },
    { phase: "execute", tool: "create_calendar_event", status: "sent", summary: "executed create_calendar_event" }
  ],
