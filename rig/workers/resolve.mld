import { @recordTypeName, @toolRuntimeMessage, @toolFailureDetail, @toolCallError } from "../runtime.mld"
import {
  @callTool,
  @normalizeResolvedValues,
  @updateResolvedState,
  @appendExecutionLog
} from "../runtime.mld"
import { @resolveAttestation } from "../records.mld"
import { @compileToolArgs } from "../intent.mld"
import { @phaseToolEntry, @wrongPhaseToolFailure } from "../tooling.mld"
import { @validatePlannerArgRefs, @plannerValidationFailure } from "../planner_inputs.mld"

exe @resolvePrompt(query, decision, toolDocs, stateSummary) = template "../prompts/resolve.att"

exe @coerceResolveAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  => @parsed
] => record @resolveAttestation

exe @resolveDebug(agent, marker) = [
  if !(@agent.logLlmCalls ?? false) [ => null ]
  run sh {
    printf '%s\n' "$marker" >> /tmp/resolve-dispatch-debug.log
  }
  => null
]

>> Resolve dispatch is mechanical: validate the planner's control refs
>> through the shared intent compiler, call the read tool, normalize
>> returned records into rig state, then append the execution log entry.
exe @dispatchResolve(agent, state, decision, query) = [
  @resolveDebug(@agent, "dispatchResolve:start")
  let @tool = @phaseToolEntry(@agent, "resolve", @decision.tool)
  if !@tool [
    let @wrongPhase = @wrongPhaseToolFailure(@agent, "resolve", @decision.tool)
    if @wrongPhase [ => @wrongPhase ]
    => { error: "unknown_resolve_tool", summary: @decision.tool }
  ]
  let @shapeCheck = @validatePlannerArgRefs(@decision.args ?? {})
  if !@shapeCheck.ok [ => @plannerValidationFailure("planner_ref_validation_failed", @shapeCheck, @shapeCheck.issues) ]
  @resolveDebug(@agent, "dispatchResolve:tool")
  let @argsCheck = @compileToolArgs(@state, @tool, @decision.args ?? {}, @query)
  if !@argsCheck.ok [ => @plannerValidationFailure(@argsCheck.error ?? "tool_arg_validation_failed", @argsCheck, @argsCheck.issues) ]
  @resolveDebug(@agent, "dispatchResolve:args")
  >> Dispatch through the routed entry so runtime metadata such as
  >> `expose` and `optional` survives. `@callTool` still resolves the
  >> concrete executable from the runtime bridge when needed.
  @resolveDebug(@agent, "dispatchResolve:beforeCallTool")
  let @raw = @callTool(@tool, @agent.toolsCollection, @decision.tool, @argsCheck.args)
  @resolveDebug(@agent, "dispatchResolve:afterCallTool")
  let @toolError = @toolCallError(@raw)
  >> Helper-return locals can be defined while still holding `null`.
  >> Check explicitly against null here so successful tool payloads do
  >> not fall into the runtime-error branch.
  if @toolError != null [
    let @detail = @toolFailureDetail(@toolError)
    => {
      error: "tool_runtime_error",
      summary: @detail ?? "tool_runtime_error",
      raw_error: @detail ?? null
    }
  ]
  let @toolMessage = @toolRuntimeMessage(@decision.tool, @raw)
  if @toolMessage != null [
    let @detail = @toolFailureDetail(@raw)
    => {
      error: "tool_runtime_error",
      summary: @toolMessage,
      raw_error: @detail ?? @toolMessage
    }
  ]
  let @recordDef = @tool.returns
  let @recordType = @recordTypeName(@recordDef)
  let @entries = @normalizeResolvedValues(@recordType, @recordDef, @raw)
  let @handles = for @entry in @entries => @entry.handle
  let @summary = `resolved @entries.length @recordType record(s)`
  let @nextState = @appendExecutionLog(
    @updateResolvedState(@state, @recordType, @entries),
    {
      phase: "resolve",
      tool: @decision.tool,
      handles: @handles,
      summary: @summary,
      session_id: null
    }
  )
  => {
    state: @nextState,
    result: {
      status: "resolved",
      record_type: @recordType,
      count: @entries.length,
      handles: @handles,
      summary: @summary
    },
    session_id: null
  }
]

export { @resolvePrompt, @coerceResolveAttestation, @dispatchResolve }
