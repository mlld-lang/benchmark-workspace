import {
  @llmCall,
  @llmCallEntry,
  @llmSessionId,
  @arrayItems,
  @recordTypeName,
  @callTool,
  @toolCallError,
  @toolRuntimeMessage,
  @extractToolResultValue,
  @previewFields,
  @updateNamedState,
  @updateExtractSources
} from "../runtime.mld"
import { @serializeLifecycleJson, @appendExecutionLogEntry } from "../lifecycle.mld"
import { @compileToolArgs, @resolveRefValue } from "../intent.mld"
import { @extractAttestation } from "../records.mld"
import { @phaseToolEntry, @wrongPhaseToolFailure } from "../tooling.mld"
import {
  @validatePlannerArgRefs,
  @validatePlannerSourceRef,
  @plannerValidationFailure
} from "../planner_inputs.mld"

exe @extractPrompt(query, sourceValue, schemaDoc, decision) = template "../prompts/extract.att"

>> Only dedup resolved sources. Re-extracting from resolved state with a
>> different name is always redundant — the data hasn't changed. But
>> extracting different schemas from extracted/derived sources is legitimate.
exe @extractSourceKey(source) = when [
  !@source.isDefined() => null
  @source.source == "resolved" && @source.handle.isDefined() => `resolved:@source.record:@source.handle`
  @source.source == "resolved" => `resolved:@source.record`
  * => null
]

exe @findPriorExtractForSource(extractSources, sourceKey) = when [
  @sourceKey == null => null
  @extractSources[@sourceKey].isDefined() => @extractSources[@sourceKey]
  * => null
]

exe @coerceExtractEnvelope(parsed) = [
  => @parsed
] => record @extractAttestation

exe @normalizeEmptyStrings(inputValue) = js {
  function walk(v) {
    if (v === "") return null;
    if (v == null || typeof v !== "object") return v;
    if (Array.isArray(v)) return v.map(walk);
    const out = {};
    for (const [k, val] of Object.entries(v)) out[k] = walk(val);
    return out;
  }
  return walk(inputValue);
}

exe @coerceExtractAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  let @coerced = @coerceExtractEnvelope(@parsed)
  let @parsedPayloadType = @typeof(@parsed.payload)
  let @normalizedPayload = when [
    @parsed.payload.isDefined() => @normalizeEmptyStrings(@parsed.payload)
    * => null
  ]
  let @result = when [
    !@coerced => null
    @normalizedPayload.isDefined() && (@parsedPayloadType == "array" || @parsedPayloadType != "object") => {
      status: @coerced.status,
      schema_name: @coerced.schema_name,
      name: @coerced.name,
      provenance: @coerced.provenance,
      preview_fields: @coerced.preview_fields,
      payload: @normalizedPayload
    }
    * => {
      status: @coerced.status,
      schema_name: @coerced.schema_name,
      name: @coerced.name,
      provenance: @coerced.provenance,
      preview_fields: @coerced.preview_fields,
      payload: @normalizeEmptyStrings(@coerced.payload)
    }
  ]
  => @result
]

exe @schemaRecord(agent, schema) = when [
  @typeof(@schema) == "string" && @agent.records[@schema].isDefined() => @agent.records[@schema]
  * => null
]

exe @validateExtractSchema(records, schema) = [
  let @recordNames = for @name, @rec in (@records ?? {}) => @name
  => when [
    !@schema.isDefined() || @schema == null => { ok: true }
    @typeof(@schema) == "string" && @schema == "" => {
      ok: false,
      error: "extract_empty_schema_name",
      issues: [{ error: "empty_schema_name", available: @recordNames }]
    }
    @typeof(@schema) == "string" => { ok: true, record: @records[@schema].isDefined() }
    @typeof(@schema) == "object" && @plainObjectKeys(@schema).length > 0 => { ok: true, record: false }
    @typeof(@schema) == "object" => {
      ok: false,
      error: "extract_empty_inline_schema",
      issues: [{ error: "empty_inline_schema", available: @recordNames }]
    }
    * => {
      ok: false,
      error: "extract_invalid_schema_type",
      issues: [{ error: "invalid_schema_type", type: @typeof(@schema), available: @recordNames }]
    }
  ]
]

>> Extract may not manufacture selection refs. The only valid producer
>> is derive, which validates them against its input set.
exe @containsSelectionRef(inputValue) = js {
  function hasSelection(value) {
    if (value == null) return false;
    if (Array.isArray(value)) return value.some(hasSelection);
    if (typeof value !== "object") return false;
    if (value.source === "selection" && value.backing) return true;
    return Object.values(value).some(hasSelection);
  }

  return hasSelection(inputValue);
}

exe @dispatchExtract(agent, state, decision, query) = [
  if @decision.tool.isDefined() [
    let @tool = @phaseToolEntry(@agent, "extract", @decision.tool)
    if !@tool [
      let @wrongPhase = @wrongPhaseToolFailure(@agent, "extract", @decision.tool)
      if @wrongPhase [ => @wrongPhase ]
      => { error: "unknown_extract_tool", summary: @decision.tool }
    ]
    let @shapeCheck = @validatePlannerArgRefs(@decision.args ?? {})
    if !@shapeCheck.ok [ => @plannerValidationFailure("planner_ref_validation_failed", @shapeCheck, @shapeCheck.issues) ]
    let @argsCheck = @compileToolArgs(@state, @tool, @decision.args ?? {}, @query)
    if !@argsCheck.ok [ => @plannerValidationFailure(@argsCheck.error ?? "intent_compile_failed", @argsCheck, @argsCheck.issues) ]
    >> Keep the routed entry intact so dispatch sees the runtime arg docs
    >> instead of a planner-only catalog object that may have shed them.
    let @raw = @callTool(@tool, @agent.toolsCollection, @decision.tool, @argsCheck.args)
    let @toolError = @toolCallError(@raw)
    >> `toolCallError()` returns null on success. Compare explicitly so a
    >> defined local holding null does not trip the error path.
    if @toolError != null [ => @toolError ]
    let @toolMessage = @toolRuntimeMessage(@decision.tool, @raw)
    if @toolMessage != null [ => { error: "tool_runtime_error", summary: @toolMessage } ]
    let @recordDef = @tool.returns
    let @recordType = @recordTypeName(@recordDef)
    let @typed = @extractToolResultValue(@recordType, @recordDef, @raw)
    let @summary = `fetched @decision.tool into @decision.name`
    let @nextState = @updateNamedState(@state, "extracted", @decision.name, {
      provenance: "extracted",
      schema_name: @recordType,
      preview_fields: @previewFields(@typed),
      value: @typed
    })
    => {
      state: @nextState,
      result: {
        status: "extracted",
        schema_name: @recordType,
        name: @decision.name,
        provenance: "extracted",
        preview_fields: @previewFields(@typed),
        summary: @summary
      },
      session_id: null
    }
  ]

  let @sourceCheck = @validatePlannerSourceRef(@decision.source, ["resolved", "selection", "extracted", "derived"])
  if !@sourceCheck.ok [ => @plannerValidationFailure("planner_source_validation_failed", @sourceCheck, @sourceCheck.issues) ]
  let @srcKey = @extractSourceKey(@decision.source)
  if @srcKey != null [
    let @priorName = @findPriorExtractForSource(@state.extract_sources ?? {}, @srcKey)
    if @priorName != null [
      let @priorEntry = @state.extracted[@priorName]
      let @priorFields = @priorEntry.preview_fields ?? []
      => {
        error: "extract_source_already_extracted",
        summary: `You already extracted from this source as "@priorName" (fields: @priorFields.join(", ")). Reference it with { "source": "extracted", "name": "@priorName" } instead of re-extracting. Proceed to derive or execute.`
      }
    ]
  ]
  let @resolvedSource = @resolveRefValue(@state, @decision.source)
  if !@resolvedSource.ok [ => @plannerValidationFailure(@resolvedSource.error ?? "extract_source_resolution_failed", @resolvedSource, @resolvedSource.issues ?? null) ]
  let @schemaCheck = @validateExtractSchema(@agent.records ?? {}, @decision.schema)
  if !@schemaCheck.ok [ => @plannerValidationFailure(@schemaCheck.error, @schemaCheck, @schemaCheck.issues) ]
  let @schemaDef = @schemaRecord(@agent, @decision.schema)
  let @prompt = @extractPrompt(@query, @resolvedSource.value, @schemaDef ?? @decision.schema, @decision)
  let @raw = @llmCall(@agent.harness, @prompt, {
    model: @agent.model,
    pure: @agent.opencodePure,
    dir: @agent.innerWorkerDir,
    dataHome: @agent.innerWorkerDataHome,
    stateHome: @agent.innerWorkerStateHome,
    tools: [],
    stubPhase: "extract",
    stubResponses: @agent.stub.extract ?? [],
    stubIndex: 0
  })
  let @attestation = @coerceExtractAttestation(@raw)
  let @sessionId = @llmSessionId(@raw)
  let @logEntry = @llmCallEntry("extract", @prompt, @raw, @attestation, @sessionId, {
    call_kind: "inner_worker",
    inner_worker_session_id: @sessionId,
    name: @decision.name,
    source: @decision.source
  })
  if !@attestation.isDefined() [ => { error: "extract_empty_response", summary: "extract_empty_response", session_id: @sessionId, llm_log: @logEntry } ]
  if @containsSelectionRef(@attestation.payload) [
    => { error: "extract_may_not_emit_selection_refs", summary: "Extract cannot produce selection refs — only derive can. If you need to select among resolved records, call derive instead of extract.", session_id: @sessionId, llm_log: @logEntry }
  ]
  let @typed = when [
    @schemaDef => @cast(@attestation.payload, @schemaDef)
    * => @attestation.payload
  ]
  let @summary = @attestation.summary ?? `extracted @decision.name`
  let @schemaName = when [
    @typeof(@decision.schema) == "string" => @decision.schema
    * => "inline-schema"
  ]
  let @extractedPreviewFields = @previewFields(@typed)
  let @dataState = @updateNamedState(@state, "extracted", @decision.name, {
    provenance: "extracted",
    schema_name: @schemaName,
    preview_fields: @extractedPreviewFields,
    value: @typed
  })
  let @nextState = when [
    @srcKey != null && @extractedPreviewFields.length > 0 => @updateExtractSources(@dataState, @srcKey, @decision.name)
    * => @dataState
  ]
  @appendExecutionLogEntry(@agent.executionLogFile, @serializeLifecycleJson({
    phase: "extract",
    name: @decision.name,
    source_key: @srcKey,
    has_content: @extractedPreviewFields.length > 0,
    summary: @summary,
    session_id: @sessionId
  }))
  => {
    state: @nextState,
    result: {
      status: "extracted",
      schema_name: @schemaName,
      name: @decision.name,
      provenance: "extracted",
      preview_fields: @previewFields(@typed),
      summary: @summary
    },
    session_id: @sessionId,
    llm_log: @logEntry
  }
]

export { @extractPrompt, @coerceExtractAttestation, @dispatchExtract }
