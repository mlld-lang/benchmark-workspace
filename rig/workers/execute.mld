import {
  @pairsToObject,
  @toolControlArgs,
  @toolOptionalArgs,
  @toolPayloadArgs,
  @toolUpdateArgs,
  @toolCorrelateControlArgs
} from "../tooling.mld"
import {
  @callTool,
  @callToolWithPolicy,
  @toolCallError,
  @toolRuntimeMessage,
  @correlatedControlArgsCheck,
  @recordTypeName,
  @normalizeResolvedValues,
  @updateResolvedState
} from "../runtime.mld"
import { @serializeLifecycleJson, @appendExecutionLogEntry } from "../lifecycle.mld"
import { @compileExecuteIntent } from "../intent.mld"
import { @executeAttestation } from "../records.mld"
import { @validatePlannerArgRefs, @plannerValidationFailure } from "../planner_inputs.mld"

>> Most execute steps dispatch directly once intent compilation and
>> policy construction succeed. The prompt remains available for suites
>> that want a worker-facing confirmation surface later.
exe @executePrompt(query, decision, preparedArgs) = template "../prompts/execute.att"

exe @coerceExecuteAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  => @parsed
] => record @executeAttestation

exe @controlArgValues(compiledEntries, controlArgs) = [
  let @controlArgNames = for @argName in (@controlArgs ?? []) => `@argName`
  let @pairs = for @entry in (@compiledEntries ?? []) when @controlArgNames.includes(`@entry.arg`) => {
    key: @entry.arg,
    value: @entry.value
  }
  => @pairsToObject(@pairs)
]

exe @hasNonNullFieldValue(inputValue, fieldNames) = [
  let @names = for @fieldName in (@fieldNames ?? []) => `@fieldName`
  let @matches = for @fieldName in @names when @inputValue[@fieldName].isDefined() && @inputValue[@fieldName] != null => @fieldName
  => @matches.length > 0
]

exe @mergeArgSources(values) = [
  let @pairs = loop(1000) [
    let @ctx = when [
      @input["_rig_cursor"] == "mergeArgSources" => @input
      * => { _rig_cursor: "mergeArgSources", index: 0, values: [] }
    ]
    if @ctx.index >= @values.length [ done @ctx.values ]
    let @source = @values[@ctx.index] ?? {}
    let @sourcePairs = for @argKey, @argValue in @source => {
      key: @argKey,
      value: @argValue
    }
    continue {
      _rig_cursor: "mergeArgSources",
      index: @ctx.index + 1,
      values: @ctx.values.concat(@sourcePairs)
    }
  ]
  => @pairsToObject(@pairs)
]


exe role:planner @dispatchExecute(agent, state, decision, query) = [
  let @shapeCheck = @validatePlannerArgRefs(@decision.args ?? {})
  if !@shapeCheck.ok [ => @plannerValidationFailure("planner_ref_validation_failed", @shapeCheck, @shapeCheck.issues) ]
  let @compiled = @compileExecuteIntent(@state, @agent.tools, @decision, @query)
  if !@compiled.ok [ => @plannerValidationFailure(@compiled.error ?? "intent_compile_failed", @compiled, @compiled.issues ?? null) ]
  let @tool = @compiled.tool
  let @operationName = @decision.operation
  let @controlArgs = for @argName in @toolControlArgs(@tool) => `@argName`
  let @optionalArgs = for @argName in @toolOptionalArgs(@tool) => `@argName`
  let @payloadArgs = for @argName in @toolPayloadArgs(@tool) => `@argName`
  let @updateFields = for @argName in @toolUpdateArgs(@tool) => `@argName`
  let @controlValues = @controlArgValues(@compiled.compiled_entries, @controlArgs)
  let @payloadPairs = for @argName in @payloadArgs when @compiled.compiled_args[@argName].isDefined() => {
    key: @argName,
    value: @compiled.compiled_args[@argName]
  }
  let @payloadValues = @pairsToObject(@payloadPairs)
  let @inputValues = @mergeArgSources([@controlValues, @payloadValues])
  >> Input records are an authorization/dispatch contract, not a cast
  >> surface. `@cast` rejects them upstream, and the live tool bridge
  >> already validates shape against `inputs:` at call time.
  let @preparedArgs = @inputValues
  if @updateFields.length > 0 && !@hasNonNullFieldValue(@preparedArgs, @updateFields) [
    => @plannerValidationFailure("no_update_fields", {
      update_fields: @updateFields,
      hint: `Update tools require at least one changed field in args alongside the control args. None of the declared update fields (@updateFields.join(", ")) are present. Pass the new value(s) directly — known literals or derived refs are both fine for update fields. Example: { args: { <control_arg>: { source: "resolved", ... }, @updateFields[0]: { source: "known", value: "<new value>" } } }. The error is NOT about source-class — switching between known/derived/selection won't fix it; you must include the field name itself.`
    }, null)
  ]
  if @toolCorrelateControlArgs(@tool) [
    let @correlated = @correlatedControlArgsCheck(@compiled.compiled_entries, @controlArgs)
    if !@correlated.ok [ => @plannerValidationFailure(@correlated.error ?? "correlated_control_args_failed", @correlated, @correlated.issues ?? null) ]
  ]
  let @policyIntent = when [
    @controlArgs.length == 0 && !@compiled.policy_intent[@operationName].isDefined() => { allow: [@operationName] }
    @compiled.policy_intent[@operationName].isDefined() => @compiled.policy_intent
    * => { allow: [@operationName] }
  ]
  let @dispatchBasePolicy = @agent.basePolicy
  let @built = when [
    @agent.defense == "defended" => @policy.build(
      @policyIntent,
      @agent.tools,
      { task: @query, basePolicy: @dispatchBasePolicy }
    )
    * => { valid: true, policy: null, issues: [] }
  ]
  if !@built.valid [ => @plannerValidationFailure("policy_build_invalid", @built, @built.issues ?? null) ]
  let @finalArgs = @mergeArgSources([@preparedArgs, @compiled.bind_args])
  >> `@policy.build(..., { basePolicy })` already returns the compiled
  >> task policy layered onto the active base policy. Re-merging
  >> `@dispatchBasePolicy` at dispatch time is redundant, and mlld's
  >> current array-policy merge path drops the compiled proof for
  >> input-record fact args. Dispatch the built policy directly so the
  >> worker sees the exact authorization envelope the builder validated.
  let @raw = when [
    @agent.defense == "defended" => @callToolWithPolicy(@tool, @agent.toolsCollection, @operationName, @finalArgs, @built.policy)
    * => @callTool(@tool, @agent.toolsCollection, @operationName, @finalArgs)
  ]
  let @toolError = @toolCallError(@raw)
  >> `toolCallError()` returns null on success. Compare explicitly so a
  >> defined local holding null does not trip the error path.
  if @toolError != null [ => @toolError ]
  let @toolMessage = @toolRuntimeMessage(@operationName, @raw)
  if @toolMessage != null [ => { error: "tool_runtime_error", summary: @toolMessage } ]
  let @returnsRecord = @tool.returns
  let @executeResultState = when [
    @returnsRecord.isDefined() && @raw.isDefined() && @typeof(@raw) != "string" => [
      let @recordType = @recordTypeName(@returnsRecord)
      let @coerced = @raw as record @returnsRecord
      let @entries = @normalizeResolvedValues(@recordType, @returnsRecord, @coerced)
      let @handles = for @entry in @entries => @entry.handle
      => { handles: @handles, state: @updateResolvedState(@state, @recordType, @entries) }
    ]
    * => { handles: [], state: @state }
  ]
  let @resultHandles = @executeResultState.handles
  let @nextState = @executeResultState.state
  let @summary = `executed @operationName`
  @appendExecutionLogEntry(@agent.executionLogFile, @serializeLifecycleJson({
    phase: "execute",
    tool: @operationName,
    summary: @summary,
    session_id: null
  }))
  => {
    state: @nextState,
    result: {
      status: "sent",
      tool: @operationName,
      result_handles: @resultHandles,
      summary: @summary
    },
    session_id: null
  }
]

export { @executePrompt, @coerceExecuteAttestation, @dispatchExecute }
