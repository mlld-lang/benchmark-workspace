import {
  @pairsToObject,
  @toolControlArgs,
  @toolOptionalArgs,
  @toolPayloadArgs,
  @toolUpdateArgs,
  @toolCorrelateControlArgs
} from "../tooling.mld"
import {
  @callTool,
  @callToolWithPolicy,
  @toolCallError,
  @toolRuntimeMessage,
  @correlatedControlArgsCheck,
  @recordTypeName,
  @writeRecordsToShelf,
  @recordHandles
} from "../runtime.mld"
import { @serializeLifecycleJson, @appendExecutionLogEntry } from "../lifecycle.mld"
import { @compileExecuteIntent } from "../intent.mld"
import { @executeAttestation } from "../records.mld"
import { @validatePlannerArgRefs, @plannerValidationFailure } from "../planner_inputs.mld"
>> @noNovelUrl is captured as the `do:` action on @urlDefense.dataflow.check[0]
>> built by orchestration's @synthesizedPolicy. When @policy.build runs here
>> (line ~127) it resolves the action by name, which requires the exe to be
>> visible in this module's scope. Without this import dispatch fails with
>> "Command not found: noNovelUrl" on tools whose suite has @hasNovelUrlRisk
>> (slack get_webpage). The import is referenced indirectly; the unused-import
>> warning would be a false positive.
import { @noNovelUrl } from "@mlld/policy"

>> Most execute steps dispatch directly once intent compilation and
>> policy construction succeed. The prompt remains available for suites
>> that want a worker-facing confirmation surface later.
exe @executePrompt(query, decision, preparedArgs) = template "../prompts/execute.att"

exe @coerceExecuteAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  => @parsed
] => record @executeAttestation

exe @controlArgValues(compiledEntries, controlArgs) = [
  let @controlArgNames = for @argName in (@controlArgs ?? []) => `@argName`
  let @pairs = for @entry in (@compiledEntries ?? []) when @controlArgNames.includes(`@entry.arg`) => {
    key: @entry.arg,
    value: @entry.value
  }
  => @pairsToObject(@pairs)
]

exe @hasNonNullFieldValue(inputValue, fieldNames) = [
  let @names = for @fieldName in (@fieldNames ?? []) => `@fieldName`
  let @matches = for @fieldName in @names when @inputValue[@fieldName].isDefined() && @inputValue[@fieldName] != null => @fieldName
  => @matches.length > 0
]

exe @mergeArgSources(values) = [
  let @pairs = loop(1000) [
    let @ctx = @input ?? { index: 0, values: [] }
    if @ctx.index >= @values.length [ done @ctx.values ]
    let @source = @values[@ctx.index] ?? {}
    let @sourcePairs = for @argKey, @argValue in @source => {
      key: @argKey,
      value: @argValue
    }
    continue {
      index: @ctx.index + 1,
      values: @ctx.values.concat(@sourcePairs)
    }
  ]
  => @pairsToObject(@pairs)
]


>> @compileForDispatch — shared "preflight" for execute and rehearse.
>>
>> Runs the deterministic, side-effect-free portion of dispatchExecute:
>> ref shape validation, intent compile, control/payload arg
>> classification, prepared-args construction, update-field check,
>> correlate check, policy compile.
>>
>> Returns either:
>>   { ok: true, tool, operation_name, control_args, optional_args,
>>     payload_args, update_fields, compiled, built, prepared_args }
>>   { ok: false, stage, failure: { error, payload, issues } }
>>
>> dispatchExecute calls this then continues with MCP dispatch.
>> dispatchRehearse calls this and reports {ok, blocked_args} only.
exe role:planner @compileForDispatch(agent, state, decision, query) = [
  let @shapeCheck = @validatePlannerArgRefs(@decision.args ?? {})
  if !@shapeCheck.ok [
    => { ok: false, stage: "shape", failure: { error: "planner_ref_validation_failed", payload: @shapeCheck, issues: @shapeCheck.issues } }
  ]
  let @compiled = @compileExecuteIntent(@agent, @state, @agent.tools, @decision, @query)
  if !@compiled.ok [
    => { ok: false, stage: "compile", failure: { error: @compiled.error ?? "intent_compile_failed", payload: @compiled, issues: @compiled.issues ?? null } }
  ]
  let @tool = @compiled.tool
  let @operationName = @decision.operation
  let @controlArgs = for @argName in @toolControlArgs(@tool) => `@argName`
  let @optionalArgs = for @argName in @toolOptionalArgs(@tool) => `@argName`
  let @payloadArgs = for @argName in @toolPayloadArgs(@tool) => `@argName`
  let @updateFields = for @argName in @toolUpdateArgs(@tool) => `@argName`
  let @controlValues = @controlArgValues(@compiled.compiled_entries, @controlArgs)
  let @payloadPairs = for @argName in @payloadArgs when @compiled.compiled_args[@argName].isDefined() => {
    key: @argName,
    value: @compiled.compiled_args[@argName]
  }
  let @payloadValues = @pairsToObject(@payloadPairs)
  let @inputValues = @mergeArgSources([@controlValues, @payloadValues])
  >> Input records are an authorization/dispatch contract, not a cast
  >> surface. `@cast` rejects them upstream, and the live tool bridge
  >> already validates shape against `inputs:` at call time.
  let @preparedArgs = @inputValues
  if @updateFields.length > 0 && !@hasNonNullFieldValue(@preparedArgs, @updateFields) [
    => { ok: false, stage: "update_fields", failure: { error: "no_update_fields", payload: {
      update_fields: @updateFields,
      hint: `Update tools require at least one changed field in args alongside the control args. None of the declared update fields (@updateFields.join(", ")) are present. Pass the new value(s) directly — known literals or derived refs are both fine for update fields. Example: { args: { <control_arg>: { source: "resolved", ... }, @updateFields[0]: { source: "known", value: "<new value>" } } }. The error is NOT about source-class — switching between known/derived/selection won't fix it; you must include the field name itself.`
    }, issues: null } }
  ]
  if @toolCorrelateControlArgs(@tool) [
    let @correlated = @correlatedControlArgsCheck(@compiled.compiled_entries, @controlArgs)
    if !@correlated.ok [
      => { ok: false, stage: "correlate", failure: { error: @correlated.error ?? "correlated_control_args_failed", payload: @correlated, issues: @correlated.issues ?? null } }
    ]
  ]
  let @policyIntent = when [
    @controlArgs.length == 0 && !@compiled.policy_intent[@operationName].isDefined() => { allow: [@operationName] }
    @compiled.policy_intent[@operationName].isDefined() => @compiled.policy_intent
    * => { allow: [@operationName] }
  ]
  let @dispatchBasePolicy = @agent.basePolicy
  let @built = when [
    @agent.defense == "defended" => @policy.build(
      @policyIntent,
      @agent.tools,
      { task: @query, basePolicy: @dispatchBasePolicy }
    )
    * => { valid: true, policy: null, issues: [] }
  ]
  if !@built.valid [
    => { ok: false, stage: "policy", failure: { error: "policy_build_invalid", payload: @built, issues: @built.issues ?? null } }
  ]
  => {
    ok: true,
    tool: @tool,
    operation_name: @operationName,
    control_args: @controlArgs,
    optional_args: @optionalArgs,
    payload_args: @payloadArgs,
    update_fields: @updateFields,
    compiled: @compiled,
    built: @built,
    prepared_args: @preparedArgs
  }
]

>> @dispatchExecute is exe role:worker because the actual MCP submit is
>> the worker's action. The inner @compileForDispatch is exe role:planner
>> — it activates planner role briefly for authorize. Don't change either
>> role annotation without understanding both gates that protect a write:
>>
>>   1. @policy.build verdict (planner-side, certifies intent fits the
>>      tool's input record schema + record permission for tools.authorize)
>>   2. write.role:worker.tools.submit (worker-side, certifies the active
>>      role at submit time has explicit submit permission)
>>
>> Both fire independently — defense in depth. Reverting either role
>> annotation regresses the migration in subtle ways: role:planner outer
>> would break submit (active role mismatch), role:worker on the inner
>> compile would skip planner-side intent verification.
>>
>> The worker-outer/planner-inner pattern is general for authorize-then-
>> submit flows. Tests that exercise this path inherit the same role
>> structure; see migration-plan.md §1 for context. `with { read: "role:X" }`
>> at call-site only affects projection — does NOT activate the write
>> context (verified via probe; error: WRITE_DENIED_NO_ROLE persists).
>>
>> Body split for c-3162-dispatch-wrap: the outer @dispatchExecute is a
>> direct-when so a policy throw bubbling from the inner @callToolWithPolicy
>> chain (e.g. labels.influenced.deny → exfil for slack/banking/workspace
>> IT0-class attacks) is captured as a denied event and converted to a
>> structured policy-denied envelope. Crossing exe boundaries converts
>> a denied event into an uncatchable MlldDirectiveError, so the catch
>> must live in the outer exe that calls dispatchImpl (probe-confirmed
>> in tmp/c-3162-dispatch-wrap/probe-exe-wraps-dispatch.mld).
exe role:worker @dispatchExecuteImpl(agent, state, decision, query) = [
  let @prep = @compileForDispatch(@agent, @state, @decision, @query)
  if !@prep.ok [
    => @plannerValidationFailure(@prep.failure.error, @prep.failure.payload, @prep.failure.issues)
  ]
  let @tool = @prep.tool
  let @operationName = @prep.operation_name
  let @compiled = @prep.compiled
  let @built = @prep.built
  let @preparedArgs = @prep.prepared_args
  let @finalArgs = @mergeArgSources([@preparedArgs, @compiled.bind_args])
  >> `@policy.build(..., { basePolicy })` already returns the compiled
  >> task policy layered onto the active base policy. Re-merging
  >> `@dispatchBasePolicy` at dispatch time is redundant, and mlld's
  >> current array-policy merge path drops the compiled proof for
  >> input-record fact args. Dispatch the built policy directly so the
  >> worker sees the exact authorization envelope the builder validated.
  let @raw = when [
    @agent.defense == "defended" => @callToolWithPolicy(@tool, @agent.toolsCollection, @operationName, @finalArgs, @built.policy)
    * => @callTool(@tool, @agent.toolsCollection, @operationName, @finalArgs)
  ]
  let @toolError = @toolCallError(@raw)
  >> `toolCallError()` returns null on success. Compare explicitly so a
  >> defined local holding null does not trip the error path.
  if @toolError != null [ => @toolError ]
  let @toolMessage = @toolRuntimeMessage(@operationName, @raw)
  if @toolMessage != null [ => { error: "tool_runtime_error", summary: @toolMessage } ]
  let @returnsRecord = @tool.returns
  let @resultHandles = when [
    @returnsRecord.isDefined() && @raw.isDefined() && @typeof(@raw) != "string" => [
      let @recordType = @recordTypeName(@returnsRecord)
      let @records = @writeRecordsToShelf(@agent, @recordType, @returnsRecord, @raw)
      => @recordHandles(@records)
    ]
    * => []
  ]
  let @nextState = @state
  let @summary = `executed @operationName`
  @appendExecutionLogEntry(@agent.executionLogFile, @serializeLifecycleJson({
    phase: "execute",
    tool: @operationName,
    summary: @summary,
    session_id: null
  }))
  => {
    state: @nextState,
    result: {
      status: "sent",
      tool: @operationName,
      result_handles: @resultHandles,
      summary: @summary
    },
    session_id: null
  }
]

>> Outer @dispatchExecute: direct-when body so a policy denial bubbling
>> from @dispatchExecuteImpl's deep call chain (@callToolWithPolicy →
>> @callToolWithOptionalPolicy → @toolEntry(...) with { policy }) surfaces
>> as a `denied` event in this exe scope. We convert it to the same
>> {ok:false, error:"policy_denied", code, message, ...} envelope shape
>> that mlld's input-validation path already produces, so downstream
>> @toolCallError + @settlePhaseDispatch handle both denial paths
>> uniformly.
exe role:worker @dispatchExecute(agent, state, decision, query) = when [
  denied => {
    state: @state,
    ok: false,
    error: "policy_denied",
    stage: "dispatch_policy",
    code: @mx.guard.code ?? "POLICY_DENIED",
    message: @mx.guard.reason ?? "Operation denied by policy",
    reason: @mx.guard.reason ?? null,
    filter: @mx.guard.filter ?? null,
    decision: @mx.guard.decision ?? null,
    guard: @mx.guard,
    session_id: null
  }
  * => @dispatchExecuteImpl(@agent, @state, @decision, @query)
]

export { @executePrompt, @coerceExecuteAttestation, @compileForDispatch, @dispatchExecute }
