import {
  @pairsToObject,
  @toolControlArgs,
  @toolOptionalArgs,
  @toolPayloadArgs,
  @toolUpdateArgs,
  @toolCorrelateControlArgs
} from "../tooling.mld"
import {
  @callTool,
  @callToolWithPolicy,
  @toolCallError,
  @toolRuntimeMessage,
  @correlatedControlArgsCheck,
  @appendExecutionLog
} from "../runtime.mld"
import { @compileExecuteIntent } from "../intent.mld"
import { @executeAttestation } from "../records.mld"

>> Most execute steps dispatch directly once intent compilation and
>> policy construction succeed. The prompt remains available for suites
>> that want a worker-facing confirmation surface later.
exe @executePrompt(query, decision, preparedArgs) = template "../prompts/execute.att"

exe @coerceExecuteAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  => @parsed
] => record @executeAttestation

exe @controlArgValues(compiledEntries, controlArgs) = [
  let @pairs = for @entry in (@compiledEntries ?? []) when @controlArgs.includes(@entry.arg) => {
    key: @entry.arg,
    value: @entry.value
  }
  => @pairsToObject(@pairs)
]

exe @hasNonNullFieldValue(inputValue, fieldNames) = [
  let @matches = for @fieldName in (@fieldNames ?? []) when @inputValue[@fieldName].isDefined() && @inputValue[@fieldName] != null => @fieldName
  => @matches.length > 0
]

exe @mergeArgSources(values) = [
  let @pairs = loop(1000) [
    let @ctx = when [
      @input["_rig_cursor"] == "mergeArgSources" => @input
      * => { _rig_cursor: "mergeArgSources", index: 0, values: [] }
    ]
    if @ctx.index >= @values.length [ done @ctx.values ]
    let @source = @values[@ctx.index] ?? {}
    let @sourcePairs = for @argKey, @argValue in @source => {
      key: @argKey,
      value: @argValue
    }
    continue {
      _rig_cursor: "mergeArgSources",
      index: @ctx.index + 1,
      values: @ctx.values.concat(@sourcePairs)
    }
  ]
  => @pairsToObject(@pairs)
]

exe @omittedOptionalControlIntent(operationName, controlArgs) = [
  let @argPairs = for @argName in (@controlArgs ?? []) => {
    key: @argName,
    value: {
      value: null,
      source: "optional control arg omitted"
    }
  }
  let @toolArgs = @pairsToObject(@argPairs)
  => {
    known: {
      [@operationName]: @toolArgs
    }
  }
]

>> Optional fact omission is a dispatched-tool contract, not planner
>> intent. When every control arg on a write tool is optional and absent,
>> the new input-record spec says the omission is benign and the runtime
>> should not force an unknown-destination check. Until mlld's base rules
>> learn that path natively, rig strips only the unknown-target rules for
>> that one dispatch and authorizes the tool-level call internally.
exe @presentControlArgs(compiledEntries, controlArgs) = [
  => for @entry in (@compiledEntries ?? []) when @controlArgs.includes(@entry.arg) => @entry.arg
]

exe @allControlArgsOptional(controlArgs, optionalArgs) = [
  let @required = for @argName in (@controlArgs ?? []) when !@optionalArgs.includes(@argName) => @argName
  => @required.length == 0
]

exe @omitUnknownTargetRules(basePolicy) = [
  let @rules = @basePolicy.defaults.rules ?? []
  let @filteredRules = for @rule in @rules when @rule != "no-send-to-unknown" && @rule != "no-destroy-unknown" => @rule
  let @defaults = @basePolicy.defaults ?? {}
  => {
    defaults: {
      unlabeled: @defaults.unlabeled ?? null,
      rules: @filteredRules
    },
    capabilities: @basePolicy.capabilities ?? {},
    operations: @basePolicy.operations ?? {},
    labels: @basePolicy.labels ?? {},
    authorizations: @basePolicy.authorizations ?? {}
  }
]

exe role:planner @dispatchExecute(agent, state, decision, query) = [
  let @compiled = @compileExecuteIntent(@state, @agent.tools, @decision, @query)
  if !@compiled.ok [ => { error: @compiled.error ?? "intent_compile_failed", summary: @compiled | @pretty } ]
  let @tool = @compiled.tool
  let @operationName = @decision.operation
  let @controlArgs = @toolControlArgs(@tool)
  let @optionalArgs = @toolOptionalArgs(@tool)
  let @payloadArgs = @toolPayloadArgs(@tool)
  let @updateFields = @toolUpdateArgs(@tool)
  let @controlValues = @controlArgValues(@compiled.compiled_entries, @controlArgs)
  let @presentControlArgNames = @presentControlArgs(@compiled.compiled_entries, @controlArgs)
  let @payloadPairs = for @argName in @payloadArgs when @compiled.compiled_args[@argName].isDefined() => {
    key: @argName,
    value: @compiled.compiled_args[@argName]
  }
  let @payloadValues = @pairsToObject(@payloadPairs)
  let @inputValues = @mergeArgSources([@controlValues, @payloadValues])
  >> Input records are an authorization/dispatch contract, not a cast
  >> surface. `@cast` rejects them upstream, and the live tool bridge
  >> already validates shape against `inputs:` at call time.
  let @preparedArgs = @inputValues
  if @updateFields.length > 0 && !@hasNonNullFieldValue(@preparedArgs, @updateFields) [
    => { error: "no_update_fields", summary: @updateFields | @pretty }
  ]
  if @toolCorrelateControlArgs(@tool) [
    let @correlated = @correlatedControlArgsCheck(@compiled.compiled_entries, @controlArgs)
    if !@correlated.ok [ => { error: @correlated.error, summary: @correlated | @pretty } ]
  ]
  let @optionalControlArgsOmitted = @controlArgs.length > 0 &&
    @presentControlArgNames.length == 0 &&
    @allControlArgsOptional(@controlArgs, @optionalArgs) &&
    !@compiled.policy_intent[@operationName].isDefined()
  let @policyIntent = when [
    @controlArgs.length == 0 && !@compiled.policy_intent[@operationName].isDefined() => { allow: [@operationName] }
    @optionalControlArgsOmitted => @omittedOptionalControlIntent(@operationName, @controlArgs)
    * => @compiled.policy_intent
  ]
  let @dispatchBasePolicy = when [
    @optionalControlArgsOmitted => @omitUnknownTargetRules(@agent.basePolicy)
    * => @agent.basePolicy
  ]
  let @built = when [
    @agent.defense == "defended" => @policy.build(
      @policyIntent,
      @agent.tools,
      { task: @query, basePolicy: @dispatchBasePolicy }
    )
    * => { valid: true, policy: null, issues: [] }
  ]
  if !@built.valid [ => { error: "policy_build_invalid", summary: @built.issues | @pretty } ]
  let @finalArgs = @mergeArgSources([@preparedArgs, @compiled.bind_args])
  >> `@policy.build(..., { basePolicy })` already returns the compiled
  >> task policy layered onto the active base policy. Re-merging
  >> `@dispatchBasePolicy` at dispatch time is redundant, and mlld's
  >> current array-policy merge path drops the compiled proof for
  >> input-record fact args. Dispatch the built policy directly so the
  >> worker sees the exact authorization envelope the builder validated.
  let @raw = when [
    @agent.defense == "defended" => @callToolWithPolicy(@tool, @agent.toolsCollection, @operationName, @finalArgs, @built.policy, @agent.runtimeTools ?? null)
    * => @callTool(@tool, @agent.toolsCollection, @operationName, @finalArgs, @agent.runtimeTools ?? null)
  ]
  let @toolError = @toolCallError(@raw)
  >> `toolCallError()` returns null on success. Compare explicitly so a
  >> defined local holding null does not trip the error path.
  if @toolError != null [ => @toolError ]
  let @toolMessage = @toolRuntimeMessage(@operationName, @raw)
  if @toolMessage != null [ => { error: "tool_runtime_error", summary: @toolMessage } ]
  let @summary = `executed @operationName`
  let @nextState = @appendExecutionLog(@state, {
    phase: "execute",
    tool: @operationName,
    summary: @summary,
    session_id: null
  })
  => {
    state: @nextState,
    result: {
      status: "sent",
      tool: @operationName,
      result_handles: [],
      summary: @summary
    },
    session_id: null
  }
]

export { @executePrompt, @coerceExecuteAttestation, @dispatchExecute }
