import {
  @pairsToObject,
  @toolControlArgs,
  @toolPayloadArgs,
  @toolUpdateArgs,
  @toolCorrelateControlArgs
} from "../tooling.mld"
import {
  @callTool,
  @callToolWithPolicy,
  @toolCallError,
  @toolRuntimeMessage,
  @correlatedControlArgsCheck,
  @appendExecutionLog
} from "../runtime.mld"
import { @compileExecuteIntent } from "../intent.mld"
import { @executeAttestation } from "../records.mld"

>> Most execute steps dispatch directly once intent compilation and
>> policy construction succeed. The prompt remains available for suites
>> that want a worker-facing confirmation surface later.
exe @executePrompt(query, decision, preparedArgs) = template "../prompts/execute.att"

exe @coerceExecuteAttestation(raw) = [
  if @raw == null [ => null ]
  let @parsed = @raw | @parse.llm
  => @parsed
] => record @executeAttestation

exe @controlArgValues(compiledEntries, controlArgs) = [
  let @pairs = for @entry in (@compiledEntries ?? []) when @controlArgs.includes(@entry.arg) => {
    key: @entry.arg,
    value: @entry.value
  }
  => @pairsToObject(@pairs)
]

exe @hasNonNullFieldValue(inputValue, fieldNames) = [
  let @matches = for @fieldName in (@fieldNames ?? []) when @inputValue[@fieldName].isDefined() && @inputValue[@fieldName] != null => @fieldName
  => @matches.length > 0
]

exe @mergeArgSources(values) = [
  let @pairs = loop(1000) [
    let @ctx = when [
      @input["_rig_cursor"] == "mergeArgSources" => @input
      * => { _rig_cursor: "mergeArgSources", index: 0, values: [] }
    ]
    if @ctx.index >= @values.length [ done @ctx.values ]
    let @source = @values[@ctx.index] ?? {}
    let @sourcePairs = for @argKey, @argValue in @source => {
      key: @argKey,
      value: @argValue
    }
    continue {
      _rig_cursor: "mergeArgSources",
      index: @ctx.index + 1,
      values: @ctx.values.concat(@sourcePairs)
    }
  ]
  => @pairsToObject(@pairs)
]

exe @dispatchExecute(agent, state, decision, query) = [
  let @compiled = @compileExecuteIntent(@state, @agent.tools, @decision, @query)
  if !@compiled.ok [ => { error: @compiled.error ?? "intent_compile_failed", summary: @compiled | @pretty } ]
  let @tool = @compiled.tool
  let @operationName = @decision.operation
  let @controlArgs = @toolControlArgs(@tool)
  let @payloadArgs = @toolPayloadArgs(@tool)
  let @updateArgs = @toolUpdateArgs(@tool)
  let @controlValues = @controlArgValues(@compiled.compiled_entries, @controlArgs)
  let @payloadPairs = for @argName in @payloadArgs when @compiled.compiled_args[@argName].isDefined() => {
    key: @argName,
    value: @compiled.compiled_args[@argName]
  }
  let @payloadValues = @pairsToObject(@payloadPairs)
  let @typedPayload = when [
    @compiled.operation.payloadRecord.isDefined() => @cast(@payloadValues, @compiled.operation.payloadRecord)
    * => @payloadValues
  ]
  if @updateArgs.length > 0 && !@hasNonNullFieldValue(@typedPayload, @updateArgs) [
    => { error: "update_args_missing_values", summary: @updateArgs | @pretty }
  ]
  if @toolCorrelateControlArgs(@tool) [
    let @correlated = @correlatedControlArgsCheck(@compiled.compiled_entries, @controlArgs)
    if !@correlated.ok [ => { error: @correlated.error, summary: @correlated | @pretty } ]
  ]
  let @policyIntent = when [
    @controlArgs.length == 0 && !@compiled.policy_intent[@operationName].isDefined() => { [@operationName]: true }
    * => @compiled.policy_intent
  ]
  let @built = when [
    @agent.defense == "defended" => @policy.build(
      @policyIntent,
      @agent.toolsCollection,
      { task: @query, basePolicy: @agent.basePolicy }
    )
    * => { valid: true, policy: null, issues: [] }
  ]
  if !@built.valid [ => { error: "policy_build_invalid", summary: @built.issues | @pretty } ]
  let @finalArgs = @mergeArgSources([@controlValues, @typedPayload, @compiled.bind_args])
  let @raw = when [
    @agent.defense == "defended" => @callToolWithPolicy(@tool, @agent.toolsCollection, @operationName, @finalArgs, [@agent.basePolicy, @built.policy], @agent.runtimeTools ?? null)
    * => @callTool(@tool, @agent.toolsCollection, @operationName, @finalArgs, @agent.runtimeTools ?? null)
  ]
  let @toolError = @toolCallError(@raw)
  >> `toolCallError()` returns null on success. Compare explicitly so a
  >> defined local holding null does not trip the error path.
  if @toolError != null [ => @toolError ]
  let @toolMessage = @toolRuntimeMessage(@operationName, @raw)
  if @toolMessage != null [ => { error: "tool_runtime_error", summary: @toolMessage } ]
  let @summary = `executed @operationName`
  let @nextState = @appendExecutionLog(@state, {
    phase: "execute",
    tool: @operationName,
    summary: @summary,
    session_id: null
  })
  => {
    state: @nextState,
    result: {
      status: "sent",
      tool: @operationName,
      result_handles: [],
      summary: @summary
    },
    session_id: null
  }
]

export { @executePrompt, @coerceExecuteAttestation, @dispatchExecute }
