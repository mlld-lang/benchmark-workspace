import { @claude } from "@mlld/claude"
import { @opencode } from "@mlld/opencode"
import { @phaseToolDocs } from "../tooling.mld"
import {
  @llmCall,
  @llmCallEntry,
  @llmSessionId,
  @normalizePositiveInt,
  @normalizeSessionId,
  @arrayItems,
  @stringValue,
  @appendLlmDebug,
  @appendExecutionLog,
  @appendPhaseEvents,
  @projectResolvedEntry
} from "../runtime.mld"
import {
  @serializeLifecycleJson,
  @appendPhaseEvent,
  @writePhaseStateFile,
  @betweenState,
  @plannerIterationEvent,
  @phaseStartEvent,
  @phaseEndEvent,
  @phaseState
} from "../lifecycle.mld"
import { @planner, @emptyPlannerRuntime, @emptyState } from "../session.mld"
import { @dispatchResolve } from "./resolve.mld"
import { @dispatchExtract } from "./extract.mld"
import { @dispatchDerive } from "./derive.mld"
import { @dispatchExecute } from "./execute.mld"
import { @dispatchCompose } from "./compose.mld"

record @planner_resolve_inputs = {
  data: [tool: string, args: object?, purpose: string?],
  validate: "strict"
}

record @planner_extract_inputs = {
  data: [
    tool: string?,
    args: object?,
    source: object?,
    schema_name: string?,
    schema: object?,
    name: string,
    purpose: string?
  ],
  validate: "strict"
}

record @planner_derive_inputs = {
  data: [
    sources: array,
    goal: string,
    schema_name: string?,
    schema: object?,
    name: string,
    purpose: string?
  ],
  validate: "strict"
}

record @planner_execute_inputs = {
  data: [operation: string, args: object?, purpose: string?],
  validate: "strict"
}

record @planner_compose_inputs = {
  data: [sources: array?, purpose: string?],
  validate: "strict"
}

record @planner_blocked_inputs = {
  data: [reason: string],
  validate: "strict"
}

record @planner_tool_result = {
  data: [
    status: string,
    phase: string?,
    error: string?,
    reason: string?,
    tool: string?,
    record_type: string?,
    count: number?,
    handles: array?,
    records: array?,
    name: string?,
    schema_name: string?,
    provenance: string?,
    preview_fields: array?,
    selection_refs: array?,
    result_handles: array?,
    summary: string?,
    issues: array?
  ],
  validate: "demote"
}

exe @plannerPrompt(query, resolveTools, extractTools, executeTools) = template "../prompts/planner.att"

exe @phaseId(phase, iteration) = `@phase:@iteration`

exe @plannerRuntimeState(toolCalls, invalidCalls, terminal, lastDecision) = [
  => {
    tool_calls: @toolCalls,
    invalid_calls: @invalidCalls,
    terminal: @terminal,
    last_decision: @lastDecision
  }
]

exe @plannerToolBudget(agent) = [
  => @normalizePositiveInt(@agent.maxIterations, 40)
]

exe @plannerInvalidBudget() = [
  => 3
]


exe @plannerResolvedRecords(records, state, recordType, handles) = [
  let @recordDef = @records[@recordType]
  if !@recordDef.isDefined() [ => [] ]
  let @handleList = for @handle in @arrayItems(@handles ?? []) => @stringValue(@handle)
  => for @entry in @arrayItems(@state.resolved[@recordType]) when @handleList.includes(@stringValue(@entry.handle)) => @projectResolvedEntry(@recordType, @recordDef, @entry, "role:planner")
]

exe @plannerToolContext(phase, decision) = [
  let @agent = @planner.agent
  if !@agent.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_uninitialized",
        summary: "planner_session_uninitialized"
      }
    }
  ]
  let @query = @planner.query
  if !@query.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_uninitialized",
        summary: "planner_session_uninitialized"
      }
    }
  ]
  let @runtime = @planner.runtime
  if @runtime.terminal.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_already_terminal",
        summary: @runtime.terminal.reason ?? @runtime.terminal.status ?? "planner_session_already_terminal"
      }
    }
  ]
  let @budget = @plannerToolBudget(@agent)
  if @runtime.tool_calls >= @budget [
    let @terminal = {
      status: "blocked",
      text: "blocked: planner_tool_budget_exhausted",
      reason: "planner_tool_budget_exhausted"
    }
    @planner.set({ runtime: @plannerRuntimeState(@runtime.tool_calls, @runtime.invalid_calls, @terminal, @decision) })
    => {
      ok: false,
      result: {
        status: "blocked",
        reason: "planner_tool_budget_exhausted"
      }
    }
  ]
  if @runtime.invalid_calls >= @plannerInvalidBudget() [
    let @terminal = {
      status: "blocked",
      text: "blocked: planner_error_budget_exhausted",
      reason: "planner_error_budget_exhausted"
    }
    @planner.set({ runtime: @plannerRuntimeState(@runtime.tool_calls, @runtime.invalid_calls, @terminal, @decision) })
    => {
      ok: false,
      result: {
        status: "blocked",
        reason: "planner_error_budget_exhausted"
      }
    }
  ]
  let @iteration = @runtime.tool_calls + 1
  let @phaseIdValue = @phaseId(@phase, @iteration)
  let @plannerEvent = @plannerIterationEvent(@iteration, @phase)
  let @startEvent = @phaseStartEvent(@iteration, @phase, @phaseIdValue)
  @appendPhaseEvent(@agent.phaseLogFile, @serializeLifecycleJson(@plannerEvent))
  @appendPhaseEvent(@agent.phaseLogFile, @serializeLifecycleJson(@startEvent))
  @writePhaseStateFile(
    @agent.phaseStateFile,
    @serializeLifecycleJson(@phaseState(@phase, @phaseIdValue, @iteration, null))
  )
  => {
    ok: true,
    agent: @agent,
    query: @query,
    state: @planner.state,
    runtime: @runtime,
    iteration: @iteration,
    phase_id: @phaseIdValue,
    planner_event: @plannerEvent,
    start_event: @startEvent,
    decision: @decision
  }
]

exe @finishPlannerTool(ctx, nextState, nextRuntime, workerSessionId, outcome, summary, llmLog) = [
  @appendLlmDebug(@ctx.agent, @llmLog)
  @writePhaseStateFile(
    @ctx.agent.phaseStateFile,
    @serializeLifecycleJson(@phaseState(@ctx.decision.phase, @ctx.phase_id, @ctx.iteration, @workerSessionId))
  )
  let @endEvent = @phaseEndEvent(
    @ctx.iteration,
    @ctx.decision.phase,
    @ctx.phase_id,
    @workerSessionId,
    @outcome,
    @summary
  )
  @appendPhaseEvent(@ctx.agent.phaseLogFile, @serializeLifecycleJson(@endEvent))
  @writePhaseStateFile(@ctx.agent.phaseStateFile, @serializeLifecycleJson(@betweenState()))
  let @stateWithEvents = @appendPhaseEvents(@nextState, [@ctx.planner_event, @ctx.start_event, @endEvent])
  @planner.set({ state: @stateWithEvents, runtime: @nextRuntime })
  => {
    state: @stateWithEvents,
    runtime: @nextRuntime
  }
]

exe @settlePhaseDispatch(toolCtx, phaseResult, decision) = [
  let @workerSessionId = @normalizeSessionId(@phaseResult.session_id)
  let @nextState = when [
    @phaseResult.error.isDefined() => @appendExecutionLog(
      @phaseResult.state ?? @toolCtx.state,
      {
        phase: @decision.phase,
        tool: @decision.tool ?? @decision.operation ?? null,
        name: @decision.name ?? null,
        status: "error",
        error: @phaseResult.error,
        summary: @phaseResult.summary ?? @phaseResult.error,
        issues: @phaseResult.issues ?? null,
        raw_error: @phaseResult.raw_error ?? null,
        worker_session_id: @workerSessionId
      }
    )
    * => @phaseResult.state
  ]
  let @invalidCalls = when [
    @phaseResult.error.isDefined() => @toolCtx.runtime.invalid_calls + 1
    * => 0
  ]
  let @terminal = when [
    @phaseResult.error.isDefined() && @invalidCalls >= @plannerInvalidBudget() => {
      status: "blocked",
      text: "blocked: planner_error_budget_exhausted",
      reason: "planner_error_budget_exhausted"
    }
    * => null
  ]
  let @nextRuntime = @plannerRuntimeState(
    @toolCtx.runtime.tool_calls + 1,
    @invalidCalls,
    @terminal,
    @decision
  )
  let @summary = when [
    @phaseResult.error.isDefined() => @phaseResult.summary ?? @phaseResult.error
    * => @phaseResult.result.summary
  ]
  let @finished = @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    @workerSessionId,
    when [ @phaseResult.error.isDefined() => "error" * => "success" ],
    @summary,
    @phaseResult.llm_log ?? null
  )
  let @budget = @plannerToolBudget(@toolCtx.agent)
  let @remaining = @budget - (@toolCtx.runtime.tool_calls + 1)
  let @budgetWarning = when [
    @remaining <= 3 => `You have @remaining tool call(s) remaining. If you can answer the user's question now, call compose immediately.`
    * => null
  ]
  => {
    finished: @finished,
    terminal: @terminal,
    summary: @summary,
    workerSessionId: @workerSessionId,
    budget_warning: @budgetWarning
  }
]

exe @plannerResolve(input) = [
  let @coerced = @input ?? {}
  let @tool = @coerced.tool
  let @args = @coerced.args ?? {}
  let @purpose = @coerced.purpose ?? null
  let @decision = { phase: "resolve", tool: @tool, args: @args, purpose: @purpose }
  let @toolCtx = @plannerToolContext("resolve", @decision)
  if !@toolCtx.ok [ -> @toolCtx.result; => @toolCtx.result ]
  let @phaseResult = @dispatchResolve(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @resolvedHandles = for @handle in @arrayItems(@phaseResult.result.handles ?? []) => @stringValue(@handle)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "resolve", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning }
    * => {
      status: "resolved",
      tool: @tool,
      record_type: @phaseResult.result.record_type,
      count: @phaseResult.result.count,
      handles: @resolvedHandles,
      records: @plannerResolvedRecords(@toolCtx.agent.records ?? {}, @settled.finished.state, @phaseResult.result.record_type, @resolvedHandles),
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerExtract(input) = [
  let @coerced = @input ?? {}
  let @tool = @coerced.tool ?? null
  let @args = @coerced.args ?? {}
  let @source = @coerced.source ?? null
  let @schema_name = @coerced.schema_name ?? null
  let @schema = @coerced.schema ?? null
  let @name = @coerced.name
  let @purpose = @coerced.purpose ?? null
  let @schemaValue = when [
    @schema_name.isDefined() => @schema_name
    * => @schema
  ]
  let @decision = when [
    @tool.isDefined() => {
      phase: "extract",
      tool: @tool,
      args: @args ?? {},
      name: @name,
      purpose: @purpose ?? null
    }
    @source.isDefined() => {
      phase: "extract",
      source: @source,
      schema: @schemaValue,
      name: @name,
      purpose: @purpose ?? null
    }
    * => {
      phase: "extract",
      name: @name,
      purpose: @purpose ?? null
    }
  ]
  let @toolCtx = @plannerToolContext("extract", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  if !@tool.isDefined() && !@source.isDefined() [
    let @missingState = @appendExecutionLog(@toolCtx.state, {
      phase: "extract",
      name: @name,
      status: "error",
      error: "extract_requires_tool_or_source",
      summary: "extract_requires_tool_or_source"
    })
    let @missingInvalidCalls = @toolCtx.runtime.invalid_calls + 1
    let @missingTerminal = when [
      @missingInvalidCalls >= @plannerInvalidBudget() => {
        status: "blocked",
        text: "blocked: planner_error_budget_exhausted",
        reason: "planner_error_budget_exhausted"
      }
      * => null
    ]
    let @missingRuntime = @plannerRuntimeState(@toolCtx.runtime.tool_calls + 1, @missingInvalidCalls, @missingTerminal, @decision)
    @finishPlannerTool(@toolCtx, @missingState, @missingRuntime, null, "error", "extract_requires_tool_or_source", null)
    let @missingResult = when [
      @missingTerminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
      * => { status: "error", phase: "extract", error: "extract_requires_tool_or_source", summary: "extract_requires_tool_or_source" }
    ]
    -> @missingResult
    => @missingResult
  ]
  let @phaseResult = @dispatchExtract(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "extract", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning }
    * => {
      status: "extracted",
      name: @phaseResult.result.name,
      schema_name: @phaseResult.result.schema_name,
      provenance: @phaseResult.result.provenance,
      preview_fields: @phaseResult.result.preview_fields,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerDerive(input) = [
  let @coerced = @input ?? {}
  let @sources = @coerced.sources ?? []
  let @goal = @coerced.goal
  let @schema_name = @coerced.schema_name ?? null
  let @schema = @coerced.schema ?? null
  let @name = @coerced.name
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "derive",
    sources: @sources,
    goal: @goal,
    schema: when [ @schema_name.isDefined() => @schema_name * => @schema ],
    name: @name,
    purpose: @purpose ?? null
  }
  let @toolCtx = @plannerToolContext("derive", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchDerive(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "derive", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning }
    * => {
      status: "derived",
      name: @phaseResult.result.name,
      schema_name: @phaseResult.result.schema_name,
      provenance: @phaseResult.result.provenance,
      preview_fields: @phaseResult.result.preview_fields,
      selection_refs: @phaseResult.result.selection_refs,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerExecute(input) = [
  let @coerced = @input ?? {}
  let @operation = @coerced.operation
  let @args = @coerced.args ?? {}
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "execute",
    operation: @operation,
    args: @args,
    purpose: @purpose
  }
  let @toolCtx = @plannerToolContext("execute", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchExecute(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "execute", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning }
    * => {
      status: "executed",
      tool: @phaseResult.result.tool,
      result_handles: @phaseResult.result.result_handles,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerCompose(input) = [
  let @coerced = @input ?? {}
  let @sources = @coerced.sources ?? []
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "compose",
    sources: @sources,
    purpose: @purpose
  }
  let @toolCtx = @plannerToolContext("compose", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchCompose(@toolCtx.agent, @toolCtx.state, @toolCtx.query)
  let @workerSessionId = @normalizeSessionId(@phaseResult.session_id)
  let @nextState = @appendExecutionLog(@toolCtx.state, {
    phase: "compose",
    status: "complete",
    summary: "final answer prepared",
    worker_session_id: @workerSessionId,
    session_id: @workerSessionId
  })
  let @nextRuntime = @plannerRuntimeState(
    @toolCtx.runtime.tool_calls + 1,
    0,
    {
      status: "complete",
      text: @phaseResult["text"],
      reason: null
    },
    @decision
  )
  @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    @workerSessionId,
    "success",
    "final answer prepared",
    @phaseResult.llm_log ?? null
  )
  let @result = {
    status: "complete",
    summary: "final answer prepared"
  }
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerBlocked(input) = [
  let @coerced = @input ?? {}
  let @reason = @coerced.reason
  let @decision = {
    phase: "blocked",
    reason: @reason
  }
  let @toolCtx = @plannerToolContext("blocked", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @nextState = @appendExecutionLog(@toolCtx.state, {
    phase: "blocked",
    status: "blocked",
    summary: @reason
  })
  let @nextRuntime = @plannerRuntimeState(
    @toolCtx.runtime.tool_calls + 1,
    0,
    {
      status: "blocked",
      text: @reason,
      reason: @reason
    },
    @decision
  )
  @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    null,
    "blocked",
    @reason,
    null
  )
  let @result = {
    status: "blocked",
    reason: @reason
  }
  -> @result
  => @result
]

var tools @plannerTools = {
  resolve: {
    mlld: @plannerResolve,
    inputs: @planner_resolve_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Ground records into planner-visible state with one resolve tool."
  },
  extract: {
    mlld: @plannerExtract,
    inputs: @planner_extract_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Fetch literal untrusted content or extract typed payload from grounded state."
  },
  derive: {
    mlld: @plannerDerive,
    inputs: @planner_derive_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Compute a typed named result from grounded inputs."
  },
  execute: {
    mlld: @plannerExecute,
    inputs: @planner_execute_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Perform one concrete write through the defended execute path."
  },
  compose: {
    mlld: @plannerCompose,
    inputs: @planner_compose_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Prepare the final answer and terminate the session."
  },
  blocked: {
    mlld: @plannerBlocked,
    inputs: @planner_blocked_inputs,
    direct: true,
    labels: ["tool:w"],
    description: "Terminate the session because no legal path remains."
  }
}

exe @runPlannerSession(agent, query) = [
  let @resolveDocs = @phaseToolDocs(@agent, "resolve")
  let @extractDocs = @phaseToolDocs(@agent, "extract")
  let @executeDocs = @phaseToolDocs(@agent, "execute")
  let @prompt = @plannerPrompt(@query, @resolveDocs, @extractDocs, @executeDocs)
  let @plannerConfig = {
    model: @agent.model,
    tools: @plannerTools,
    stubPhase: "planner",
    stubResponses: @agent.stub.planner ?? []
  }
  let @raw = when [
    @agent.harness == "stub" => @llmCall("stub", @prompt, @plannerConfig) with { display: "role:planner" }
    @agent.harness == "opencode" => @opencode(@prompt, @plannerConfig) with { display: "role:planner", session: @planner, seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() } }
    * => @claude(@prompt, @plannerConfig) with { display: "role:planner", session: @planner, seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() } }
  ]
  let @sessionId = @llmSessionId(@raw)
  let @finalSession = @raw.mx.sessions.planner
  let @runtime = @finalSession.runtime ?? @emptyPlannerRuntime()
  let @sessionState = @finalSession.state ?? @emptyState()
  let @logEntry = @llmCallEntry(
    "planner",
    @prompt,
    @raw,
    null,
    @sessionId,
    {
      call_kind: "outer_planner",
      outer_planner_session_id: @sessionId,
      tool_use: true,
      tool_calls: @runtime.tool_calls,
      terminal: @runtime.terminal.status ?? null
    }
  )
  @appendLlmDebug(@agent, @logEntry)
  let @terminal = when [
    @runtime.terminal.isDefined() => @runtime.terminal
    * => {
      status: "blocked",
      text: "planner_session_ended_without_terminal_tool",
      reason: "planner_session_ended_without_terminal_tool"
    }
  ]
  => {
    terminal: @terminal.status,
    final: { text: @terminal.text },
    execution_log: @sessionState.execution_log ?? [],
    phase_events: @sessionState.phase_events ?? [],
    last_decision: @runtime.last_decision ?? null
  }
]

export { @planner, @plannerPrompt, @plannerTools, @runPlannerSession }
