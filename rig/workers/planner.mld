import { @claude } from "@mlld/claude"
import { @opencode } from "@mlld/opencode"
import { @phaseToolDocs } from "../tooling.mld"
import {
  @llmCall,
  @llmCallEntry,
  @llmSessionId,
  @normalizePositiveInt,
  @normalizeSessionId,
  @arrayItems,
  @stringValue,
  @appendLlmDebug,
  @updateExtractSources,
  @projectResolvedEntry,
  @bucketItems
} from "../runtime.mld"
import {
  @serializeLifecycleJson,
  @appendPhaseEvent,
  @appendExecutionLogEntry,
  @readExecutionLogFile,
  @writePhaseStateFile,
  @betweenState,
  @plannerIterationEvent,
  @phaseStartEvent,
  @phaseEndEvent,
  @phaseState
} from "../lifecycle.mld"
import { @planner, @emptyPlannerRuntime, @emptyState } from "../session.mld"
import { @dispatchResolve } from "./resolve.mld"
import { @dispatchExtract } from "./extract.mld"
import { @dispatchDerive } from "./derive.mld"
import { @dispatchExecute } from "./execute.mld"
import { @dispatchCompose } from "./compose.mld"
import "../diagnostics.mld"

record @planner_resolve_inputs = {
  data: [tool: string, args: object?, purpose: string?],
  validate: "strict"
}

record @planner_resolve_batch_inputs = {
  data: [resolves: array, purpose: string?],
  validate: "strict"
}

record @planner_extract_inputs = {
  data: [
    tool: string?,
    args: object?,
    source: object?,
    schema_name: string?,
    schema: object?,
    name: string,
    purpose: string?
  ],
  validate: "strict"
}

record @planner_derive_inputs = {
  data: [
    sources: array,
    goal: string,
    schema_name: string?,
    schema: object?,
    name: string,
    purpose: string?
  ],
  validate: "strict"
}

record @planner_execute_inputs = {
  data: [operation: string, args: object?, purpose: string?],
  validate: "strict"
}

record @planner_compose_inputs = {
  data: [sources: array?, purpose: string?],
  validate: "strict"
}

record @planner_blocked_inputs = {
  data: [reason: string],
  validate: "strict"
}

record @planner_tool_result = {
  data: [
    status: string,
    phase: string?,
    error: string?,
    reason: string?,
    tool: string?,
    record_type: string?,
    count: number?,
    handles: array?,
    records: array?,
    name: string?,
    schema_name: string?,
    provenance: string?,
    preview_fields: array?,
    selection_refs: array?,
    result_handles: array?,
    summary: string?,
    issues: array?
  ],
  validate: "demote"
}

exe @plannerPrompt(query, resolveTools, extractTools, executeTools, suiteAddendum) = template "../prompts/planner.att"

exe @phaseId(phase, iteration) = `@phase:@iteration`

exe @plannerRuntimeState(toolCalls, invalidCalls, terminal, lastDecision) = [
  => {
    tool_calls: @toolCalls,
    invalid_calls: @invalidCalls,
    terminal: @terminal,
    last_decision: @lastDecision,
    progress_fingerprint: "",
    calls_since_progress: 0
  }
]

>> c-3438 (B): extended runtime state with no-progress tracking.
>> Used by @finishPlannerTool when computing the new fingerprint —
>> @plannerRuntimeState above is kept for callers that don't yet
>> track progress (compose/blocked terminals, error short-circuits).
exe @plannerRuntimeStateWithProgress(toolCalls, invalidCalls, terminal, lastDecision, progressFingerprint, callsSinceProgress) = [
  => {
    tool_calls: @toolCalls,
    invalid_calls: @invalidCalls,
    terminal: @terminal,
    last_decision: @lastDecision,
    progress_fingerprint: @progressFingerprint ?? "",
    calls_since_progress: @callsSinceProgress ?? 0
  }
]

exe @plannerToolBudget(agent) = [
  => @normalizePositiveInt(@agent.maxIterations, 40)
]

exe @plannerInvalidBudget() = [
  => 5
]

>> c-3438 (B): warn when the planner has made N calls without state
>> progress. Threshold tuned empirically — start at 6 (15% of default
>> 40-call budget). Lower if planners rarely flail this long; higher
>> if legitimate multi-step gather phases trip it.
exe @plannerNoProgressThreshold() = [
  => 6
]

>> c-3438 (B): compute a stable signature of the meaningful state.
>> Two signatures are equal iff the planner has not added/changed any
>> resolved handle, gained any new field on an existing handle, named
>> a new extract/derive, or flipped one from empty to non-empty.
>>
>> Captures (per GPT review):
>> - new resolved handle (changes per-bucket key list)
>> - existing record gained a previously-null field (changes per-handle
>>   field count)
>> - resolved bucket version change (e.g. from a write that touched it)
>> - new extract/derive name with non-empty payload
>> - existing extract/derive name flipped empty→non-empty
>>
>> Does NOT capture (intentional — those are not progress):
>> - repeated zero-result resolves to the same tool+args
>> - repeated validation errors
exe @stateProgressFingerprint(state) = node {
  if (!state || typeof state !== 'object') return '';
  const parts = [];

  // Resolved buckets — sorted by record type for stable signature.
  const resolved = state.resolved || {};
  for (const recordType of Object.keys(resolved).sort()) {
    const bucket = resolved[recordType];
    if (!bucket) continue;
    const version = (typeof bucket.version === 'number') ? bucket.version : 0;
    const byHandle = bucket.by_handle || {};
    const handleSigs = [];
    for (const handle of Object.keys(byHandle).sort()) {
      const entry = byHandle[handle];
      // Field count = # of non-null/non-empty fields visible on the entry.
      // Walk multiple shapes since records can be wrapped or raw depending
      // on whether they came through coerce-record vs direct mutation.
      const data = (entry && entry.value && entry.value.data)
        ? entry.value.data
        : (entry && entry.value && typeof entry.value === 'object')
          ? entry.value
          : (entry && entry.field_values) || {};
      let fieldCount = 0;
      for (const k of Object.keys(data || {})) {
        const v = data[k];
        if (v === null || v === undefined || v === '') continue;
        if (Array.isArray(v) && v.length === 0) continue;
        if (typeof v === 'object' && !Array.isArray(v) && Object.keys(v).length === 0) continue;
        fieldCount++;
      }
      handleSigs.push(handle + '@' + fieldCount);
    }
    parts.push('R:' + recordType + ':v' + version + ':' + handleSigs.join('|'));
  }

  // Extract/derive — name + non-empty status.
  // A derive/extract is "non-empty progress" iff it has selection_refs OR
  // its preview_fields contain content beyond just ["items"]. The bare
  // ["items"] preview signals an empty payload (UT10 case): worker returned
  // {items: []} which serializes as preview=["items"] selection=[]. Treating
  // that as progress would suppress the no-progress warning when the planner
  // re-derives an empty result repeatedly.
  const isPayloadNonEmpty = (rec) => {
    if (!rec) return false;
    const refs = Array.isArray(rec.selection_refs) ? rec.selection_refs : [];
    if (refs.length > 0) return true;
    const fields = Array.isArray(rec.preview_fields) ? rec.preview_fields : [];
    if (fields.length === 0) return false;
    if (fields.length === 1 && fields[0] === 'items') return false;
    return true;
  };

  const extracted = state.extracted || {};
  for (const name of Object.keys(extracted).sort()) {
    parts.push('E:' + name + ':' + (isPayloadNonEmpty(extracted[name]) ? '1' : '0'));
  }
  const derived = state.derived || {};
  for (const name of Object.keys(derived).sort()) {
    parts.push('D:' + name + ':' + (isPayloadNonEmpty(derived[name]) ? '1' : '0'));
  }

  return parts.join(';');
}


exe @plannerResolvedRecords(records, state, recordType, handles) = [
  let @recordDef = @records[@recordType]
  if !@recordDef.isDefined() [ => [] ]
  let @handleList = for @handle in @arrayItems(@handles ?? []) => @stringValue(@handle)
  => for @entry in @bucketItems(@state.resolved[@recordType]) when @handleList.includes(@stringValue(@entry.handle)) => @projectResolvedEntry(@recordType, @recordDef, @entry, "role:planner")
]

exe @plannerToolContext(phase, decision) = [
  let @agent = @planner.agent
  if !@agent.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_uninitialized",
        summary: "planner_session_uninitialized"
      }
    }
  ]
  let @query = @planner.query
  if !@query.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_uninitialized",
        summary: "planner_session_uninitialized"
      }
    }
  ]
  let @runtime = @planner.runtime
  if @runtime.terminal.isDefined() [
    => {
      ok: false,
      result: {
        status: "error",
        phase: @phase,
        error: "planner_session_already_terminal",
        summary: @runtime.terminal.reason ?? @runtime.terminal.status ?? "planner_session_already_terminal"
      }
    }
  ]
  let @budget = @plannerToolBudget(@agent)
  if @runtime.tool_calls >= @budget [
    let @terminal = {
      status: "blocked",
      text: "blocked: planner_tool_budget_exhausted",
      reason: "planner_tool_budget_exhausted"
    }
    @planner.set({ runtime: @plannerRuntimeState(@runtime.tool_calls, @runtime.invalid_calls, @terminal, @decision) })
    => {
      ok: false,
      result: {
        status: "blocked",
        reason: "planner_tool_budget_exhausted"
      }
    }
  ]
  if @runtime.invalid_calls >= @plannerInvalidBudget() [
    let @lastPhase = @runtime.last_decision.phase ?? @phase
    let @terminal = {
      status: "blocked",
      text: `blocked: @runtime.invalid_calls consecutive errors (last phase: @lastPhase). Check the error messages above and fix the call shape, or call blocked if the task cannot be completed.`,
      reason: "planner_error_budget_exhausted"
    }
    @planner.set({ runtime: @plannerRuntimeState(@runtime.tool_calls, @runtime.invalid_calls, @terminal, @decision) })
    => {
      ok: false,
      result: {
        status: "blocked",
        reason: `planner_error_budget_exhausted: @runtime.invalid_calls consecutive errors, last phase: @lastPhase`
      }
    }
  ]
  let @iteration = @runtime.tool_calls + 1
  let @phaseIdValue = @phaseId(@phase, @iteration)
  let @plannerEvent = @plannerIterationEvent(@iteration, @phase)
  let @startEvent = @phaseStartEvent(@iteration, @phase, @phaseIdValue)
  @appendPhaseEvent(@agent.phaseLogFile, @serializeLifecycleJson(@plannerEvent))
  @appendPhaseEvent(@agent.phaseLogFile, @serializeLifecycleJson(@startEvent))
  @writePhaseStateFile(
    @agent.phaseStateFile,
    @serializeLifecycleJson(@phaseState(@phase, @phaseIdValue, @iteration, null))
  )
  => {
    ok: true,
    agent: @agent,
    query: @query,
    state: @planner.state,
    runtime: @runtime,
    iteration: @iteration,
    phase_id: @phaseIdValue,
    planner_event: @plannerEvent,
    start_event: @startEvent,
    decision: @decision
  }
]

exe @finishPlannerTool(ctx, nextState, nextRuntime, workerSessionId, outcome, summary, llmLog) = [
  @appendLlmDebug(@ctx.agent, @llmLog)
  @writePhaseStateFile(
    @ctx.agent.phaseStateFile,
    @serializeLifecycleJson(@phaseState(@ctx.decision.phase, @ctx.phase_id, @ctx.iteration, @workerSessionId))
  )
  let @endEvent = @phaseEndEvent(
    @ctx.iteration,
    @ctx.decision.phase,
    @ctx.phase_id,
    @workerSessionId,
    @outcome,
    @summary
  )
  @appendPhaseEvent(@ctx.agent.phaseLogFile, @serializeLifecycleJson(@endEvent))
  @writePhaseStateFile(@ctx.agent.phaseStateFile, @serializeLifecycleJson(@betweenState()))
  @planner.set({ state: @nextState, runtime: @nextRuntime })
  => {
    state: @nextState,
    runtime: @nextRuntime
  }
]

exe @settlePhaseDispatch(toolCtx, phaseResult, decision) = [
  let @workerSessionId = @normalizeSessionId(@phaseResult.session_id)
  let @nextState = when [
    @phaseResult.error.isDefined() => @phaseResult.state ?? @toolCtx.state
    * => @phaseResult.state
  ]
  let @logEntry = when [
    @phaseResult.error.isDefined() => {
      phase: @decision.phase,
      tool: @decision.tool ?? @decision.operation ?? null,
      name: @decision.name ?? null,
      status: "error",
      error: @phaseResult.error,
      summary: @phaseResult.summary ?? @phaseResult.error,
      issues: @phaseResult.issues ?? null,
      raw_error: @phaseResult.raw_error ?? null,
      worker_session_id: @workerSessionId
    }
    * => null
  ]
  if @logEntry.isDefined() [
    @appendExecutionLogEntry(@toolCtx.agent.executionLogFile, @serializeLifecycleJson(@logEntry))
  ]
  let @invalidCalls = when [
    @phaseResult.error.isDefined() => @toolCtx.runtime.invalid_calls + 1
    * => 0
  ]
  let @terminal = when [
    @phaseResult.error.isDefined() && @invalidCalls >= @plannerInvalidBudget() => {
      status: "blocked",
      text: "blocked: planner_error_budget_exhausted",
      reason: "planner_error_budget_exhausted"
    }
    * => null
  ]
  >> c-3438 (B): compute progress fingerprint, compare to prior,
  >> update calls_since_progress. Errors and successful calls both
  >> count toward "no progress" if state didn't actually change.
  let @newFingerprint = @stateProgressFingerprint(@nextState)
  let @priorFingerprint = @toolCtx.runtime.progress_fingerprint ?? ""
  let @priorCallsSinceProgress = @toolCtx.runtime.calls_since_progress ?? 0
  let @nextCallsSinceProgress = when [
    @newFingerprint != @priorFingerprint => 0
    * => @priorCallsSinceProgress + 1
  ]

  let @nextRuntime = @plannerRuntimeStateWithProgress(
    @toolCtx.runtime.tool_calls + 1,
    @invalidCalls,
    @terminal,
    @decision,
    @newFingerprint,
    @nextCallsSinceProgress
  )
  let @summary = when [
    @phaseResult.error.isDefined() => @phaseResult.summary ?? @phaseResult.error
    * => @phaseResult.result.summary
  ]
  let @finished = @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    @workerSessionId,
    when [ @phaseResult.error.isDefined() => "error" * => "success" ],
    @summary,
    @phaseResult.llm_log ?? null
  )
  let @budget = @plannerToolBudget(@toolCtx.agent)
  let @remaining = @budget - (@toolCtx.runtime.tool_calls + 1)
  let @halfBudget = @budget / 2
  let @budgetWarning = when [
    @remaining <= 3 => `URGENT: @remaining call(s) remaining. You MUST call compose (to answer) or execute (to write) on your next call. If you cannot complete the task, call blocked.`
    @remaining <= @halfBudget => `Budget checkpoint: @toolCtx.runtime.tool_calls of @budget calls used. If you can answer the question or perform the write from current data, do it now. Each additional resolve/extract/derive costs a call.`
    * => null
  ]
  >> c-3438 (B): no-progress warning. Fires when N consecutive calls
  >> haven't changed the meaningful state. Tells the planner that
  >> retrying isn't yielding new info and suggests blocked() as the
  >> clean exit. Threshold via @plannerNoProgressThreshold().
  let @noProgressThreshold = @plannerNoProgressThreshold()
  let @progressWarning = when [
    @nextCallsSinceProgress >= @noProgressThreshold => `NO PROGRESS: @nextCallsSinceProgress consecutive calls without state change (no new resolved handles, no new fields on existing records, no new extract/derive results). The current approach is not yielding new information. If a critical piece of data is genuinely missing and no other tool can produce it, call blocked(reason). Otherwise pivot to a different phase or tool — repeating the same calls against unchanged state will not produce a different result.`
    * => null
  ]
  => {
    finished: @finished,
    terminal: @terminal,
    summary: @summary,
    workerSessionId: @workerSessionId,
    budget_warning: @budgetWarning,
    progress_warning: @progressWarning
  }
]

exe @plannerResolve(input) = [
  let @coerced = @input ?? {}
  let @tool = @coerced.tool
  let @args = @coerced.args ?? {}
  let @purpose = @coerced.purpose ?? null
  let @decision = { phase: "resolve", tool: @tool, args: @args, purpose: @purpose }
  let @toolCtx = @plannerToolContext("resolve", @decision)
  if !@toolCtx.ok [ -> @toolCtx.result; => @toolCtx.result ]
  let @phaseResult = @dispatchResolve(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @resolvedHandles = for @handle in @arrayItems(@phaseResult.result.handles ?? []) => @stringValue(@handle)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "resolve", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning, progress_warning: @settled.progress_warning }
    * => {
      status: "resolved",
      tool: @tool,
      record_type: @phaseResult.result.record_type,
      count: @phaseResult.result.count,
      handles: @resolvedHandles,
      records: @plannerResolvedRecords(@toolCtx.agent.records ?? {}, @settled.finished.state, @phaseResult.result.record_type, @resolvedHandles),
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning,
      progress_warning: @settled.progress_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerResolveBatch(input) = [
  let @coerced = @input ?? {}
  let @resolves = @coerced.resolves ?? []
  let @batchPurpose = @coerced.purpose ?? null

  >> Phase A — parallel dispatch. resolve_batch is for parallel-safe
  >> resolves only (chained dependencies are not its use case — the
  >> planner would emit separate resolves for that). All specs share
  >> the same starting @toolCtx; @dispatchResolve has no @planner side
  >> effects so concurrent calls are safe. This collapses what was
  >> ~75s/spec sequentially into ~75s wall for the whole batch.
  let @initialCtx = @plannerToolContext("resolve", { phase: "resolve" })
  if !@initialCtx.ok [ -> @initialCtx.result; => @initialCtx.result ]

  let @dispatched = for parallel(8) @spec in @resolves [
    let @decision = { phase: "resolve", tool: @spec.tool, args: @spec.args ?? {}, purpose: @spec.purpose ?? @batchPurpose }
    let @phaseResult = @dispatchResolve(@initialCtx.agent, @initialCtx.state, @decision, @initialCtx.query)
    => { spec: @spec, decision: @decision, phaseResult: @phaseResult }
  ]

  >> Phase B — sequential settle. @settlePhaseDispatch writes @planner
  >> state/runtime; must run one at a time. Re-read context per spec so
  >> we see the prior settle's state changes (budget, fingerprint, etc).
  let @results = for @item in @dispatched [
    let @currentCtx = @plannerToolContext("resolve", @item.decision)
    if !@currentCtx.ok [ => @currentCtx.result ]
    let @settled = @settlePhaseDispatch(@currentCtx, @item.phaseResult, @item.decision)
    let @resolvedHandles = for @handle in @arrayItems(@item.phaseResult.result.handles ?? []) => @stringValue(@handle)
    => when [
      @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
      @item.phaseResult.error.isDefined() => { status: "error", phase: "resolve", error: @item.phaseResult.error, summary: @settled.summary }
      * => {
        status: "resolved",
        tool: @item.spec.tool,
        record_type: @item.phaseResult.result.record_type,
        count: @item.phaseResult.result.count,
        handles: @resolvedHandles,
        records: @plannerResolvedRecords(@currentCtx.agent.records ?? {}, @settled.finished.state, @item.phaseResult.result.record_type, @resolvedHandles),
        summary: @item.phaseResult.result.summary
      }
    ]
  ]

  let @combined = { status: "batch_resolved", results: @results }
  -> @combined
  => @combined
] => record @planner_tool_result

exe @plannerExtract(input) = [
  let @coerced = @input ?? {}
  let @tool = @coerced.tool ?? null
  let @args = @coerced.args ?? {}
  let @source = @coerced.source ?? null
  let @schema_name = @coerced.schema_name ?? null
  let @schema = @coerced.schema ?? null
  let @name = @coerced.name
  let @purpose = @coerced.purpose ?? null
  let @schemaValue = when [
    @schema_name.isDefined() => @schema_name
    * => @schema
  ]
  let @decision = when [
    @tool.isDefined() => {
      phase: "extract",
      tool: @tool,
      args: @args ?? {},
      name: @name,
      purpose: @purpose ?? null
    }
    @source.isDefined() => {
      phase: "extract",
      source: @source,
      schema: @schemaValue,
      name: @name,
      purpose: @purpose ?? null
    }
    * => {
      phase: "extract",
      name: @name,
      purpose: @purpose ?? null
    }
  ]
  let @toolCtx = @plannerToolContext("extract", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  if !@tool.isDefined() && !@source.isDefined() [
    @appendExecutionLogEntry(@toolCtx.agent.executionLogFile, @serializeLifecycleJson({
      phase: "extract",
      name: @name,
      status: "error",
      error: "extract_requires_tool_or_source",
      summary: "extract_requires_tool_or_source"
    }))
    let @missingState = @toolCtx.state
    let @missingInvalidCalls = @toolCtx.runtime.invalid_calls + 1
    let @missingTerminal = when [
      @missingInvalidCalls >= @plannerInvalidBudget() => {
        status: "blocked",
        text: "blocked: planner_error_budget_exhausted",
        reason: "planner_error_budget_exhausted"
      }
      * => null
    ]
    let @missingRuntime = @plannerRuntimeState(@toolCtx.runtime.tool_calls + 1, @missingInvalidCalls, @missingTerminal, @decision)
    @finishPlannerTool(@toolCtx, @missingState, @missingRuntime, null, "error", "extract_requires_tool_or_source", null)
    let @missingResult = when [
      @missingTerminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
      * => { status: "error", phase: "extract", error: "extract_requires_tool_or_source", summary: "extract_requires_tool_or_source" }
    ]
    -> @missingResult
    => @missingResult
  ]
  let @phaseResult = @dispatchExtract(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "extract", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning, progress_warning: @settled.progress_warning }
    * => {
      status: "extracted",
      name: @phaseResult.result.name,
      schema_name: @phaseResult.result.schema_name,
      provenance: @phaseResult.result.provenance,
      preview_fields: @phaseResult.result.preview_fields,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning,
      progress_warning: @settled.progress_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerDerive(input) = [
  let @coerced = @input ?? {}
  let @sources = @coerced.sources ?? []
  let @goal = @coerced.goal
  let @schema_name = @coerced.schema_name ?? null
  let @schema = @coerced.schema ?? null
  let @name = @coerced.name
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "derive",
    sources: @sources,
    goal: @goal,
    schema: when [ @schema_name.isDefined() => @schema_name * => @schema ],
    name: @name,
    purpose: @purpose ?? null
  }
  let @toolCtx = @plannerToolContext("derive", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchDerive(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "derive", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning, progress_warning: @settled.progress_warning }
    * => {
      status: "derived",
      name: @phaseResult.result.name,
      schema_name: @phaseResult.result.schema_name,
      provenance: @phaseResult.result.provenance,
      preview_fields: @phaseResult.result.preview_fields,
      selection_refs: @phaseResult.result.selection_refs,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning,
      progress_warning: @settled.progress_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerExecute(input) = [
  let @coerced = @input ?? {}
  let @operation = @coerced.operation
  let @args = @coerced.args ?? {}
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "execute",
    operation: @operation,
    args: @args,
    purpose: @purpose
  }
  let @toolCtx = @plannerToolContext("execute", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchExecute(@toolCtx.agent, @toolCtx.state, @decision, @toolCtx.query)
  let @settled = @settlePhaseDispatch(@toolCtx, @phaseResult, @decision)
  let @result = when [
    @settled.terminal.isDefined() => { status: "blocked", reason: "planner_error_budget_exhausted" }
    @phaseResult.error.isDefined() => { status: "error", phase: "execute", error: @phaseResult.error, summary: @settled.summary, issues: @phaseResult.issues ?? null, budget_warning: @settled.budget_warning, progress_warning: @settled.progress_warning }
    * => {
      status: "executed",
      tool: @phaseResult.result.tool,
      result_handles: @phaseResult.result.result_handles,
      summary: @phaseResult.result.summary,
      budget_warning: @settled.budget_warning,
      progress_warning: @settled.progress_warning
    }
  ]
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerCompose(input) = [
  let @coerced = @input ?? {}
  let @sources = @coerced.sources ?? []
  let @purpose = @coerced.purpose ?? null
  let @decision = {
    phase: "compose",
    sources: @sources,
    purpose: @purpose
  }
  let @toolCtx = @plannerToolContext("compose", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  let @phaseResult = @dispatchCompose(@toolCtx.agent, @toolCtx.state, @toolCtx.query, @decision)
  let @workerSessionId = @normalizeSessionId(@phaseResult.session_id)
  @appendExecutionLogEntry(@toolCtx.agent.executionLogFile, @serializeLifecycleJson({
    phase: "compose",
    status: "complete",
    summary: "final answer prepared",
    worker_session_id: @workerSessionId,
    session_id: @workerSessionId
  }))
  let @nextState = @toolCtx.state
  let @nextRuntime = @plannerRuntimeState(
    @toolCtx.runtime.tool_calls + 1,
    0,
    {
      status: "complete",
      text: @phaseResult["text"],
      reason: null
    },
    @decision
  )
  @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    @workerSessionId,
    "success",
    "final answer prepared",
    @phaseResult.llm_log ?? null
  )
  let @result = {
    status: "complete",
    summary: "final answer prepared"
  }
  -> @result
  => @result
] => record @planner_tool_result

exe @plannerBlocked(input) = [
  let @coerced = @input ?? {}
  let @reason = @coerced.reason
  let @decision = {
    phase: "blocked",
    reason: @reason
  }
  let @toolCtx = @plannerToolContext("blocked", @decision)
  if !@toolCtx.ok [
    -> @toolCtx.result
    => @toolCtx.result
  ]
  @appendExecutionLogEntry(@toolCtx.agent.executionLogFile, @serializeLifecycleJson({
    phase: "blocked",
    status: "blocked",
    summary: @reason
  }))
  let @nextState = @toolCtx.state
  let @nextRuntime = @plannerRuntimeState(
    @toolCtx.runtime.tool_calls + 1,
    0,
    {
      status: "blocked",
      text: @reason,
      reason: @reason
    },
    @decision
  )
  @finishPlannerTool(
    @toolCtx,
    @nextState,
    @nextRuntime,
    null,
    "blocked",
    @reason,
    null
  )
  let @result = {
    status: "blocked",
    reason: @reason
  }
  -> @result
  => @result
]

var tools @terminalTools = {
  compose: {
    mlld: @plannerCompose,
    inputs: @planner_compose_inputs,
    labels: ["tool:w"],
    description: "Write the final answer for the user and end the session."
  },
  blocked: {
    mlld: @plannerBlocked,
    inputs: @planner_blocked_inputs,
    labels: ["tool:w"],
    description: "Stop and explain why the task cannot be completed."
  }
}

var tools @plannerTools = {
  resolve: {
    mlld: @plannerResolve,
    inputs: @planner_resolve_inputs,
    labels: ["tool:w"],
    description: "Look up information using a read tool. Returns structured records with handles you can reference later."
  },
  resolve_batch: {
    mlld: @plannerResolveBatch,
    inputs: @planner_resolve_batch_inputs,
    labels: ["tool:w"],
    description: "Look up multiple independent record types in one call. Each entry in the resolves array is { tool, args?, purpose? }. Saves round-trips."
  },
  extract: {
    mlld: @plannerExtract,
    inputs: @planner_extract_inputs,
    labels: ["tool:w"],
    description: "Read hidden content from a resolved record (like an email body or file content) and extract specific fields into a named result."
  },
  derive: {
    mlld: @plannerDerive,
    inputs: @planner_derive_inputs,
    labels: ["tool:w"],
    description: "Compute a result from data you already have — ranking, selection, comparison, arithmetic, or summarization. Returns a named result."
  },
  execute: {
    mlld: @plannerExecute,
    inputs: @planner_execute_inputs,
    labels: ["tool:w"],
    description: "Perform a write operation (send email, create event, update record, etc.). Target values must come from prior resolves or exact task text."
  },
  compose: {
    mlld: @plannerCompose,
    inputs: @planner_compose_inputs,
    labels: ["tool:w"],
    description: "Write the final answer for the user and end the session."
  },
  blocked: {
    mlld: @plannerBlocked,
    inputs: @planner_blocked_inputs,
    labels: ["tool:w"],
    description: "Stop and explain why the task cannot be completed."
  }
}

exe @plannerLlmCallStub(prompt, config, agent, query) =
  @llmCall("stub", @prompt, @config) with { display: "role:planner", session: @planner, seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() } }

exe @plannerLlmCallOpencode(prompt, config, agent, query) =
  @opencode(@prompt, @config) with { display: "role:planner", session: @planner, seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() } }

exe @plannerLlmCallClaude(prompt, config, agent, query) =
  @claude(@prompt, @config) with { display: "role:planner", session: @planner, seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() } }

>> Compose retry: when the planner session ends without a terminal tool,
>> resume with terminal-only tools. Blocked on m-0f63 (opencode provider
>> field in resume enforcement).
guard after @composeRetryStub for op:named:plannerLlmCallStub = when [
  !@planner.runtime.terminal.isDefined() && @mx.guard.try < 2
    => resume "You completed work but didn't write a final answer. Call compose now — it will read your execution log and resolved data to write the user's answer. If the task cannot be completed, call blocked with a reason." with { tools: @terminalTools }
  * => allow
]

guard after @composeRetryOpencode for op:named:plannerLlmCallOpencode = when [
  !@planner.runtime.terminal.isDefined() && @mx.guard.try < 2
    => resume "You completed work but didn't write a final answer. Call compose now — it will read your execution log and resolved data to write the user's answer. If the task cannot be completed, call blocked with a reason." with { tools: @terminalTools }
  * => allow
]

guard after @composeRetryClaude for op:named:plannerLlmCallClaude = when [
  !@planner.runtime.terminal.isDefined() && @mx.guard.try < 2
    => resume "You completed work but didn't write a final answer. Call compose now — it will read your execution log and resolved data to write the user's answer. If the task cannot be completed, call blocked with a reason." with { tools: @terminalTools }
  * => allow
]

exe @runPlannerSession(agent, query) = [
  let @resolveDocs = @phaseToolDocs(@agent, "resolve")
  let @extractDocs = @phaseToolDocs(@agent, "extract")
  let @executeDocs = @phaseToolDocs(@agent, "execute")
  let @addendum = @agent.plannerAddendum ?? ""
  let @prompt = @plannerPrompt(@query, @resolveDocs, @extractDocs, @executeDocs, @addendum)
  >> c-63fe / m-0710: testing 500000 (8.3min) — give legit slow batches
  >> plenty of headroom to disambiguate whether the regression at 120s
  >> was (a) legit batches needing 150-300s sometimes vs (b) something
  >> else (cancellation interaction, etc). If 500s recovers ≥11/20, the
  >> 120s setting was the problem. If still <11/20, root cause is elsewhere.
  let @plannerConfig = {
    model: @agent.model,
    pure: @agent.opencodePure,
    tools: @plannerTools,
    stubPhase: "planner",
    stubResponses: @agent.stub.planner ?? [],
    mcpTimeoutMs: 500000
  }
  let @raw = when [
    @agent.harness == "stub" => @plannerLlmCallStub(@prompt, @plannerConfig, @agent, @query)
    @agent.harness == "opencode" => @plannerLlmCallOpencode(@prompt, @plannerConfig, @agent, @query)
    * => @plannerLlmCallClaude(@prompt, @plannerConfig, @agent, @query)
  ]
  let @sessionId = @llmSessionId(@raw)
  let @finalSession = @raw.mx.sessions.planner
  let @runtime = @finalSession.runtime ?? @emptyPlannerRuntime()
  let @sessionState = @finalSession.state ?? @emptyState()
  let @logEntry = @llmCallEntry(
    "planner",
    @prompt,
    @raw,
    null,
    @sessionId,
    {
      call_kind: "outer_planner",
      outer_planner_session_id: @sessionId,
      tool_use: true,
      tool_calls: @runtime.tool_calls,
      terminal: @runtime.terminal.status ?? null
    }
  )
  @appendLlmDebug(@agent, @logEntry)
  let @terminal = when [
    @runtime.terminal.isDefined() => @runtime.terminal
    * => {
      status: "blocked",
      text: "planner_session_ended_without_terminal_tool",
      reason: "planner_session_ended_without_terminal_tool"
    }
  ]
  let @finalExecutionLog = @readExecutionLogFile(@agent.executionLogFile)
  => {
    terminal: @terminal.status,
    final: { text: @terminal.text },
    execution_log: @finalExecutionLog,
    phase_events: [],
    last_decision: @runtime.last_decision ?? null
  }
]

export { @planner, @plannerPrompt, @plannerTools, @runPlannerSession, @stateProgressFingerprint, @plannerNoProgressThreshold, @plannerRuntimeStateWithProgress }
