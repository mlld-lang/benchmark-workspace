import {
  @llmCall,
  @llmCallEntry,
  @llmSessionId,
  @arrayItems,
  @bucketItems,
  @previewFields,
  @updateNamedState
} from "../runtime.mld"
import { @serializeLifecycleJson, @appendExecutionLogEntry } from "../lifecycle.mld"
import { @lowerSelectionRef, @resolveRefValue, @resolvedEntries } from "../intent.mld"
import { @deriveAttestation } from "../records.mld"
import {
  @validatePlannerSourcesArray,
  @plannerValidationFailure
} from "../planner_inputs.mld"

exe @derivePrompt(query, sources, schemaDoc, decision, handleMap) = template "../prompts/derive.att"

>> Mirrors the extract-side hardening (see extract.mld for rationale).
>> Without this, `@parse.llm` turns "" / "null" / non-JSON into mlld-null,
>> the demoted record stays defined, and `derive_empty_response` never
>> fires. Derive accepts an empty payload IF selection_refs is non-empty
>> (selection-only goals).
exe @isDegenerateDeriveRaw(raw) = js {
  if (raw == null) return true;
  if (typeof raw === "string") {
    const trimmed = raw.trim();
    if (trimmed === "") return true;
    if (trimmed.toLowerCase() === "null" || trimmed.toLowerCase() === "undefined") return true;
  }
  return false;
}

exe @isDegenerateDerivePayload(payload, selectionRefs) = js {
  const hasRefs = Array.isArray(selectionRefs) && selectionRefs.length > 0;
  if (hasRefs) return false;
  if (payload == null) return true;
  if (Array.isArray(payload)) return payload.length === 0;
  if (typeof payload === "object") return Object.keys(payload).length === 0;
  return false;
}

>> The record post-coercion is applied on the envelope helper, not the
>> outer function. Otherwise `=> null` from the outer body still flows
>> through record coercion and returns a defined-but-empty wrapper,
>> defeating the dispatcher's `if @attestation == null` check.
exe @coerceDeriveEnvelope(parsed) = [
  => @parsed
] => record @deriveAttestation

exe @coerceDeriveAttestation(raw) = [
  if @isDegenerateDeriveRaw(@raw) [ => null ]
  let @parsed = @raw | @parse.llm
  if !@parsed.isDefined() [ => null ]
  let @parsedType = @typeof(@parsed)
  if @parsedType != "object" && @parsedType != "array" [ => null ]
  if @isDegenerateDerivePayload(@parsed.payload, @parsed.selection_refs) [ => null ]
  => @coerceDeriveEnvelope(@parsed)
]

exe @allowedSelectionKeys(state, sources) = [
  let @pairs = for @source in (@sources ?? []) [
    => when [
      @source.source == "resolved" && @source.handle.isDefined() => [{ key: `@source.record:@source.handle`, value: true }]
      @source.source == "resolved" => for @entry in @bucketItems(@state.resolved[@source.record] ?? []) => {
        key: `@source.record:@entry.handle`,
        value: true
      }
      @source.source == "selection" => [{
        key: `@source.backing.record:@source.backing.handle`,
        value: true
      }]
      * => []
    ]
  ]
  let @flattened = loop(1000) [
    let @ctx = when [
      @input["_rig_cursor"] == "deriveFlattened" => @input
      * => { _rig_cursor: "deriveFlattened", index: 0, values: [] }
    ]
    if @ctx.index >= @pairs.length [ done @ctx.values ]
    continue {
      _rig_cursor: "deriveFlattened",
      index: @ctx.index + 1,
      values: @ctx.values.concat(@pairs[@ctx.index] ?? [])
    }
  ]
  let @keys = for @pair in @flattened => @pair.key
  => @keys
]

exe @validateSelectionRefs(state, sources, refs) = [
  let @allowed = @allowedSelectionKeys(@state, @sources)
  let @validated = for @ref in (@refs ?? []) [
    let @lowered = @lowerSelectionRef(@state, @ref)
    => when [
      !@lowered.ok => { ok: false, error: @lowered.error, ref: @ref, available_handles: @lowered.available_handles ?? null }
      !@allowed.includes(`@lowered.ref.record:@lowered.ref.handle`) => {
        ok: false,
        error: "selection_ref_not_in_derive_input",
        ref: @ref
      }
      * => { ok: true, ref: @ref }
    ]
  ]
  let @errors = for @entry in @validated when !@entry.ok => @entry
  let @refsValue = for @entry in @validated => @entry.ref
  => when [
    @errors.length == 0 => { ok: true, refs: @refsValue }
    * => { ok: false, error: "selection_ref_validation_failed", issues: @errors }
  ]
]

exe @dispatchDerive(agent, state, decision, query) = [
  let @sourceCheck = @validatePlannerSourcesArray(@decision.sources ?? [], ["resolved", "selection", "extracted", "derived"])
  if !@sourceCheck.ok [ => @plannerValidationFailure("planner_source_validation_failed", @sourceCheck, @sourceCheck.issues) ]
  let @resolved = for @source in (@decision.sources ?? []) => @resolveRefValue(@state, @source)
  let @errors = for @entry in @resolved when !@entry.ok => @entry
  if @errors.length > 0 [ => @plannerValidationFailure("derive_source_resolution_failed", { issues: @errors }, @errors) ]
  let @sources = for @entry in @resolved => @entry.value
  let @handleMap = for @source in (@decision.sources ?? []) when @source.source == "resolved" [
    let @entries = @resolvedEntries(@state, @source.record)
    => for @e in @entries => { record: @source.record, handle: @e.handle }
  ]
  let @flatHandles = @handleMap.flat()
  let @prompt = @derivePrompt(@query, @sources, @decision.schema, @decision, @flatHandles)
  let @raw = @llmCall(@agent.harness, @prompt, {
    model: @agent.workerModel ?? @agent.model,
    pure: @agent.opencodePure,
    dir: @agent.innerWorkerDir,
    dataHome: @agent.innerWorkerDataHome,
    stateHome: @agent.innerWorkerStateHome,
    tools: [],
    stubPhase: "derive",
    stubResponses: @agent.stub.derive ?? [],
    stubIndex: @arrayItems(@state.execution_log).length
  })
  let @attestation = @coerceDeriveAttestation(@raw)
  let @sessionId = @llmSessionId(@raw)
  let @logEntry = @llmCallEntry("derive", @prompt, @raw, @attestation, @sessionId, {
    call_kind: "inner_worker",
    inner_worker_session_id: @sessionId,
    name: @decision.name,
    goal: @decision.goal ?? null
  })
  >> Use `== null` not `.isDefined()`: exe-returned null is a wrapper whose
  >> .isDefined() reports true, masking degenerate worker output.
  if @attestation == null [ => { error: "derive_empty_response", summary: "derive_empty_response", session_id: @sessionId, llm_log: @logEntry } ]
  let @selectionCheck = @validateSelectionRefs(@state, @decision.sources ?? [], @attestation.selection_refs ?? [])
  if !@selectionCheck.ok [
    let @failure = @plannerValidationFailure(@selectionCheck.error ?? "selection_ref_validation_failed", @selectionCheck, @selectionCheck.issues)
    => {
      error: @failure.error,
      summary: @failure.summary,
      issues: @failure.issues,
      raw_error: @failure.raw_error,
      session_id: @sessionId,
      llm_log: @logEntry
    }
  ]
  let @summary = @attestation.summary ?? `derived @decision.name`
  let @schemaName = @attestation.schema_name ?? "inline-schema"
  let @nextState = @updateNamedState(@state, "derived", @decision.name, {
    provenance: "derived",
    schema_name: @schemaName,
    preview_fields: @previewFields(@attestation.payload),
    value: @attestation.payload,
    selection_refs: @selectionCheck.refs
  })
  @appendExecutionLogEntry(@agent.executionLogFile, @serializeLifecycleJson({
    phase: "derive",
    name: @decision.name,
    summary: @summary,
    session_id: @sessionId
  }))
  => {
    state: @nextState,
    result: {
      status: "derived",
      schema_name: @schemaName,
      name: @decision.name,
      provenance: "derived",
      preview_fields: @previewFields(@attestation.payload),
      selection_refs: @selectionCheck.refs,
      summary: @summary
    },
    session_id: @sessionId,
    llm_log: @logEntry
  }
]

export { @derivePrompt, @coerceDeriveAttestation, @dispatchDerive }
