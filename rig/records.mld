record @resolveAttestation = {
  data: [
    status: string,
    record_type: string?,
    count: number?,
    handles: array?,
    summary: string?
  ],
  validate: "demote"
}

record @extractAttestation = {
  data: [
    status: string,
    schema_name: string?,
    name: string?,
    provenance: string?,
    preview_fields: array?,
    payload: object?
  ],
  validate: "demote"
}

>> Derive output schema. `payload` is declared `data.trusted` so the §4.2
>> coercion clears the exe-level untrusted on the payload object, allowing
>> derived scalars (e.g. arithmetic over clean inputs) to flow into
>> tool-input fields declared `data.trusted` on the destination tool.
>>
>> This is suboptimal as a general records-as-policy practice — if derive
>> accepts an extracted-source input that carries attacker-controlled text,
>> declaring payload trusted would launder it. We're safe today because:
>>
>>   1. Display projection guarantees the planner sees `preview_fields` (and
>>      handles via `selection_refs`), NOT raw payload values. Untrusted
>>      values in payload cannot influence planner reasoning.
>>   2. The only consumer of payload values is execute, which validates
>>      against the destination tool's input-record schema (data.trusted /
>>      data.untrusted per field) and rejects mismatches at dispatch time.
>>   3. Next-architecture work (per ~/mlld/mlld m-9f33) will replace this
>>      schema-level blanket trust with conditional input-aware trust
>>      propagation, so derive output trust tracks input cleanliness.
>>
>> Other fields stay `data.untrusted` because the planner reads them
>> directly (status, name, reason are surfaced in tool-call returns).
record @deriveAttestation = {
  data: {
    trusted: [payload: object?],
    untrusted: [
      status: string,
      schema_name: string?,
      name: string?,
      provenance: string?,
      selection_refs: array?,
      reason: string?
    ]
  },
  validate: "demote"
}

record @executeAttestation = {
  data: [
    status: string,
    tool: string?,
    result_handles: array?,
    summary: string?
  ],
  validate: "demote"
}

record @composeAttestation = {
  data: [
    text: string
  ],
  validate: "demote"
}

>> URL promotion capability record. Sibling to bench-level @url_ref —
>> @url_ref is the public handle-bearing record (no URL); @url_capability
>> is the rig-private store for the URL string keyed by the url_ref
>> handle string. Lives on a typed shelf threaded onto the agent
>> (urlCapShelf); never projected to any LLM role. Orchestrator dispatch
>> code reads it via @shelf.read + handle-equality filter.
record @url_capability = {
  facts: [url_ref_handle: { type: string, kind: "url_ref_handle" }],
  data: { untrusted: [url: string?] },
  key: url_ref_handle,
  read: {
    default: [],
    role:planner: [],
    role:worker: []
  },
  write: { role:worker: { shelves: true } }
}

export {
  @resolveAttestation,
  @extractAttestation,
  @deriveAttestation,
  @executeAttestation,
  @composeAttestation,
  @url_capability
}
