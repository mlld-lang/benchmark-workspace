>> Host/rig lifecycle helpers.
>>
>> The benchmark host treats lifecycle emission as part of the runtime
>> contract, not optional debug noise. Keeping the file IO in one module
>> makes the contract easy to audit and easy to test with stub flows.

>> Lifecycle files carry plain diagnostic JSON. They are not proof-
>> bearing values, so compact JSON serialization through JS is fine here.
exe @serializeLifecycleJson(input) = js {
  return JSON.stringify(input);
}

exe @appendPhaseEventRaw(phaseLogFile, eventJson) = sh {
  printf '%s\n' "$eventJson" >> "$phaseLogFile"
}

exe @appendPhaseEvent(phaseLogFile, eventJson) = [
  if !@phaseLogFile.isDefined() [ => false ]
  if @phaseLogFile == "" [ => false ]
  if !@eventJson.isDefined() [ => false ]
  if @eventJson == "" [ => false ]
  @appendPhaseEventRaw(@phaseLogFile, @eventJson)
  => true
]

exe @writePhaseStateFileRaw(phaseStateFile, stateJson) = sh {
  printf '%s' "$stateJson" > "$phaseStateFile"
}

exe @writePhaseStateFile(phaseStateFile, stateJson) = [
  if !@phaseStateFile.isDefined() [ => false ]
  if @phaseStateFile == "" [ => false ]
  @writePhaseStateFileRaw(@phaseStateFile, @stateJson)
  => true
]

>> LLM call logging uses the same NDJSON file discipline as phase events:
>> append-only lines written by rig, consumed later by the benchmark host.
>> These logs are debug-only and never participate in authorization.
exe @appendLlmCallRaw(llmCallLogFile, entryJson) = sh {
  printf '%s\n' "$entryJson" >> "$llmCallLogFile"
}

exe @appendLlmCall(llmCallLogFile, entryJson) = [
  if !@llmCallLogFile.isDefined() [ => false ]
  if @llmCallLogFile == "" [ => false ]
  if !@entryJson.isDefined() [ => false ]
  if @entryJson == "" [ => false ]
  @appendLlmCallRaw(@llmCallLogFile, @entryJson)
  => true
]

exe @betweenState() = [
  => { phase: "between" }
]

exe @resetLifecycleFiles(phaseLogFile, phaseStateFile) = [
  let @between = @serializeLifecycleJson(@betweenState())
  @truncatePhaseLog(@phaseLogFile)
  @writePhaseStateFile(@phaseStateFile, @between)
  => true
]

exe @truncateFileRaw(filePath) = sh {
  : > "$filePath"
}

exe @truncateLlmCallLog(llmCallLogFile) = [
  if !@llmCallLogFile.isDefined() [ => false ]
  if @llmCallLogFile == "" [ => false ]
  @truncateFileRaw(@llmCallLogFile)
  => true
]

exe @truncatePhaseLog(phaseLogFile) = [
  if !@phaseLogFile.isDefined() [ => false ]
  if @phaseLogFile == "" [ => false ]
  @truncateFileRaw(@phaseLogFile)
  => true
]

exe @appendExecutionLogEntryRaw(executionLogFile, entryJson) = sh {
  printf '%s\n' "$entryJson" >> "$executionLogFile"
}

exe @appendExecutionLogEntry(executionLogFile, entryJson) = [
  if !@executionLogFile.isDefined() [ => false ]
  if @executionLogFile == "" [ => false ]
  if !@entryJson.isDefined() [ => false ]
  if @entryJson == "" [ => false ]
  @appendExecutionLogEntryRaw(@executionLogFile, @entryJson)
  => true
]

exe @truncateExecutionLog(executionLogFile) = [
  if !@executionLogFile.isDefined() [ => false ]
  if @executionLogFile == "" [ => false ]
  @truncateFileRaw(@executionLogFile)
  => true
]

exe @readExecutionLogFile(executionLogFile) = js {
  if (!executionLogFile) return [];
  const fs = require('fs');
  if (!fs.existsSync(executionLogFile)) return [];
  const content = fs.readFileSync(executionLogFile, 'utf8').trim();
  if (!content) return [];
  return content.split('\n').map(line => {
    try { return JSON.parse(line); } catch { return null; }
  }).filter(Boolean);
}

exe @plannerIterationEvent(iteration, phase) = [
  => {
    event: "planner_iteration",
    iteration: @iteration,
    decision_phase: @phase
  }
]

exe @phaseStartEvent(iteration, phase, phaseId) = [
  => {
    event: "phase_start",
    iteration: @iteration,
    worker: @phase,
    phase: @phase,
    phase_id: @phaseId
  }
]

exe @phaseEndEvent(iteration, phase, phaseId, workerSessionId, outcome, summary) = [
  => {
    event: "phase_end",
    iteration: @iteration,
    worker: @phase,
    phase: @phase,
    phase_id: @phaseId,
    worker_session_id: @workerSessionId,
    outcome: @outcome,
    summary: @summary
  }
]

exe @phaseState(phase, phaseId, iteration, workerSessionId) = [
  => {
    phase: @phase,
    phase_id: @phaseId,
    iteration: @iteration,
    worker_session_id: @workerSessionId
  }
]

export {
  @serializeLifecycleJson,
  @appendPhaseEvent,
  @appendLlmCall,
  @appendExecutionLogEntry,
  @truncateExecutionLog,
  @readExecutionLogFile,
  @writePhaseStateFile,
  @truncatePhaseLog,
  @truncateLlmCallLog,
  @betweenState,
  @resetLifecycleFiles,
  @plannerIterationEvent,
  @phaseStartEvent,
  @phaseEndEvent,
  @phaseState
}
