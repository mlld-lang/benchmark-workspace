import { @emptyState } from "./runtime.mld"

record @plannerRuntime = {
  data: [tool_calls: number, invalid_calls: number, terminal: object?, last_decision: object?]
}

var session @planner = {
  agent: object?,
  query: string?,
  state: object,
  runtime: @plannerRuntime
}

exe @emptyPlannerRuntime() = [
  => {
    tool_calls: 0,
    invalid_calls: 0,
    terminal: null,
    last_decision: null
  }
]

export { @planner, @plannerRuntime, @emptyPlannerRuntime, @emptyState }
