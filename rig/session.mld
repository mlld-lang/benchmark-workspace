import { @emptyState } from "./runtime.mld"

record @plannerRuntime = {
  data: [
    tool_calls: number,
    invalid_calls: number,
    terminal: object?,
    last_decision: object?,
    progress_fingerprint: string?,
    calls_since_progress: number?
  ]
}

var session @planner = {
  agent: object?,
  query: string?,
  state: object,
  runtime: @plannerRuntime,
  rehearse_history: array?
}

exe @emptyPlannerRuntime() = [
  => {
    tool_calls: 0,
    invalid_calls: 0,
    terminal: null,
    last_decision: null,
    progress_fingerprint: "",
    calls_since_progress: 0
  }
]

export { @planner, @plannerRuntime, @emptyPlannerRuntime, @emptyState }
