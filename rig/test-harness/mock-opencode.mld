>> Mock harness that mirrors @opencode/@claude for c-63fe Phase B
>> memory profiling without LLM cost or network. Drives the rig planner
>> tool exes directly from a JSON script, exercising Phase B (state
>> merge, planner cache, projection) end-to-end. Inner Python MCP server
>> still runs and returns real AgentDojo data.
>>
>> Limitation: does NOT exercise the OUTER function-mcp-bridge per-call
>> socket lifecycle (path A in c-8dff). The bridge cascade is downstream
>> of Phase B's multi-minute tail; profiling Phase B captures the trigger.
>>
>> Usage from a test program:
>>
>>   import { @mockPlannerRun } from "./mock-opencode.mld"
>>   var @result = @mockPlannerRun(@agent, @query, @script)
>>   show @result.text

import { @planner, @emptyPlannerRuntime, @emptyState } from "../session.mld"
import { @plannerTools } from "../workers/planner.mld"

>> Dispatch one script step against the planner exes. The planner
>> session is already seeded (see @mockPlannerRun's `with` wrapper),
>> so these exes see the same agent/query/state context the real
>> planner would. Each call may mutate session state via @planner.set
>> inside @settlePhaseDispatch — that's the Phase B work we want to
>> profile.
exe @dispatchScriptStep(step) = [
  let @tool = @step.tool
  let @args = @step.args
  let @entry = @plannerTools[@tool]
  if !@entry.isDefined() [ => { error: "unknown_tool_in_script", tool: @tool } ]
  let @fn = @entry.mlld
  => @fn(@args)
]

>> Iterate the script in a bounded loop. Each step runs against the
>> seeded planner session; @resolveBatchWorker in particular triggers
>> the Phase B settle/merge/cache/projection chain we're profiling.
>> Returns the LAST step's result (typically compose).
exe @runScript(script) = [
  let @results = loop(100) [
    let @ctx = @input ?? { index: 0, results: [], lastResult: null }
    if @ctx.index >= @script.length [ done @ctx ]
    let @step = @script[@ctx.index]
    let @result = @dispatchScriptStep(@step)
    continue {
      index: @ctx.index + 1,
      results: @ctx.results.concat([@result]),
      lastResult: @result
    }
  ]
  => @results
]

>> Mock LLM-shaped function — `exe llm` so it gets the same session
>> binding semantics as the real @opencode/@claude. The planner-session
>> seed in the `with` block applies for the duration of this call;
>> planner-tool exes called inside @runScript see the seeded @planner.
>>
>> Signature mirrors @opencode(prompt, config) so this can drop into
>> the same call sites if needed.
exe llm @mockOpencode(prompt, config) = [
  let @cfg = @config ? @config : {}
  let @script = @cfg.toolScript ? @cfg.toolScript : []
  => @runScript(@script)
]

>> Convenience driver: builds the proper config + with-wrapper around
>> @mockOpencode so callers don't need to know the planner-session
>> seeding pattern. Use this from a test program.
exe @mockPlannerRun(agent, query, script) =
  @mockOpencode(@query, { toolScript: @script }) with {
    read: "role:planner",
    session: @planner,
    seed: { agent: @agent, query: @query, state: @emptyState(), runtime: @emptyPlannerRuntime() }
  }

export { @mockPlannerRun, @mockOpencode, @runScript, @dispatchScriptStep }
